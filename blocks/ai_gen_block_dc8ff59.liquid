{% doc %}
  @prompt
    A magazine-style editorial layout, add more cards below so I can display more information. the top is good, need to write more and have a button below, add options for even more text and buttons below
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    align-items: start;
  }

  .ai-editorial-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    {% if block.settings.layout == 'image-left' %}
      grid-column: 1 / 8;
    {% elsif block.settings.layout == 'image-right' %}
      grid-column: 6 / 13;
    {% elsif block.settings.layout == 'image-top' %}
      grid-column: 1 / 13;
    {% endif %}
  }

  .ai-editorial-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-editorial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-editorial-content-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image-left' %}
      grid-column: 8 / 13;
    {% elsif block.settings.layout == 'image-right' %}
      grid-column: 1 / 6;
    {% elsif block.settings.layout == 'image-top' %}
      grid-column: 1 / 13;
    {% endif %}
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    {% if block.settings.layout == 'image-top' %}
      margin-top: {{ block.settings.content_spacing }}px;
    {% endif %}
  }

  .ai-editorial-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.eyebrow_color }};
    text-transform: {{ block.settings.eyebrow_transform }};
    letter-spacing: {{ block.settings.eyebrow_spacing }}em;
    margin: 0;
  }

  .ai-editorial-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: {{ block.settings.heading_line_height }};
    margin: 0;
  }

  .ai-editorial-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: {{ block.settings.body_line_height }};
    margin: 0;
  }

  .ai-editorial-body-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-editorial-body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-editorial-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    text-decoration: none;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_size }}px;
    text-transform: {{ block.settings.button_transform }};
    letter-spacing: {{ block.settings.button_spacing }}em;
    transition: all 0.3s ease;
  }

  .ai-editorial-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-editorial-cards-section-{{ ai_gen_id }} {
    margin-top: {{ block.settings.cards_section_spacing }}px;
  }

  .ai-editorial-cards-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.cards_per_row }}, 1fr);
    gap: {{ block.settings.cards_gap }}px;
  }

  .ai-editorial-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_content_spacing }}px;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_bg_color }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-editorial-card-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_heading_font.family }}, {{ block.settings.card_heading_font.fallback_families }};
    font-weight: {{ block.settings.card_heading_font.weight }};
    font-size: {{ block.settings.card_heading_size }}px;
    color: {{ block.settings.card_heading_color }};
    line-height: {{ block.settings.card_heading_line_height }};
    margin: 0;
  }

  .ai-editorial-card-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    line-height: {{ block.settings.card_text_line_height }};
    margin: 0;
  }

  .ai-editorial-card-text-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-editorial-card-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-editorial-card-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.card_button_padding_vertical }}px {{ block.settings.card_button_padding_horizontal }}px;
    background-color: {{ block.settings.card_button_bg_color }};
    color: {{ block.settings.card_button_text_color }};
    border: {{ block.settings.card_button_border_width }}px solid {{ block.settings.card_button_border_color }};
    text-decoration: none;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.card_button_size }}px;
    text-transform: {{ block.settings.button_transform }};
    letter-spacing: {{ block.settings.button_spacing }}em;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .ai-editorial-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.card_button_hover_bg_color }};
    color: {{ block.settings.card_button_hover_text_color }};
    border-color: {{ block.settings.card_button_hover_border_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.cards_per_row_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-editorial-image-wrapper-{{ ai_gen_id }},
    .ai-editorial-content-{{ ai_gen_id }} {
      grid-column: 1 / -1;
    }

    .ai-editorial-content-{{ ai_gen_id }} {
      margin-top: {{ block.settings.content_spacing }}px;
    }

    .ai-editorial-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-editorial-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-editorial-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-editorial-card-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_heading_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<magazine-editorial-{{ ai_gen_id }}
  class="ai-editorial-layout-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <div class="ai-editorial-grid-{{ ai_gen_id }}">
      <div class="ai-editorial-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-editorial-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-editorial-image-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
              Add an image to complete the editorial layout
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-editorial-content-{{ ai_gen_id }}">
        {% if block.settings.eyebrow != blank %}
          <p class="ai-editorial-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</p>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-editorial-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.body != blank %}
          <div class="ai-editorial-body-{{ ai_gen_id }}">
            {{ block.settings.body }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-editorial-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="4" y1="8" x2="12" y2="8"></line>
              <polyline points="9 5 12 8 9 11"></polyline>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>

    {% if block.settings.show_cards %}
      <div class="ai-editorial-cards-section-{{ ai_gen_id }}">
        <div class="ai-editorial-cards-grid-{{ ai_gen_id }}">
          {% for i in (1..8) %}
            {% liquid
              assign card_heading_key = 'card_' | append: i | append: '_heading'
              assign card_text_key = 'card_' | append: i | append: '_text'
              assign card_button_text_key = 'card_' | append: i | append: '_button_text'
              assign card_button_link_key = 'card_' | append: i | append: '_button_link'

              assign card_heading = block.settings[card_heading_key]
              assign card_text = block.settings[card_text_key]
              assign card_button_text = block.settings[card_button_text_key]
              assign card_button_link = block.settings[card_button_link_key]
            %}

            {% if card_heading != blank or card_text != blank %}
              <div class="ai-editorial-card-{{ ai_gen_id }}">
                {% if card_heading != blank %}
                  <h3 class="ai-editorial-card-heading-{{ ai_gen_id }}">{{ card_heading }}</h3>
                {% endif %}

                {% if card_text != blank %}
                  <div class="ai-editorial-card-text-{{ ai_gen_id }}">
                    {{ card_text }}
                  </div>
                {% endif %}

                {% if card_button_text != blank and card_button_link != blank %}
                  <a
                    href="{{ card_button_link }}"
                    class="ai-editorial-card-button-{{ ai_gen_id }}"
                  >
                    {{ card_button_text }}
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="4" y1="8" x2="12" y2="8"></line>
                      <polyline points="9 5 12 8 9 11"></polyline>
                    </svg>
                  </a>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</magazine-editorial-{{ ai_gen_id }}>

<script>
  (function() {
    class MagazineEditorial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustLayout();
        window.addEventListener('resize', () => this.adjustLayout());
      }

      adjustLayout() {
        const isMobile = window.innerWidth < 750;
        if (isMobile) {
          this.classList.add('mobile-view');
        } else {
          this.classList.remove('mobile-view');
        }
      }
    }

    customElements.define('magazine-editorial-{{ ai_gen_id }}', MagazineEditorial{{ ai_gen_id }});
  })();
</script>

