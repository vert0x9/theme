{%- comment -%}
  BFC PDP Reviews Snippet — Judge.me powered (via shop metafield)
  Usage: {% render 'bfc-pdp-reviews', pdp_handle: product.handle, pdp_title: product.title, cust: customer %}

  Note on `cust`: snippets rendered with {% render %} get an isolated
  variable scope, so globals like `customer` may not always pass through
  reliably depending on the parent template. To guarantee the followup
  modal can read the customer's name/email/address, the parent must pass
  `cust: customer` explicitly. The snippet falls back to `customer`
  directly if `cust` isn't passed, but the explicit form is more reliable.

  Data source:
    shop.metafields.bfc.reviews_json  (populated hourly by Base44 syncJudgemeReviews)
    product.metafields.reviews.rating / .rating_count  (auto-synced by Judge.me)
    shop.metafields.judgeme.all_reviews_rating / all_reviews_count  (auto-synced by Judge.me)

  All rendering is server-side. JS handles tab switching, carousel nav, drag,
  and the Leave a Review button triggering Judge.me's form.
{%- endcomment -%}

{%- comment -%} ── Resolve customer (passed in as `cust` or fallback to global) ── {%- endcomment -%}
{%- if cust == nil -%}{%- assign cust = customer -%}{%- endif -%}

{%- comment -%} ── Resolve product + stats ── {%- endcomment -%}
{%- assign bfc_rv_product = all_products[pdp_handle] -%}
{%- assign bfc_rv_product_id = bfc_rv_product.id -%}
{%- capture bfc_rv_pid_str -%}{{ bfc_rv_product.id }}{%- endcapture -%}
{%- assign bfc_rv_match_handle = pdp_handle -%}

{%- comment -%} ── Pull full review array from shop metafield FIRST (we'll compute product stats from it) ── {%- endcomment -%}
{%- assign bfc_reviews_blob = shop.metafields.bfc.reviews_json.value -%}
{%- assign all_reviews = bfc_reviews_blob.reviews -%}

{%- comment -%} ── Compute product-specific count + average from the blob itself ── {%- endcomment -%}
{%- assign product_review_count = 0 -%}
{%- assign product_rating_sum = 0 -%}
{%- if all_reviews != blank -%}
  {%- for review in all_reviews -%}
    {%- capture bfc_rv_this_pid -%}{{ review.product_id }}{%- endcapture -%}
    {%- assign bfc_rv_is_match = false -%}
    {%- if review.product_handle != blank and review.product_handle == bfc_rv_match_handle -%}
      {%- assign bfc_rv_is_match = true -%}
    {%- elsif bfc_rv_this_pid == bfc_rv_pid_str -%}
      {%- assign bfc_rv_is_match = true -%}
    {%- endif -%}
    {%- if bfc_rv_is_match -%}
      {%- assign product_review_count = product_review_count | plus: 1 -%}
      {%- assign product_rating_sum = product_rating_sum | plus: review.rating -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if product_review_count > 0 -%}
  {%- assign product_rating_x10 = product_rating_sum | times: 10 | divided_by: product_review_count -%}
  {%- assign product_avg_whole = product_rating_x10 | divided_by: 10 -%}
  {%- assign product_avg_frac = product_rating_x10 | modulo: 10 -%}
{%- else -%}
  {%- assign product_avg_whole = 0 -%}
  {%- assign product_avg_frac = 0 -%}
{%- endif -%}

{%- assign all_review_count = shop.metafields.judgeme.all_reviews_count | plus: 0 -%}
{%- capture shop_rating_str -%}{{ shop.metafields.judgeme.all_reviews_rating | default: 0 }}{%- endcapture -%}
{%- assign shop_rating_num = shop_rating_str | plus: 0.0 -%}
{%- assign shop_rating_x10 = shop_rating_num | times: 10 | round -%}
{%- assign all_avg_whole = shop_rating_x10 | divided_by: 10 -%}
{%- assign all_avg_frac = shop_rating_x10 | modulo: 10 -%}

{%- comment -%} ── Fallback: if Judge.me shop metafield is missing, use the blob count ── {%- endcomment -%}
{%- if all_review_count == 0 and all_reviews != blank -%}
  {%- assign blob_count = 0 -%}
  {%- assign blob_sum = 0 -%}
  {%- for review in all_reviews -%}
    {%- assign blob_count = blob_count | plus: 1 -%}
    {%- assign blob_sum = blob_sum | plus: review.rating -%}
  {%- endfor -%}
  {%- assign all_review_count = blob_count -%}
  {%- if blob_count > 0 -%}
    {%- assign shop_rating_x10 = blob_sum | times: 10 | divided_by: blob_count -%}
    {%- assign all_avg_whole = shop_rating_x10 | divided_by: 10 -%}
    {%- assign all_avg_frac = shop_rating_x10 | modulo: 10 -%}
  {%- endif -%}
{%- endif -%}

{%- assign has_product_reviews = false -%}
{%- if product_review_count > 0 -%}{%- assign has_product_reviews = true -%}{%- endif -%}

{%- if all_review_count > 0 and all_reviews != blank -%}

<div class="bfc-rv" id="bfc-rv-section">
<style>
.bfc-rv { background: var(--bk, #202009); border-top: 1px solid rgba(255,255,255,0.06); padding: 56px 48px 64px; }
.bfc-rv-head { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: 8px; }
.bfc-rv-title { font-family: var(--sr, 'Cormorant Garamond', Georgia, serif); font-size: 36px; font-weight: 300; color: #fff; line-height: 1; margin: 0; }
.bfc-rv-summary { display: flex; align-items: center; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
.bfc-rv-avg { font-family: var(--sr, 'Cormorant Garamond', Georgia, serif); font-size: 28px; font-weight: 300; color: #fff; }
.bfc-rv-stars-inline { display: flex; gap: 2px; color: var(--or, #E36E15); }
.bfc-rv-count { font-size: 11px; color: rgba(255,255,255,0.45); letter-spacing: 0.04em; }

/* ── Leave a Review CTA ── */
.bfc-rv-cta { display: flex; align-items: center; justify-content: space-between; gap: 24px; margin: 0 0 28px; padding: 20px 28px; background: rgba(227,110,21,0.06); border-top: 1px solid rgba(227,110,21,0.22); border-bottom: 1px solid rgba(227,110,21,0.22); flex-wrap: wrap; }
.bfc-rv-cta-text { font-family: var(--sr, 'Cormorant Garamond', Georgia, serif); font-size: 17px; color: rgba(255,255,255,0.82); margin: 0; line-height: 1.4; flex: 1; min-width: 220px; }
a.bfc-rv-cta-btn { display: inline-block; background: var(--or, #E36E15) !important; color: var(--cn, #F8F6EE) !important; font-family: var(--sn, 'Poppins', Helvetica, sans-serif); font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none !important; padding: 13px 28px; border: 2px solid var(--or, #E36E15) !important; border-radius: 2px; cursor: pointer; transition: all 0.2s ease; line-height: 1; opacity: 1 !important; white-space: nowrap; }
a.bfc-rv-cta-btn:hover, a.bfc-rv-cta-btn:focus, a.bfc-rv-cta-btn:active { background: var(--gh, #F4A027) !important; border-color: var(--gh, #F4A027) !important; color: var(--cn, #F8F6EE) !important; opacity: 1 !important; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(227,110,21,0.35); }

.bfc-rv-tabs { display: flex; gap: 0; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 28px; }
.bfc-rv-tab { background: none; border: none; border-bottom: 2px solid transparent; padding: 10px 20px; font-family: var(--sn, 'Poppins', sans-serif); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.4); cursor: pointer; transition: color 0.2s, border-color 0.2s; }
.bfc-rv-tab:hover { color: rgba(255,255,255,0.7); }
.bfc-rv-tab.is-active { color: #fff; border-bottom-color: var(--or, #E36E15); }
.bfc-rv-tab-count { font-size: 9px; font-weight: 700; color: var(--or, #E36E15); margin-left: 4px; }
.bfc-rv-panel { display: none; }
.bfc-rv-panel.is-active { display: block; }
.bfc-rv-track-wrap { position: relative; overflow: hidden; }
.bfc-rv-track { display: flex; gap: 16px; transition: transform 400ms ease; cursor: grab; }
.bfc-rv-track.is-dragging { cursor: grabbing; transition: none; }
.bfc-rv-card { flex: 0 0 calc((100% - 32px) / 3); min-width: 280px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); padding: 24px 22px 20px; display: flex; flex-direction: column; gap: 12px; }
.bfc-rv-card-stars { display: flex; gap: 2px; color: var(--or, #E36E15); font-size: 14px; line-height: 1; }
.bfc-rv-card-body { font-size: 13px; line-height: 1.65; color: rgba(255,255,255,0.7); flex: 1; margin: 0; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 7; -webkit-box-orient: vertical; }
.bfc-rv-card-product { display: block; font-size: 10px; color: var(--ce, #ABCC99); text-decoration: none; margin-top: -4px; font-family: var(--sn, 'Poppins', sans-serif); letter-spacing: 0.04em; text-transform: uppercase; }
.bfc-rv-card-product:hover { text-decoration: underline; }
.bfc-rv-card-footer { display: flex; align-items: center; justify-content: space-between; gap: 8px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.06); margin-top: auto; }
.bfc-rv-card-name { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.85); }
.bfc-rv-card-verified { font-size: 9px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ce, #ABCC99); }
/* ── Review photo thumbnails + lightbox ── */
.bfc-rv-card-photos { display: flex; gap: 8px; flex-wrap: wrap; margin: -2px 0 2px; }
.bfc-rv-card-photo { width: 80px; height: 80px; object-fit: cover; cursor: pointer; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); transition: border-color 0.15s, transform 0.15s; display: block; image-rendering: auto; }
.bfc-rv-card-photo:hover { border-color: var(--or, #E36E15); transform: scale(1.05); }
.bfc-rv-card-photo-more { width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); cursor: pointer; transition: border-color 0.15s; }
.bfc-rv-card-photo-more:hover { border-color: var(--or, #E36E15); color: #fff; }
.bfc-rv-lightbox { position: fixed; inset: 0; z-index: 100000; background: rgba(10,10,4,0.92); display: none; align-items: center; justify-content: center; padding: 32px; }
.bfc-rv-lightbox.is-open { display: flex; }
.bfc-rv-lightbox img { max-width: 90vw; max-height: 86vh; object-fit: contain; display: block; }
.bfc-rv-lightbox-close { position: absolute; top: 20px; right: 24px; width: 40px; height: 40px; background: rgba(255,255,255,0.08); border: none; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.bfc-rv-lightbox-close:hover { background: rgba(255,255,255,0.18); }
.bfc-rv-lightbox-nav { position: absolute; top: 50%; transform: translateY(-50%); width: 44px; height: 44px; background: rgba(255,255,255,0.08); border: none; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 22px; }
.bfc-rv-lightbox-nav:hover { background: rgba(255,255,255,0.18); }
.bfc-rv-lightbox-nav.is-prev { left: 20px; }
.bfc-rv-lightbox-nav.is-next { right: 20px; }
.bfc-rv-nav { display: flex; gap: 8px; flex-shrink: 0; }
.bfc-rv-arrow { width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.6); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: background 0.15s, color 0.15s; padding: 0; }
.bfc-rv-arrow:hover { background: rgba(255,255,255,0.08); color: #fff; }
.bfc-rv-empty { font-size: 12px; color: rgba(255,255,255,0.35); font-style: italic; padding: 20px 0; }
@media (max-width: 900px) {
  .bfc-rv { padding: 36px 20px 48px; }
  .bfc-rv-title { font-size: 28px; }
  .bfc-rv-card { flex: 0 0 calc((100% - 16px) / 2); min-width: 260px; }
  .bfc-rv-tab { padding: 8px 14px; font-size: 10px; }
}
@media (max-width: 599px) {
  .bfc-rv-card { flex: 0 0 85%; min-width: 0; }
  .bfc-rv-head { flex-direction: column; gap: 12px; align-items: flex-start; }
  .bfc-rv-cta { flex-direction: column; padding: 18px 16px; text-align: center; }
  .bfc-rv-cta-text { font-size: 15px; }
  a.bfc-rv-cta-btn { width: 100%; padding: 14px 24px; text-align: center; }
}
</style>

  <div class="bfc-rv-head">
    <h2 class="bfc-rv-title">Reviews</h2>
    <div class="bfc-rv-nav">
      <button type="button" class="bfc-rv-arrow" data-bfc-rv-prev aria-label="Previous reviews">&larr;</button>
      <button type="button" class="bfc-rv-arrow" data-bfc-rv-next aria-label="Next reviews">&rarr;</button>
    </div>
  </div>

  {%- comment -%} ── Summary ── {%- endcomment -%}
  <div class="bfc-rv-summary">
    {%- if has_product_reviews -%}
      <span class="bfc-rv-avg">{{ product_avg_whole }}.{{ product_avg_frac }}</span>
      <span class="bfc-rv-stars-inline">
        {%- assign partial_pct = product_avg_frac | times: 10 -%}
        {%- assign partial_star = product_avg_whole | plus: 1 -%}
        {%- for s in (1..5) -%}
          {%- if s <= product_avg_whole -%}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- elsif s == partial_star and product_avg_frac > 0 -%}
            <svg width="14" height="14" viewBox="0 0 24 24"><defs><linearGradient id="rv-partial-p"><stop offset="{{ partial_pct }}%" stop-color="currentColor"/><stop offset="{{ partial_pct }}%" stop-color="transparent"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#rv-partial-p)" stroke="currentColor" stroke-width="1"/></svg>
          {%- else -%}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- endif -%}
        {%- endfor -%}
      </span>
      <span class="bfc-rv-count">{{ product_review_count }} review{%- if product_review_count != 1 -%}s{%- endif -%} for this product</span>
    {%- else -%}
      <span class="bfc-rv-avg">{{ all_avg_whole }}.{{ all_avg_frac }}</span>
      <span class="bfc-rv-stars-inline">
        {%- assign all_partial_pct = all_avg_frac | times: 10 -%}
        {%- assign all_partial_star = all_avg_whole | plus: 1 -%}
        {%- for s in (1..5) -%}
          {%- if s <= all_avg_whole -%}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- elsif s == all_partial_star and all_avg_frac > 0 -%}
            <svg width="14" height="14" viewBox="0 0 24 24"><defs><linearGradient id="rv-partial-s"><stop offset="{{ all_partial_pct }}%" stop-color="currentColor"/><stop offset="{{ all_partial_pct }}%" stop-color="transparent"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#rv-partial-s)" stroke="currentColor" stroke-width="1"/></svg>
          {%- else -%}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- endif -%}
        {%- endfor -%}
      </span>
      <span class="bfc-rv-count">{{ all_review_count }} shop reviews</span>
    {%- endif -%}
  </div>

  {%- comment -%} ── Leave a Review CTA ── {%- endcomment -%}
  <div class="bfc-rv-cta">
    <p class="bfc-rv-cta-text">Shot something beautiful? Share it &mdash; your review helps other film folks find the good stuff.</p>
    <a href="#"
       class="jdgm-write-rev-link bfc-rv-cta-btn"
       data-product-id="{{ bfc_rv_product.id }}"
       data-product-title="{{ bfc_rv_product.title | escape }}"
       data-product-handle="{{ pdp_handle }}"
       onclick="event.preventDefault();">Leave a Review</a>
  </div>

  {%- comment -%} ── Tabs ── {%- endcomment -%}
  <div class="bfc-rv-tabs">
    {%- if has_product_reviews -%}
      <button class="bfc-rv-tab is-active" data-bfc-rv-tab="product">This Product<span class="bfc-rv-tab-count">{{ product_review_count }}</span></button>
    {%- endif -%}
    <button class="bfc-rv-tab{% unless has_product_reviews %} is-active{% endunless %}" data-bfc-rv-tab="shop">Shop Reviews<span class="bfc-rv-tab-count">{{ all_review_count }}</span></button>
  </div>

  {%- comment -%} ── Product panel (filtered to this product) ── {%- endcomment -%}
  {%- if has_product_reviews -%}
  <div class="bfc-rv-panel is-active" data-bfc-rv-panel="product">
    <div class="bfc-rv-track-wrap">
      <div class="bfc-rv-track" data-bfc-rv-track="product">
        {%- assign product_matches_found = 0 -%}
        {%- for review in all_reviews -%}
          {%- capture bfc_rv_this_pid -%}{{ review.product_id }}{%- endcapture -%}
          {%- assign bfc_rv_is_match = false -%}
          {%- if review.product_handle != blank and review.product_handle == bfc_rv_match_handle -%}
            {%- assign bfc_rv_is_match = true -%}
          {%- elsif bfc_rv_this_pid == bfc_rv_pid_str -%}
            {%- assign bfc_rv_is_match = true -%}
          {%- endif -%}
          {%- if bfc_rv_is_match -%}
            {%- assign product_matches_found = product_matches_found | plus: 1 -%}
            <div class="bfc-rv-card" data-bfc-rv-card data-rv-rating="{{ review.rating }}">
              <div class="bfc-rv-card-stars" aria-label="{{ review.rating }} out of 5 stars">
                {%- for s in (1..5) -%}
                  {%- if s <= review.rating -%}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {%- else -%}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <p class="bfc-rv-card-body">{{ review.body | escape }}</p>
              {%- comment -%} ── Review photos ──
                   The Base44 sync may store pictures in a few shapes:
                     • review.pictures = ["url1","url2"]            (array of strings)
                     • review.pictures = [{url:"…"}, …]             (array of objects w/ .url)
                     • review.pictures = [{urls:{compact:"…",…}}]   (Judge.me native shape)
                   We normalize all three. Show up to 4 thumbnails; if more,
                   the 4th becomes a "+N" tile that opens the lightbox at index 3.
                   Each thumbnail carries data-full (the largest URL we can find)
                   so the lightbox shows the high-res version. {%- endcomment -%}
              {%- assign rv_pics = review.picture_urls -%}
              {%- if rv_pics == blank -%}{%- assign rv_pics = review.pictures -%}{%- endif -%}
              {%- if rv_pics == blank -%}{%- assign rv_pics = review.images -%}{%- endif -%}
              {%- if rv_pics == blank -%}{%- assign rv_pics = review.photos -%}{%- endif -%}
              {%- if rv_pics != blank and rv_pics.size > 0 -%}
                <div class="bfc-rv-card-photos">
                  {%- for pic in rv_pics limit: 4 -%}
                    {%- comment -%} Resolve thumb + full URL across the shapes. {%- endcomment -%}
                    {%- assign pic_thumb = '' -%}
                    {%- assign pic_full = '' -%}
                    {%- if pic.urls != blank -%}
                      {%- assign pic_thumb = pic.urls.compact | default: pic.urls.small | default: pic.urls.original -%}
                      {%- assign pic_full = pic.urls.huge | default: pic.urls.original | default: pic.urls.compact -%}
                    {%- elsif pic.url != blank -%}
                      {%- assign pic_thumb = pic.url -%}
                      {%- assign pic_full = pic.url -%}
                    {%- else -%}
                      {%- assign pic_thumb = pic -%}
                      {%- assign pic_full = pic -%}
                    {%- endif -%}
                    {%- comment -%} Judge.me serves imgix URLs ending in "?auto=format&w=1024".
                         imgix honours w= for resizing, so we rewrite the width to get a
                         small crisp thumbnail (160px, sharp on retina at 56px display) and
                         a large lightbox version (1600px). If the URL doesn't contain
                         "w=1024" the replace is a no-op and the original URL is used. {%- endcomment -%}
                    {%- assign pic_thumb = pic_thumb | replace: 'w=1024', 'w=240' -%}
                    {%- assign pic_full = pic_full | replace: 'w=1024', 'w=1600' -%}
                    {%- if pic_thumb != blank -%}
                      {%- if forloop.last and rv_pics.size > 4 -%}
                        {%- assign extra_count = rv_pics.size | minus: 4 -%}
                        <div class="bfc-rv-card-photo-more" data-rv-photo data-full="{{ pic_full | escape }}" role="button" tabindex="0" aria-label="View {{ extra_count | plus: 1 }} more photos">+{{ extra_count | plus: 1 }}</div>
                      {%- else -%}
                        <img class="bfc-rv-card-photo" src="{{ pic_thumb }}" data-rv-photo data-full="{{ pic_full | escape }}" loading="lazy" alt="Customer photo" />
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
              <div class="bfc-rv-card-footer">
                <span class="bfc-rv-card-name">{{ review.author | escape }}</span>
                {%- if review.verified -%}
                  <span class="bfc-rv-card-verified">Verified Buyer</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
