<script>
(function(){
  var sec = document.getElementById('bfc-rv-section');
  if (!sec) return;

  /* ── Smooth-scroll the header rating link (bfc-rating-stars) to reviews ── */
  document.querySelectorAll('a.bfc-rs[href="#bfc-rv-section"]').forEach(function(link){
    link.addEventListener('click', function(e){
      e.preventDefault();
      sec.scrollIntoView({ behavior: 'smooth' });
    });
  });

  var pos = 0;

  /* ── Tab switching ── */
  var tabs = sec.querySelectorAll('[data-bfc-rv-tab]');
  var panels = sec.querySelectorAll('[data-bfc-rv-panel]');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.dataset.bfcRvTab;
      tabs.forEach(function(t) { t.classList.toggle('is-active', t.dataset.bfcRvTab === target); });
      panels.forEach(function(p) { p.classList.toggle('is-active', p.dataset.bfcRvPanel === target); });
      pos = 0;
      var t = activeTrack();
      if (t) t.style.transform = 'translateX(0)';
    });
  });

  /* ── Leave a Review button — find Judge.me's hidden trigger and click it ── */
  var cta = sec.querySelector('.bfc-rv-cta-btn');
  if (cta) {
    cta.addEventListener('click', function(e) {
      e.preventDefault();

      /* Judge.me's new widget renders a "Write a review" button.
         Find it by class first, fall back to text-content matching. */
      var trigger = document.querySelector('.jdgm-widget .jm-action-buttons__button')
                 || document.querySelector('.jdgm-widget .jm-button--primary')
                 || document.querySelector('#judgeme_product_reviews .jm-button--primary');

      /* If class match failed, find by visible text "Write a review" */
      if (!trigger) {
        var allBtns = document.querySelectorAll('.jdgm-widget button, #judgeme_product_reviews button');
        for (var i = 0; i < allBtns.length; i++) {
          var t = allBtns[i].textContent.trim().toLowerCase();
          if (t === 'write a review' || t === 'leave a review' || t.indexOf('write a review') !== -1) {
            trigger = allBtns[i];
            break;
          }
        }
      }

      if (trigger) {
        trigger.click();
        return;
      }

      /* Old class fallbacks (legacy Judge.me) */
      var legacyTrigger = document.querySelector('.jdgm-write-rev-link')
                       || document.querySelector('[data-review-form-trigger]');
      if (legacyTrigger) {
        legacyTrigger.click();
        return;
      }

      /* Last resort: navigate to PDP with review anchor */
      window.location.href = '/products/' + cta.dataset.productHandle + '#judgeme_product_reviews';
    });
  }

  /* ── Carousel navigation ── */
  function activeTrack() {
    var active = sec.querySelector('.bfc-rv-panel.is-active [data-bfc-rv-track]');
    return active || sec.querySelector('[data-bfc-rv-track="shop"]');
  }
  function getStep() {
    var w = sec.offsetWidth;
    if (w < 600) return 1;
    if (w < 900) return 2;
    return 3;
  }
  function slide(dir) {
    var track = activeTrack();
    if (!track) return;
    var cards = track.querySelectorAll('[data-bfc-rv-card]');
    if (!cards.length) return;
    var step = getStep();
    pos += dir * step;
    if (pos >= cards.length) pos = 0;
    if (pos < 0) pos = Math.max(0, cards.length - step);
    var card = cards[pos];
    if (!card) { pos = 0; card = cards[0]; }
    if (card) track.style.transform = 'translateX(-' + card.offsetLeft + 'px)';
  }

  var prevBtn = sec.querySelector('[data-bfc-rv-prev]');
  var nextBtn = sec.querySelector('[data-bfc-rv-next]');
  if (prevBtn) prevBtn.addEventListener('click', function() { slide(-1); });
  if (nextBtn) nextBtn.addEventListener('click', function() { slide(1); });

  /* ── Touch/drag on both tracks ── */
  var rvDragMoved = false; /* shared flag so the photo click handler can ignore drag-clicks */
  var tracks = sec.querySelectorAll('[data-bfc-rv-track]');
  tracks.forEach(function(track) {
    var startX = 0, startTx = 0, dragging = false;
    function getTx() {
      var st = getComputedStyle(track).transform;
      if (!st || st === 'none') return 0;
      var m = st.match(/matrix\((.+)\)/);
      return m ? parseFloat(m[1].split(',')[4]) : 0;
    }
    track.addEventListener('mousedown', function(e) { dragging = true; rvDragMoved = false; startX = e.clientX; startTx = getTx(); track.classList.add('is-dragging'); });
    track.addEventListener('touchstart', function(e) { dragging = true; rvDragMoved = false; startX = e.touches[0].clientX; startTx = getTx(); track.classList.add('is-dragging'); }, { passive: true });
    window.addEventListener('mousemove', function(e) { if (!dragging) return; if (Math.abs(e.clientX - startX) > 6) rvDragMoved = true; track.style.transform = 'translateX(' + (startTx + e.clientX - startX) + 'px)'; });
    window.addEventListener('touchmove', function(e) { if (!dragging) return; if (Math.abs(e.touches[0].clientX - startX) > 6) rvDragMoved = true; track.style.transform = 'translateX(' + (startTx + e.touches[0].clientX - startX) + 'px)'; }, { passive: true });
    function end(e) {
      if (!dragging) return;
      dragging = false;
      track.classList.remove('is-dragging');
      var x = e.changedTouches ? e.changedTouches[0].clientX : e.clientX;
      if (Math.abs(x - startX) > 40) slide(x - startX < 0 ? 1 : -1);
      else track.style.transform = 'translateX(' + startTx + 'px)';
    }
    window.addEventListener('mouseup', end);
    window.addEventListener('touchend', end);
  });
})();
</script>

<script>
/* ── Review photo lightbox ── (separate <script> so an error in the carousel
   JS above can never prevent photo clicks from binding. Deferred to DOMready
   because the lightbox overlay div is rendered after this script tag.) */
(function(){
  function rvInitLightbox(){
  var sec = document.getElementById('bfc-rv-section');
  if (!sec) return;
  var rvLightbox = document.getElementById('bfc-rv-lightbox');
  if (rvLightbox) {
    var rvLbImg = rvLightbox.querySelector('img');
    var rvPhotoEls = [];
    var rvCurrentIdx = 0;

    function rvRefreshPhotoList() {
      rvPhotoEls = Array.prototype.slice.call(sec.querySelectorAll('[data-rv-photo]'));
    }
    function rvOpenLightbox(idx) {
      rvRefreshPhotoList();
      if (!rvPhotoEls.length) return;
      rvCurrentIdx = Math.max(0, Math.min(idx, rvPhotoEls.length - 1));
      rvLbImg.src = rvPhotoEls[rvCurrentIdx].getAttribute('data-full');
      rvLightbox.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }
    function rvCloseLightbox() {
      rvLightbox.classList.remove('is-open');
      document.body.style.overflow = '';
    }
    function rvStep(dir) {
      if (!rvPhotoEls.length) return;
      rvCurrentIdx = (rvCurrentIdx + dir + rvPhotoEls.length) % rvPhotoEls.length;
      rvLbImg.src = rvPhotoEls[rvCurrentIdx].getAttribute('data-full');
    }

    /* Bind each photo directly with pointer tracking. We measure how far the
       pointer moved between down and up; only a near-stationary release counts
       as a click. This is fully independent of the carousel drag handler, so
       it works whether or not the photo lives inside a draggable track. Bound
       per-element (not delegated) and re-bound whenever the list refreshes. */
    function rvBindPhotoClicks() {
      rvRefreshPhotoList();
      rvPhotoEls.forEach(function(el, i) {
        if (el.__rvBound) return;
        el.__rvBound = true;
        var downX = 0, downY = 0;
        el.addEventListener('pointerdown', function(e) { downX = e.clientX; downY = e.clientY; });
        el.addEventListener('pointerup', function(e) {
          var moved = Math.abs(e.clientX - downX) + Math.abs(e.clientY - downY);
          if (moved > 10) return; /* was a drag/swipe, not a tap */
          e.preventDefault();
          e.stopPropagation();
          rvRefreshPhotoList();
          var idx = rvPhotoEls.indexOf(el);
          rvOpenLightbox(idx > -1 ? idx : 0);
        });
        el.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            rvRefreshPhotoList();
            var idx = rvPhotoEls.indexOf(el);
            rvOpenLightbox(idx > -1 ? idx : 0);
          }
        });
      });
    }
    rvBindPhotoClicks();
    /* Re-bind after tab switches (shop reviews tab cards mount/unmount). */
    sec.querySelectorAll('[data-bfc-rv-tab]').forEach(function(tab) {
      tab.addEventListener('click', function() { setTimeout(rvBindPhotoClicks, 50); });
    });

    var rvLbClose = rvLightbox.querySelector('[data-rv-lb-close]');
    var rvLbPrev = rvLightbox.querySelector('[data-rv-lb-prev]');
    var rvLbNext = rvLightbox.querySelector('[data-rv-lb-next]');
    if (rvLbClose) rvLbClose.addEventListener('click', rvCloseLightbox);
    rvLightbox.addEventListener('click', function(e) { if (e.target === rvLightbox) rvCloseLightbox(); });
    if (rvLbPrev) rvLbPrev.addEventListener('click', function(e) { e.stopPropagation(); rvStep(-1); });
    if (rvLbNext) rvLbNext.addEventListener('click', function(e) { e.stopPropagation(); rvStep(1); });
    document.addEventListener('keydown', function(e) {
      if (!rvLightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape') rvCloseLightbox();
      else if (e.key === 'ArrowLeft') rvStep(-1);
      else if (e.key === 'ArrowRight') rvStep(1);
    });
  }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', rvInitLightbox);
  } else {
    rvInitLightbox();
  }
})();
</script>

