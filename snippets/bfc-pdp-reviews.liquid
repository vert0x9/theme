            <label class="bfc-rvf-radio-opt is-active" data-bfc-rvf-radio="ship">
              <input type="radio" name="delivery" value="ship" checked>
              <div class="bfc-rvf-radio-title">Ship to me</div>
              <div class="bfc-rvf-radio-sub">USPS, 1-2 weeks</div>
            </label>
            <label class="bfc-rvf-radio-opt" data-bfc-rvf-radio="pickup">
              <input type="radio" name="delivery" value="pickup">
              <div class="bfc-rvf-radio-title">In-store pickup</div>
              <div class="bfc-rvf-radio-sub">855 Grand St</div>
            </label>
          </div>
        </div>

        <div class="bfc-rvf-ship-only" id="bfc-rvf-ship-only">
          <div class="bfc-rvf-default-addr">
            <label class="bfc-rvf-default-label">
              <input type="checkbox" id="bfc-rvf-use-default" checked>
              <span>Use my default address on file</span>
            </label>
          </div>

          <div class="bfc-rvf-ship-fields is-hidden" id="bfc-rvf-ship-fields">
            <div class="bfc-rvf-field">
              <label class="bfc-rvf-label" for="bfc-rvf-addr1">Address line 1</label>
              <input class="bfc-rvf-input" type="text" id="bfc-rvf-addr1" name="address1">
            </div>
            <div class="bfc-rvf-field">
              <label class="bfc-rvf-label" for="bfc-rvf-addr2">Address line 2 (optional)</label>
              <input class="bfc-rvf-input" type="text" id="bfc-rvf-addr2" name="address2">
            </div>
            <div class="bfc-rvf-field-row">
              <div>
                <label class="bfc-rvf-label" for="bfc-rvf-city">City</label>
                <input class="bfc-rvf-input" type="text" id="bfc-rvf-city" name="city">
              </div>
              <div>
                <label class="bfc-rvf-label" for="bfc-rvf-zip">ZIP</label>
                <input class="bfc-rvf-input" type="text" id="bfc-rvf-zip" name="zip">
              </div>
            </div>
            <div class="bfc-rvf-field-row">
              <div>
                <label class="bfc-rvf-label" for="bfc-rvf-province">State</label>
                <input class="bfc-rvf-input" type="text" id="bfc-rvf-province" name="province">
              </div>
              <div>
                <label class="bfc-rvf-label" for="bfc-rvf-country">Country</label>
                <input class="bfc-rvf-input" type="text" id="bfc-rvf-country" name="country" value="United States">
              </div>
            </div>
          </div>
        </div>

        <div class="bfc-rvf-error" id="bfc-rvf-error"></div>

        <div class="bfc-rvf-actions">
          <button type="button" class="bfc-rvf-cancel" data-bfc-rvf-close>No thanks</button>
          <button type="submit" class="bfc-rvf-submit" id="bfc-rvf-submit">Claim my free roll</button>
        </div>
      </form>
    </div>

    <div id="bfc-rvf-success-view" style="display:none;">
      <div class="bfc-rvf-success">
        <span class="bfc-rvf-ey">// CLAIM RECEIVED</span>
        <h2 class="bfc-rvf-success-title">Thank you. We'll be in touch.</h2>
        <p class="bfc-rvf-success-body" id="bfc-rvf-success-message">You'll receive a confirmation email when we process your free roll.</p>
        <div class="bfc-rvf-actions" style="justify-content:center;">
          <button type="button" class="bfc-rvf-cancel" data-bfc-rvf-close>Close</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var STORAGE_KEY = 'bfcReviewFollowupToken';
  var SUBMITTED_KEY = 'bfcReviewFollowupSubmitted';

  /* Stash judgeme_token if URL contains it. */
  try {
    var params = new URLSearchParams(window.location.search);
    var token = params.get('judgeme_token');
    if (token) sessionStorage.setItem(STORAGE_KEY, token);
  } catch (e) {}

  var storedToken = null;
  try { storedToken = sessionStorage.getItem(STORAGE_KEY); } catch (e) {}
  if (!storedToken) return;

  var alreadySubmitted = false;
  try { alreadySubmitted = sessionStorage.getItem(SUBMITTED_KEY) === '1'; } catch (e) {}
  if (alreadySubmitted) return;

  var modal = document.getElementById('bfc-rvf-modal');
  if (!modal) return;

  window._bfcRvfArmed = true;
  console.log('[BFC review followup] Armed. Token:', storedToken);

  /* ── Detect Judge.me review submission ──
     Judge.me's review form is a multi-step wizard. The 3rd "Next" click
     submits the product review; step 4 is an optional shop-review prompt.
     We trigger our followup AFTER Judge.me's modal disappears entirely
     from the DOM — so the user can engage with the shop prompt (or skip
     it) without our modal popping over theirs. */
  var hasOpened = false;
  function openModalIfNew() {
    if (hasOpened) return;
    hasOpened = true;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    setTimeout(function() {
      var nameInput = document.getElementById('bfc-rvf-name');
      if (nameInput) nameInput.focus();
    }, 200);
  }

  var jdgmNextClicks = 0;
  var productReviewSubmitted = false;
  var jdgmCloseInterval = null;

  document.addEventListener('click', function(ev) {
    if (hasOpened || productReviewSubmitted) return;
    var target = ev.target;
    if (!target || target.nodeType !== 1) return;
    var nextBtn = target.closest('.jdgm-write-review-modal__nav-btn-next');
    if (!nextBtn) return;

    jdgmNextClicks++;
    console.log('[BFC review followup] Judge.me Next click #' + jdgmNextClicks);

    if (jdgmNextClicks >= 3) {
      productReviewSubmitted = true;
      console.log('[BFC review followup] Product review submitted, polling for Judge.me modal to close');

      var checks = 0;
      jdgmCloseInterval = setInterval(function() {
        checks++;
        var jdgmModal = document.querySelector('.jdgm-write-review-modal');
        var isGone = !jdgmModal ||
                     getComputedStyle(jdgmModal).display === 'none' ||
                     getComputedStyle(jdgmModal).visibility === 'hidden';
        if (isGone) {
          console.log('[BFC review followup] Judge.me modal is gone — opening followup');
          clearInterval(jdgmCloseInterval);
          setTimeout(function() { openModalIfNew(); }, 600);
        } else if (checks > 600) {
          clearInterval(jdgmCloseInterval);
        }
      }, 500);
    }
  }, true);

  /* ── Modal interactions ── */
  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
  }
  modal.querySelectorAll('[data-bfc-rvf-close]').forEach(function(btn) {
    btn.addEventListener('click', closeModal);
  });
  modal.addEventListener('click', function(ev) {
    if (ev.target === modal) closeModal();
  });
  document.addEventListener('keydown', function(ev) {
    if (ev.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });

  /* ── Ship/pickup radio toggle ── */
  var shipOnly = document.getElementById('bfc-rvf-ship-only');
  modal.querySelectorAll('[data-bfc-rvf-radio]').forEach(function(opt) {
    opt.addEventListener('click', function() {
      modal.querySelectorAll('.bfc-rvf-radio-opt').forEach(function(o) {
        o.classList.remove('is-active');
      });
      opt.classList.add('is-active');
      var val = opt.getAttribute('data-bfc-rvf-radio');
      opt.querySelector('input[type="radio"]').checked = true;
      if (val === 'pickup') {
        shipOnly.classList.add('is-hidden');
      } else {
        shipOnly.classList.remove('is-hidden');
      }
    });
  });

  /* ── "Use my default address" checkbox toggle ── */
  var useDefaultCheckbox = document.getElementById('bfc-rvf-use-default');
  var useDefaultHidden = document.getElementById('bfc-rvf-use-default-hidden');
  var shipFields = document.getElementById('bfc-rvf-ship-fields');
  function syncDefaultAddrState() {
    if (useDefaultCheckbox.checked) {
      shipFields.classList.add('is-hidden');
      useDefaultHidden.value = '1';
    } else {
      shipFields.classList.remove('is-hidden');
      useDefaultHidden.value = '0';
    }
  }
  if (useDefaultCheckbox) {
    useDefaultCheckbox.addEventListener('change', syncDefaultAddrState);
    syncDefaultAddrState();
  }

  /* ── Form submission ── */
  var form = document.getElementById('bfc-rvf-form');
  var submitBtn = document.getElementById('bfc-rvf-submit');
  var errorEl = document.getElementById('bfc-rvf-error');
  var formView = document.getElementById('bfc-rvf-form-view');
  var successView = document.getElementById('bfc-rvf-success-view');

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.add('is-shown');
  }

  form.addEventListener('submit', function(ev) {
    /* Validate first; if anything's missing, block submission. Otherwise
       allow the native POST to fire through the hidden iframe. */
    errorEl.classList.remove('is-shown');

    var fd = new FormData(form);
    var delivery = fd.get('delivery');
    var name = (fd.get('name') || '').trim();
    var email = (fd.get('email') || '').trim();

    if (!name || !email) {
      ev.preventDefault();
      showError('Please provide your name and email.');
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      ev.preventDefault();
      showError('Please enter a valid email address.');
      return;
    }

    /* Address validation only applies when:
       - Delivery is "ship", AND
       - "Use my default address" is unchecked */
    if (delivery === 'ship' && !useDefaultCheckbox.checked) {
      var addr1 = (fd.get('address1') || '').trim();
      var city  = (fd.get('city') || '').trim();
      var zip   = (fd.get('zip') || '').trim();
      if (!addr1 || !city || !zip) {
        ev.preventDefault();
        showError('Please complete your shipping address.');
        return;
      }
    }

    /* Populate the judgeme_token hidden input from sessionStorage. */
    var tokenInput = document.getElementById('bfc-rvf-token');
    if (tokenInput) tokenInput.value = storedToken || '';

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    /* Native form POST fires now (we didn't preventDefault). Since the
       response goes to the hidden iframe and we can't read it cross-origin,
       we just show success after a brief delay. Base44 validates server-
       side and notifies addie@ on real submissions; rejected attempts
       (duplicates, no matching order) are visible in Base44 admin. */
    setTimeout(function() {
      try { sessionStorage.setItem(SUBMITTED_KEY, '1'); } catch (e) {}
      formView.style.display = 'none';
      successView.style.display = 'block';
    }, 1500);
  });
})();
</script>
