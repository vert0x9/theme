{%- comment -%}
  Renders the article footer author card: publish/update dates, author name,
  bio and social links.

  Author identity is resolved in main-article.liquid (metafields → name map →
  generic fallback) and passed in, so the visible card and the JSON-LD stay in
  sync.

  Params:
    article          - the article object (for dates)
    author_name      - resolved display name
    author_bio       - resolved bio text
    author_instagram - Instagram URL or ''
    author_url       - secondary website URL or ''
    author_url_label - label for the secondary link (default 'Website')
{%- endcomment -%}

{%- liquid
  assign date_format = 'theme.date.format_short' | t
  assign published_at = article.published_at | date: date_format
  assign updated_at = article.updated_at | date: date_format
-%}

<div class="article__author-card">
  <div class="article__author-dates">
    <time class="article__author-date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
      {{- 'blog.posted' | t }} {{ published_at -}}
    </time>
    {%- if updated_at != published_at -%}
      <time class="article__author-date article__author-date--updated" datetime="{{ article.updated_at | date: '%Y-%m-%d' }}" itemprop="dateModified">
        {{- 'blog.updated_on' | t: date: updated_at | capitalize -}}
      </time>
    {%- endif -%}
  </div>

  <div class="article__author-body" itemprop="author" itemscope itemtype="https://schema.org/{{ author_type | default: 'Person' }}">
    <p class="article__author-name" itemprop="name">{{ author_name }}</p>
    {%- if author_bio != blank -%}
      <p class="article__author-text" itemprop="description">{{ author_bio }}</p>
    {%- endif -%}

    {%- if author_instagram != '' or author_url != '' -%}
      <ul class="article__author-socials list-unstyled">
        {%- if author_instagram != '' -%}
          <li>
            <a href="{{ author_instagram }}" target="_blank" rel="noopener me" itemprop="sameAs">Instagram</a>
          </li>
        {%- endif -%}
        {%- if author_url != '' -%}
          <li>
            <a href="{{ author_url }}" target="_blank" rel="noopener me" itemprop="sameAs">{{ author_url_label | default: 'Website' }}</a>
          </li>
        {%- endif -%}
      </ul>
    {%- endif -%}
  </div>
</div>
