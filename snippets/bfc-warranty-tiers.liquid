{%- comment -%}
  ============================================================================
  BFC WARRANTY TIERS — Liquid pricing snippet — snippets/bfc-warranty-tiers.liquid

  Single source of truth for extended-warranty variant IDs and prices.
  Returns assigns for use on a PDP. Usage from a PDP:

    {%- include 'bfc-warranty-tiers', category: 'slr', cam_price: current_variant.price -%}

  Required input:
    - category   one of 'slr', 'polaroid', 'mf', 'pas'
    - cam_price  the camera price in cents (current_variant.price)

  Outputs (use after include):
    For SLR / Polaroid / MF (only +6 mo offered):
      w_w12_vid       variant id of the +6 month tier matching cam_price
      w_w12_price     price in cents

    For PAS (all three: +3 mo / +6 mo / +9 mo):
      w_w6_vid, w_w6_price    +3 months (6 mo total)
      w_w9_vid, w_w9_price    +6 months (9 mo total)
      w_w12_vid, w_w12_price  +9 months (12 mo total)

  Tier brackets (matches Shopify Price Tier option exactly):
    0: $0-$200       6: $1001-$1500
    1: $201-$300     7: $1501-$2000
    2: $301-$400     8: $2001-$3000
    3: $401-$500     9: $3001-$4000
    4: $501-$700    10: $4001+
    5: $701-$1000

  Updated 2026-05-13 with the new bfc-extended-warranty-new product variants.
  ============================================================================
{%- endcomment -%}

{%- comment -%} Pick tier index based on camera price (in cents) {%- endcomment -%}
{%- if cam_price <= 20000 -%}
  {%- assign w_tier = 0 -%}
{%- elsif cam_price <= 30000 -%}
  {%- assign w_tier = 1 -%}
{%- elsif cam_price <= 40000 -%}
  {%- assign w_tier = 2 -%}
{%- elsif cam_price <= 50000 -%}
  {%- assign w_tier = 3 -%}
{%- elsif cam_price <= 70000 -%}
  {%- assign w_tier = 4 -%}
{%- elsif cam_price <= 100000 -%}
  {%- assign w_tier = 5 -%}
{%- elsif cam_price <= 150000 -%}
  {%- assign w_tier = 6 -%}
{%- elsif cam_price <= 200000 -%}
  {%- assign w_tier = 7 -%}
{%- elsif cam_price <= 300000 -%}
  {%- assign w_tier = 8 -%}
{%- elsif cam_price <= 400000 -%}
  {%- assign w_tier = 9 -%}
{%- else -%}
  {%- assign w_tier = 10 -%}
{%- endif -%}

{%- if category == 'slr' -%}
  {%- comment -%} SLR / Rangefinder — only +6 month offered (single button) {%- endcomment -%}
  {%- case w_tier -%}
    {%- when 0 -%}{%- assign w_w12_vid = '46244383752364' -%}{%- assign w_w12_price = 1500 -%}
    {%- when 1 -%}{%- assign w_w12_vid = '46244383785132' -%}{%- assign w_w12_price = 2500 -%}
