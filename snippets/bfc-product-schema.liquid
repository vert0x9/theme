{%- liquid
  assign jm_count = 0
  assign jm_avg = 0
  assign jm_raw = product.metafields.judgeme.review_widget_data
  if jm_raw != blank
    assign jm_num = jm_raw.number_of_reviews
    if jm_num != blank
      assign jm_count = jm_num | plus: 0
    endif
    assign jm_ar = jm_raw.average_rating
    if jm_ar != blank
      assign jm_avg = jm_ar | times: 1.0
    endif
    if jm_count == 0
      assign jm_str = jm_raw | json
      if jm_str contains 'number_of_reviews'
        assign jm_p1 = jm_str | split: '"number_of_reviews":'
        if jm_p1.size > 1
          assign jm_p2 = jm_p1[1] | split: ',' | first | split: '}' | first | strip
          assign jm_count = jm_p2 | plus: 0
        endif
      endif
      if jm_str contains 'average_rating'
        assign jm_p3 = jm_str | split: '"average_rating":"'
        if jm_p3.size > 1
          assign jm_p4 = jm_p3[1] | split: '"' | first
          assign jm_avg = jm_p4 | times: 1.0
        endif
      endif
    endif
  endif

  assign schema_condition = 'https://schema.org/RefurbishedCondition'
  assign product_type_lower = product.type | downcase
  if product_type_lower contains 'film' or product_type_lower contains 'accessor' or product_type_lower contains 'strap' or product_type_lower contains 'bag' or product_type_lower contains 'battery' or product_type_lower contains 'filter' or product_type_lower contains 'print' or product_type_lower contains 'gift' or product_type_lower contains 'membership' or product_type_lower contains 'subscription' or product_type_lower contains 'apparel' or product_type_lower contains 'book'
    assign schema_condition = 'https://schema.org/NewCondition'
  endif
  if product.tags contains 'new-condition'
    assign schema_condition = 'https://schema.org/NewCondition'
  endif

  assign current_variant = product.selected_or_first_available_variant
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "{{ shop.url }}{{ product.url }}/#product",
  "name": {{ product.title | json }},
  "url": {{ shop.url | append: product.url | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "image": [{% for image in product.images limit: 5 %}{{ image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
  {% if product.vendor != blank %}"brand": { "@type": "Brand", "name": {{ product.vendor | json }} },{% endif %}
  {% if current_variant.sku != blank %}"sku": {{ current_variant.sku | json }},{% endif %}
  {% if current_variant.barcode != blank %}"mpn": {{ current_variant.barcode | json }},
  {% if current_variant.barcode.size == 12 %}"gtin12": {{ current_variant.barcode | json }},
  {% elsif current_variant.barcode.size == 13 %}"gtin13": {{ current_variant.barcode | json }},
  {% elsif current_variant.barcode.size == 14 %}"gtin14": {{ current_variant.barcode | json }},
  {% endif %}{% endif %}
  "itemCondition": "{{ schema_condition }}",
  "offers": {% if product.variants.size == 1 %}{
    "@type": "Offer",
    "url": {{ shop.url | append: current_variant.url | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ current_variant.price | divided_by: 100.00 | json }},
    "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "priceValidUntil": {{ "today" | date: '%s' | plus: 2592000 | date: "%Y-%m-%d" | json }},
    "seller": { "@id": "{{ shop.url }}/#organization" },
    "shippingDetails": { "@id": "{{ shop.url }}/#shipping_policy" },
    "hasMerchantReturnPolicy": { "@id": "{{ shop.url }}/#return_policy" }
    {% if current_variant.sku != blank %},"sku": {{ current_variant.sku | json }}{% endif %}
  }{% else %}[{% for variant in product.variants %}{
    "@type": "Offer",
    "url": {{ shop.url | append: variant.url | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ variant.price | divided_by: 100.00 | json }},
    "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "priceValidUntil": {{ "today" | date: '%s' | plus: 2592000 | date: "%Y-%m-%d" | json }},
    "seller": { "@id": "{{ shop.url }}/#organization" },
    "shippingDetails": { "@id": "{{ shop.url }}/#shipping_policy" },
    "hasMerchantReturnPolicy": { "@id": "{{ shop.url }}/#return_policy" }
    {% if variant.sku != blank %},"sku": {{ variant.sku | json }}{% endif %}
    {% if variant.barcode != blank %}
    {% if variant.barcode.size == 12 %},"gtin12": {{ variant.barcode | json }}
    {% elsif variant.barcode.size == 13 %},"gtin13": {{ variant.barcode | json }}
    {% elsif variant.barcode.size == 14 %},"gtin14": {{ variant.barcode | json }}
    {% endif %}{% endif %}
  }{% unless forloop.last %},{% endunless %}{% endfor %}]{% endif %}
  {% if jm_count > 0 and jm_avg > 0 %}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ jm_avg | json }},
    "reviewCount": {{ jm_count | json }},
    "bestRating": 5,
    "worstRating": 1
  }
  {% endif %}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "OfferShippingDetails",
  "@id": "{{ shop.url }}/#shipping_policy",
  "shippingRate": {
    "@type": "MonetaryAmount",
    "value": "0",
    "currency": "USD"
  },
  "shippingDestination": {
    "@type": "DefinedRegion",
    "addressCountry": "US"
  },
  "deliveryTime": {
    "@type": "ShippingDeliveryTime",
    "handlingTime": { "@type": "QuantitativeValue", "minValue": 1, "maxValue": 3, "unitCode": "DAY" },
    "transitTime": { "@type": "QuantitativeValue", "minValue": 2, "maxValue": 7, "unitCode": "DAY" }
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MerchantReturnPolicy",
  "@id": "{{ shop.url }}/#return_policy",
  "applicableCountry": "US",
  "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
  "merchantReturnDays": 14,
  "returnMethod": "https://schema.org/ReturnByMail",
  "returnFees": "https://schema.org/ReturnShippingFees"
}
</script>
