{%- case request.page_type -%}
  {%- when 'page' -%}
    {%- assign page_type = 'WebPage' -%}
    {%- if page.handle == 'about-us' -%}
      {%- assign page_type = 'AboutPage' -%}
    {%- elsif page.handle == 'contact' -%}
      {%- assign page_type = 'ContactPage' -%}
    {%- endif -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "{{ page_type }}",
      "@id": "{{ shop.url }}{{ page.url }}/#page",
      "name": {{ page.title | json }},
      "url": {{ shop.url | append: page.url | json }},
      "isPartOf": { "@id": "{{ shop.url }}/#website" }
    }
    </script>

  {%- when 'search' -%}
    {%- if search.performed -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SearchResultsPage",
      "@id": "{{ shop.url }}/search/#searchresults",
      "name": "Search: {{ search.terms | escape }}",
      "url": {{ shop.url | append: routes.search_url | append: '?q=' | append: search.terms | json }},
      "isPartOf": { "@id": "{{ shop.url }}/#website" }
    }
    </script>
    {%- endif -%}
{%- endcase -%}
