{%- liquid
  assign meta_title = page_title | default: shop.name
  assign meta_description = page_description | default: shop.description | default: shop.name
  assign meta_url = canonical_url | default: request.origin
  assign meta_type = 'website'

  if request.page_type == 'product'
    assign meta_type = 'product'
  elsif request.page_type == 'article'
    assign meta_type = 'article'
    if page_description == blank
      assign meta_description = article.excerpt_or_content | strip_html | truncate: 320
    endif
  elsif request.page_type == 'blog'
    if page_description == blank and blog.description != blank
      assign meta_description = blog.description | strip_html | truncate: 320
    endif
  elsif request.page_type == 'collection'
    assign meta_type = 'product.group'
  elsif request.page_type == 'password'
    assign meta_url = request.origin
  endif
%}

{%- for locale in shop.published_locales -%}
  <link rel="alternate" hreflang="{{ locale.iso_code }}" href="{{ request.origin }}{{ locale.root_url }}{{ request.path | remove_first: '/' }}">
  {%- if locale.primary -%}
    <link rel="alternate" hreflang="x-default" href="{{ request.origin }}{{ locale.root_url }}{{ request.path | remove_first: '/' }}">
  {%- endif -%}
{%- endfor -%}

<title>
  {{ meta_title }}
  {%- if current_tags %}
    &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %}
    &ndash; Page {{ current_page }}{% endif -%}
  {%- unless meta_title contains shop.name %}
    &ndash; {{ shop.name }}{% endunless -%}
</title>

{%- if meta_description -%}
  <meta name="description" content="{{ meta_description | escape }}">
{%- endif -%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ meta_url }}">
<meta property="og:title" content="{{ meta_title | escape }}">
<meta property="og:type" content="{{ meta_type }}">
<meta property="og:description" content="{{ meta_description | escape }}">

{%- liquid
  assign og_image = page_image | default: settings.share_image
  if request.page_type == 'article' and page_image == blank and article.image != blank
    assign og_image = article.image
  endif
-%}
{%- if og_image -%}
  <meta property="og:image" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="{{ og_image.width | at_most: 1200 }}">
  <meta property="og:image:height" content="{{ og_image.height }}">
  <meta name="twitter:image" content="https:{{ og_image | image_url: width: 1200 }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ meta_title | escape }}">
<meta name="twitter:description" content="{{ meta_description | escape }}">

{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ shop.url }}/#organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "logo": {
        "@type": "ImageObject",
        "url": "https:{{ 'logo.png' | asset_url }}"
      },
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "telephone": "+1-718-218-4023",
          "email": "hello@brooklynfilmcamera.com",
          "availableLanguage": "English"
        },
        {
          "@type": "ContactPoint",
          "contactType": "technical support",
          "email": "repairs@brooklynfilmcamera.com",
          "availableLanguage": "English"
        }
      ],
      "sameAs": [
        {%- if settings.social_instagram_link != blank -%}{{ settings.social_instagram_link | json }},{%- endif -%}
        {%- if settings.social_twitter_link != blank -%}{{ settings.social_twitter_link | json }},{%- endif -%}
        {%- if settings.social_facebook_link != blank -%}{{ settings.social_facebook_link | json }},{%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}{{ settings.social_tiktok_link | json }},{%- endif -%}
        {%- if settings.social_youtube_link != blank -%}{{ settings.social_youtube_link | json }},{%- endif -%}
        "https://brooklynfilmcamera.com"
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": "{{ shop.url }}/#localbusiness",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "description": "Brooklyn's film camera shop. Refurbished 35mm and medium format cameras, film developing, camera repairs, and film supplies.",
      "parentOrganization": { "@id": "{{ shop.url }}/#organization" },
      "telephone": "+1-718-218-4023",
      "email": "hello@brooklynfilmcamera.com",
      "priceRange": "$$",
      "image": "https:{{ 'logo.png' | asset_url }}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "855 Grand St",
        "addressLocality": "Brooklyn",
        "addressRegion": "NY",
        "postalCode": "11211",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 40.7128,
        "longitude": -73.9387
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "11:00",
          "closes": "19:00"
        }
      ],
      "hasMap": "https://maps.google.com/?q=855+Grand+St+Brooklyn+NY+11211"
    },
    {
      "@type": "WebSite",
      "@id": "{{ shop.url }}/#website",
      "url": {{ shop.url | json }},
      "name": {{ shop.name | json }},
      "publisher": { "@id": "{{ shop.url }}/#organization" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  ]
}
</script>
{%- endif -%}
