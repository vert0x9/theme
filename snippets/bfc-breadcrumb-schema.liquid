{%- liquid
  assign bc_items = '' -%}
  assign bc_pos = 1 -%}

{%- comment -%} Position 1: Home {%- endcomment -%}
{%- capture bc_home -%}
{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ 'theme.breadcrumb.home' | t | json }},
  "item": {{ shop.url | json }}
}
{%- endcapture -%}
{%- assign bc_items = bc_items | append: bc_home -%}

{%- case request.page_type -%}
  {%- when 'product' -%}
    {%- assign bc_pos = bc_pos | plus: 1 -%}
    {%- assign bc_collection = collection -%}
    {%- if bc_collection == blank -%}
      {%- assign bc_collection = product.collections.first -%}
    {%- endif -%}
    {%- if bc_collection != blank -%}
      {%- capture bc_coll -%}
,{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ bc_collection.title | json }},
  "item": {{ shop.url | append: bc_collection.url | json }}
}
      {%- endcapture -%}
      {%- assign bc_items = bc_items | append: bc_coll -%}
      {%- assign bc_pos = bc_pos | plus: 1 -%}
    {%- endif -%}
    {%- capture bc_prod -%}
,{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ product.title | json }}
}
    {%- endcapture -%}
    {%- assign bc_items = bc_items | append: bc_prod -%}

  {%- when 'collection' -%}
    {%- if collection != blank -%}
      {%- assign bc_pos = bc_pos | plus: 1 -%}
      {%- capture bc_coll -%}
,{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ collection.title | json }}
}
      {%- endcapture -%}
      {%- assign bc_items = bc_items | append: bc_coll -%}
      {%- if current_tags -%}
        {%- assign bc_pos = bc_pos | plus: 1 -%}
        {%- capture bc_tag -%}
,{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ current_tags | join: ', ' | json }}
}
        {%- endcapture -%}
        {%- assign bc_items = bc_items | append: bc_tag -%}
      {%- endif -%}
    {%- endif -%}

  {%- when 'article' -%}
    {%- assign bc_pos = bc_pos | plus: 1 -%}
    {%- capture bc_blog -%}
,{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ blog.title | json }},
  "item": {{ shop.url | append: blog.url | json }}
}
    {%- endcapture -%}
    {%- assign bc_items = bc_items | append: bc_blog -%}
    {%- assign bc_pos = bc_pos | plus: 1 -%}
    {%- capture bc_art -%}
,{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ article.title | json }}
}
    {%- endcapture -%}
    {%- assign bc_items = bc_items | append: bc_art -%}

  {%- when 'page' -%}
    {%- assign bc_pos = bc_pos | plus: 1 -%}
    {%- capture bc_page -%}
,{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ page.title | json }}
}
    {%- endcapture -%}
    {%- assign bc_items = bc_items | append: bc_page -%}

  {%- when 'blog' -%}
    {%- assign bc_pos = bc_pos | plus: 1 -%}
    {%- capture bc_blog -%}
,{
  "@type": "ListItem",
  "position": {{ bc_pos }},
  "name": {{ blog.title | json }}
}
    {%- endcapture -%}
    {%- assign bc_items = bc_items | append: bc_blog -%}
{%- endcase -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{{ bc_items }}]
}
</script>
