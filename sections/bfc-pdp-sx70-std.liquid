{%- comment -%}
  ================================================================
  JAVASCRIPT
  ================================================================
{%- endcomment -%}
<script>
(function(){
// ── XHR helper (bypasses Judge.me monkey-patching of window.fetch) ─────
function sxXhr(url, opts) {
  opts = opts || {};
  return new Promise(function(resolve, reject) {
    var xhr = new XMLHttpRequest();
    xhr.open(opts.method || 'GET', url, true);
    xhr.withCredentials = true;
    if (opts.headers) Object.keys(opts.headers).forEach(function(k){xhr.setRequestHeader(k, opts.headers[k]);});
    xhr.setRequestHeader('X-Requested-With','XMLHttpRequest');
    xhr.onload = function() {
      resolve({
        ok: xhr.status>=200 && xhr.status<300,
        status: xhr.status,
        json: function(){ try{return Promise.resolve(JSON.parse(xhr.responseText));}catch(e){return Promise.resolve({});} },
        text: function(){ return Promise.resolve(xhr.responseText); }
      });
    };
    xhr.onerror = function(){ reject(new Error('Network error')); };
    xhr.send(opts.body || null);
  });
}
  const sid = '{{ section.id }}';

  /* ── Slider + Thumbs ── */
  const slider = document.getElementById('sxSlider-' + sid);
  const dots   = document.querySelectorAll('#sxDots-' + sid + ' .sx-dot');
  const thumbs = document.querySelectorAll('#sxThumbs-' + sid + ' .sx-thumb');
  if (slider) {
    const updateActive = () => {
      const idx = Math.round(slider.scrollLeft / slider.offsetWidth);
      dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      thumbs.forEach((t, i) => t.classList.toggle('is-active', i === idx));
    };
    slider.addEventListener('scroll', updateActive, { passive: true });
    const goTo = (idx) => slider.scrollTo({ left: idx * slider.offsetWidth, behavior: 'smooth' });
    dots.forEach(d => d.addEventListener('click', () => goTo(+d.dataset.idx)));
    thumbs.forEach(t => t.addEventListener('click', () => goTo(+t.dataset.idx)));
  }

  /* ── Variant picker ── */
  const variantBtns = document.querySelectorAll('#sxVariants-' + sid + ' .sx-variant-btn');
  const priceEl     = document.getElementById('sxPrice-' + sid);
  const compareEl   = document.getElementById('sxCompare-' + sid);
  const varInput    = document.getElementById('sxVariantInput-' + sid);
  const addBtn      = document.querySelector('#sxATC-' + sid + ' .sx-add-btn');

  variantBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.classList.contains('is-sold-out')) return;
      variantBtns.forEach(b => b.classList.remove('is-selected'));
      btn.classList.add('is-selected');
      varInput.value = btn.dataset.variantId;
      if (priceEl) priceEl.textContent = btn.dataset.price;
      if (compareEl) {
        compareEl.textContent = btn.dataset.compare || '';
        compareEl.style.display = btn.dataset.compare ? '' : 'none';
      }
      const avail = btn.dataset.available === 'true';
      addBtn.disabled = !avail;
      addBtn.textContent = avail ? 'Add to Cart' : 'Sold Out';

      /* Update URL */
      const url = new URL(window.location);
      url.searchParams.set('variant', btn.dataset.variantId);
      window.history.replaceState({}, '', url);

      /* Update warranty tier */
      if (btn.dataset.priceCents) sxUpdateWarrantyTier(parseInt(btn.dataset.priceCents, 10));

      /* Update sticky bar */
      const stickyGrade = document.getElementById('sx-sticky-grade');
      const stickyPrice = document.getElementById('sx-sticky-price');
      const stickyBtn   = document.getElementById('sx-sticky-btn');
      if (stickyGrade) stickyGrade.textContent = btn.textContent.trim();
      if (stickyPrice) stickyPrice.textContent = btn.dataset.price;
      if (stickyBtn)   stickyBtn.disabled = !avail;
    });
  });

  /* ── Kit builder ── */
  const kitTiles = document.querySelectorAll('.bfcsx .sx-kit-tile');
  const kitCart  = [];
  kitTiles.forEach(tile => {
    tile.addEventListener('click', () => {
      tile.classList.toggle('is-selected');
      const vid = tile.dataset.variantId;
      const idx = kitCart.indexOf(vid);
      if (idx > -1) kitCart.splice(idx, 1);
      else kitCart.push(vid);
    });
  });

  /* ── Extended Warranty ── */
  let sxWarranty = null;
  // Warranty tier table — sourced from snippets/bfc-warranty-tiers-js.liquid
  // (Polaroid pricing, 9 brackets). Snippet emits BFC_WARRANTY_TIERS;
  // SX_WARRANTY_TIERS aliased here so existing sxGetWarrantyTier code is unchanged.
  {% render 'bfc-warranty-tiers-js', category: 'polaroid' %}
  const SX_WARRANTY_TIERS = BFC_WARRANTY_TIERS;
  function sxGetWarrantyTier(price) {
    for (let i = 0; i < SX_WARRANTY_TIERS.length; i++) {
      if (price <= SX_WARRANTY_TIERS[i].max) return SX_WARRANTY_TIERS[i];
    }
    return SX_WARRANTY_TIERS[SX_WARRANTY_TIERS.length - 1];
  }
  function sxUpdateWarrantyTier(variantPrice) {
    const tier = sxGetWarrantyTier(variantPrice);
    const td = [{ vid: tier.v9, price: tier.p9 }, { vid: tier.v12, price: tier.p12 }];
    document.querySelectorAll('.sx-ext-w-btn').forEach((btn, i) => {
      if (!td[i]) return;
      btn.dataset.variantId = td[i].vid;
      btn.dataset.price = td[i].price;
      const el = btn.querySelector('.sx-ext-w-price');
      if (el) el.textContent = '+$' + (td[i].price / 100).toFixed(0);
      if (btn.classList.contains('is-sel') && sxWarranty) {
        sxWarranty.variantId = td[i].vid;
        sxWarranty.price = td[i].price;
      }
    });
  }
  window.sxSelectWarranty = function(btn) {
    const wasSelected = btn.classList.contains('is-sel');
    document.querySelectorAll('.sx-ext-w-btn').forEach(b => b.classList.remove('is-sel'));
    const clearBtn = document.getElementById('sx-ext-w-clear');
    if (wasSelected) {
      sxWarranty = null;
      if (clearBtn) clearBtn.classList.remove('is-vis');
    } else {
      btn.classList.add('is-sel');
      sxWarranty = {
        months: parseInt(btn.dataset.months, 10),
        total:  parseInt(btn.dataset.total, 10),
        price:  parseInt(btn.dataset.price, 10),
        variantId: btn.dataset.variantId || null
      };
      if (clearBtn) clearBtn.classList.add('is-vis');
    }
  };
  window.sxClearWarranty = function() {
    document.querySelectorAll('.sx-ext-w-btn').forEach(b => b.classList.remove('is-sel'));
    sxWarranty = null;
    const clearBtn = document.getElementById('sx-ext-w-clear');
    if (clearBtn) clearBtn.classList.remove('is-vis');
  };
  sxUpdateWarrantyTier({{ current_variant.price }});

  /* ── Intercept ATC to include kit + warranty items ── */
  const form = document.getElementById('sxATC-' + sid);
  if (form) {
    form.addEventListener('submit', function(e) {
      if (kitCart.length === 0 && !sxWarranty) return; /* default single-item submit */
      e.preventDefault();
      const items = [{ id: parseInt(varInput.value), quantity: 1 }];
      kitCart.forEach(vid => items.push({ id: parseInt(vid), quantity: 1 }));
      if (sxWarranty && sxWarranty.variantId) {
        items.push({ id: parseInt(sxWarranty.variantId), quantity: 1, properties: { _extended_warranty: 'true' } });
      }
      sxXhr('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      }).then(r => {
        if (r.ok) window.location.href = '/cart';
        else r.json().then(d => alert(d.description || 'Could not add to cart'));
      }).catch(() => alert('Something went wrong — please try again.'));
    });
  }

  /* ── Sticky Mobile ATC Bar ── */
  const stickyBar = document.getElementById('sx-sticky-bar');
  const mainBtn   = document.querySelector('#sxATC-' + sid + ' .sx-add-btn');
  if (stickyBar && mainBtn && window.innerWidth <= 767) {
    new IntersectionObserver(entries => {
      entries.forEach(e => stickyBar.classList.toggle('is-visible', !e.isIntersecting));
    }, { threshold: 0 }).observe(mainBtn);
  }
})();
</script>

