<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/></noscript>

<style>
#bfc-feat-{{ section.id }} *, #bfc-feat-{{ section.id }} *::before, #bfc-feat-{{ section.id }} *::after { box-sizing: border-box; margin: 0; padding: 0; }

#bfc-feat-{{ section.id }} {
  --or: #E36E15;
  --go: #F4A027;
  --ce: #ABCC99;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sr: 'Cormorant Garamond', Georgia, serif;
  --sn: 'Poppins', sans-serif;
  --t: 0.25s ease;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
  position: relative;
}
#bfc-feat-{{ section.id }}.is-dark { background: var(--bk); color: #fff; }

{%- comment -%} ── TRACK: holds the visible camera cards side by side ── {%- endcomment -%}
#bfc-feat-{{ section.id }} .feat-track {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
#bfc-feat-{{ section.id }} .feat-track.is-showing-1 { grid-template-columns: 1fr; }

{%- comment -%} Each card hidden until JS reveals it; noscript reveals the first {%- endcomment -%}
#bfc-feat-{{ section.id }} .feat-card { display: none; }
#bfc-feat-{{ section.id }} .feat-card.is-on { display: grid; }

#bfc-feat-{{ section.id }} .feat-card {
  grid-template-columns: 0.82fr 1fr;
  height: clamp(240px, 27vh, 330px);
  align-items: stretch;
  border-left: 1px solid rgba(32,32,9,0.1);
}
#bfc-feat-{{ section.id }} .feat-card:first-child { border-left: none; }
#bfc-feat-{{ section.id }}.is-dark .feat-card { border-left-color: rgba(255,255,255,0.1); }

{%- comment -%} ── CAMERA IMAGE (left of card) — always fit, never cropped ── {%- endcomment -%}
#bfc-feat-{{ section.id }} .feat-cam {
  position: relative;
  background: var(--cv);
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  height: 100%;
}
#bfc-feat-{{ section.id }}.is-dark .feat-cam { background: #18180a; }
#bfc-feat-{{ section.id }} .feat-cam img {
  position: relative; z-index: 1;
  width: 100%; height: 100%; object-fit: cover; object-position: center; display: block;
  transition: transform 0.5s ease;
}
#bfc-feat-{{ section.id }} .feat-cam:hover img { transform: scale(1.04); }
#bfc-feat-{{ section.id }} .feat-cam-grade {
  position: absolute; top: 14px; left: 14px; z-index: 2;
  font-size: 8px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: #fff; background: var(--or); padding: 3px 9px;
}

{%- comment -%} ── TEXT (right of card) ── {%- endcomment -%}
#bfc-feat-{{ section.id }} .feat-text {
  position: relative;
  padding: 30px 34px;
  display: flex; flex-direction: column; justify-content: center;
  overflow: hidden;
  border-left: 1px solid rgba(32,32,9,0.1);
}
#bfc-feat-{{ section.id }}.is-dark .feat-text { border-left-color: rgba(255,255,255,0.1); }
#bfc-feat-{{ section.id }} .feat-eyebrow {
  position: absolute; top: 22px; right: 34px; z-index: 2;
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 9px; font-weight: 700; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--or);
}
#bfc-feat-{{ section.id }} .feat-eyebrow::before { content: ''; width: 16px; height: 1px; background: var(--or); display: block; }
#bfc-feat-{{ section.id }} .feat-title {
  font-family: var(--sr); font-size: 23px; font-weight: 300;
  line-height: 1.25; letter-spacing: -0.01em; margin-bottom: 9px;
  max-width: 92%;
}
#bfc-feat-{{ section.id }}.is-dark .feat-title { color: #fff; }
#bfc-feat-{{ section.id }} .feat-desc {
  font-size: 12px; line-height: 1.6; color: var(--ch);
  margin-bottom: 18px; max-width: 46ch;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}
#bfc-feat-{{ section.id }}.is-dark .feat-desc { color: rgba(255,255,255,0.7); }
#bfc-feat-{{ section.id }} .feat-buy { display: flex; align-items: center; gap: 14px; }
#bfc-feat-{{ section.id }} .feat-price { font-family: var(--sr); font-size: 21px; font-weight: 300; line-height: 1; }
#bfc-feat-{{ section.id }}.is-dark .feat-price { color: #fff; }
#bfc-feat-{{ section.id }} .feat-price small {
  display: block; font-family: var(--sn); font-size: 8px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--ch); margin-bottom: 4px;
}
#bfc-feat-{{ section.id }}.is-dark .feat-price small { color: rgba(255,255,255,0.5); }
#bfc-feat-{{ section.id }} .feat-cta {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 10px 16px; background: var(--or); color: #fff;
  font-family: var(--sn); font-size: 9px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  text-decoration: none; transition: background var(--t); white-space: nowrap;
}
#bfc-feat-{{ section.id }} .feat-cta:hover { background: #c9600f; }
#bfc-feat-{{ section.id }} .feat-cta svg { transition: transform var(--t); }
#bfc-feat-{{ section.id }} .feat-cta:hover svg { transform: translateX(3px); }

{%- comment -%} ── SHUFFLE (optional) ── {%- endcomment -%}
#bfc-feat-{{ section.id }} .feat-shuffle {
  position: absolute; top: 12px; right: 16px; z-index: 6;
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 11px; background: rgba(248,246,238,0.9);
  border: 1px solid rgba(32,32,9,0.12);
  font-family: var(--sn); font-size: 8.5px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--ch);
  cursor: pointer; transition: all var(--t);
}
#bfc-feat-{{ section.id }} .feat-shuffle:hover { color: var(--or); border-color: var(--or); }
#bfc-feat-{{ section.id }}.is-dark .feat-shuffle { background: rgba(32,32,9,0.6); border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.75); }
#bfc-feat-{{ section.id }} .feat-shuffle svg { transition: transform 0.4s ease; }
#bfc-feat-{{ section.id }} .feat-shuffle:hover svg { transform: rotate(180deg); }

{%- comment -%} ── TABLET: drop to one camera ── {%- endcomment -%}
@media (max-width: 990px) {
  #bfc-feat-{{ section.id }} .feat-track { grid-template-columns: 1fr; }
}

{%- comment -%} ── MOBILE: compact single strip ── {%- endcomment -%}
@media (max-width: 749px) {
  #bfc-feat-{{ section.id }} .feat-card { grid-template-columns: 0.82fr 1fr; height: clamp(150px, 22vh, 200px); }
  #bfc-feat-{{ section.id }} .feat-cam:hover img { transform: none; }
  #bfc-feat-{{ section.id }} .feat-text { padding: 14px 16px; }
  #bfc-feat-{{ section.id }} .feat-eyebrow { position: static; margin-bottom: 8px; font-size: 8.5px; }
  #bfc-feat-{{ section.id }} .feat-title { font-size: 18px; margin-bottom: 6px; }
  #bfc-feat-{{ section.id }} .feat-desc { display: none; }
  #bfc-feat-{{ section.id }} .feat-price { font-size: 18px; }
  #bfc-feat-{{ section.id }} .feat-cta { padding: 9px 14px; }
  #bfc-feat-{{ section.id }} .feat-cam-grade { top: 10px; left: 10px; }
}
@media (max-width: 480px) {
  #bfc-feat-{{ section.id }} .feat-card { grid-template-columns: 0.78fr 1fr; height: clamp(135px, 20vh, 175px); }
  #bfc-feat-{{ section.id }} .feat-title { font-size: 16px; }
  #bfc-feat-{{ section.id }} .feat-buy { flex-direction: column; align-items: flex-start; gap: 8px; }
}
</style>

{%- comment -%} noscript: reveal the first card(s) when JS is off {%- endcomment -%}
<noscript><style>
  #bfc-feat-{{ section.id }} .feat-card:nth-child(-n+2) { display: grid !important; }
  @media (max-width: 990px) { #bfc-feat-{{ section.id }} .feat-card:nth-child(n+2) { display: none !important; } }
</style></noscript>

<div id="bfc-feat-{{ section.id }}" class="{% if section.settings.theme == 'dark' %}is-dark{% endif %}"
     data-count="{{ section.settings.cameras_desktop }}"
     data-shuffle="{{ section.settings.randomize }}">

  {%- assign cams_shown = section.settings.cameras_desktop | plus: 0 -%}
  {%- if section.settings.show_shuffle and section.blocks.size > cams_shown -%}
    <button type="button" class="feat-shuffle" data-feat-shuffle aria-label="Show different cameras">
      <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 4h3l5 6h2M2 10h3l5-6h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M10.5 2.5L12 4l-1.5 1.5M10.5 8.5L12 10l-1.5 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Shuffle
    </button>
  {%- endif -%}

  {%- comment -%} Count cameras we can actually feature (in stock, product set). In the editor,
       treat all set products as showable so the section never looks empty while editing. {%- endcomment -%}
  {%- assign available_cams = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.product != blank -%}
      {%- if block.settings.product.available or request.design_mode -%}
        {%- assign available_cams = available_cams | plus: 1 -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if available_cams > 0 -%}
    <div class="feat-track">
      {%- for block in section.blocks -%}
        {%- liquid
          assign p = block.settings.product
          if p == blank
            continue
          endif
          comment # Only feature in-stock cameras. In the theme editor we still render
            sold-out ones so they don't silently vanish while you're setting up. #
          endcomment
          unless p.available or request.design_mode
            continue
          endunless
          assign feat_heading = block.settings.heading_override | default: p.title
          assign feat_desc = block.settings.card_text
          assign desc_is_custom = true
          if feat_desc == blank
            assign feat_desc = p.description | strip_html | strip | truncatewords: 26
            assign desc_is_custom = false
          endif
        -%}
        <div class="feat-card" {{ block.shopify_attributes }}>
          <a class="feat-cam" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
            {%- if p.featured_image -%}
              {%- assign fp = p.featured_image.presentation.focal_point | default: '50% 50%' -%}
              <img
                src="{{ p.featured_image | image_url: width: 800 }}"
                srcset="{{ p.featured_image | image_url: width: 500 }} 500w, {{ p.featured_image | image_url: width: 800 }} 800w"
                sizes="(max-width: 749px) 40vw, 22vw"
                style="object-position: {{ fp }};"
                alt="{{ p.title | escape }}" loading="lazy" width="800" height="800"/>
            {%- endif -%}
            {%- if block.settings.show_grade_badge -%}
              <span class="feat-cam-grade">{{ block.settings.grade_badge_text | default: 'Restored' }}</span>
            {%- endif -%}
          </a>
          <div class="feat-text">
            <span class="feat-eyebrow">{{ block.settings.eyebrow | default: 'Featured Camera' }}</span>
            <h2 class="feat-title">{{ feat_heading }}</h2>
            {%- if feat_desc != blank -%}<p class="feat-desc">{% if desc_is_custom %}{{ feat_desc | escape | newline_to_br }}{% else %}{{ feat_desc }}{% endif %}</p>{%- endif -%}
            <div class="feat-buy">
              {%- if p.available -%}
                <div class="feat-price"><small>{% if p.price_varies %}From{% else %}Price{% endif %}</small>{{ p.price | money }}</div>
              {%- else -%}
                <div class="feat-price"><small>Status</small>Sold Out</div>
              {%- endif -%}
              <a class="feat-cta" href="{{ p.url }}">
                {{ block.settings.cta_label | default: 'Shop this camera' }}
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
              </a>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- elsif section.blocks.size == 0 and request.design_mode -%}
    <div style="padding: 40px; text-align: center; font-size: 13px; color: #4E4741;">Add one or more Camera blocks in the theme editor.</div>
  {%- elsif request.design_mode -%}
    <div style="padding: 40px; text-align: center; font-size: 13px; color: #4E4741;">No cameras are in stock right now, so this section is hidden on the live store.</div>
  {%- endif -%}

</div>

<script>
(function() {
  var root = document.getElementById('bfc-feat-{{ section.id }}');
  if (!root) return;
  var track = root.querySelector('.feat-track');
  var cards = root.querySelectorAll('.feat-card');
  var n = cards.length;
  if (!track || !n) return;

  var key = 'bfcFeat2_{{ section.id }}';
  var inEditor = !!(window.Shopify && window.Shopify.designMode);
  var desktopCount = Math.max(1, parseInt(root.getAttribute('data-count'), 10) || 2);
  var randomize = root.getAttribute('data-shuffle') !== 'false';
  var mqMobile = window.matchMedia('(max-width: 990px)');

  function allIdx() { var a = []; for (var i = 0; i < n; i++) a.push(i); return a; }
  function shuffle(a) { for (var i = a.length - 1; i > 0; i--) { var j = Math.floor(Math.random() * (i + 1)); var t = a[i]; a[i] = a[j]; a[j] = t; } return a; }
  function targetCount() { return mqMobile.matches ? 1 : Math.min(desktopCount, n); }

  function show(idxs) {
    for (var i = 0; i < n; i++) cards[i].classList.toggle('is-on', idxs.indexOf(i) >= 0);
    track.classList.toggle('is-showing-1', idxs.length <= 1);
  }

  function pick(count, avoid) {
    if (n <= count) return allIdx();
    var idxs, tries = 0;
    do { idxs = shuffle(allIdx()).slice(0, count).sort(function(a,b){return a-b;}); tries++; }
    while (avoid && idxs.join(',') === avoid && tries < 8);
    return idxs;
  }

  function rollFresh() {
    var avoid = null;
    try { avoid = sessionStorage.getItem(key); } catch (e) {}
    var idxs = pick(targetCount(), avoid);
    try { sessionStorage.setItem(key, idxs.join(',')); } catch (e) {}
    show(idxs);
  }

  if (inEditor) {
    show(allIdx().slice(0, targetCount()));
  } else if (randomize) {
    rollFresh();
  } else {
    show(allIdx().slice(0, targetCount()));
  }

  // Adjust visible count when crossing the desktop/mobile breakpoint, keep current picks where possible.
  function reflow() {
    var count = targetCount();
    var visible = [];
    for (var i = 0; i < n; i++) if (cards[i].classList.contains('is-on')) visible.push(i);
    if (visible.length === count) return;
    if (visible.length > count) { show(visible.slice(0, count)); }
    else {
      var pool = allIdx().filter(function(i){ return visible.indexOf(i) < 0; });
      shuffle(pool);
      show(visible.concat(pool.slice(0, count - visible.length)).sort(function(a,b){return a-b;}));
    }
  }
  if (mqMobile.addEventListener) mqMobile.addEventListener('change', reflow);
  else if (mqMobile.addListener) mqMobile.addListener(reflow);

  // Shuffle button — reroll to a different set without reloading.
  root.querySelectorAll('[data-feat-shuffle]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var cur = [];
      for (var i = 0; i < n; i++) if (cards[i].classList.contains('is-on')) cur.push(i);
      var idxs = pick(targetCount(), cur.join(','));
      try { sessionStorage.setItem(key, idxs.join(',')); } catch (e2) {}
      show(idxs);
    });
  });
})();
</script>

{% schema %}
{
  "name": "BFC Featured Camera",
  "tag": "section",
  "class": "bfc-featured-camera-section",
  "max_blocks": 30,
  "settings": [
    {
      "type": "select", "id": "cameras_desktop", "label": "Cameras shown (desktop)", "default": "2",
      "info": "Tablet and mobile always show one.",
      "options": [
        { "value": "1", "label": "One" },
        { "value": "2", "label": "Two" }
      ]
    },
    { "type": "checkbox", "id": "randomize", "label": "Pick random cameras on each page load", "default": true, "info": "When on, a fresh set shows each reload. When off, shows the first block(s)." },
    { "type": "checkbox", "id": "show_shuffle", "label": "Show a Shuffle button", "default": false, "info": "Lets visitors swap to other cameras without reloading. Appears when there are more cameras than shown." },
    {
      "type": "select", "id": "theme", "label": "Theme", "default": "light",
      "options": [
        { "value": "light", "label": "Light (cream)" },
        { "value": "dark", "label": "Dark" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "camera",
      "name": "Camera",
      "settings": [
        { "type": "product", "id": "product", "label": "Camera" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured Camera" },
        { "type": "text", "id": "heading_override", "label": "Heading override", "info": "Leave blank to use the product title." },
        { "type": "textarea", "id": "card_text", "label": "Custom card text", "info": "Write something interesting about this camera. Leave blank to fall back to the product description." },
        { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop this camera" },
        { "type": "header", "content": "Grade badge" },
        { "type": "checkbox", "id": "show_grade_badge", "label": "Show badge on camera image", "default": true },
        { "type": "text", "id": "grade_badge_text", "label": "Badge text", "default": "Restored" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BFC Featured Camera",
      "blocks": [
        { "type": "camera" },
        { "type": "camera" }
      ]
    }
  ]
}
{% endschema %}
