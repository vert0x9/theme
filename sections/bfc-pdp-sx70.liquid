{{- 'section-product.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'product-variants.js' | asset_url }}" defer="defer"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/></noscript>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  assign g1 = product.metafields.custom.gallery_1.value
  assign g2 = product.metafields.custom.gallery_2.value
  assign g3 = product.metafields.custom.gallery_3.value
  assign g4 = product.metafields.custom.gallery_4.value
  assign g5 = product.metafields.custom.gallery_5.value
  assign g6 = product.metafields.custom.gallery_6.value

  assign spec_shutter = product.metafields.custom.spec_shutterspeeds.value
  assign spec_battery = product.metafields.custom.spec_battery.value
  assign spec_flash   = product.metafields.custom.spec_flash.value
  assign spec_focus   = product.metafields.custom.spec_focus.value
  assign spec_meter   = product.metafields.custom.spec_meter.value
  assign spec_lens    = product.metafields.custom.spec_lens.value
-%}

{% style %}
/* ================================================================
   BFC SX-70 PDP — bfcsx namespace
   ================================================================ */
.bfcsx *,
.bfcsx *::before,
.bfcsx *::after { box-sizing: border-box; margin: 0; padding: 0; }

.bfcsx {
  --or:  #E36E15;
  --go:  #F4A027;
  --ce:  #ABCC99;
  --cv:  #F8F6EE;
  --bk:  #202009;
  --ol:  #525741;
  --br:  #5A3E2D;
  --ch:  #4E4741;
  --gr:  #E3DDDA;
  --sr:  'Cormorant Garamond', Georgia, serif;
  --sn:  'Poppins', sans-serif;
  --t:   0.2s ease;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
}

/* ── PDP TOP (two-column: photos left, info right) ── */
.bfcsx .sx-pdp-top {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  align-items: stretch;
  max-width: 100%;
  padding: 0;
}
.bfcsx .sx-photos {
  position: sticky; top: 0;
  align-self: start;
}
.bfcsx .sx-hero {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--bk);
}
.bfcsx .sx-hero::after {
  content: "SX-70";
  position: absolute;
  top: 50%;
  right: -6%;
  transform: translateY(-50%);
  font-family: var(--sr);
  font-style: italic;
  font-weight: 300;
  font-size: clamp(180px, 32vw, 360px);
  line-height: 0.85;
  color: #fff;
  opacity: 0.08;
  letter-spacing: -0.02em;
  pointer-events: none;
  white-space: nowrap;
  z-index: 2;
  mix-blend-mode: overlay;
}
.bfcsx .sx-info-pane {
  padding: 28px 48px 48px;
  max-width: 100%;
}
.bfcsx .sx-slider {
  display: flex;
  width: 100%;
  height: 100%;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  position: relative;
  z-index: 1;
}
.bfcsx .sx-slider::-webkit-scrollbar { display: none; }
.bfcsx .sx-slide {
  flex: 0 0 100%;
  scroll-snap-align: start;
  position: relative;
}
.bfcsx .sx-slide img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  display: block;
}
.bfcsx .sx-dots {
  position: absolute; bottom: 16px; left: 50%;
  transform: translateX(-50%);
  display: flex; gap: 8px; z-index: 2;
}
.bfcsx .sx-dot {
  width: 8px; height: 8px;
  background: rgba(32,32,9,0.2);
  cursor: pointer;
  transition: background var(--t);
  border: none;
}
.bfcsx .sx-dot.is-active { background: var(--or); }
.bfcsx .sx-arrow {
  position: absolute; top: 50%;
  transform: translateY(-50%);
  width: 44px; height: 44px;
  background: rgba(255,255,255,0.85);
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  z-index: 3; color: var(--bk);
  transition: background var(--t);
  backdrop-filter: blur(4px);
}
.bfcsx .sx-arrow:hover { background: #fff; }
.bfcsx .sx-arrow-prev { left: 16px; }
.bfcsx .sx-arrow-next { right: 16px; }
.bfcsx .sx-thumbs {
  display: flex; gap: 8px; margin-top: 8px;
}
.bfcsx .sx-thumb {
  width: 64px; height: 64px;
  background: #eae6db;
  cursor: pointer;
  opacity: 0.5;
  transition: opacity var(--t);
  border: none; padding: 0;
}
.bfcsx .sx-thumb.is-active { opacity: 1; }
.bfcsx .sx-thumb img {
  width: 100%; height: 100%;
  object-fit: contain; display: block;
}

/* ── PRODUCT INFO (right column) ──────────────── */
.bfcsx .sx-info {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.bfcsx .sx-eyebrow {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--or);
  margin-bottom: 16px; display: block;
}
.bfcsx .sx-board-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px 6px 8px;
  background: var(--bk);
  color: #fff;
  font-family: var(--sn);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 10px;
  text-decoration: none;
  transition: background var(--t);
}
.bfcsx .sx-board-pill:hover { background: #000; }
.bfcsx .sx-board-pill-tag {
  background: var(--or);
  color: #fff;
  padding: 3px 7px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.16em;
}
.bfcsx .sx-board-pill-arrow {
  width: 10px; height: 10px;
  margin-left: 2px;
  opacity: 0.7;
}
/* When the pill sits below the title (instead of above the breadcrumbs),
   it needs different vertical spacing: no top margin baked into the
   default, but a clear gap from the title above and the stars below. */
.bfcsx .sx-board-pill--below-title {
  margin-top: 2px;
  margin-bottom: 14px;
}
.bfcsx .sx-title {
  font-family: var(--sr);
  font-size: clamp(26px, 3vw, 36px);
  font-weight: 300; line-height: 1.1;
  color: var(--bk);
  margin-bottom: 8px;
}
.bfcsx .sx-mini-specs {
  display: flex; flex-wrap: wrap; gap: 0;
  margin-top: 16px;
  margin-bottom: 18px;
  padding-top: 16px;
  border-top: 1px solid rgba(32,32,9,0.08);
}
.bfcsx .sx-mini-spec {
  display: flex; flex-direction: column;
  padding: 0 20px 0 0;
  border-right: 1px solid rgba(82,87,65,0.12);
  margin-right: 20px;
}
.bfcsx .sx-mini-spec:last-child { border-right: none; margin-right: 0; padding-right: 0; }
.bfcsx .sx-spec-key {
  font-size: 8px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(82,87,65,0.7); margin-bottom: 6px;
}
.bfcsx .sx-spec-val {
  font-size: 14px; font-weight: 500; color: var(--bk);
  line-height: 1.4;
}

/* ── Under-fold summary strip ──
   Full-width band that sits between the hero (above the fold) and the
   green OpenSX70 chapter. Three stacked rows on a cream background:
   - Top: three sample frames (uploaded via section settings)
   - Middle: three evenly-distributed specs (Film / Board / Condition)
   - Bottom: the restoration summary line, full-width
   The cream background visually segues into the dark chapter below. */
.bfcsx .sx-summary-strip {
  background: var(--cv);
  border-top: 1px solid rgba(32,32,9,0.08);
  padding: 32px 48px 36px;
}
.bfcsx .sx-summary-strip-inner {
  max-width: 1200px;
  margin: 0 auto;
}

/* Sample frames row — three square images, equal width. The "01 / 02 / 03"
   eyebrow in the corner suggests film-strip ordering. Placeholder cards
   render as muted cream squares so the layout doesn't collapse if photos
   aren't set yet. */
.bfcsx .sx-summary-photos {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-bottom: 22px;
}
.bfcsx .sx-summary-photo {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--gr);
}
.bfcsx .sx-summary-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.bfcsx .sx-summary-photo-placeholder {
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    -45deg,
    rgba(78,71,65,0.05) 0,
    rgba(78,71,65,0.05) 8px,
    rgba(78,71,65,0.08) 8px,
    rgba(78,71,65,0.08) 16px
  );
}
.bfcsx .sx-summary-photo-num {
  position: absolute;
  top: 10px;
  left: 12px;
  font-family: var(--sm);
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.16em;
  color: rgba(255,255,255,0.85);
  text-shadow: 0 1px 2px rgba(0,0,0,0.35);
  z-index: 2;
}
.bfcsx .sx-summary-specs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  padding-bottom: 16px;
  margin-bottom: 16px;
  border-bottom: 1px solid rgba(82,87,65,0.12);
}
.bfcsx .sx-summary-spec {
  display: flex;
  flex-direction: column;
  padding: 0 20px;
  border-right: 1px solid rgba(82,87,65,0.12);
}
.bfcsx .sx-summary-spec:first-child { padding-left: 0; }
.bfcsx .sx-summary-spec:last-child {
  border-right: none;
  padding-right: 0;
}
.bfcsx .sx-summary-spec .sx-spec-key {
  font-family: var(--sm);
  font-size: 8.5px; font-weight: 700;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(82,87,65,0.65);
  margin-bottom: 5px;
}
.bfcsx .sx-summary-spec .sx-spec-val {
  font-family: var(--sn);
  font-size: 13.5px; font-weight: 500; color: var(--bk);
  line-height: 1.3;
  letter-spacing: -0.005em;
}
.bfcsx .sx-summary-line {
  font-size: 12.5px;
  line-height: 1.65;
  color: var(--ch);
  margin: 0;
  max-width: 76ch;
}
@media (max-width: 900px) {
  .bfcsx .sx-summary-strip { padding: 24px 20px 26px; }
  .bfcsx .sx-summary-photos {
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    margin-bottom: 18px;
  }
  .bfcsx .sx-summary-photo-num {
    top: 6px; left: 8px;
    font-size: 8.5px;
  }
  .bfcsx .sx-summary-specs {
    grid-template-columns: 1fr;
    gap: 10px;
    padding-bottom: 14px;
    margin-bottom: 14px;
  }
  .bfcsx .sx-summary-spec {
    padding: 0;
    border-right: none;
    flex-direction: row;
    align-items: baseline;
    gap: 12px;
  }
  .bfcsx .sx-summary-spec .sx-spec-key {
    margin-bottom: 0;
    min-width: 72px;
  }
  .bfcsx .sx-summary-spec .sx-spec-val { font-size: 14px; }
  .bfcsx .sx-summary-line { font-size: 12.5px; }
}
.bfcsx .sx-desc {
  font-family: var(--sn);
  font-size: 14px; line-height: 1.7;
  color: var(--ch);
  margin-bottom: 32px;
  padding-bottom: 32px;
  border-bottom: 1px solid rgba(32,32,9,0.08);
}
.bfcsx .sx-desc p { margin-bottom: 12px; }
.bfcsx .sx-desc p:last-child { margin-bottom: 0; }
.bfcsx .sx-desc-intro {
  font-family: var(--sn);
  font-size: 14.5px;
  font-style: normal;
  font-weight: 400;
  line-height: 1.65;
  color: var(--bk);
  margin-bottom: 18px !important;
  padding-left: 14px;
  border-left: 2px solid var(--or);
}
.bfcsx .sx-desc-intro--above {
  font-size: 14px;
  line-height: 1.55;
  margin-top: 0;
  margin-bottom: 0 !important;
  padding-left: 12px;
}
/* Theme CSS sometimes collapses <p>, <ul>, and <li> tags inside the
   description (e.g. flattening list items inline or stripping bullets).
   Re-establish proper spacing and bullet rendering here so descriptions
   with multiple paragraphs and lists render correctly. */
.bfcsx .sx-desc-intro p {
  margin: 0 0 12px 0;
}
.bfcsx .sx-desc-intro p:last-child { margin-bottom: 0; }
.bfcsx .sx-desc-intro ul,
.bfcsx .sx-desc-intro ol {
  display: block;
  list-style-position: outside;
  margin: 12px 0;
  padding-left: 22px;
}
.bfcsx .sx-desc-intro ul { list-style: disc; }
.bfcsx .sx-desc-intro ol { list-style: decimal; }
.bfcsx .sx-desc-intro li {
  display: list-item;
  margin: 0 0 6px 0;
  padding: 0;
}
.bfcsx .sx-desc-intro li:last-child { margin-bottom: 0; }
.bfcsx .sx-desc-intro strong { font-weight: 600; }
.bfcsx .sx-desc-intro a {
  color: var(--or);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 2px;
}

/* ── ATC (inline in right column) ─────────────── */
.bfcsx .sx-atc-panel {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid rgba(82,87,65,0.1);
}
/* Description block when placed below the ATC panel (default new layout) */
.bfcsx .sx-desc-after-atc {
  margin-top: 32px;
  padding-top: 32px;
  border-top: 1px solid rgba(32,32,9,0.08);
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: 0;
}
/* Price + variant swatches share a single row to save vertical space.
   Price/compare-at left, variant selector right, baseline-aligned so the
   small variant label sits flush with the price's baseline. */
.bfcsx .sx-atc-priceline {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}
.bfcsx .sx-atc-pricegroup {
  display: flex;
  align-items: baseline;
  gap: 10px;
  flex-wrap: wrap;
}
.bfcsx .sx-atc-price {
  font-family: var(--sr);
  font-size: 30px; font-weight: 300;
  color: var(--bk);
  line-height: 1.1;
  margin: 0;
}
.bfcsx .sx-atc-compare {
  font-size: 12px; color: rgba(82,87,65,0.45);
  text-decoration: line-through;
  margin: 0;
  display: inline;
}
.bfcsx .sx-atc-variant-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 0;
  flex-wrap: nowrap;
}
.bfcsx .sx-atc-variant-label {
  font-size: 8.5px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(82,87,65,0.55);
  margin: 0;
}
.bfcsx .sx-atc-variants {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin: 0;
}
/* Variant selector rendered as small color swatches.
   Each variant is a 18px circle filled with its matching button color.
   The swatch grows a subtle ring when selected. Text variant title is
   shown next to the swatches in a tiny mono label so it's discoverable
   but doesn't dominate the ATC area. */
.bfcsx .sx-variant-btn {
  position: relative;
  width: 18px; height: 18px;
  padding: 0;
  border: 1px solid rgba(82,87,65,0.25);
  border-radius: 50%;
  background: var(--gr);
  cursor: pointer;
  font-size: 0;
  color: transparent;
  transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  flex-shrink: 0;
}
/* Auto-color swatches when the variant title contains "Red" or "Blue".
   These selectors target the button via its data-variant-id but we read
   the title text via a more reliable trick: a data attribute is added by
   the JS, OR we use :has() with text. Simpler approach: render the
   color via inline style at build time. */
.bfcsx .sx-variant-btn[data-color="red"]  { background: #C8362B; border-color: rgba(0,0,0,0.15); }
.bfcsx .sx-variant-btn[data-color="blue"] { background: #2B5DA8; border-color: rgba(0,0,0,0.15); }
.bfcsx .sx-variant-btn:hover {
  transform: scale(1.1);
}
.bfcsx .sx-variant-btn.is-selected {
  box-shadow: 0 0 0 2px var(--cv), 0 0 0 3px var(--bk);
}
.bfcsx .sx-variant-btn.is-sold-out {
  opacity: 0.35; cursor: not-allowed;
  position: relative;
}
.bfcsx .sx-variant-btn.is-sold-out::after {
  content: '';
  position: absolute;
  inset: -2px;
  border-top: 1px solid var(--ch);
  transform: rotate(45deg);
  transform-origin: center;
  top: 50%;
}
.bfcsx .sx-variant-name {
  font-family: var(--sm);
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--ch);
  margin-left: 4px;
}
.bfcsx .sx-add-btn {
  width: 100%;
  font-family: var(--sn);
  font-size: 13px; font-weight: 600;
  letter-spacing: 0.06em; text-transform: uppercase;
  padding: 16px;
  background: var(--or); color: #fff;
  border: none; cursor: pointer;
  transition: background var(--t);
  margin-top: 8px;
  margin-bottom: 0;
}
.bfcsx .sx-add-btn:hover { background: #c75e10; }
.bfcsx .sx-add-btn:disabled {
  background: var(--gr); color: rgba(82,87,65,0.4); cursor: not-allowed;
}
.bfcsx .sx-atc-badges {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 16px;
  row-gap: 10px;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid rgba(82,87,65,0.1);
}
.bfcsx .sx-badge {
  font-size: 11px; color: var(--ol);
  display: flex; align-items: center; gap: 8px;
  line-height: 1.35;
}
.bfcsx .sx-badge-icon {
  width: 16px; height: 16px; flex-shrink: 0;
  fill: var(--or);
}
.bfcsx .sx-itype-note {
  font-size: 10px; line-height: 1.5;
  color: rgba(82,87,65,0.45);
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid rgba(82,87,65,0.08);
}

/* ── BOARD CHAPTER WRAPPER ─────────────────────── */
.bfcsx .sx-chapter {
  background: var(--bk);
  color: #fff;
  position: relative;
  /* Thin orange accent reads as a refined transition from the cream
     summary strip into the dark chapter — the previous 8px slab was
     too heavy and felt disconnected from both blocks. */
  border-top: 2px solid var(--or);
}
.bfcsx .sx-chapter-header {
  max-width: 880px;
  margin: 0 auto;
  padding: 64px 48px 48px;
  text-align: center;
}
.bfcsx .sx-chapter-eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--or);
  margin-bottom: 24px;
  padding-bottom: 12px;
  border-bottom: 1px solid rgba(227,110,21,0.4);
}
.bfcsx .sx-chapter-title {
  font-family: var(--sr);
  font-size: 48px;
  font-weight: 300;
  color: #fff;
  margin: 0 0 24px;
  line-height: 1.05;
  letter-spacing: -0.01em;
}
.bfcsx .sx-chapter-title em {
  font-style: italic;
  color: var(--or);
  font-weight: 300;
}
.bfcsx .sx-chapter-sub {
  font-size: 15px;
  color: rgba(255,255,255,0.75);
  line-height: 1.65;
  max-width: 640px;
  margin: 0 auto 32px;
}

/* Toggle button */
.bfcsx .sx-chapter-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  background: transparent;
  border: 1px solid rgba(227,110,21,0.6);
  color: var(--or);
  font-family: var(--sn);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
}
.bfcsx .sx-chapter-toggle:hover {
  background: rgba(227,110,21,0.1);
  border-color: var(--or);
}
.bfcsx .sx-chapter-toggle-icon {
  transition: transform 0.3s ease;
}
.bfcsx .sx-chapter-toggle[aria-expanded="true"] .sx-chapter-toggle-icon {
  transform: rotate(180deg);
}

/* Collapsed body */
.bfcsx .sx-chapter-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s ease;
}
.bfcsx .sx-chapter-body.is-open {
  max-height: 12000px;
}

/* Inner sections — these sit inside the dark .sx-chapter wrapper.
   Note: .sx-sch is intentionally NOT in this list because it's our
   cream-colored schematic block which sits inside the chapter as a
   distinct printed-sheet-on-display element. */
.bfcsx .sx-chapter .sx-features,
.bfcsx .sx-chapter .sx-dongle,
.bfcsx .sx-chapter .sx-led {
  background: transparent;
  border-top: 1px solid rgba(255,255,255,0.08);
}

@media (max-width: 768px) {
  .bfcsx .sx-chapter-header { padding: 48px 20px 32px; }
  .bfcsx .sx-chapter-title { font-size: 32px; }
  .bfcsx .sx-chapter-sub { font-size: 14px; margin-bottom: 24px; }
  .bfcsx .sx-chapter-eyebrow { font-size: 10px; letter-spacing: 0.2em; }
  .bfcsx .sx-chapter-toggle { padding: 10px 20px; font-size: 10px; }
}

/* ── OPENSX70 INTRO ───────────────────────────── */
.bfcsx .sx-osx-intro {
  background: var(--bk); color: #fff;
  padding: 80px 48px;
  margin-top: 0;
}
.bfcsx .sx-osx-intro-inner {
  max-width: 1200px; margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.bfcsx .sx-osx-ey {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--go); margin-bottom: 16px; display: block;
}
.bfcsx .sx-osx-title {
  font-family: var(--sr);
  font-size: clamp(32px, 4vw, 46px);
  font-weight: 300; line-height: 1.1;
  color: #fff; margin-bottom: 20px;
}
.bfcsx .sx-osx-title em {
  font-style: italic; color: rgba(255,255,255,0.3);
}
.bfcsx .sx-osx-body {
  font-size: 14px; line-height: 1.75;
  color: rgba(255,255,255,0.6);
}
.bfcsx .sx-osx-body p { margin-bottom: 16px; }
.bfcsx .sx-osx-body p:last-child { margin-bottom: 0; }
.bfcsx .sx-osx-img-slot {
  aspect-ratio: 4 / 3;
  background: rgba(255,255,255,0.03);
  overflow: hidden;
}
.bfcsx .sx-osx-img-slot img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* ── OPENSX70 SCHEMATIC ────────────────────────
   Interactive annotated drawing replacing the static intro+photo.
   Three pieces: chapter intro (top), schematic frame (middle), three
   pillars (bottom). Animations are scroll-triggered via IntersectionObserver
   and gated by [data-sx-sch-reveal] attributes — see JS below.
   Mono is system-stack; no webfont required. */
.bfcsx .sx-sch {
  background: var(--cv);
  padding: 96px 32px 80px;
  --sm: ui-monospace, 'SF Mono', Menlo, Monaco, Consolas, monospace;
}
@media (max-width: 900px) {
  .bfcsx .sx-sch { padding: 56px 16px 56px; }
}

/* Reveal-on-scroll: each element starts hidden, IntersectionObserver
   adds .is-visible when section enters viewport, transition runs. */
.bfcsx .sx-sch [data-sx-sch-reveal] {
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 480ms ease, transform 480ms ease;
}
.bfcsx .sx-sch [data-sx-sch-reveal].is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* Chapter intro — top row */
.bfcsx .sx-sch-intro {
  max-width: 640px; margin: 0 auto 32px;
}
.bfcsx .sx-sch-intro-ey {
  font-family: var(--sm); font-size: 11px; letter-spacing: 0.18em;
  color: var(--or); display: block; margin-bottom: 12px;
}
.bfcsx .sx-sch-intro-title {
  font-family: var(--sr); font-size: 36px; line-height: 1.05;
  font-weight: 400; color: var(--bk); margin-bottom: 14px;
}
@media (max-width: 900px) {
  .bfcsx .sx-sch-intro-title { font-size: 28px; }
}
.bfcsx .sx-sch-intro-title em { font-style: italic; }
.bfcsx .sx-sch-intro-lead {
  font-size: 15px; line-height: 1.6; color: var(--ch); margin: 0;
}

/* Schematic frame — cream container with dot grid background */
.bfcsx .sx-sch-frame {
  position: relative;
  background: var(--cv);
  border: 0.5px solid rgba(78,71,65,0.18);
  margin: 0 auto 40px;
  max-width: 1100px;
  overflow: hidden;
}
.bfcsx .sx-sch-grid {
  position: absolute; inset: 0;
  background-image: radial-gradient(circle, rgba(78,71,65,0.09) 1px, transparent 1px);
  background-size: 20px 20px;
  pointer-events: none;
}
.bfcsx .sx-sch-frame-inner {
  position: relative; z-index: 1;
  padding: 28px 28px 20px;
}
@media (max-width: 900px) {
  .bfcsx .sx-sch-frame-inner { padding: 20px 16px 16px; }
}

/* Frame header — eyebrow + title left, technical meta right */
.bfcsx .sx-sch-head {
  display: flex; justify-content: space-between; align-items: flex-start;
  gap: 16px; margin-bottom: 18px; padding-bottom: 14px;
  border-bottom: 0.5px solid rgba(78,71,65,0.18);
}
.bfcsx .sx-sch-head-ey {
  font-family: var(--sm); font-size: 10px; letter-spacing: 0.18em;
  color: var(--or); display: block; margin-bottom: 8px;
}
.bfcsx .sx-sch-head-title {
  font-family: var(--sr); font-size: 24px; line-height: 1.1;
  color: var(--bk); font-weight: 400;
}
@media (max-width: 900px) {
  .bfcsx .sx-sch-head-title { font-size: 19px; }
}
.bfcsx .sx-sch-head-title em { font-style: italic; }
.bfcsx .sx-sch-head-meta {
  font-family: var(--sm); font-size: 9px; letter-spacing: 0.14em;
  color: var(--ol); text-align: right; white-space: nowrap;
  padding-top: 4px; line-height: 1.6;
}
@media (max-width: 600px) {
  .bfcsx .sx-sch-head-meta { display: none; }
}

/* Stage — the photo + everything overlaid on it.
   On desktop the padding gives breathing room for labels above/below.
   On mobile, the labels are hidden entirely and only the dots/click-card
   pattern is used. */
.bfcsx .sx-sch-stage {
  position: relative;
  padding: 96px 16px;
  min-height: 360px;
}
@media (max-width: 900px) {
  .bfcsx .sx-sch-stage { padding: 12px 0; min-height: 0; }
}

.bfcsx .sx-sch-photo {
  position: relative; z-index: 1;
}
.bfcsx .sx-sch-photo img {
  display: block; width: 100%; height: auto;
}
.bfcsx .sx-sch-photo-placeholder {
  aspect-ratio: 16/7;
  background: rgba(78,71,65,0.05);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--sm); font-size: 11px;
  color: var(--ol); letter-spacing: 0.1em;
  border: 1px dashed rgba(78,71,65,0.3);
}

/* Leader lines — SVG-based vertical lines from a dot to its label area.
   Each hotspot has two stacked <line>s inside the SVG: a faint static
   line that's always visible after section reveal, and an active line
   that draws in (animated stroke-dashoffset) when the hotspot's panel
   is open.

   The .--top variants run from the top label area down to the dot. The
   .--bottom variants run from the dot down to the bottom label area.
   Position via .x and --y (CSS variable) inline styles. */
/* Leader paths — single full-frame SVG overlay containing one <g> per
   hotspot. Each <g> has two <path>s: a static (always visible after
   reveal, faint charcoal) and an active (orange dashed, draws in via
   stroke-dashoffset when the hotspot's panel is open).

   The SVG uses viewBox=0 0 100 100 with preserveAspectRatio="none", so
   path coordinates are in 0-100 percent of the frame's dimensions. */
.bfcsx .sx-sch-paths {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 2;
  overflow: visible;
  fill: none;
}

/* Static path — DISABLED.
   Previously a faint always-on charcoal line was visible after section
   reveal. Per design feedback, the schematic should show NOTHING but the
   numbered dots until a hotspot is clicked. The static path is kept in
   the markup for structural symmetry but rendered fully transparent. */
.bfcsx .sx-sch-line .sx-sch-line-static {
  opacity: 0;
}

/* Active path — simple solid orange line that fades in when the hotspot's
   panel opens. No drawing animation, no dashed pattern; just a clean
   appear. The previous dash-drawing technique kept rendering inconsistently
   across browsers so we swapped to this simpler approach. */
.bfcsx .sx-sch-line .sx-sch-line-active {
  opacity: 0;
  transition: opacity 400ms ease-out;
}
.bfcsx .sx-sch-line.is-line-active .sx-sch-line-active {
  opacity: 1;
}

@media (max-width: 900px) {
  .bfcsx .sx-sch-paths { display: none; }
}

/* Bare label — just floating text. Default state is no chrome at all.
   Click target. Position: left edge anchored at desc_x%, width fixed.
   This means the label's left edge sits flush with the panel's left
   edge below it — no centering offset to drift them out of alignment. */
.bfcsx .sx-sch-label {
  position: absolute;
  width: 240px;
  background: none; border: none; padding: 0;
  font-family: var(--sn);
  text-align: left;
  cursor: pointer;
  z-index: 5;
  user-select: none;
  opacity: 0;
  pointer-events: none;
  transform: translateY(0);
  transition: opacity 480ms ease, transform 480ms ease;
}
/* Label visibility — labels stay HIDDEN by default. They only appear when
   their corresponding panel is open (aria-expanded="true"), making the
   "click the dot to reveal" interaction work consistently for both the
   line, the title, and the description.

   The label fades in AFTER the line has substantially drawn (700ms delay),
   so the visual sequence is: click → line draws toward title spot → title
   appears at line's end → description follows. */
.bfcsx .sx-sch-label[aria-expanded="true"] {
  opacity: 1;
  pointer-events: auto;
  transition: opacity 280ms ease 700ms;
}
.bfcsx .sx-sch-label-num {
  display: block;
  font-family: var(--sm); font-size: 10px;
  color: var(--or); font-weight: 500; letter-spacing: 0.18em;
  margin-bottom: 4px;
  padding-left: 0;
}
.bfcsx .sx-sch-label-name {
  display: block;
  font-family: var(--sr); font-size: 16px; line-height: 1.15;
  color: var(--bk);
  transition: color 200ms ease;
}
.bfcsx .sx-sch-label-name em { font-style: italic; }
.bfcsx .sx-sch-label[aria-expanded="true"] .sx-sch-label-name { color: var(--or); }
.bfcsx .sx-sch-label:hover .sx-sch-label-name { color: var(--or); }
.bfcsx .sx-sch-label:focus-visible { outline: 1px solid var(--or); outline-offset: 4px; }

/* (Removed: .is-clamp-left / .is-clamp-right rules — desc_x is now
   clamped at the Liquid level to keep label, panel, and line in sync
   without needing CSS overrides.) */

@media (max-width: 900px) {
  /* Hide the bare labels on mobile — only dots + click panel are used. */
  .bfcsx .sx-sch-label { display: none; }
}

/* Popout panel — opens when its label or dot is clicked. Hidden until
   a click handler adds .is-open. Position: left edge anchored at
   desc_x%, matching the label above it. */
.bfcsx .sx-sch-panel {
  position: absolute;
  width: 240px;
  background: #fff;
  border: 0.5px solid var(--bk);
  padding: 12px 14px;
  z-index: 7;
  pointer-events: none;
  opacity: 0;
  transform: scale(0.97);
  transform-origin: top left;
  transition: opacity 240ms ease, transform 240ms ease;
  box-shadow: 0 6px 18px rgba(32,32,9,0.1);
}
.bfcsx .sx-sch-panel--top {
  border-bottom: 2px solid var(--or);
}
.bfcsx .sx-sch-panel--bottom {
  border-top: 2px solid var(--or);
}
/* Panel slides in last in the sequence: line draws (0-900ms),
   title fades in (700ms delay), then panel appears (~900ms delay). */
.bfcsx .sx-sch-panel.is-open {
  opacity: 1;
  pointer-events: auto;
  transform: scale(1);
  transition: opacity 280ms ease 900ms, transform 280ms ease 900ms;
}
.bfcsx .sx-sch-panel-tech {
  font-family: var(--sm); font-size: 9px; color: var(--ol);
  letter-spacing: 0.14em; margin-bottom: 8px;
  padding-bottom: 8px; border-bottom: 0.5px dashed rgba(78,71,65,0.25);
}
.bfcsx .sx-sch-panel-body {
  font-size: 13px; line-height: 1.55; color: var(--ch);
  margin-bottom: 8px;
}
.bfcsx .sx-sch-panel-close {
  background: none; border: none; padding: 0;
  font-family: var(--sm); font-size: 9px;
  color: var(--ol); letter-spacing: 0.14em;
  cursor: pointer;
}
.bfcsx .sx-sch-panel-close:hover { color: var(--or); }

/* Bare mode (default) — strips the box chrome from panels so the
   description sits as raw typography on the cream schematic background.
   The user explicitly opted into this via the schematic_panels_boxed
   checkbox being OFF (which adds .sx-sch--bare to the root).

   No background, no border, no shadow. Slightly tighter padding and
   smaller width so it doesn't read as a card. The orange accent line
   moves to a small horizontal rule above the tech readout. */
.bfcsx .sx-sch--bare .sx-sch-panel {
  background: none;
  border: none;
  border-radius: 0;
  box-shadow: none;
  padding: 6px 0 0 0;
  width: 240px;
}
.bfcsx .sx-sch--bare .sx-sch-panel--top,
.bfcsx .sx-sch--bare .sx-sch-panel--bottom {
  border: none;
}
.bfcsx .sx-sch--bare .sx-sch-panel-tech {
  border-bottom: none;
  padding-bottom: 4px;
  margin-bottom: 6px;
  position: relative;
}
.bfcsx .sx-sch--bare .sx-sch-panel-tech::after {
  content: '';
  position: absolute;
  left: 0; bottom: 0;
  width: 24px; height: 1px;
  background: var(--or);
}
.bfcsx .sx-sch--bare .sx-sch-panel-body {
  font-size: 12.5px;
  color: var(--bk);
  margin-bottom: 6px;
}
.bfcsx .sx-sch--bare .sx-sch-panel-close {
  font-size: 8.5px;
}

@media (max-width: 900px) {
  /* Mobile: panels become a single shared zone below the photo. We
     re-position them to anchor below the photo regardless of label_side
     and stretch full width. The active panel still uses .is-open. */
  .bfcsx .sx-sch-panel {
    position: relative;
    left: auto; right: auto;
    margin: 0;
    width: 100%;
    top: auto; bottom: auto;
    transform: none;
    box-shadow: none;
    border: 0.5px solid rgba(78,71,65,0.25);
    border-left: 3px solid var(--or);
    margin-bottom: 8px;
    display: none;
  }
  .bfcsx .sx-sch-panel.is-open { display: block; }
}

/* Numbered dots — orange circles with white halo, sit on the photo at
   each component. Click toggles the same panel as the label. */
.bfcsx .sx-sch-dot {
  position: absolute;
  width: 28px; height: 28px;
  margin-left: -14px; margin-top: -14px;
  border: none; padding: 0;
  border-radius: 50%;
  background: var(--or);
  box-shadow: 0 0 0 3px rgba(255,255,255,0.95), 0 0 0 4px var(--or);
  color: #fff;
  font-family: var(--sm); font-size: 11px; font-weight: 500;
  letter-spacing: 0.04em;
  display: flex; align-items: center; justify-content: center;
  z-index: 6; cursor: pointer;
  transition: transform 200ms ease;
}
.bfcsx .sx-sch-dot:hover { transform: scale(1.08); }
.bfcsx .sx-sch-dot.is-active { transform: scale(1.12); }
.bfcsx .sx-sch-dot:focus-visible { outline: 2px solid var(--bk); outline-offset: 4px; }

/* Pulse — single soft ring expanding from each dot when section first
   enters viewport. Triggered by JS toggling .is-pulsing on the parent.
   Each dot's animation delay is staggered via nth-of-type(n). */
.bfcsx .sx-sch.is-pulsing .sx-sch-dot {
  animation: bfcSchPulse 1.6s ease-out 1;
}
.bfcsx .sx-sch.is-pulsing .sx-sch-dot:nth-of-type(2) { animation-delay: 120ms; }
.bfcsx .sx-sch.is-pulsing .sx-sch-dot:nth-of-type(3) { animation-delay: 240ms; }
.bfcsx .sx-sch.is-pulsing .sx-sch-dot:nth-of-type(4) { animation-delay: 360ms; }
@keyframes bfcSchPulse {
  0%   { box-shadow: 0 0 0 3px rgba(255,255,255,0.95), 0 0 0 4px var(--or), 0 0 0 4px rgba(227,110,21,0.5); }
  60%  { box-shadow: 0 0 0 3px rgba(255,255,255,0.95), 0 0 0 4px var(--or), 0 0 0 18px rgba(227,110,21,0); }
  100% { box-shadow: 0 0 0 3px rgba(255,255,255,0.95), 0 0 0 4px var(--or), 0 0 0 0 rgba(227,110,21,0); }
}

/* No-spots merchant warning */
.bfcsx .sx-sch-no-spots {
  position: absolute; inset: 50% 24px auto;
  transform: translateY(-50%);
  background: rgba(227,110,21,0.06);
  border: 1px dashed var(--or);
  padding: 14px 16px;
  font-family: var(--sm); font-size: 12px;
  color: var(--ol); text-align: center;
  z-index: 10;
}

/* Footer strip */
.bfcsx .sx-sch-foot {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 14px; margin-top: 14px;
  border-top: 0.5px solid rgba(78,71,65,0.18);
  font-family: var(--sm); font-size: 9px;
  color: var(--ol); letter-spacing: 0.12em;
}

/* Three pillars */
.bfcsx .sx-sch-pillars {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1100px;
  margin: 0 auto;
}
@media (max-width: 900px) {
  .bfcsx .sx-sch-pillars { grid-template-columns: 1fr; gap: 0; }
}
.bfcsx .sx-sch-pillar {
  padding: 18px 0;
  border-top: 0.5px solid rgba(78,71,65,0.25);
}
.bfcsx .sx-sch-pillar-num {
  font-family: var(--sm); font-size: 10px;
  color: var(--or); letter-spacing: 0.16em;
  display: block; margin-bottom: 10px;
}
.bfcsx .sx-sch-pillar-title {
  font-family: var(--sr); font-size: 19px; line-height: 1.15;
  color: var(--bk); margin-bottom: 10px;
}
.bfcsx .sx-sch-pillar-title em { font-style: italic; }
.bfcsx .sx-sch-pillar-body {
  font-size: 13px; line-height: 1.55; color: var(--ch);
  margin: 0;
}

/* ── CORE FEATURES ────────────────────────────── */
.bfcsx .sx-features {
  background: var(--bk);
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 0 48px 56px;
}
.bfcsx .sx-features-inner {
  max-width: 1200px; margin: 0 auto;
}
.bfcsx .sx-feat-head {
  padding: 52px 0 28px;
  margin-bottom: 0;
}
.bfcsx .sx-feat-ey {
  display: block;
  font-family: var(--sn);
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or);
  margin-bottom: 12px;
}
.bfcsx .sx-feat-sub {
  font-family: var(--sn);
  font-size: 14px; line-height: 1.7;
  color: rgba(255,255,255,0.7);
  margin: 0;
  max-width: 60ch;
}
.bfcsx .sx-feat-label {
  font-family: var(--sm);
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--go);
}
.bfcsx .sx-feat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  column-gap: 56px;
  row-gap: 0;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.bfcsx .sx-feat-card {
  display: grid;
  grid-template-columns: 38px 1fr;
  column-gap: 18px;
  padding: 22px 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  align-items: start;
}
/* The last row's cards have no bottom border (avoids double-line at the
   section end). Works for 6-card layout: cards 5 & 6 are the last row. */
.bfcsx .sx-feat-card:nth-last-child(-n+2) { border-bottom: none; }
.bfcsx .sx-feat-num {
  font-family: var(--sm);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--or);
  line-height: 1.4;
  padding-top: 3px;
}
.bfcsx .sx-feat-name {
  font-family: var(--sr);
  font-size: 18px; font-weight: 400;
  color: #fff;
  line-height: 1.25;
  margin-bottom: 6px;
}
.bfcsx .sx-feat-name em { font-style: italic; color: rgba(255,255,255,0.55); }
.bfcsx .sx-feat-desc {
  font-size: 12px; line-height: 1.6;
  color: rgba(255,255,255,0.5);
}
.bfcsx .sx-feat-tag {
  display: inline-block;
  font-family: var(--sm);
  font-size: 8px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  padding: 3px 7px; margin-top: 10px;
  background: rgba(227,110,21,0.12);
  color: var(--go);
}

/* ── COMPARISON (collapsed inside features section) ──
   Was a standalone full-width section; now folded into the features
   block as an opt-in expandable. The toggle sits as a thin bar below
   the feature cards; clicking it slides the comparison table out. */
.bfcsx .sx-compare-collapse {
  margin-top: 24px;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.bfcsx .sx-compare-toggle {
  display: flex; align-items: center; justify-content: center;
  gap: 10px;
  width: 100%;
  background: transparent;
  border: none;
  padding: 20px 0;
  cursor: pointer;
  font-family: var(--sm);
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  transition: color 0.18s ease;
}
.bfcsx .sx-compare-toggle:hover { color: var(--or); }
.bfcsx .sx-compare-toggle:focus-visible {
  outline: 1px solid var(--or);
  outline-offset: 4px;
}
.bfcsx .sx-compare-toggle-icon {
  transition: transform 0.25s ease;
}
.bfcsx .sx-compare-toggle[aria-expanded="true"] .sx-compare-toggle-icon {
  transform: rotate(180deg);
}
.bfcsx .sx-compare-panel {
  display: none;
  padding: 8px 0 32px;
}
.bfcsx .sx-compare-panel.is-open {
  display: block;
}

/* Table styling — dark theme since it lives inside the features section */
.bfcsx .sx-compare-table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
}
.bfcsx .sx-compare-wrap {
  width: 100%;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.bfcsx .sx-compare-table thead th {
  font-family: var(--sm);
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  padding: 14px 16px;
  text-align: left;
  border-bottom: 1px solid rgba(255,255,255,0.18);
}
.bfcsx .sx-compare-table thead th:first-child {
  color: rgba(255,255,255,0.55); width: 22%;
}
.bfcsx .sx-compare-table thead th:nth-child(2) {
  color: rgba(255,255,255,0.4); width: 39%;
}
.bfcsx .sx-compare-table thead th:nth-child(3) {
  color: var(--or); width: 39%;
}
.bfcsx .sx-compare-table tbody td {
  font-size: 12px; line-height: 1.55;
  padding: 13px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  vertical-align: top;
}
.bfcsx .sx-compare-table tbody td:first-child {
  font-size: 11px; font-weight: 600;
  color: rgba(255,255,255,0.85);
}
.bfcsx .sx-compare-table tbody td:nth-child(2) {
  color: rgba(255,255,255,0.45);
}
.bfcsx .sx-compare-table tbody td:nth-child(3) {
  color: rgba(255,255,255,0.92);
  background: rgba(227,110,21,0.08);
}
.bfcsx .sx-compare-table tbody tr:last-child td {
  border-bottom: none;
}

/* ── DONGLE SECTION ─────────────────────────────
   Dark background to match the Built-Into-the-Board section directly above, so
   they read as a single visual pair: "Included" (top half) vs "Optional" (bottom
   half) with the same headline pattern. */
.bfcsx .sx-dongle {
  background: var(--bk);
  padding: 0 48px 56px;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.bfcsx .sx-dongle-inner {
  max-width: 1200px; margin: 0 auto;
}
.bfcsx .sx-dongle-head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  margin-bottom: 0;
  padding: 52px 0 28px;
}
.bfcsx .sx-dongle-head-text { min-width: 0; }
.bfcsx .sx-dongle-ey {
  display: block;
  font-family: var(--sn);
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or);
  margin-bottom: 12px;
}
.bfcsx .sx-dongle-sub {
  font-family: var(--sn);
  font-size: 14px; line-height: 1.7;
  color: rgba(255,255,255,0.7);
  margin: 0;
  max-width: 60ch;
}
.bfcsx .sx-dongle-ey {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or); margin-bottom: 16px; display: block;
}
.bfcsx .sx-dongle-title {
  font-family: var(--sr);
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 300; line-height: 1.1;
  color: #fff; margin-bottom: 16px;
}
.bfcsx .sx-dongle-sub {
  font-size: 14px; line-height: 1.7;
  color: rgba(255,255,255,0.75);
}

/* ── UNIFIED SECTION HEADER ────────────────────
   Shared eyebrow + title + sub pattern used by both the "Built Into the Board"
   and "With the Dongle" sections so they read as a matched pair. */
.bfcsx .sx-section-head .sx-section-ey {
  display: inline-block;
  font-family: var(--sn);
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--go);
  margin-bottom: 18px;
}
.bfcsx .sx-section-head .sx-section-title {
  font-family: var(--sr);
  font-size: clamp(30px, 3.6vw, 44px);
  font-weight: 300; line-height: 1.05;
  color: #fff;
  margin: 0 0 16px;
  letter-spacing: -0.01em;
}
.bfcsx .sx-section-head .sx-section-title em {
  font-style: italic;
  color: var(--or);
}
.bfcsx .sx-section-head .sx-section-sub {
  font-family: var(--sn);
  font-size: 14px; line-height: 1.7;
  color: rgba(255,255,255,0.7);
  max-width: 60ch;
  margin: 0;
}
.bfcsx .sx-features .sx-section-head {
  padding: 52px 0 32px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  margin-bottom: 0;
}
.bfcsx .sx-dongle .sx-section-head {
  padding: 0 0 0;
  grid-template-columns: 1.2fr 0.8fr;
}
.bfcsx .sx-dongle .sx-section-head .sx-section-title { color: #fff; }
.bfcsx .sx-dongle .sx-section-head .sx-section-sub { color: rgba(255,255,255,0.75); }
.bfcsx .sx-dongle .sx-section-head .sx-section-ey { color: var(--or); }

.bfcsx .sx-dongle-img {
  aspect-ratio: 4 / 3;
  background: rgba(255,255,255,0.04);
  overflow: hidden;
}
.bfcsx .sx-dongle-img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* ── COMING SOON BLOCK ──
   Sits in the right column of the dongle head, replacing the dongle image
   while the product is still in development. Note beneath reassures buyers
   that their camera will work with the dongle whenever it ships. */
.bfcsx .sx-dongle-soon {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.bfcsx .sx-dongle-soon-card {
  position: relative;
  aspect-ratio: 4 / 3;
  background: rgba(255,255,255,0.04);
  border: 1px dashed rgba(255,255,255,0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 32px 24px;
  overflow: hidden;
}
.bfcsx .sx-dongle-soon-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 30%, rgba(227,110,21,0.08), transparent 60%);
  pointer-events: none;
}
.bfcsx .sx-dongle-soon-ey {
  font-family: var(--sn);
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or);
  margin-bottom: 14px;
  position: relative;
}
.bfcsx .sx-dongle-soon-title {
  font-family: var(--sr);
  font-size: clamp(28px, 3.4vw, 40px);
  font-weight: 300;
  line-height: 1.05;
  color: #fff;
  letter-spacing: -0.01em;
  margin-bottom: 10px;
  position: relative;
}
.bfcsx .sx-dongle-soon-meta {
  font-family: var(--sm);
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  position: relative;
}
.bfcsx .sx-dongle-soon-note {
  font-family: var(--sn);
  font-size: 12px; line-height: 1.6;
  color: rgba(255,255,255,0.6);
  text-align: center;
  margin: 0;
  padding: 0 8px;
}
.bfcsx .sx-dongle-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  column-gap: 56px;
  row-gap: 0;
}
.bfcsx .sx-dgrid-card {
  display: grid;
  grid-template-columns: 38px 1fr;
  column-gap: 18px;
  padding: 22px 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  align-items: start;
}
.bfcsx .sx-dgrid-card:nth-last-child(-n+2) { border-bottom: none; }
.bfcsx .sx-dgrid-num {
  font-family: var(--sm);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--or);
  line-height: 1.4;
  padding-top: 3px;
}
.bfcsx .sx-dgrid-body { min-width: 0; }
.bfcsx .sx-dgrid-name {
  font-family: var(--sr);
  font-size: 18px; font-weight: 400;
  color: #fff;
  line-height: 1.25;
  margin-bottom: 6px;
}
.bfcsx .sx-dgrid-name em { font-style: italic; color: rgba(255,255,255,0.55); }
.bfcsx .sx-dgrid-desc {
  font-family: var(--sn);
  font-size: 12px; line-height: 1.6;
  color: rgba(255,255,255,0.5);
}

/* ── LED QUICK REFERENCE ──────────────────────── */
.bfcsx .sx-led-ref {
  background: var(--bk);
  padding: 40px 48px;
}
.bfcsx .sx-led-inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center;
  gap: 40px; flex-wrap: wrap;
}
.bfcsx .sx-led-label {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  flex-shrink: 0;
}
.bfcsx .sx-led-items {
  display: flex; gap: 32px; flex-wrap: wrap;
}
.bfcsx .sx-led-item {
  display: flex; align-items: center; gap: 10px;
}
.bfcsx .sx-led-dot {
  width: 10px; height: 10px;
  flex-shrink: 0;
}
.bfcsx .sx-led-dot--blue { background: #4A90D9; }
.bfcsx .sx-led-dot--red { background: #D94A4A; }
.bfcsx .sx-led-dot--red-solid { background: #D94A4A; box-shadow: 0 0 6px rgba(217,74,74,0.5); }
.bfcsx .sx-led-text {
  font-size: 11px; color: rgba(255,255,255,0.5);
}

/* ── KIT BUILDER ──────────────────────────────── */
.bfcsx .sx-kit {
  background: var(--cv);
  padding: 64px 48px 48px;
  border-top: 1px solid rgba(82,87,65,0.08);
}
.bfcsx .sx-kit-inner {
  max-width: 1200px; margin: 0 auto;
}
.bfcsx .sx-kit-ey {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--or); margin-bottom: 12px; display: block;
}
.bfcsx .sx-kit-title {
  font-family: var(--sr);
  font-size: 32px; font-weight: 300;
  color: var(--bk); margin-bottom: 8px;
}
.bfcsx .sx-kit-sub {
  font-size: 13px; color: var(--ol); margin-bottom: 40px;
}
.bfcsx .sx-kit-cols {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.bfcsx .sx-kit-col {
  border-right: 1px solid rgba(82,87,65,0.08);
}
.bfcsx .sx-kit-col:last-child { border-right: none; }
.bfcsx .sx-kit-col-head {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--ol);
  padding: 16px 20px;
  border-bottom: 2px solid var(--bk);
}
.bfcsx .sx-kit-tile {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 20px;
  border-bottom: 1px solid rgba(82,87,65,0.06);
  cursor: pointer;
  transition: background var(--t);
}
.bfcsx .sx-kit-tile:hover { background: rgba(227,110,21,0.04); }
.bfcsx .sx-kit-tile.is-selected { background: rgba(227,110,21,0.08); }
.bfcsx .sx-kit-tile-img {
  width: 48px; height: 48px;
  object-fit: contain; flex-shrink: 0;
  background: #fff;
}
.bfcsx .sx-kit-tile-info { flex: 1; min-width: 0; }
.bfcsx .sx-kit-tile-name {
  font-size: 12px; font-weight: 500;
  color: var(--bk);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.bfcsx .sx-kit-tile-price {
  font-size: 11px; color: var(--ol);
}
.bfcsx .sx-kit-tile-check {
  width: 18px; height: 18px;
  border: 1.5px solid rgba(82,87,65,0.2);
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: all var(--t);
}
.bfcsx .sx-kit-tile.is-selected .sx-kit-tile-check {
  background: var(--or); border-color: var(--or);
}
.bfcsx .sx-kit-tile.is-selected .sx-kit-tile-check::after {
  content: '';
  width: 6px; height: 10px;
  border: solid #fff; border-width: 0 2px 2px 0;
  transform: rotate(45deg) translate(-1px, -1px);
}
/* Kit tile — sold out state. Shown when the picked product (and all its
   alternates) are OOS. Tile is still visible so customers see what was
   intended, but it can't be selected. */
.bfcsx .sx-kit-tile.is-oos {
  opacity: 0.55;
  cursor: not-allowed;
  background: rgba(32,32,9,0.02);
}
.bfcsx .sx-kit-tile.is-oos:hover { background: rgba(32,32,9,0.02); }
.bfcsx .sx-kit-tile.is-oos .sx-kit-tile-img { filter: grayscale(0.6); }
.bfcsx .sx-kit-tile.is-oos .sx-kit-tile-price {
  color: rgba(32,32,9,0.45);
  font-style: italic;
  font-weight: 500;
}
.bfcsx .sx-kit-tile.is-oos .sx-kit-tile-check { display: none; }

/* ── RESTORATION ──────────────────────────────── */
.bfcsx .sx-restore {
  background: var(--cv);
  padding: 0 48px;
  border-top: 1px solid rgba(32,32,9,0.08);
}
.bfcsx .sx-restore-inner {
  max-width: 1200px; margin: 0 auto;
}
.bfcsx .sx-restore-head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
  padding: 64px 0 48px;
  border-bottom: 1px solid rgba(32,32,9,0.12);
}
.bfcsx .sx-restore-head--simple {
  display: block;
  padding: 48px 0 32px;
}
.bfcsx .sx-restore-head--simple .sx-restore-ey {
  margin-bottom: 0;
}
.bfcsx .sx-restore-text { min-width: 0; }
.bfcsx .sx-restore-text .sx-restore-ey { margin-bottom: 14px; }
.bfcsx .sx-restore-text .sx-restore-h2 {
  font-family: var(--sr);
  font-size: clamp(28px, 3.2vw, 40px);
  font-weight: 300; line-height: 1.05;
  color: var(--bk);
  margin: 0 0 14px;
  letter-spacing: -0.01em;
}
.bfcsx .sx-restore-text .sx-restore-h2 em {
  font-style: italic; color: var(--or);
}
.bfcsx .sx-restore-text .sx-restore-lead {
  font-family: var(--sn);
  font-size: 14px; line-height: 1.65;
  color: var(--ch);
  margin: 0;
  max-width: 48ch;
}

/* Restoration photo — plain image, no wrapper styling. The uploaded scan
   already has its own framing. */
.bfcsx .sx-restore-photo {
  display: block;
  max-width: 340px;
  width: 100%;
  height: auto;
  margin: 0 auto;
}
.bfcsx .sx-restore-headline {
  padding: 64px 48px 64px 0;
  display: flex; flex-direction: column; justify-content: flex-end;
}
.bfcsx .sx-restore-ey {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or); margin-bottom: 16px; display: block;
}
.bfcsx .sx-restore-title {
  font-family: var(--sr);
  font-size: 42px; font-weight: 300;
  color: var(--bk); line-height: 1.05;
}
.bfcsx .sx-restore-title em {
  font-style: italic; color: var(--ch);
}
.bfcsx .sx-restore-stats {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;
  padding: 64px 0 64px 48px;
}
.bfcsx .sx-r-stat {
  padding: 0 24px;
  border-left: 1px solid rgba(32,32,9,0.12);
  display: flex; flex-direction: column; justify-content: center;
}
.bfcsx .sx-r-stat:first-child { border-left: none; padding-left: 0; }
.bfcsx .sx-r-stat-num {
  font-family: var(--sr);
  font-size: 52px; font-weight: 300;
  color: var(--bk); line-height: 1; margin-bottom: 8px;
}
.bfcsx .sx-r-stat-num span { color: var(--or); font-size: 0.6em; }
.bfcsx .sx-r-stat-label {
  font-size: 10.5px; color: var(--ch);
  line-height: 1.5; max-width: 120px;
}
.bfcsx .sx-restore-steps {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
}
.bfcsx .sx-r-step {
  padding: 28px 24px;
  border-right: 1px solid rgba(32,32,9,0.08);
}
.bfcsx .sx-r-step:last-child { border-right: none; }
.bfcsx .sx-r-num {
  font-family: var(--sr);
  font-size: 36px; font-weight: 300;
  color: rgba(227,110,21,0.5);
  line-height: 1; margin-bottom: 12px; display: block;
}
.bfcsx .sx-r-title {
  font-size: 12px; font-weight: 600;
  color: var(--bk); margin-bottom: 4px;
}
.bfcsx .sx-r-desc {
  font-size: 10.5px; color: var(--ch);
  line-height: 1.5;
}

/* ── FULL SPECS (editorial cream layout) ──────── */
.bfcsx .sx-specs {
  background: var(--cv);
  border-top: 1px solid rgba(32,32,9,0.08);
  padding: 80px 48px;
}
.bfcsx .sx-specs-inner {
  max-width: 1100px; margin: 0 auto;
}
.bfcsx .sx-specs-head {
  text-align: center;
  margin-bottom: 56px;
  padding: 0;
}
.bfcsx .sx-specs-eyebrow {
  display: inline-block;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.24em; text-transform: uppercase;
  color: var(--or);
  margin-bottom: 16px;
}
.bfcsx .sx-specs-title {
  font-family: var(--sr);
  font-size: 48px; font-weight: 300;
  color: var(--bk);
  line-height: 1; margin: 0 0 16px;
  letter-spacing: -0.01em;
}
.bfcsx .sx-specs-note {
  font-size: 13px;
  color: var(--ch);
  line-height: 1.6;
  max-width: 480px;
  margin: 0 auto;
  font-style: italic;
}
.bfcsx .sx-specs-body { padding: 0; }
.bfcsx .sx-specs-table {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border-top: 1px solid rgba(32,32,9,0.15);
  border-left: 1px solid rgba(32,32,9,0.15);
}
.bfcsx .sx-spec {
  display: grid;
  grid-template-columns: 130px 1fr;
  gap: 20px;
  align-items: baseline;
  padding: 18px 24px;
  border-right: 1px solid rgba(32,32,9,0.15);
  border-bottom: 1px solid rgba(32,32,9,0.15);
  background: transparent;
  transition: background 0.2s ease;
}
.bfcsx .sx-spec:hover { background: rgba(227,110,21,0.04); }
.bfcsx .sx-spec-k {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--or);
  margin: 0;
}
.bfcsx .sx-spec-v {
  font-family: var(--sn);
  font-size: 14px; font-weight: 400;
  color: var(--bk);
  line-height: 1.45;
}
.bfcsx .sx-spec-asterisk {
  color: var(--or);
  font-weight: 700;
  font-size: 0.7em;
  vertical-align: super;
  margin-left: 1px;
  line-height: 0;
}
.bfcsx .sx-spec-footnote {
  margin-top: 32px;
  padding: 16px 24px;
  background: rgba(227,110,21,0.06);
  border-left: 3px solid var(--or);
  font-size: 12px;
  font-style: italic;
  color: var(--ch);
  line-height: 1.6;
  max-width: 100%;
}

/* ── WARRANTY STRIP ───────────────────────────── */
.bfcsx .sx-warranty {
  background: var(--cv);
  padding: 48px;
  border-top: 1px solid rgba(82,87,65,0.08);
}
.bfcsx .sx-warranty-inner {
  max-width: 1200px; margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.bfcsx .sx-w-item {
  padding: 0 32px;
  border-right: 1px solid rgba(82,87,65,0.1);
}
.bfcsx .sx-w-item:first-child { padding-left: 0; }
.bfcsx .sx-w-item:last-child { border-right: none; padding-right: 0; }
.bfcsx .sx-w-label {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--or); margin-bottom: 6px;
}
.bfcsx .sx-w-text {
  font-size: 13px; line-height: 1.55;
  color: var(--ol);
}

/* ── MOBILE ───────────────────────────────────── */
@media (max-width: 768px) {
  .bfcsx .sx-pdp-top {
    grid-template-columns: 1fr;
    padding: 0;
    gap: 0;
  }
  .bfcsx .sx-photos { position: static; height: auto; max-height: none; }
  .bfcsx .sx-hero { aspect-ratio: 1 / 1; height: auto; }
  .bfcsx .sx-hero::after {
    font-size: clamp(120px, 50vw, 220px);
    right: -8%;
    opacity: 0.06;
  }
  .bfcsx .sx-info-pane { padding: 24px 20px 32px; max-width: 100%; }
  .bfcsx .sx-thumbs { display: none; }
  .bfcsx .sx-mini-specs { gap: 0; }
  .bfcsx .sx-osx-intro { padding: 48px 20px; }
  .bfcsx .sx-osx-intro-inner {
    grid-template-columns: 1fr; gap: 32px;
  }
  .bfcsx .sx-features { padding: 0 20px 40px; }
  .bfcsx .sx-feat-head { padding: 32px 0 20px; }
  .bfcsx .sx-feat-grid {
    grid-template-columns: 1fr;
    column-gap: 0;
  }
  .bfcsx .sx-feat-card {
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 18px 0;
    grid-template-columns: 32px 1fr;
    column-gap: 14px;
  }
  /* On mobile (single column), only the very last card has no border */
  .bfcsx .sx-feat-card:nth-last-child(-n+2) { border-bottom: 1px solid rgba(255,255,255,0.08); }
  .bfcsx .sx-feat-card:last-child { border-bottom: none; }
  .bfcsx .sx-feat-name { font-size: 16px; }
  .bfcsx .sx-feat-desc { font-size: 12px; }
  .bfcsx .sx-compare-table { display: block; overflow-x: auto; }
  .bfcsx .sx-dongle { padding: 48px 20px; }
  .bfcsx .sx-dongle-head {
    grid-template-columns: 1fr; gap: 32px;
  }
  .bfcsx .sx-dongle-grid {
    grid-template-columns: 1fr;
  }
  .bfcsx .sx-dgrid-card {
    border-right: none;
    border-bottom: 1px solid rgba(82,87,65,0.08);
    padding: 24px 0;
  }
  .bfcsx .sx-dgrid-card:last-child { border-bottom: none; }
  .bfcsx .sx-led-ref { padding: 28px 20px; }
  .bfcsx .sx-led-inner { flex-direction: column; gap: 16px; align-items: flex-start; }
  .bfcsx .sx-led-items { flex-direction: column; gap: 12px; }
  .bfcsx .sx-kit { padding: 40px 20px; }
  .bfcsx .sx-kit-cols {
    grid-template-columns: 1fr;
  }
  .bfcsx .sx-kit-col { border-right: none; border-bottom: 1px solid rgba(82,87,65,0.08); }
  .bfcsx .sx-kit-col:last-child { border-bottom: none; }
  .bfcsx .sx-restore { padding: 0 20px; }
  .bfcsx .sx-restore-head {
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 40px 0 28px;
  }
  .bfcsx .sx-restore-head--simple { padding: 32px 0 20px; }
  .bfcsx .sx-restore-photo { max-width: 280px; }
  .bfcsx .sx-restore-steps {
    grid-template-columns: 1fr;
  }
  .bfcsx .sx-r-step { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .bfcsx .sx-r-step:last-child { border-bottom: none; }
  .bfcsx .sx-specs { padding: 56px 20px; }
  .bfcsx .sx-specs-head { padding: 0; margin-bottom: 32px; }
  .bfcsx .sx-specs-title { font-size: 32px; }
  .bfcsx .sx-specs-body { padding: 0; }
  .bfcsx .sx-specs-table { grid-template-columns: 1fr; }
  .bfcsx .sx-spec { grid-template-columns: 110px 1fr; padding: 14px 18px; }
  .bfcsx .sx-spec-v { font-size: 14px; }
  .bfcsx .sx-spec:nth-child(even) { padding-left: 0; border-left: none; }
  .bfcsx .sx-spec:nth-child(odd) { padding-right: 0; }
  .bfcsx .sx-warranty { padding: 32px 20px; }
  .bfcsx .sx-warranty-inner { grid-template-columns: 1fr; gap: 24px; }
  .bfcsx .sx-w-item { padding: 0; border-right: none; border-bottom: 1px solid rgba(82,87,65,0.08); padding-bottom: 20px; }
  .bfcsx .sx-w-item:last-child { border-bottom: none; padding-bottom: 0; }
}

/* ── Extended Warranty ── */
.bfcsx .sx-ext-warranty { border-top: 1px solid rgba(32,32,9,0.08); padding-top: 16px; margin-top: 16px; }
.bfcsx .sx-ext-w-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.bfcsx .sx-ext-w-eyebrow { font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--or); }
.bfcsx .sx-ext-w-baseline { font-size: 10px; color: var(--ch); margin-bottom: 10px; display: flex; align-items: flex-start; gap: 5px; line-height: 1.5; }
.bfcsx .sx-ext-w-baseline svg { flex-shrink: 0; color: #2a4820; margin-top: 2px; }
.bfcsx .sx-ext-w-baseline strong { color: var(--bk); }
.bfcsx .sx-ext-w-options { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; }
.bfcsx .sx-ext-w-options.sx-ext-w-options--single { grid-template-columns: 1fr; }
.bfcsx .sx-ext-w-btn { border: 1px solid rgba(32,32,9,0.1); background: #fff; padding: 10px 8px; cursor: pointer; font-family: var(--sn); text-align: center; transition: border-color 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: column; gap: 3px; position: relative; }
.bfcsx .sx-ext-w-btn:hover { border-color: var(--or); }
.bfcsx .sx-ext-w-btn.is-sel { border: 2px solid var(--or); box-shadow: 0 0 0 1px rgba(227,110,21,0.15); }
.bfcsx .sx-ext-w-btn.is-sel::after { content: '✓'; position: absolute; top: 4px; right: 5px; font-size: 8px; font-weight: 700; color: var(--or); }
.bfcsx .sx-ext-w-extend { font-size: 11px; font-weight: 700; color: var(--or); line-height: 1; }
.bfcsx .sx-ext-w-months { font-size: 9px; color: var(--ch); letter-spacing: 0.04em; line-height: 1; }
.bfcsx .sx-ext-w-price { font-size: 11px; font-weight: 700; color: var(--bk); margin-top: 2px; }
.bfcsx .sx-ext-w-acc { font-size: 7.5px; color: #2a4820; font-weight: 600; letter-spacing: 0.04em; margin-top: 1px; }
.bfcsx .sx-ext-w-none { font-size: 8.5px; color: rgba(32,32,9,0.4); margin-top: 8px; text-align: left; cursor: pointer; background: none; border: none; font-family: var(--sn); transition: color 0.2s ease; padding: 0; display: none; }
.bfcsx .sx-ext-w-none.is-vis { display: block; }
.bfcsx .sx-ext-w-none:hover { color: var(--bk); }

/* ── Warranty & Returns Policy ── */
.bfcsx .sx-policy { background: var(--cv); border-top: 1px solid rgba(32,32,9,0.06); }
.bfcsx .sx-policy-col { padding: 48px; }
.bfcsx .sx-policy-ey { font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--go); display: block; margin-bottom: 12px; }
.bfcsx .sx-policy-title { font-family: var(--sr); font-size: 28px; font-weight: 300; color: var(--bk); line-height: 1.1; margin: 0 0 16px; }
.bfcsx .sx-policy-pill { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; background: rgba(171,204,153,0.2); color: var(--or); font-size: 10px; font-weight: 600; letter-spacing: 0.06em; margin-bottom: 20px; }
.bfcsx .sx-policy-body { font-size: 13px; line-height: 1.6; color: var(--ch); }
.bfcsx .sx-policy-body p { margin: 0; }
.bfcsx .sx-policy-body strong { color: var(--bk); }
@media (max-width: 767px) {
  .bfcsx .sx-policy { grid-template-columns: 1fr; }
  .bfcsx .sx-policy-col { padding: 32px 20px; }
  .bfcsx .sx-policy-col:first-child { border-right: none; border-bottom: 1px solid rgba(32,32,9,0.06); }
  .bfcsx .sx-policy-title { font-size: 22px; }
}

/* ── Sticky Mobile ATC Bar ────────────────── */
.bfcsx .sx-sticky-bar { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--cv); border-top: 1px solid rgba(32,32,9,0.15); padding: 10px 16px; z-index: 9999; align-items: center; gap: 12px; box-shadow: 0 -2px 12px rgba(0,0,0,0.08); }
.bfcsx .sx-sticky-info { flex: 1; min-width: 0; }
.bfcsx .sx-sticky-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--bk); }
.bfcsx .sx-sticky-meta { display: flex; align-items: center; gap: 6px; margin-top: 1px; }
.bfcsx .sx-sticky-grade { font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ch); }
.bfcsx .sx-sticky-price { font-size: 13px; font-weight: 700; color: var(--or); }
.bfcsx .sx-sticky-btn { background: var(--or); color: #fff; border: none; padding: 12px 24px; font-size: 10px; font-weight: 700; font-family: var(--sn); text-transform: uppercase; letter-spacing: 0.14em; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
.bfcsx .sx-sticky-btn:disabled { opacity: 0.5; cursor: not-allowed; }
@media (max-width: 767px) {
  .bfcsx .sx-sticky-bar.is-visible { display: flex; }
}

/* ── STICKY TOP-LEVEL TOC ──
   Top-of-viewport anchor nav. Slides in once the buy box scrolls out of view,
   hides on mobile (≤767px) where the bottom sticky ATC bar covers the same
   affordance. Lives OUTSIDE .bfcsx so future overflow on the wrapper can't
   clip it. Brand vars re-declared since it's outside the wrapper. */
.sx-toc {
  --or: #E36E15;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --sn: 'Poppins', sans-serif;
  position: fixed;
  top: 0; left: 0; right: 0; width: 100%;
  z-index: 30;
  background: var(--cv);
  border-bottom: 1px solid rgba(32,32,9,0.12);
  font-family: var(--sn);
  transform: translateY(-100%);
  transition: transform 0.25s ease;
  pointer-events: none;
  visibility: hidden;
  box-sizing: border-box;
}
.sx-toc * { box-sizing: border-box; }
.sx-toc.is-visible {
  transform: translateY(0);
  pointer-events: auto;
  visibility: visible;
}
.sx-toc-inner {
  display: flex; align-items: center; justify-content: space-between;
  gap: 24px;
  padding: 11px 28px;
  max-width: 1400px;
  margin: 0 auto;
}
.sx-toc-links {
  display: flex; gap: 28px;
  list-style: none; margin: 0; padding: 0;
  flex-wrap: nowrap; overflow-x: auto;
  scrollbar-width: none;
}
.sx-toc-links::-webkit-scrollbar { display: none; }
.sx-toc-links a {
  display: inline-block;
  padding: 4px 0;
  font-size: 11.5px; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--ch); text-decoration: none;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: color 0.15s, border-color 0.15s;
}
.sx-toc-links a:hover { color: var(--bk); }
.sx-toc-links a.is-active {
  color: var(--bk);
  border-bottom-color: var(--or);
}
.sx-toc-atc {
  flex-shrink: 0;
  padding: 9px 18px;
  background: var(--or); color: #fff;
  border: none;
  font-family: var(--sn);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  cursor: pointer;
  transition: background 0.15s;
}
.sx-toc-atc:hover { background: #c9600f; }
.sx-toc-atc:disabled { opacity: 0.7; cursor: not-allowed; }
@media (max-width: 767px) {
  .sx-toc { display: none !important; }
}
@media (max-width: 900px) {
  .sx-toc-inner { padding: 9px 14px; gap: 12px; }
  .sx-toc-links { gap: 18px; }
  .sx-toc-links a { font-size: 10.5px; letter-spacing: 0.06em; }
  .sx-toc-atc { padding: 7px 12px; font-size: 10px; letter-spacing: 0.06em; }
}

/* ── IN-CHAPTER SUB-TABS ──
   Horizontal nav strip at the top of the expanded OpenSX70 chapter body.
   In-flow (not sticky) — scrolls away with the rest of the chapter so it
   never covers the chapter title or other content. Clicking still smooth-
   scrolls to the correct sub-section. */
.bfcsx .sx-subtoc {
  background: var(--bk);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  font-family: var(--sn);
}
.bfcsx .sx-subtoc-inner {
  max-width: 1200px; margin: 0 auto;
  padding: 0 48px;
  display: flex;
  gap: 32px;
  align-items: stretch;
  overflow-x: auto;
  scrollbar-width: none;
}
.bfcsx .sx-subtoc-inner::-webkit-scrollbar { display: none; }
.bfcsx .sx-subtoc a {
  display: inline-flex; align-items: center;
  padding: 16px 0;
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  text-decoration: none;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: color 0.15s, border-color 0.15s;
}
.bfcsx .sx-subtoc a:hover { color: rgba(255,255,255,0.85); }
.bfcsx .sx-subtoc a.is-active {
  color: #fff;
  border-bottom-color: var(--or);
}
@media (max-width: 900px) {
  .bfcsx .sx-subtoc-inner { padding: 0 20px; gap: 22px; }
  .bfcsx .sx-subtoc a { font-size: 10px; padding: 13px 0; letter-spacing: 0.1em; }
}
{% endstyle %}

{%- comment -%}
  ================================================================
  HTML
  ================================================================
{%- endcomment -%}

<div class="bfcsx" data-section-id="{{ section.id }}">

  {%- comment -%} ── PDP TOP: Photos Left | Info + ATC Right ── {%- endcomment -%}
  <div class="sx-pdp-top" id="sx-top">
    <div class="sx-photos">
      <div class="sx-hero">
        <div class="sx-slider" id="sxSlider-{{ section.id }}">
          {%- assign warranty_base = product.metafields.bfc.warranty_months | default: 6 -%}
{%- assign slide_imgs = '' -%}
          {%- for i in (1..5) -%}
            {%- assign slide_key = 'slide_' | append: i -%}
            {%- assign slide_img = section.settings[slide_key] -%}
            {%- if slide_img != blank -%}
              <div class="sx-slide">
                <img src="{{ slide_img | image_url: width: 900 }}" alt="{{ product.title }} - image {{ i }}" loading="{% if i == 1 %}eager{% else %}lazy{% endif %}" width="900" height="900">
              </div>
              {%- assign slide_imgs = slide_imgs | append: '1,' -%}
            {%- endif -%}
          {%- endfor -%}
          {%- comment -%} Fallback to product images {%- endcomment -%}
          {%- assign slide_count = slide_imgs | split: ',' | size -%}
          {%- if slide_count == 0 -%}
            {%- for img in product.images limit: 5 -%}
              <div class="sx-slide">
                <img src="{{ img | image_url: width: 900 }}" alt="{{ img.alt | default: product.title }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" width="{{ img.width }}" height="{{ img.height }}">
              </div>
            {%- endfor -%}
            {%- assign slide_count = product.images.size | at_most: 5 -%}
          {%- endif -%}
        </div>
        {%- if slide_count > 1 -%}
          <button class="sx-arrow sx-arrow-prev" id="sxPrev-{{ section.id }}" aria-label="Previous image" type="button">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="sx-arrow sx-arrow-next" id="sxNext-{{ section.id }}" aria-label="Next image" type="button">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="sx-dots" id="sxDots-{{ section.id }}">
            {%- for i in (1..slide_count) -%}
              <button class="sx-dot{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="Slide {{ i }}"></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      {%- comment -%} Thumbnail strip {%- endcomment -%}
      {%- if slide_count > 1 -%}
        <div class="sx-thumbs" id="sxThumbs-{{ section.id }}">
          {%- assign thumb_idx = 0 -%}
          {%- for i in (1..5) -%}
            {%- assign slide_key = 'slide_' | append: i -%}
            {%- assign slide_img = section.settings[slide_key] -%}
            {%- if slide_img != blank -%}
              <button class="sx-thumb{% if thumb_idx == 0 %} is-active{% endif %}" data-idx="{{ thumb_idx }}">
                <img src="{{ slide_img | image_url: width: 128 }}" alt="Thumbnail {{ i }}" loading="lazy">
              </button>
              {%- assign thumb_idx = thumb_idx | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if slide_count == 0 -%}
            {%- for img in product.images limit: 5 -%}
              <button class="sx-thumb{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}">
                <img src="{{ img | image_url: width: 128 }}" alt="{{ img.alt | default: 'Thumbnail' }}" loading="lazy">
              </button>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="sx-info-pane">
    <div class="sx-info">
      {% render 'bfc-pdp-breadcrumbs' %}
      <h1 class="sx-title">{{ product.title }}</h1>

      {%- if section.settings.show_board_pill -%}
        <a href="#sx-chapter" class="sx-board-pill sx-board-pill--below-title">
          <span class="sx-board-pill-tag">New</span>
          <span>{{ section.settings.board_pill_text | default: 'OpenSX70 V2 Board' }}</span>
          <svg class="sx-board-pill-arrow" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 8L8 2M8 2H3M8 2V7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- endif -%}

      <div id="bfc4-star-placeholder"></div>

      {%- comment -%} ── Product description (cleaned) ──
          Sits up top now, between stars and ATC. Per-product, editable from
          product admin. We run the same cleanup as before: strip legacy
          <table>/<div>/<ul> spec blocks that older imports left behind, so
          only the prose remains. The Film / Board / Condition strip and
          the static restoration summary (driven by section.settings.intro_text)
          live in the under-fold strip below, not in this column. {%- endcomment -%}
      {%- assign desc_clean = product.description -%}

      {%- comment -%} 1. Strip <table>...</table> blocks {%- endcomment -%}
      {%- assign table_parts = desc_clean | split: '<table' -%}
      {%- if table_parts.size > 1 -%}
        {%- assign desc_clean = table_parts[0] -%}
        {%- for part in table_parts -%}
          {%- if forloop.first -%}{%- continue -%}{%- endif -%}
          {%- assign after_table = part | split: '</table>' -%}
          {%- if after_table.size > 1 -%}
            {%- assign desc_clean = desc_clean | append: after_table[1] -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} 2. Strip <div>...</div> blocks whose inner text starts with spec keys {%- endcomment -%}
      {%- assign div_parts = desc_clean | split: '<div' -%}
      {%- if div_parts.size > 1 -%}
        {%- assign desc_rebuilt = div_parts[0] -%}
        {%- for part in div_parts -%}
          {%- if forloop.first -%}{%- continue -%}{%- endif -%}
          {%- assign div_text = part | strip_html | strip -%}
          {%- assign div_is_spec = false -%}
          {%- if div_text contains 'Lens:' or div_text contains 'Shutter:' or div_text contains 'Battery:' or div_text contains 'Film Type:' or div_text contains 'Focus:' or div_text contains 'Metering:' or div_text contains 'Flash:' or div_text contains 'ISO:' or div_text contains 'Viewfinder:' or div_text contains 'Aperture:' or div_text contains 'Self-Timer:' or div_text contains 'Self Timer:' or div_text contains 'Mount:' -%}
            {%- assign div_is_spec = true -%}
          {%- endif -%}
          {%- if div_is_spec -%}
            {%- assign after_div = part | split: '</div>' -%}
            {%- if after_div.size > 1 -%}
              {%- for seg in after_div -%}
                {%- if forloop.first -%}{%- continue -%}{%- endif -%}
                {%- assign desc_rebuilt = desc_rebuilt | append: seg -%}
                {%- unless forloop.last -%}
                  {%- assign desc_rebuilt = desc_rebuilt | append: '</div>' -%}
                {%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          {%- else -%}
            {%- assign desc_rebuilt = desc_rebuilt | append: '<div' | append: part -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign desc_clean = desc_rebuilt -%}
      {%- endif -%}

      {%- comment -%} 3. Strip <ul>...</ul> blocks containing spec keys {%- endcomment -%}
      {%- assign ul_parts = desc_clean | split: '<ul' -%}
      {%- if ul_parts.size > 1 -%}
        {%- assign desc_rebuilt = ul_parts[0] -%}
        {%- for part in ul_parts -%}
          {%- if forloop.first -%}{%- continue -%}{%- endif -%}
          {%- assign ul_text = part | strip_html | strip -%}
          {%- assign ul_is_spec = false -%}
          {%- if ul_text contains 'Lens:' or ul_text contains 'Shutter:' or ul_text contains 'Battery:' or ul_text contains 'Film:' or ul_text contains 'Focus:' or ul_text contains 'Metering:' or ul_text contains 'Flash:' or ul_text contains 'ISO:' or ul_text contains 'Viewfinder:' or ul_text contains 'Aperture:' -%}
            {%- assign ul_is_spec = true -%}
          {%- endif -%}
          {%- if ul_is_spec -%}
            {%- assign after_ul = part | split: '</ul>' -%}
            {%- if after_ul.size > 1 -%}
              {%- assign desc_rebuilt = desc_rebuilt | append: after_ul[1] -%}
            {%- endif -%}
          {%- else -%}
            {%- assign desc_rebuilt = desc_rebuilt | append: '<ul' | append: part -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign desc_clean = desc_rebuilt -%}
      {%- endif -%}

      {%- assign desc_check = desc_clean | strip_html | strip -%}
      {%- if desc_check != '' -%}
        <div class="sx-desc-intro sx-desc-intro--above">{{ desc_clean }}</div>
      {%- endif -%}

      {%- comment -%} ── ATC ── {%- endcomment -%}
      <div class="sx-atc-panel">
        {%- comment -%} Price and variant swatches share a single row.
            Price/compare-at on the left, variant swatches + name on the
            right (when product has multiple variants). This saves ~30px
            of vertical real estate vs stacking them. {%- endcomment -%}
        <div class="sx-atc-priceline">
          <div class="sx-atc-pricegroup">
            <div class="sx-atc-price" id="sxPrice-{{ section.id }}">
              {{ current_variant.price | money }}
            </div>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="sx-atc-compare" id="sxCompare-{{ section.id }}">
                {{ current_variant.compare_at_price | money }}
              </span>
            {%- endif -%}
          </div>

          {%- if product.variants.size > 1 -%}
            {%- comment -%} Variant selector for the shutter-button color
                (Red / Blue). Rendered as small color swatches so the
                cosmetic choice doesn't dominate the ATC area. The selected
                variant's name appears as a tiny mono label after the
                swatches so the choice is discoverable. {%- endcomment -%}
            <div class="sx-atc-variant-row">
              <span class="sx-atc-variant-label">Button</span>
              <div class="sx-atc-variants" id="sxVariants-{{ section.id }}">
                {%- for v in product.variants -%}
                  {%- assign v_title_lower = v.title | downcase -%}
                  {%- assign v_color = '' -%}
                  {%- if v_title_lower contains 'red' -%}{%- assign v_color = 'red' -%}{%- endif -%}
                  {%- if v_title_lower contains 'blue' -%}{%- assign v_color = 'blue' -%}{%- endif -%}
                  <button class="sx-variant-btn{% if v == current_variant %} is-selected{% endif %}{% unless v.available %} is-sold-out{% endunless %}"
                    data-variant-id="{{ v.id }}"
                    data-variant-title="{{ v.title | escape }}"
                    data-color="{{ v_color }}"
                    data-price="{{ v.price | money }}"
                    data-price-cents="{{ v.price }}"
                    data-compare="{{ v.compare_at_price | money }}"
                    data-available="{{ v.available }}"
                    aria-label="{{ v.title | escape }}{% unless v.available %} (sold out){% endunless %}"
                    title="{{ v.title | escape }}"
                    {% unless v.available %}disabled{% endunless %}>
                    {{ v.title }}
                  </button>
                {%- endfor -%}
              </div>
              <span class="sx-variant-name" id="sxVariantName-{{ section.id }}">{{ current_variant.title }}</span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Urgency signals {%- endcomment -%}
        {% render 'bfc-pdp-urgency', variant: current_variant, handle: product.handle, show_trust: true, price: current_variant.price %}

        <form method="post" action="/cart/add" id="sxATC-{{ section.id }}">
