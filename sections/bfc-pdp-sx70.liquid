        {%- if product.variants.size > 1 and current_variant.title != "Default Title" -%}<span class="sx-sticky-grade" id="sx-sticky-grade">{{ current_variant.title }}</span>{%- endif -%}
        <span class="sx-sticky-price" id="sx-sticky-price">{{ current_variant.price | money }}</span>
      </div>
    </div>
    <button class="sx-sticky-btn" id="sx-sticky-btn" onclick="this.textContent='Adding\u2026';this.style.opacity='0.7';document.getElementById('sxATC-{{ section.id }}').requestSubmit()"{% unless current_variant.available %} disabled{% endunless %}>Add to Cart</button>
  </div>

</div>

