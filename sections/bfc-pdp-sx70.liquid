            <span>Your camera includes a <strong>{{ warranty_base }}-month warranty</strong> &mdash; extend to a full year below:</span>
          </div>
          <div class="sx-ext-w-options sx-ext-w-options--single">
            <button class="sx-ext-w-btn" data-months="6" data-total="12" data-price="{{ w12_price }}" data-variant-id="{{ w12_vid }}" onclick="sxSelectWarranty(this)">
              <span class="sx-ext-w-extend">+6 months</span>
