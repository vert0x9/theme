<script>
function sxToggleChapter() {
  var btn = document.getElementById('sx-chapter-toggle');
  var body = document.getElementById('sx-chapter-body');
  var txt = btn ? btn.querySelector('.sx-chapter-toggle-text') : null;
  if (!btn || !body) return;
  var isOpen = body.classList.toggle('is-open');
  btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  if (txt) txt.textContent = isOpen ? 'Hide details' : 'Learn how it works';
}

/* Theme editor: auto-open the chapter on every render so merchants can
   edit any setting inside it without the whole section collapsing. Only
   runs in Shopify.designMode — customers still get the click-to-expand
   discovery moment. */
(function() {
  if (!(window.Shopify && window.Shopify.designMode)) return;
  function openChapter() {
    var btn = document.getElementById('sx-chapter-toggle');
    var body = document.getElementById('sx-chapter-body');
    if (!btn || !body) return;
    if (!body.classList.contains('is-open')) {
      body.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
      var txt = btn.querySelector('.sx-chapter-toggle-text');
      if (txt) txt.textContent = 'Hide details';
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', openChapter);
  } else {
    openChapter();
  }
  /* Also re-open after Shopify section reloads (which fire when a setting
     is changed in the editor sidebar). */
  document.addEventListener('shopify:section:load', openChapter);
})();

/* ── Compare-vs-stock toggle ──
   Reveals the (collapsed by default) comparison table inside the features
   block. Lives at script scope (not inside the design-mode IIFE above) so
   it's defined on the live site, not just in the theme editor. */
window.bfcsxToggleCompare = function() {
  var btn   = document.getElementById('sx-compare-toggle');
  var panel = document.getElementById('sx-compare-panel');
  var label = btn ? btn.querySelector('.sx-compare-toggle-label') : null;
  if (!btn || !panel) return;
  var isOpen = panel.classList.toggle('is-open');
  btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  panel.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
  if (label) {
    label.textContent = isOpen
      ? 'Hide comparison'
      : 'Compare vs an unmodded SX-70';
  }
};
</script>

<script>
(function(){
  const sid = '{{ section.id }}';

  /* ── Slider + Thumbs ── */
  const slider = document.getElementById('sxSlider-' + sid);
  const dots   = document.querySelectorAll('#sxDots-' + sid + ' .sx-dot');
  const thumbs = document.querySelectorAll('#sxThumbs-' + sid + ' .sx-thumb');
  const prevArr = document.getElementById('sxPrev-' + sid);
  const nextArr = document.getElementById('sxNext-' + sid);
  if (slider) {
    const updateActive = () => {
      const idx = Math.round(slider.scrollLeft / slider.offsetWidth);
      dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      thumbs.forEach((t, i) => t.classList.toggle('is-active', i === idx));
    };
    slider.addEventListener('scroll', updateActive, { passive: true });
    const goTo = (idx) => slider.scrollTo({ left: idx * slider.offsetWidth, behavior: 'smooth' });
    dots.forEach(d => d.addEventListener('click', () => goTo(+d.dataset.idx)));
    thumbs.forEach(t => t.addEventListener('click', () => goTo(+t.dataset.idx)));
    if (prevArr) prevArr.addEventListener('click', () => {
      const cur = Math.round(slider.scrollLeft / slider.offsetWidth);
      const max = slider.children.length - 1;
      goTo(cur === 0 ? max : cur - 1);
    });
    if (nextArr) nextArr.addEventListener('click', () => {
      const cur = Math.round(slider.scrollLeft / slider.offsetWidth);
      const max = slider.children.length - 1;
      goTo(cur === max ? 0 : cur + 1);
    });
  }

  /* ── Variant picker ── */
  const variantBtns = document.querySelectorAll('#sxVariants-' + sid + ' .sx-variant-btn');
  const priceEl     = document.getElementById('sxPrice-' + sid);
  const compareEl   = document.getElementById('sxCompare-' + sid);
  const varInput    = document.getElementById('sxVariantInput-' + sid);
  const varNameEl   = document.getElementById('sxVariantName-' + sid);
  const addBtn      = document.querySelector('#sxATC-' + sid + ' .sx-add-btn');

  variantBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.classList.contains('is-sold-out')) return;
      variantBtns.forEach(b => b.classList.remove('is-selected'));
      btn.classList.add('is-selected');
      varInput.value = btn.dataset.variantId;
      if (priceEl) priceEl.textContent = btn.dataset.price;
      if (compareEl) {
        compareEl.textContent = btn.dataset.compare || '';
        compareEl.style.display = btn.dataset.compare ? '' : 'none';
      }
      /* Reflect selected variant name in the tiny mono label next to
         the color swatches. Falls back to the button's text content if
         the data-variant-title attribute is missing. */
      if (varNameEl) {
        varNameEl.textContent = btn.dataset.variantTitle || btn.textContent.trim();
      }
      const avail = btn.dataset.available === 'true';
      addBtn.disabled = !avail;
      addBtn.textContent = avail ? 'Add to Cart' : 'Sold Out';

      /* Update URL */
      const url = new URL(window.location);
      url.searchParams.set('variant', btn.dataset.variantId);
      window.history.replaceState({}, '', url);

      /* Update warranty tier */
      if (btn.dataset.priceCents) sxUpdateWarrantyTier(parseInt(btn.dataset.priceCents, 10));

      /* Update sticky bar */
      const stickyGrade = document.getElementById('sx-sticky-grade');
      const stickyPrice = document.getElementById('sx-sticky-price');
      const stickyBtn   = document.getElementById('sx-sticky-btn');
      if (stickyGrade) stickyGrade.textContent = btn.dataset.variantTitle || btn.textContent.trim();
      if (stickyPrice) stickyPrice.textContent = btn.dataset.price;
      if (stickyBtn)   stickyBtn.disabled = !avail;
    });
  });

  /* ── Kit builder ── */
  const kitTiles = document.querySelectorAll('.bfcsx .sx-kit-tile');
  const kitCart  = [];
  kitTiles.forEach(tile => {
    tile.addEventListener('click', () => {
      // Skip OOS tiles — they're rendered for visual continuity but can't be added.
      if (tile.dataset.oos === 'true') return;
      tile.classList.toggle('is-selected');
      const vid = tile.dataset.variantId;
      const idx = kitCart.indexOf(vid);
      if (idx > -1) kitCart.splice(idx, 1);
      else kitCart.push(vid);
    });
  });

  /* ── Extended Warranty ── */
  let sxWarranty = null;
  // Warranty tier table — sourced from snippets/bfc-warranty-tiers-js.liquid
  // (Polaroid pricing, 9 brackets). Snippet emits BFC_WARRANTY_TIERS;
  // SX_WARRANTY_TIERS aliased here so existing sxGetWarrantyTier code is unchanged.
  {% render 'bfc-warranty-tiers-js', category: 'polaroid' %}
  const SX_WARRANTY_TIERS = BFC_WARRANTY_TIERS;
  function sxGetWarrantyTier(price) {
    for (let i = 0; i < SX_WARRANTY_TIERS.length; i++) {
      if (price <= SX_WARRANTY_TIERS[i].max) return SX_WARRANTY_TIERS[i];
    }
    return SX_WARRANTY_TIERS[SX_WARRANTY_TIERS.length - 1];
  }
  function sxUpdateWarrantyTier(variantPrice) {
    const tier = sxGetWarrantyTier(variantPrice);
    // SX-70 (uses Polaroid pricing): single +6 month button. Pulls v12/p12 only.
    document.querySelectorAll('.sx-ext-w-btn').forEach(btn => {
      btn.dataset.variantId = tier.v12;
      btn.dataset.price = tier.p12;
      const el = btn.querySelector('.sx-ext-w-price');
      if (el) el.textContent = '+$' + (tier.p12 / 100).toFixed(0);
      if (btn.classList.contains('is-sel') && sxWarranty) {
        sxWarranty.variantId = tier.v12;
        sxWarranty.price = tier.p12;
      }
    });
  }
  window.sxSelectWarranty = function(btn) {
    const wasSelected = btn.classList.contains('is-sel');
    document.querySelectorAll('.sx-ext-w-btn').forEach(b => b.classList.remove('is-sel'));
    const clearBtn = document.getElementById('sx-ext-w-clear');
    if (wasSelected) {
      sxWarranty = null;
      if (clearBtn) clearBtn.classList.remove('is-vis');
    } else {
      btn.classList.add('is-sel');
      sxWarranty = {
        months: parseInt(btn.dataset.months, 10),
        total:  parseInt(btn.dataset.total, 10),
        price:  parseInt(btn.dataset.price, 10),
        variantId: btn.dataset.variantId || null
      };
      if (clearBtn) clearBtn.classList.add('is-vis');
    }
  };
  window.sxClearWarranty = function() {
    document.querySelectorAll('.sx-ext-w-btn').forEach(b => b.classList.remove('is-sel'));
    sxWarranty = null;
    const clearBtn = document.getElementById('sx-ext-w-clear');
    if (clearBtn) clearBtn.classList.remove('is-vis');
  };
  sxUpdateWarrantyTier({{ current_variant.price }});

  /* ── Intercept ATC to include kit + warranty items ── */
  const form = document.getElementById('sxATC-' + sid);
  if (form) {
    form.addEventListener('submit', function(e) {
      if (kitCart.length === 0 && !sxWarranty) return; /* default single-item submit */
      e.preventDefault();
      const items = [{ id: parseInt(varInput.value), quantity: 1 }];
      kitCart.forEach(vid => items.push({ id: parseInt(vid), quantity: 1 }));
      if (sxWarranty && sxWarranty.variantId) {
        items.push({ id: parseInt(sxWarranty.variantId), quantity: 1, properties: { _extended_warranty: 'true' } });
      }
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      }).then(r => {
        if (r.ok) {
          if (window.bfcTrackActivity) bfcTrackActivity('atc');
          if (window._bfcStickySuppress) window._bfcStickySuppress();
      var sBar = document.getElementById('sx-sticky-bar');
          if (sBar) sBar.classList.remove('is-visible');
          window.location.href = '/cart';
        }
        else r.json().then(d => alert(d.description || 'Could not add to cart'));
      }).catch(() => alert('Something went wrong — please try again.'));
    });
  }

  /* ── Hide sticky bar on native form submit ── */
  if (form) {
    form.addEventListener('submit', function() {
      if (window._bfcStickySuppress) window._bfcStickySuppress();
      var sBar = document.getElementById('sx-sticky-bar');
      var sBtn = document.getElementById('sx-sticky-btn');
      if (sBtn) { sBtn.textContent = 'Added!'; sBtn.style.background = '#2a4820'; }
      if (sBar) setTimeout(function() { sBar.classList.remove('is-visible'); }, 1500);
    }); /* sx-sticky-hide-on-submit */
  }

  /* ── Sticky Mobile ATC Bar ── */
  const stickyBar = document.getElementById('sx-sticky-bar');
  const mainBtn   = document.querySelector('#sxATC-' + sid + ' .sx-add-btn');
  if (stickyBar && mainBtn) {
    var _stickySuppress = false;
    new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!_stickySuppress) stickyBar.classList.toggle('is-visible', !e.isIntersecting);
      });
    }, { threshold: 0 }).observe(mainBtn);
    window._bfcStickySuppress = function() { _stickySuppress = true; };
    window._bfcStickyUnsuppress = function() { _stickySuppress = false; };
  }
  /* Hide sticky bar when cart drawer opens (minimal, safe) */
  if (stickyBar) {
    var _hideSticky = function() { stickyBar.classList.remove('is-visible'); };
    /* Click any cart icon/link → hide immediately */
    document.addEventListener('click', function(e) {
      var t = e.target.closest('a[href="/cart"], a[href^="/cart?"], [data-cart-icon], [data-cart-toggle], summary[aria-controls*="cart" i], button[aria-controls*="cart" i], .header__icon--cart');
      if (t) _hideSticky();
    }, true);
    /* Body class changes (js-drawer-open etc) */
    new MutationObserver(function() {
      if (document.body.classList.contains('js-drawer-open')
       || document.body.classList.contains('drawer-open')
       || document.body.classList.contains('cart-open')) _hideSticky();
    }).observe(document.body, { attributes: true, attributeFilter: ['class'] });
    /* Theme events (cart:open, cart:refresh — NOT cart:updated which is noisy) */
    ['cart:open', 'cart-drawer:open', 'drawer:open'].forEach(function(ev) {
      document.addEventListener(ev, _hideSticky);
    });
  }
  /* ── OpenSX70 Schematic — interactive hotspots + reveal animation ──
     - Click a hotspot dot or its bare label → opens the matching panel.
     - Clicking again or another label → closes the open one (single-active).
     - Clicking [ CLOSE ] → closes the panel without opening another.
     - On scroll-into-view, the section animates in: chapter intro reveals
       first, then the schematic frame slides up, then dots pulse once each
       (staggered), then leader lines fade in, then bare labels cascade.
     - The data-sx-sch-reveal attribute holds the per-element delay (ms).
     - Mobile (<900px) hides bare labels and uses a panel-stack-below pattern
       (CSS-controlled — JS doesn't change behavior, just classes).
     - In Shopify's theme editor (Shopify.designMode), all reveal animations
       are skipped (everything renders instantly) so merchants don't see
       the animation replay every time they change a setting.
  */
  (function() {
    var schEl = document.querySelector('.bfcsx [data-sx-sch]');
    if (!schEl) return;

    var isDesignMode = !!(window.Shopify && window.Shopify.designMode);

    /* In design mode: skip animations entirely. Mark everything visible
       upfront so merchants never see fade-in delays while editing. */
    if (isDesignMode) {
      schEl.classList.add('is-revealed');
      schEl.querySelectorAll('[data-sx-sch-reveal]').forEach(function(el) {
        el.classList.add('is-visible');
      });
    }

    /* ── Reveal-on-scroll (gates animations until section is in view) ── */
    var revealTargets = schEl.querySelectorAll('[data-sx-sch-reveal]');
    if (!isDesignMode) {
      var schemaObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(en) {
          if (!en.isIntersecting) return;
          var el = en.target;
          var delay = parseInt(el.getAttribute('data-sx-sch-reveal'), 10) || 0;
          setTimeout(function() { el.classList.add('is-visible'); }, delay);
          schemaObserver.unobserve(el);
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
      revealTargets.forEach(function(el) { schemaObserver.observe(el); });
    }

    /* ── Schematic frame — reveal labels + dots + lines together ──
       The frame element itself has data-sx-sch-reveal=380. After that
       fires, we add .is-revealed to the root section, which CSS uses
       to fade in labels and lines. We also briefly add .is-pulsing
       to trigger the one-time hotspot pulse animation. */
    var frameEl = schEl.querySelector('.sx-sch-frame');
    if (frameEl && !isDesignMode) {
      var frameObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(en) {
          if (!en.isIntersecting) return;
          /* Stage 1 (~600ms after frame): pulse the dots */
          setTimeout(function() {
            schEl.classList.add('is-pulsing');
          }, 980);
          setTimeout(function() {
            schEl.classList.remove('is-pulsing');
          }, 980 + 1800);
          /* Stage 2 (~800ms after frame): reveal labels + leader lines */
          setTimeout(function() {
            schEl.classList.add('is-revealed');
          }, 1180);
          /* Stage 3 (auto-preview, optional): if the merchant enabled
             schematic_auto_preview, briefly open each hotspot in sequence
             so the customer sees component names without clicking. Each
             hotspot stays open ~900ms before the next opens; the last one
             closes after ~1100ms. Total preview duration scales with the
             number of hotspots. The preview cancels itself if the user
             interacts with any hotspot mid-cycle. */
          var autoPreview = schEl.getAttribute('data-sx-sch-auto-preview') === 'true';
          if (autoPreview) {
            var hotspots = schEl.querySelectorAll('.sx-sch-dot[data-sx-sch-target]');
            var stepMs = 900;
            var startDelay = 2200; /* wait for reveal + pulse to settle */
            var previewTimers = [];
            var cancelPreview = function() {
              previewTimers.forEach(function(t) { clearTimeout(t); });
              previewTimers = [];
              schEl.removeEventListener('click', cancelPreview, true);
            };
            schEl.addEventListener('click', cancelPreview, true);

            hotspots.forEach(function(dot, i) {
              var tid = dot.getAttribute('data-sx-sch-target');
              if (!tid) return;
              previewTimers.push(setTimeout(function() {
                openTarget(tid);
              }, startDelay + i * stepMs));
            });
            /* Close all after the last preview has shown for ~1100ms. */
            previewTimers.push(setTimeout(function() {
              closeAll();
              schEl.removeEventListener('click', cancelPreview, true);
            }, startDelay + hotspots.length * stepMs + 200));
          }
          frameObserver.unobserve(frameEl);
        });
      }, { threshold: 0.2, rootMargin: '0px 0px -60px 0px' });
      frameObserver.observe(frameEl);
    }

    /* ── Click handlers: open / close panels ── */
    var allDots   = schEl.querySelectorAll('[data-sx-sch-target]');
    var allPanels = schEl.querySelectorAll('[data-sx-sch-panel]');

    function closeAll() {
      allPanels.forEach(function(p) {
        p.classList.remove('is-open');
        p.setAttribute('aria-hidden', 'true');
      });
      allDots.forEach(function(d) { d.classList.remove('is-active'); });
      schEl.querySelectorAll('.sx-sch-label[aria-expanded="true"]').forEach(function(b) {
        b.setAttribute('aria-expanded', 'false');
      });
      /* Clear all active leader lines — fades them back to static. */
      schEl.querySelectorAll('.sx-sch-line.is-line-active').forEach(function(l) {
        l.classList.remove('is-line-active');
      });
    }

    function openTarget(targetId) {
      var panel = schEl.querySelector('[data-sx-sch-panel="' + targetId + '"]');
      if (!panel) return;
      var alreadyOpen = panel.classList.contains('is-open');
      closeAll();
      if (alreadyOpen) return;  /* clicking the same one closes it */
      panel.classList.add('is-open');
      panel.setAttribute('aria-hidden', 'false');
      /* Mark the matching dot as active */
      var matchingDot = schEl.querySelector('.sx-sch-dot[data-sx-sch-target="' + targetId + '"]');
      if (matchingDot) matchingDot.classList.add('is-active');
      /* Mark the matching label as expanded */
      var matchingLabel = schEl.querySelector('.sx-sch-label[data-sx-sch-target="' + targetId + '"]');
      if (matchingLabel) matchingLabel.setAttribute('aria-expanded', 'true');
      /* Activate the leader line — triggers the dashed draw-in animation.
         We set is-line-active in a microtask so that if the same line was
         just removed by closeAll(), the browser sees a state change and
         restarts the animation rather than skipping it. */
      var matchingLine = schEl.querySelector('.sx-sch-line[data-sx-sch-line="' + targetId + '"]');
      if (matchingLine) {
        /* Force reflow so animation restarts cleanly between hotspots */
        void matchingLine.offsetWidth;
        matchingLine.classList.add('is-line-active');
      }
    }

    allDots.forEach(function(el) {
      el.addEventListener('click', function(ev) {
        ev.preventDefault();
        var tid = el.getAttribute('data-sx-sch-target');
        if (tid) openTarget(tid);
      });
    });

    schEl.querySelectorAll('[data-sx-sch-close]').forEach(function(el) {
      el.addEventListener('click', function(ev) {
        ev.preventDefault();
        ev.stopPropagation();
        closeAll();
      });
    });

    /* Click outside any hotspot/panel → close (desktop only — on mobile the
       panels are inline below the photo so closing via outside-click is less
       discoverable, but doesn't hurt to keep the behavior). */
    document.addEventListener('click', function(ev) {
      if (!schEl.contains(ev.target)) {
        closeAll();
        return;
      }
      var inHotspot = ev.target.closest('[data-sx-sch-target], [data-sx-sch-panel], [data-sx-sch-close]');
      if (!inHotspot) closeAll();
    });

    /* Escape key → close any open panel */
    document.addEventListener('keydown', function(ev) {
      if (ev.key === 'Escape') closeAll();
    });

    /* ── Open by default (theme editor convenience) ──
       Each hotspot block has an "Open by default" checkbox. When set,
       its dot/label/panel get the data-sx-sch-default-open="true" flag
       in the rendered HTML. We open the first such panel here on initial
       page load. Lets merchants pin a panel open while they edit it
       without fighting Shopify's section re-renders. */
    var defaultOpenEl = schEl.querySelector('[data-sx-sch-default-open="true"]');
    if (defaultOpenEl) {
      var targetId = defaultOpenEl.getAttribute('data-sx-sch-target')
                  || defaultOpenEl.getAttribute('data-sx-sch-panel');
      if (targetId) {
        /* Brief delay so the open transition runs visibly rather than
           appearing pre-opened with no animation. */
        setTimeout(function() { openTarget(targetId); }, 50);
      }
    }
  })();

})();
</script>

<script>
/* ─── STICKY TOP-LEVEL TOC — section tracking + smooth scroll ─── */
(function() {
  var toc = document.getElementById('sx-toc');
  if (!toc) return;
  var anchors = ['top', 'chapter', 'specs', 'reviews'];
  var sections = anchors
    .map(function(id) { return { id: id, el: document.getElementById('sx-' + id) }; })
    .filter(function(s) { return s.el; });

  function setActive(id) {
    toc.querySelectorAll('a[data-toc]').forEach(function(a) {
      a.classList.toggle('is-active', a.dataset.toc === id);
    });
  }

  function getThemeHeaderHeight() {
    var selectors = [
      'sticky-header', '.shopify-section-header-sticky',
      'header.shopify-section', 'header.site-header',
      '.header-wrapper', 'header[role="banner"]', '.section-header'
    ];
    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (el) {
        var pos = getComputedStyle(el).position;
        if (pos === 'fixed' || pos === 'sticky') {
          var h = el.offsetHeight;
          if (h > 0 && h < 200) return h;
        }
      }
    }
    return 0;
  }

  var themeHeaderHeight = 0;
  function refreshHeaderOffset() {
    themeHeaderHeight = getThemeHeaderHeight();
    toc.style.top = (themeHeaderHeight > 0 ? themeHeaderHeight - 1 : 0) + 'px';
  }

  // Overview tab → absolute page top (no offset gap). Others use offset.
  toc.querySelectorAll('a[data-toc]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.getElementById('sx-' + a.dataset.toc);
      if (!target) return;
      e.preventDefault();
      if (a.dataset.toc === 'top') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      var offset = (toc.offsetHeight || 48) + themeHeaderHeight + 12;
      var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: top, behavior: 'smooth' });
    });
  });

  var topEl = document.getElementById('sx-top');

  function isOverlayOpen() {
    var bodyClasses = document.body.className || '';
    if (/\b(cart-drawer-open|drawer-open|is-cart-open|drawer--open|overlay-open|modal-open|js-drawer-open|cart-open)\b/.test(bodyClasses)) return true;
    var drawer = document.querySelector(
      'cart-drawer[open], cart-notification[open], .cart-drawer.is-open, .cart-drawer.active, ' +
      '.cart-drawer.drawer--active, .drawer.is-active, .drawer.is-open, [data-cart-drawer].is-open, ' +
      'cart-drawer.active'
    );
    return !!drawer;
  }

  function updateTocVisibility() {
    if (isOverlayOpen()) {
      toc.classList.remove('is-visible');
      return;
    }
    if (!topEl) {
      toc.classList.toggle('is-visible', window.pageYOffset > 200);
      return;
    }
    var rect = topEl.getBoundingClientRect();
    toc.classList.toggle('is-visible', rect.bottom < themeHeaderHeight + 80);
  }

  function updateActiveSection() {
    if (!sections.length) return;
    var threshold = themeHeaderHeight + (toc.offsetHeight || 48) + 20;
    var current = sections[0].id;
    sections.forEach(function(s) {
      var rect = s.el.getBoundingClientRect();
      if (rect.top <= threshold) current = s.id;
    });
    setActive(current);
  }

  function onScroll() {
    updateTocVisibility();
    updateActiveSection();
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', function() { refreshHeaderOffset(); onScroll(); });
  if ('MutationObserver' in window) {
    new MutationObserver(onScroll).observe(document.body, { attributes: true, attributeFilter: ['class', 'style'] });
  }
  refreshHeaderOffset();
  onScroll();
  setTimeout(function() { refreshHeaderOffset(); onScroll(); }, 600);
})();

/* ─── IN-CHAPTER SUB-TABS — smooth scroll + active tracking within chapter ─── */
(function() {
  var subtoc = document.getElementById('sx-subtoc');
  if (!subtoc) return;
  var topToc = document.getElementById('sx-toc');
  var subIds = ['schematic', 'features', 'dongle', 'led-ref'];
  var subSections = subIds
    .map(function(id) { return { id: id, el: document.getElementById('sx-' + id) }; })
    .filter(function(s) { return s.el; });

  function setActiveSub(id) {
    subtoc.querySelectorAll('a[data-subtoc]').forEach(function(a) {
      a.classList.toggle('is-active', a.dataset.subtoc === id);
    });
  }

  subtoc.querySelectorAll('a[data-subtoc]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.getElementById('sx-' + a.dataset.subtoc);
      if (!target) return;
      e.preventDefault();
      // Auto-expand the chapter if collapsed (so the target is actually scrollable)
      var chBody = document.getElementById('sx-chapter-body');
      if (chBody && !chBody.classList.contains('is-open') && typeof window.sxToggleChapter === 'function') {
        window.sxToggleChapter();
      }
      var topTocH = (topToc && topToc.classList.contains('is-visible')) ? (topToc.offsetHeight || 48) : 0;
      var subtocH = subtoc.offsetHeight || 48;
      var offset = topTocH + subtocH + 12;
      var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: top, behavior: 'smooth' });
    });
  });

  function updateActiveSub() {
    if (!subSections.length) return;
    var topTocH = (topToc && topToc.classList.contains('is-visible')) ? (topToc.offsetHeight || 48) : 0;
    var subtocH = subtoc.offsetHeight || 48;
    var threshold = topTocH + subtocH + 20;
    var current = subSections[0].id;
    subSections.forEach(function(s) {
      var rect = s.el.getBoundingClientRect();
      if (rect.top <= threshold) current = s.id;
    });
    setActiveSub(current);
  }

  window.addEventListener('scroll', updateActiveSub, { passive: true });
  updateActiveSub();
})();

// Top TOC's ATC button mirrors the bottom sticky bar — both trigger the
// hidden product form via requestSubmit().
window.sxTocAddToCart = function() {
  var wrap = document.querySelector('.bfcsx');
  if (!wrap) return;
  var sectionId = wrap.dataset.sectionId;
  var form = document.getElementById('sxATC-' + sectionId);
  if (form && typeof form.requestSubmit === 'function') {
    var btn = document.getElementById('sx-toc-atc-text');
    if (btn) btn.textContent = 'Adding…';
    form.requestSubmit();
  }
};
</script>

