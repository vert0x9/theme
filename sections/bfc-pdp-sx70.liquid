          {%- if photo_2 != blank -%}
            <img src="{{ photo_2 | image_url: width: 800 }}"
                 srcset="{{ photo_2 | image_url: width: 400 }} 400w,
                         {{ photo_2 | image_url: width: 800 }} 800w,
                         {{ photo_2 | image_url: width: 1200 }} 1200w"
                 sizes="(max-width: 900px) 100vw, 380px"
                 alt="Sample frame 02" loading="lazy">
          {%- else -%}
            <div class="sx-summary-photo-placeholder"></div>
          {%- endif -%}
        </div>

        <div class="sx-summary-photo">
          <span class="sx-summary-photo-num">03</span>
          {%- if photo_3 != blank -%}
            <img src="{{ photo_3 | image_url: width: 800 }}"
                 srcset="{{ photo_3 | image_url: width: 400 }} 400w,
                         {{ photo_3 | image_url: width: 800 }} 800w,
                         {{ photo_3 | image_url: width: 1200 }} 1200w"
                 sizes="(max-width: 900px) 100vw, 380px"
                 alt="Sample frame 03" loading="lazy">
          {%- else -%}
            <div class="sx-summary-photo-placeholder"></div>
          {%- endif -%}
        </div>
