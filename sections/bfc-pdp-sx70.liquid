  {%- comment -%} ── KIT BUILDER ── {%- endcomment -%}
  <div class="sx-kit">
    <div class="sx-kit-inner">
      <span class="sx-kit-ey">Build Your Kit</span>
      <div class="sx-kit-title">Add What You Need</div>
      <div class="sx-kit-sub">Grab your film, flash, dongle, or any accessories — everything ships together.</div>

      {%- comment -%} Build column names from blocks. A block contributes a column
          if it has a product picked AND passes the only_show_for filter for this
          PDP. We only want columns that will actually have visible items —
          otherwise we render an empty column with just a header. {%- endcomment -%}
      {%- assign col_names = '' -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'kit_item' and block.settings.product != blank -%}
          {%- if block.settings.only_show_for == blank or block.settings.only_show_for.handle == product.handle -%}
            {%- assign block_col = block.settings.column | default: block.settings.label | default: 'Add-Ons' -%}
            {%- unless col_names contains block_col -%}
              {%- if col_names != '' -%}{%- assign col_names = col_names | append: '||' -%}{%- endif -%}
              {%- assign col_names = col_names | append: block_col -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign columns = col_names | split: '||' -%}

      {%- if columns.size > 0 -%}
        <div class="sx-kit-cols" style="grid-template-columns: repeat({{ columns.size | at_most: 4 }}, 1fr);">
          {%- for col_name in columns -%}
            <div class="sx-kit-col">
              <div class="sx-kit-col-head">{{ col_name }}</div>
              {%- for block in section.blocks -%}
                {%- if block.type == 'kit_item' and block.settings.product != blank -%}
                  {%- if block.settings.only_show_for == blank or block.settings.only_show_for.handle == product.handle -%}
                    {%- assign block_col = block.settings.column | default: block.settings.label | default: 'Add-Ons' -%}
                    {%- if block_col == col_name -%}
                      {%- comment -%} Pick the best available product: primary, then alt 1, then alt 2.
                          Previously, if all three were OOS the block was silently skipped — confusing
                          for merchants who configured items that weren't appearing. Now we render
                          the primary product even if OOS, with a visible 'Sold Out' state, so the
                          tile is at least visible and explanatory. {%- endcomment -%}
                      {%- assign kit_prod = block.settings.product -%}
                      {%- unless kit_prod.available -%}
                        {%- if block.settings.product_alt_1 != blank and block.settings.product_alt_1.available -%}
                          {%- assign kit_prod = block.settings.product_alt_1 -%}
                        {%- elsif block.settings.product_alt_2 != blank and block.settings.product_alt_2.available -%}
                          {%- assign kit_prod = block.settings.product_alt_2 -%}
                        {%- endif -%}
                      {%- endunless -%}
                      {%- assign kit_var = kit_prod.selected_or_first_available_variant | default: kit_prod.variants.first -%}
                      {%- assign tile_oos = false -%}
                      {%- unless kit_prod.available -%}{%- assign tile_oos = true -%}{%- endunless -%}
                      <div class="sx-kit-tile{% if tile_oos %} is-oos{% endif %}"
                           data-variant-id="{{ kit_var.id }}"
                           data-price="{{ kit_var.price }}"
                           {% if tile_oos %}data-oos="true" aria-disabled="true"{% endif %}
                           {{ block.shopify_attributes }}>
                        {%- if kit_prod.featured_image != blank -%}
                          <img class="sx-kit-tile-img" src="{{ kit_prod.featured_image | image_url: width: 96 }}" alt="{{ kit_prod.title }}" loading="lazy">
                        {%- endif -%}
                        <div class="sx-kit-tile-info">
                          <div class="sx-kit-tile-name">{{ block.settings.label | default: kit_prod.title }}</div>
                          <div class="sx-kit-tile-price">
                            {%- if tile_oos -%}
                              Sold Out
                            {%- else -%}
                              {{ kit_var.price | money }}
                            {%- endif -%}
                          </div>
                        </div>
                        <div class="sx-kit-tile-check"></div>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        {%- comment -%} No kit_item blocks configured (or all filtered out by only_show_for).
            Surface a merchant-only hint so this isn't silently empty. Customers won't
            see anything because of the request.design_mode check — only the theme editor
            shows this. {%- endcomment -%}
        {%- if request.design_mode -%}
          <div style="padding:24px;background:rgba(227,110,21,0.08);border:1px dashed var(--or);font-size:12px;color:var(--ch);line-height:1.5;">
            <strong>No kit items configured for this product.</strong><br/>
            Add kit items via Theme Editor → this section → "Add Kit Item". Each block needs a Product, a Column name (e.g. "Film"), and the "Only show for product" field can be left blank to show on every SX-70 PDP.
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

