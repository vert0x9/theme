{%- comment -%}
============================================================
  BFC Unlisted / Discontinued Product PDP
  bfc-pdp-unlisted.liquid
  ------------------------------------------------------------
  For products we no longer carry. Shows:
    - Product image + title with "no longer available" state
    - Auto-detected similar collections based on product type/tags
    - Featured collections grid pulled from schema settings as fallback
============================================================
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/></noscript>

{%- comment -%}
  Auto-detect relevant collections from product type and tags.
  We look for collections whose handle or title contains the product type
  or any of the product's tags.
{%- endcomment -%}
{%- assign pt_lower = product.type | downcase | strip -%}
{%- assign auto_cols = '' -%}
{%- assign auto_col_list = '' | split: ',' -%}

{%- comment -%} Build a deduplicated list of collections that match the product type or tags {%- endcomment -%}
{%- for col in collections -%}
  {%- assign col_handle_lower = col.handle | downcase -%}
  {%- assign col_title_lower = col.title | downcase -%}
  {%- assign is_match = false -%}

  {%- comment -%} Match on product type {%- endcomment -%}
  {%- if pt_lower != blank -%}
    {%- if col_handle_lower contains pt_lower or col_title_lower contains pt_lower -%}
      {%- assign is_match = true -%}
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} Match on tags {%- endcomment -%}
  {%- unless is_match -%}
    {%- for tag in product.tags -%}
      {%- assign tag_lower = tag | downcase | strip -%}
      {%- if col_handle_lower contains tag_lower or col_title_lower contains tag_lower -%}
        {%- assign is_match = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endunless -%}

  {%- comment -%} Skip "all", "frontpage", hidden or catch-all collections {%- endcomment -%}
  {%- if col.handle == 'all' or col.handle == 'frontpage' or col.handle == 'unlisted' or col.handle == 'discontinued' -%}
    {%- assign is_match = false -%}
  {%- endif -%}

  {%- if is_match and col.products_count > 0 -%}
    {%- assign auto_col_list = auto_col_list | push: col -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Schema fallback collections {%- endcomment -%}
{%- assign fb1 = section.settings.fallback_col_1 -%}
{%- assign fb2 = section.settings.fallback_col_2 -%}
{%- assign fb3 = section.settings.fallback_col_3 -%}
{%- assign fb4 = section.settings.fallback_col_4 -%}

{%- comment -%}
  ── SEE SIMILAR: brand-name to collection mapping ──────────────
  Maps the product's vendor/brand (and type as a fallback) to a
  destination collection handle. Camera brands map to "cameras".
  Edit the map_pairs string to add more mappings. Format:
    "matchword:collection-handle"  comma separated.
  Matching is substring based and case insensitive against the
  product's vendor first, then its type.
{%- endcomment -%}
{%- assign map_pairs = section.settings.brand_map | default: "yashica:cameras,canon:cameras,nikon:cameras,minolta:cameras,olympus:cameras,pentax:cameras,leica:cameras,contax:cameras,konica:cameras,ricoh:cameras,fujifilm:cameras,fuji:cameras,kodak:cameras,polaroid:cameras,hasselblad:cameras,mamiya:cameras,bronica:cameras,rollei:cameras,voigtlander:cameras,film:film,lens:lenses,lenses:lenses,flash:accessories,accessory:accessories" -%}

{%- assign similar_col = blank -%}
{%- assign vendor_lower = product.vendor | downcase | strip -%}
{%- assign type_lower = product.type | downcase | strip -%}
{%- assign map_list = map_pairs | split: ',' -%}

{%- comment -%} Try vendor match first, then type match {%- endcomment -%}
{%- for pair in map_list -%}
  {%- assign kv = pair | split: ':' -%}
  {%- assign matchword = kv[0] | downcase | strip -%}
  {%- assign target_handle = kv[1] | strip -%}
  {%- if matchword != blank and target_handle != blank -%}
    {%- if vendor_lower contains matchword -%}
      {%- assign similar_col = collections[target_handle] -%}
      {%- break -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if similar_col == blank -%}
  {%- for pair in map_list -%}
    {%- assign kv = pair | split: ':' -%}
    {%- assign matchword = kv[0] | downcase | strip -%}
    {%- assign target_handle = kv[1] | strip -%}
    {%- if matchword != blank and target_handle != blank -%}
      {%- if type_lower contains matchword -%}
        {%- assign similar_col = collections[target_handle] -%}
        {%- break -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%} Fall back to first auto-detected collection if no map hit {%- endcomment -%}
{%- if similar_col == blank or similar_col.products_count == 0 -%}
  {%- assign similar_col = auto_col_list | first -%}
{%- endif -%}

<style>
.bfcu *, .bfcu *::before, .bfcu *::after { box-sizing: border-box; margin: 0; padding: 0; }
.bfcu {
  --or: #E36E15;
  --go: #F4A027;
  --ce: #ABCC99;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sr: 'Cormorant Garamond', Georgia, serif;
  --sn: 'Poppins', sans-serif;
  --t: 0.2s ease;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
}

/* ── BREADCRUMBS ─────────────────────────────────── */
.bfcu-crumbs {
  font-size: 10px; font-weight: 500; letter-spacing: 0.06em;
  text-transform: uppercase; color: rgba(32,32,9,0.5);
}
.bfcu-crumbs a { color: inherit; text-decoration: none; transition: color var(--t); }
.bfcu-crumbs a:hover { color: var(--or); }
.bfcu-crumbs-sep { margin: 0 8px; opacity: 0.35; }
.bfcu-crumbs-current { color: var(--bk); font-weight: 500; }

/* ── HERO SPLIT ──────────────────────────────────── */
.bfcu-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 70vh;
  align-items: stretch;
}

/* ── LEFT: faded product image ───────────────────── */
.bfcu-left {
  position: relative;
  background: var(--gr);
  overflow: hidden;
}
.bfcu-img-wrap {
  width: 100%; height: 100%;
  display: block;
}
.bfcu-img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0.45;
  filter: grayscale(40%);
}
.bfcu-img-none {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(32,32,9,0.2);
}
/* Diagonal "sold out" stamp over the image */
.bfcu-stamp {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) rotate(-18deg);
  font-family: var(--sn);
  font-size: 13px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(32,32,9,0.18);
  border: 2px solid rgba(32,32,9,0.12);
  padding: 8px 18px;
  white-space: nowrap;
  pointer-events: none;
  user-select: none;
}

/* ── RIGHT: copy + CTAs ──────────────────────────── */
.bfcu-right {
  background: var(--cv);
  padding: 56px 48px 56px 52px;
  display: flex; flex-direction: column;
  justify-content: center;
  gap: 0;
}
.bfcu-eyebrow {
  font-size: 10px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--ch); opacity: 0.5;
  margin-bottom: 12px;
}
.bfcu-title {
  font-family: var(--sn);
  font-size: 32px; font-weight: 600; line-height: 1.1;
  letter-spacing: -0.3px;
  color: rgba(32,32,9,0.35);
  margin-bottom: 20px;
}
.bfcu-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(32,32,9,0.06);
  padding: 8px 14px;
  font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--ch);
  margin-bottom: 28px;
  width: fit-content;
}
.bfcu-badge svg { flex-shrink: 0; opacity: 0.5; }
.bfcu-message {
  font-size: 14px; line-height: 1.65; color: var(--ch);
  margin-bottom: 32px;
  max-width: 44ch;
}
.bfcu-message strong { color: var(--bk); font-weight: 600; }

/* ── CTA GROUP ───────────────────────────────────── */
.bfcu-ctas {
  display: flex; flex-direction: column; gap: 8px;
  margin-bottom: 32px;
}
.bfcu-cta-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--ch);
  margin-bottom: 4px;
}
.bfcu-cta-btns { display: flex; flex-wrap: wrap; gap: 8px; }
.bfcu-cta-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 22px;
  background: var(--bk); color: #fff;
  font-family: var(--sn); font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  text-decoration: none;
  transition: background var(--t);
  border: none; cursor: pointer;
}
.bfcu-cta-btn:hover { background: var(--or); }
.bfcu-cta-btn.is-secondary {
  background: transparent;
  color: var(--bk);
  border: 1px solid rgba(32,32,9,0.2);
}
.bfcu-cta-btn.is-secondary:hover { border-color: var(--or); color: var(--or); background: transparent; }
.bfcu-cta-btn svg { flex-shrink: 0; }

/* ── DIVIDER ─────────────────────────────────────── */
.bfcu-divider {
  width: 40px; height: 1px;
  background: rgba(32,32,9,0.15);
  margin-bottom: 24px;
}

/* ── SEE SIMILAR (inline rail) ───────────────────── */
.bfcu-similar {
  margin-top: 4px;
  border-top: 1px solid rgba(32,32,9,0.08);
  padding-top: 22px;
}
.bfcu-similar-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--ch);
  margin-bottom: 14px; display: block;
}
.bfcu-similar-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}
.bfcu-similar-card {
  display: flex; flex-direction: column;
  background: #fff; border: 1px solid rgba(32,32,9,0.08);
  text-decoration: none; color: var(--bk);
  transition: border-color var(--t);
}
.bfcu-similar-card:hover { border-color: var(--or); }
.bfcu-similar-img-wrap {
  aspect-ratio: 1/1; background: var(--gr); overflow: hidden;
}
.bfcu-similar-img {
  width: 100%; height: 100%; object-fit: contain; display: block;
  transition: transform 0.35s ease;
}
.bfcu-similar-card:hover .bfcu-similar-img { transform: scale(1.04); }
.bfcu-similar-body { padding: 8px 10px 10px; }
.bfcu-similar-name {
  font-size: 10px; font-weight: 600; line-height: 1.3;
  overflow: hidden; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  margin-bottom: 3px;
}
.bfcu-similar-price { font-size: 10px; font-weight: 700; color: var(--or); }
.bfcu-similar-all {
  display: inline-block; margin-top: 14px;
  font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--or); text-decoration: none;
}
.bfcu-similar-all:hover { text-decoration: underline; text-underline-offset: 3px; }

/* ── COLLECTIONS SECTION ─────────────────────────── */
.bfcu-shop {
  padding: 64px 48px 72px;
  border-top: 1px solid rgba(32,32,9,0.08);
  background: var(--cv);
}
.bfcu-shop-head {
  margin-bottom: 36px;
}
.bfcu-shop-eyebrow {
  display: block;
  font-size: 10px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--or);
  margin-bottom: 10px;
}
.bfcu-shop-title {
  font-family: var(--sr);
  font-size: 42px; font-weight: 300; line-height: 1;
  color: var(--bk);
}
.bfcu-shop-sub {
  font-size: 13px; color: var(--ch); line-height: 1.6;
  margin-top: 10px; max-width: 60ch;
}
.bfcu-cols-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 12px;
}
.bfcu-col-card {
  display: block; text-decoration: none; color: var(--bk);
  background: #fff;
  border: 1px solid rgba(32,32,9,0.08);
  overflow: hidden;
  transition: border-color var(--t), transform var(--t);
  position: relative;
}
.bfcu-col-card:hover { border-color: var(--or); transform: translateY(-2px); }
.bfcu-col-img-wrap {
  aspect-ratio: 4/3;
  overflow: hidden;
  background: var(--gr);
}
.bfcu-col-img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.4s ease;
}
.bfcu-col-card:hover .bfcu-col-img { transform: scale(1.04); }
.bfcu-col-img-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(32,32,9,0.2);
}
.bfcu-col-body {
  padding: 16px 18px 18px;
  display: flex; align-items: center; justify-content: space-between; gap: 8px;
}
.bfcu-col-info { flex: 1; min-width: 0; }
.bfcu-col-title {
  font-family: var(--sn);
  font-size: 13px; font-weight: 600; line-height: 1.2;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.bfcu-col-count {
  font-size: 10px; color: var(--ch); margin-top: 2px;
}
.bfcu-col-arrow {
  flex-shrink: 0;
  width: 28px; height: 28px;
  border: 1px solid rgba(32,32,9,0.12);
  display: flex; align-items: center; justify-content: center;
  color: var(--bk); transition: border-color var(--t), background var(--t), color var(--t);
}
.bfcu-col-card:hover .bfcu-col-arrow {
  border-color: var(--or);
  background: var(--or);
  color: #fff;
}

/* ── PRODUCT SAMPLES ─────────────────────────────── */
.bfcu-samples {
  padding: 0 48px 72px;
}
.bfcu-samples-head {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 24px;
}
.bfcu-samples-title {
  font-family: var(--sr); font-size: 32px; font-weight: 300;
  color: var(--bk);
}
.bfcu-samples-link {
  font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--or);
  text-decoration: none;
}
.bfcu-samples-link:hover { text-decoration: underline; text-underline-offset: 3px; }
.bfcu-samples-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}
.bfcu-sample-card {
  display: flex; flex-direction: column;
  background: #fff; border: 1px solid rgba(32,32,9,0.08);
  text-decoration: none; color: var(--bk);
  transition: border-color var(--t);
}
.bfcu-sample-card:hover { border-color: rgba(32,32,9,0.22); }
.bfcu-sample-img-wrap {
  aspect-ratio: 1/1; background: var(--gr); overflow: hidden;
}
.bfcu-sample-img {
  width: 100%; height: 100%; object-fit: contain; display: block;
  transition: transform 0.35s ease;
}
.bfcu-sample-card:hover .bfcu-sample-img { transform: scale(1.04); }
.bfcu-sample-body { padding: 10px 12px 12px; }
.bfcu-sample-name {
  font-size: 11px; font-weight: 600; line-height: 1.3;
  overflow: hidden; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  margin-bottom: 4px;
}
.bfcu-sample-price { font-size: 11px; font-weight: 700; color: var(--or); }

/* ── DESCRIPTION ─────────────────────────────────── */
.bfcu-desc {
  border-top: 1px solid rgba(32,32,9,0.08);
  padding-top: 20px;
  margin-top: 4px;
}
.bfcu-desc-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--ch);
  margin-bottom: 10px; display: block;
}
.bfcu-desc-body {
  font-size: 12px; line-height: 1.65; color: var(--ch);
  opacity: 0.65;
}
.bfcu-desc-body p { margin: 0 0 8px; }
.bfcu-desc-body p:last-child { margin: 0; }
.bfcu-desc-body a { color: var(--or); }
.bfcu-desc-body ul, .bfcu-desc-body ol { padding-left: 18px; margin: 0 0 8px; }

/* ── YOU MAY ALSO LIKE ───────────────────────────── */
.bfcu-also {
  border-top: 1px solid rgba(32,32,9,0.08);
  padding: 56px 48px 64px;
  background: var(--cv);
  overflow: hidden;
}
.bfcu-also-head {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 28px;
}
.bfcu-also-title {
  font-family: var(--sr); font-size: 40px; font-weight: 300;
  line-height: 1; color: var(--bk);
}
.bfcu-also-link {
  font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--or); text-decoration: none;
}
.bfcu-also-link:hover { text-decoration: underline; text-underline-offset: 3px; }
.bfcu-also-track-wrap { position: relative; }
.bfcu-also-track {
  display: flex; gap: 12px;
  overflow-x: auto; scroll-behavior: smooth;
  scrollbar-width: none; -ms-overflow-style: none;
  padding: 0 2px;
}
.bfcu-also-track::-webkit-scrollbar { display: none; }
.bfcu-also-card {
  flex-shrink: 0; width: 200px;
  background: #fff; border: 1px solid rgba(32,32,9,0.08);
  text-decoration: none; color: var(--bk);
  display: flex; flex-direction: column;
  transition: border-color var(--t);
}
.bfcu-also-card:hover { border-color: rgba(32,32,9,0.25); }
.bfcu-also-img-wrap { aspect-ratio: 1/1; overflow: hidden; background: var(--gr); }
.bfcu-also-img-wrap img {
  width: 100%; height: 100%; object-fit: contain;
  display: block; transition: transform 0.4s ease;
}
.bfcu-also-card:hover .bfcu-also-img-wrap img { transform: scale(1.04); }
.bfcu-also-body { padding: 12px 12px 14px; display: flex; flex-direction: column; gap: 3px; }
.bfcu-also-name {
  font-size: 11px; font-weight: 600; line-height: 1.3;
  overflow: hidden; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.bfcu-also-price { font-size: 12px; font-weight: 700; color: var(--or); }
.bfcu-also-arr {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: #fff; border: 1px solid rgba(32,32,9,0.12);
  width: 36px; height: 36px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  z-index: 2; transition: border-color var(--t), box-shadow var(--t);
  box-shadow: 0 2px 8px rgba(32,32,9,0.08);
}
.bfcu-also-arr:hover { border-color: var(--or); box-shadow: 0 2px 12px rgba(32,32,9,0.15); }
.bfcu-also-arr.is-prev { left: -4px; }
.bfcu-also-arr.is-next { right: -4px; }
.bfcu-also-arr[disabled] { opacity: 0.3; pointer-events: none; }

/* ── MOBILE ──────────────────────────────────────── */
@media (max-width: 900px) {
  .bfcu-split { grid-template-columns: 1fr; min-height: 0; }
  .bfcu-left { min-height: 60vw; }
  .bfcu-right { padding: 32px 20px 40px; justify-content: flex-start; }
  .bfcu-title { font-size: 24px; }
  .bfcu-shop { padding: 40px 20px 48px; }
  .bfcu-shop-title { font-size: 32px; }
  .bfcu-cols-grid { grid-template-columns: 1fr 1fr; }
  .bfcu-samples { padding: 0 20px 48px; }
  .bfcu-samples-grid { grid-template-columns: repeat(2, 1fr); }
  .bfcu-also { padding: 36px 20px 40px; }
  .bfcu-also-title { font-size: 28px; }
  .bfcu-also-card { width: 160px; }
  .bfcu-also-arr { display: none; }
  .bfcu-similar-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>

<div class="bfcu">

  {%- comment -%} Hero split {%- endcomment -%}
  <div class="bfcu-split">

    {%- comment -%} LEFT: faded product photo {%- endcomment -%}
    <div class="bfcu-left">
      <div class="bfcu-img-wrap">
        {%- if product.featured_image -%}
          <img class="bfcu-img"
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.title | escape }}"
            loading="eager"
            fetchpriority="high"/>
        {%- else -%}
          <div class="bfcu-img-none">No image</div>
        {%- endif -%}
      </div>
      <div class="bfcu-stamp">No longer available</div>
    </div>

    {%- comment -%} RIGHT: messaging + CTAs {%- endcomment -%}
    <div class="bfcu-right">

      {%- comment -%} Breadcrumbs {%- endcomment -%}
      <nav class="bfcu-crumbs" aria-label="Breadcrumb" style="margin-bottom:20px">
        <a href="/">Home</a>
        <span class="bfcu-crumbs-sep">/</span>
        {%- if product.collections.size > 0 -%}
          {%- assign first_col = product.collections | first -%}
          <a href="{{ first_col.url }}">{{ first_col.title }}</a>
          <span class="bfcu-crumbs-sep">/</span>
        {%- elsif product.type != blank -%}
          <a href="/collections/all?filter.p.product_type={{ product.type | url_encode }}">{{ product.type }}</a>
          <span class="bfcu-crumbs-sep">/</span>
        {%- endif -%}
        <span class="bfcu-crumbs-current">{{ product.title }}</span>
      </nav>

      {%- if product.type != blank -%}
        <p class="bfcu-eyebrow">{{ product.type }}</p>
      {%- endif -%}

      <h1 class="bfcu-title">{{ product.title }}</h1>

      <div class="bfcu-badge">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M6 4v2.5M6 8h.01" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        No longer available
      </div>

      <p class="bfcu-message">
        {{ section.settings.message | default: "We no longer carry this item, but we have plenty of similar cameras in stock. Browse below to find something you'll love." }}
      </p>

      {%- comment -%} Primary CTAs — shop link + contact {%- endcomment -%}
      <div class="bfcu-ctas">
        <p class="bfcu-cta-label">Find something similar</p>
        <div class="bfcu-cta-btns">
          {%- if auto_col_list.size > 0 -%}
            {%- assign cta_col = auto_col_list | first -%}
            <a class="bfcu-cta-btn" href="{{ cta_col.url }}">
              Shop {{ cta_col.title }}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </a>
          {%- elsif fb1 != blank -%}
            <a class="bfcu-cta-btn" href="{{ fb1.url }}">
              Shop {{ fb1.title }}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </a>
          {%- else -%}
            <a class="bfcu-cta-btn" href="/collections/all">
              Browse all cameras
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </a>
          {%- endif -%}
          <a class="bfcu-cta-btn is-secondary" href="mailto:hello@brooklynfilmcamera.com">
            Ask us for a rec
          </a>
        </div>
      </div>

      {%- comment -%}
        See similar — top sellers from the brand-mapped collection.
        Shows up to 6 available products, excluding the current item.
      {%- endcomment -%}
      {%- if similar_col != blank and similar_col.products_count > 0 -%}
        <div class="bfcu-similar">
          <span class="bfcu-similar-label">See similar</span>
          <div class="bfcu-similar-grid">
            {%- assign sim_shown = 0 -%}
            {%- for sp in similar_col.products -%}
              {%- if sp.id != product.id and sp.available and sim_shown < 6 -%}
                {%- assign sim_shown = sim_shown | plus: 1 -%}
                {%- assign sp_v = sp.selected_or_first_available_variant -%}
                <a class="bfcu-similar-card" href="{{ sp.url }}">
                  <div class="bfcu-similar-img-wrap">
                    {%- if sp.featured_image -%}
                      <img class="bfcu-similar-img" src="{{ sp.featured_image | image_url: width: 300 }}" alt="{{ sp.title | escape }}" loading="lazy" width="300" height="300"/>
                    {%- endif -%}
                  </div>
                  <div class="bfcu-similar-body">
                    <div class="bfcu-similar-name">{{ sp.title }}</div>
                    <div class="bfcu-similar-price">{{ sp_v.price | money }}</div>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if sim_shown > 0 -%}
            <a class="bfcu-similar-all" href="{{ similar_col.url }}">View all {{ similar_col.title | downcase }} &rsaquo;</a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if product.description != blank -%}
        <div class="bfcu-desc">
          <span class="bfcu-desc-label">About this camera</span>
          <div class="bfcu-desc-body">{{ product.description }}</div>
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%}
    Collections grid — auto-detected from product type/tags, with schema fallbacks.
    Shows up to 4 collections max.
  {%- endcomment -%}

  {%- assign display_cols = '' | split: ',' -%}
  {%- comment -%} Seed with the brand-mapped collection if present {%- endcomment -%}
  {%- if similar_col != blank and similar_col.products_count > 0 -%}
    {%- assign display_cols = display_cols | push: similar_col -%}
  {%- endif -%}
  {%- for col in auto_col_list limit: 4 -%}
    {%- assign in_list = false -%}
    {%- for dc in display_cols -%}
      {%- if dc.handle == col.handle -%}{%- assign in_list = true -%}{%- endif -%}
    {%- endfor -%}
    {%- unless in_list -%}
      {%- if display_cols.size < 4 -%}
        {%- assign display_cols = display_cols | push: col -%}
      {%- endif -%}
    {%- endunless -%}
  {%- endfor -%}
  {%- comment -%} Pad with schema fallbacks if we have fewer than 4 {%- endcomment -%}
  {%- for _i in (1..4) -%}
    {%- assign fb = blank -%}
    {%- if _i == 1 -%}{%- assign fb = fb1 -%}
    {%- elsif _i == 2 -%}{%- assign fb = fb2 -%}
    {%- elsif _i == 3 -%}{%- assign fb = fb3 -%}
    {%- elsif _i == 4 -%}{%- assign fb = fb4 -%}
    {%- endif -%}
    {%- if fb != blank and display_cols.size < 4 -%}
      {%- assign already = false -%}
      {%- for dc in display_cols -%}
        {%- if dc.handle == fb.handle -%}{%- assign already = true -%}{%- endif -%}
      {%- endfor -%}
      {%- unless already -%}
        {%- assign display_cols = display_cols | push: fb -%}
      {%- endunless -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if display_cols.size > 0 -%}
    <section class="bfcu-shop" aria-label="Shop similar">
      <div class="bfcu-shop-head">
        <span class="bfcu-shop-eyebrow">Still looking?</span>
        <h2 class="bfcu-shop-title">{{ section.settings.shop_heading }}</h2>
        {%- if section.settings.shop_sub != blank -%}
          <p class="bfcu-shop-sub">{{ section.settings.shop_sub }}</p>
        {%- endif -%}
      </div>
      <div class="bfcu-cols-grid">
        {%- for col in display_cols -%}
          <a class="bfcu-col-card" href="{{ col.url }}">
            <div class="bfcu-col-img-wrap">
              {%- assign col_img_product = col.products | first -%}
              {%- if col_img_product.featured_image -%}
                <img class="bfcu-col-img"
                  src="{{ col_img_product.featured_image | image_url: width: 600 }}"
                  alt="{{ col.title | escape }}"
                  loading="lazy"/>
              {%- else -%}
                <div class="bfcu-col-img-placeholder">{{ col.title }}</div>
              {%- endif -%}
            </div>
            <div class="bfcu-col-body">
              <div class="bfcu-col-info">
                <div class="bfcu-col-title">{{ col.title }}</div>
                <div class="bfcu-col-count">{{ col.products_count }} item{% if col.products_count != 1 %}s{% endif %}</div>
              </div>
              <div class="bfcu-col-arrow">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5h6M5 2l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
    Product samples — pulls up to 8 available products from the best-matched collection.
    Excludes the current (unlisted) product.
  {%- endcomment -%}
  {%- assign sample_col = similar_col -%}
  {%- if sample_col == blank -%}{%- assign sample_col = auto_col_list | first -%}{%- endif -%}
  {%- if sample_col == blank and fb1 != blank -%}{%- assign sample_col = fb1 -%}{%- endif -%}
  {%- if sample_col != blank -%}
    {%- assign sample_count = 0 -%}
    {%- for sp in sample_col.products -%}
      {%- if sp.id != product.id and sp.available -%}
        {%- assign sample_count = sample_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if sample_count > 0 -%}
      <section class="bfcu-also" aria-label="You may also like">
        <div class="bfcu-also-head">
          <h2 class="bfcu-also-title">You may also like</h2>
          <a class="bfcu-also-link" href="{{ sample_col.url }}">View all &rsaquo;</a>
        </div>
        <div class="bfcu-also-track-wrap">
          <button class="bfcu-also-arr is-prev" aria-label="Previous" onclick="bfcuAlsoSlide(-1)" disabled>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M8 2L4 6L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
          </button>
          <div class="bfcu-also-track" id="bfcu-also-track">
            {%- assign also_shown = 0 -%}
            {%- for sp in sample_col.products -%}
              {%- if sp.id != product.id and sp.available and also_shown < 12 -%}
                {%- assign also_shown = also_shown | plus: 1 -%}
                {%- assign sp_v = sp.selected_or_first_available_variant -%}
                <a class="bfcu-also-card" href="{{ sp.url }}">
                  <div class="bfcu-also-img-wrap">
                    {%- if sp.featured_image -%}
                      <img src="{{ sp.featured_image | image_url: width: 400 }}" alt="{{ sp.title | escape }}" loading="lazy" width="400" height="400"/>
                    {%- endif -%}
                  </div>
                  <div class="bfcu-also-body">
                    <div class="bfcu-also-name">{{ sp.title }}</div>
                    <div class="bfcu-also-price">{{ sp_v.price | money }}</div>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <button class="bfcu-also-arr is-next" aria-label="Next" onclick="bfcuAlsoSlide(1)">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4 2L8 6L4 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
          </button>
        </div>
      </section>
    {%- endif -%}
  {%- endif -%}

</div>

<script>
(function() {
  var track = document.getElementById('bfcu-also-track');
  if (!track) return;
  var prevBtn = document.querySelector('.bfcu-also-arr.is-prev');
  var nextBtn = document.querySelector('.bfcu-also-arr.is-next');
  function updateArrows() {
    if (prevBtn) prevBtn.disabled = track.scrollLeft <= 4;
    if (nextBtn) nextBtn.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 4;
  }
  window.bfcuAlsoSlide = function(dir) {
    track.scrollLeft += dir * 440;
    setTimeout(updateArrows, 350);
  };
  track.addEventListener('scroll', updateArrows, { passive: true });
  updateArrows();
})();
</script>

{% schema %}
{
  "name": "BFC Redirect Product",
  "tag": "section",
  "class": "bfc-redirect-section",
  "settings": [
    {
      "type": "header",
      "content": "Messaging"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Unavailable message",
      "default": "We no longer carry this item, but we have plenty of similar cameras in stock. Browse below to find something you'll love."
    },
    {
      "type": "textarea",
      "id": "brand_map",
      "label": "See similar brand mapping",
      "info": "Maps a product's brand or type to a collection handle for the See similar rail. Format: matchword:collection-handle, comma separated. Leave blank to use the built-in camera-brand defaults.",
      "default": "yashica:cameras,canon:cameras,nikon:cameras,minolta:cameras,olympus:cameras,pentax:cameras,leica:cameras,contax:cameras,konica:cameras,ricoh:cameras,fujifilm:cameras,fuji:cameras,kodak:cameras,polaroid:cameras,hasselblad:cameras,mamiya:cameras,bronica:cameras,rollei:cameras,voigtlander:cameras,film:film,lens:lenses,lenses:lenses,flash:accessories,accessory:accessories"
    },
    {
      "type": "header",
      "content": "Shop section"
    },
    {
      "type": "text",
      "id": "shop_heading",
      "label": "Section heading",
      "default": "Find something you'll love"
    },
    {
      "type": "text",
      "id": "shop_sub",
      "label": "Section subheading",
      "info": "Optional. Leave blank to hide."
    },
    {
      "type": "header",
      "content": "Fallback collections",
      "info": "Shown if no collections match the product's type or tags. Also used to pad the grid up to 4 columns."
    },
    {
      "type": "collection",
      "id": "fallback_col_1",
      "label": "Fallback collection 1"
    },
    {
      "type": "collection",
      "id": "fallback_col_2",
      "label": "Fallback collection 2"
    },
    {
      "type": "collection",
      "id": "fallback_col_3",
      "label": "Fallback collection 3"
    },
    {
      "type": "collection",
      "id": "fallback_col_4",
      "label": "Fallback collection 4"
    }
  ],
  "presets": [
    {
      "name": "BFC Unlisted Product"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
