                <label class="bfc-print__label">Color</label>
                <div class="bfc-print__color-row">
                  <div class="bfc-print__swatch bfc-print__swatch--white active" data-c="#FFFFFF" style="background:#FFFFFF;"></div>
                  <div class="bfc-print__swatch" data-c="#F5F0E8" style="background:#F5F0E8;"></div>
                  <div class="bfc-print__swatch" data-c="#E8E0D0" style="background:#E8E0D0;"></div>
                  <div class="bfc-print__swatch" data-c="#202009" style="background:#202009;"></div>
                  <div class="bfc-print__swatch" data-c="#4E4741" style="background:#4E4741;"></div>
                  <input type="color" class="bfc-print__custom-color" id="bfcCustomColor" value="#FFFFFF" title="Custom color">
                </div>
              </div>
            </div>
          </div>
          <div class="bfc-print__sidebar-section" style="flex:1;">
            <label class="bfc-print__label">Pricing</label>
            <div class="bfc-print__price-row">
              <span class="bfc-print__price-label">Base print</span>
              <span class="bfc-print__price-value" id="bfcBasePrice">$40.00</span>
            </div>
            <div class="bfc-print__price-row" id="bfcBorderPriceRow" style="display:none;">
              <span class="bfc-print__price-label">Border</span>
              <span class="bfc-print__price-value" id="bfcBorderPrice">$0.00</span>
            </div>
            <div class="bfc-print__price-total">
              <span class="bfc-print__price-total-label">Total</span>
              <span class="bfc-print__price-total-amount" id="bfcTotalPrice">$40.00</span>
            </div>
            <button class="bfc-print__atc" id="bfcAtcBtn" disabled>Upload an image first</button>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Cloudinary Upload Widget -->
<script src="https://upload-widget.cloudinary.com/global/all.js"></script>

<!-- Cropper.js — upload cropper.min.js to theme Assets -->
{{ 'cropper.min.js' | asset_url | script_tag }}

<script>
document.addEventListener('DOMContentLoaded', function() {

  /* ═══════════ CONFIG ═══════════ */
  const CLOUD_NAME = {{ section.settings.cloud_name | json }};
  const UPLOAD_PRESET = {{ section.settings.upload_preset | json }};
  const VARIANT_ID = {{ variant_id | json }};
  const PRICE_PER_STEP = {{ section.settings.price_per_step }};
  const STEP_SIZE = 2.5;

  /* ═══════════ STATE ═══════════ */
  let cropper = null;
  let fileUrl = '';      // Cloudinary URL
  let fileName = '';
  let natW = 0, natH = 0;
  let printW = 8, printH = 10;
  let orient = 'portrait';
  let borderOn = false, borderW = 0.5, borderC = '#FFFFFF';

  const $ = id => document.getElementById(id);

  /* ═══════════ CLOUDINARY UPLOAD ═══════════ */
  const widget = cloudinary.createUploadWidget({
    cloudName: CLOUD_NAME,
    uploadPreset: UPLOAD_PRESET,
    sources: ['local', 'camera'],
    multiple: false,
    maxFileSize: 100000000,
    clientAllowedFormats: ['jpg', 'jpeg', 'png', 'tiff', 'tif', 'webp'],
    showPoweredBy: false,
    styles: {
      palette: {
        window: '#F8F6EE',
        windowBorder: '#E3DDDA',
        tabIcon: '#E36E15',
        menuIcons: '#4E4741',
        textDark: '#202009',
        textLight: '#F8F6EE',
        link: '#E36E15',
        action: '#E36E15',
        inactiveTabIcon: '#4E4741',
        error: '#E65100',
        inProgress: '#E36E15',
        complete: '#2D8A4E',
        sourceBg: '#F8F6EE'
      }
    }
  }, (error, result) => {
    if (error) {
      console.error('Upload error:', error);
      $('bfcProgressText').textContent = 'Upload failed. Try again.';
      return;
    }
    if (result.event === 'upload-added') {
      $('bfcProgress').classList.add('visible');
      $('bfcProgressFill').style.width = '0%';
      $('bfcProgressText').textContent = 'Uploading...';
    }
    if (result.event === 'progress' && result.info) {
      $('bfcProgressFill').style.width = result.info.progress + '%';
      $('bfcProgressText').textContent = 'Uploading... ' + Math.round(result.info.progress) + '%';
    }
    if (result.event === 'success') {
      fileUrl = result.info.secure_url;
      fileName = result.info.original_filename + '.' + result.info.format;
      natW = result.info.width;
      natH = result.info.height;
      $('bfcProgress').classList.remove('visible');
      initCropper(fileUrl);
    }
  });

  /* Also support drag-and-drop + click on our custom zone */
  $('bfcUploadZone').addEventListener('click', () => widget.open());
  $('bfcUploadZone').addEventListener('dragover', e => { e.preventDefault(); $('bfcUploadZone').classList.add('dragover'); });
  $('bfcUploadZone').addEventListener('dragleave', () => $('bfcUploadZone').classList.remove('dragover'));
  $('bfcUploadZone').addEventListener('drop', e => {
    e.preventDefault();
    $('bfcUploadZone').classList.remove('dragover');
    /* For drag-and-drop, fall back to direct file input since widget.open() won't accept drops */
    if (e.dataTransfer.files.length) {
      handleLocalFile(e.dataTransfer.files[0]);
    }
  });
  $('bfcChangeBtn').addEventListener('click', () => widget.open());

  /* Fallback: direct file upload via hidden input (for drag-and-drop) */
  $('bfcFileInput').addEventListener('change', e => {
    if (e.target.files.length) handleLocalFile(e.target.files[0]);
  });

  function handleLocalFile(file) {
    /* Upload to Cloudinary via unsigned upload API */
    if (!file.type.startsWith('image/')) return;
    $('bfcProgress').classList.add('visible');
    $('bfcProgressFill').style.width = '10%';
    $('bfcProgressText').textContent = 'Uploading...';

    const fd = new FormData();
    fd.append('file', file);
    fd.append('upload_preset', UPLOAD_PRESET);

    fetch('https://api.cloudinary.com/v1_1/' + CLOUD_NAME + '/image/upload', {
      method: 'POST',
      body: fd
    })
    .then(r => r.json())
    .then(data => {
      if (data.secure_url) {
        fileUrl = data.secure_url;
        fileName = data.original_filename + '.' + data.format;
        natW = data.width;
        natH = data.height;
        $('bfcProgress').classList.remove('visible');
        initCropper(fileUrl);
      } else {
        throw new Error(data.error?.message || 'Upload failed');
      }
    })
    .catch(err => {
      console.error('Direct upload failed:', err);
      $('bfcProgressText').textContent = 'Upload failed: ' + err.message;
    });
  }

  /* ═══════════ CROPPER ═══════════ */
  function initCropper(src) {
    $('bfcUploadPanel').style.display = 'none';
    $('bfcCropPanel').style.display = 'block';
    $('bfcStep2').classList.remove('bfc-print__step--inactive');
    $('bfcS2Num').classList.remove('bfc-print__step-num--inactive');
    $('bfcS2Title').classList.remove('bfc-print__step-title--inactive');
    $('bfcAtcBtn').disabled = false;
    $('bfcAtcBtn').textContent = 'Add to Cart';

    $('bfcFileName').textContent = fileName;
    $('bfcFileMeta').textContent = natW + '\u00D7' + natH + 'px';

    if (cropper) { cropper.destroy(); cropper = null; }
    const imgEl = $('bfcCropImg');
    imgEl.onload = function() {
      cropper = new Cropper(imgEl, {
        aspectRatio: printW / printH,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 0.92,
        responsive: true,
        guides: true,
        center: true,
        highlight: true,
        cropBoxMovable: true,
        cropBoxResizable: false,
        toggleDragModeOnDblclick: false,
        ready: () => updateAll(),
        crop: debounce(() => updateAll(), 50),
      });
    };
    imgEl.crossOrigin = 'anonymous';
    imgEl.src = src;
  }

  /* ═══════════ RATIOS ═══════════ */
  $('bfcRatioGrid').addEventListener('click', e => {
    const btn = e.target.closest('.bfc-print__ratio-btn');
    if (!btn) return;
    $('bfcRatioGrid').querySelectorAll('.bfc-print__ratio-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const w = parseFloat(btn.dataset.w), h = parseFloat(btn.dataset.h);
    if (w === 0 && h === 0) {
      if (cropper) { cropper.setAspectRatio(NaN); cropper.options.cropBoxResizable = true; }
      return;
    }
    const pw = orient === 'portrait' ? Math.min(w,h) : Math.max(w,h);
    const ph = orient === 'portrait' ? Math.max(w,h) : Math.min(w,h);
    $('bfcPrintW').value = pw; $('bfcPrintH').value = ph;
    printW = pw; printH = ph;
    if (cropper) { cropper.setAspectRatio(pw/ph); cropper.options.cropBoxResizable = false; }
    updateAll();
  });

  /* ═══════════ ORIENTATION ═══════════ */
  document.querySelectorAll('.bfc-print__orient-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.bfc-print__orient-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      orient = btn.dataset.o;
      const w = parseFloat($('bfcPrintW').value), h = parseFloat($('bfcPrintH').value);
      if (orient === 'portrait' && w > h) { $('bfcPrintW').value = h; $('bfcPrintH').value = w; }
      else if (orient === 'landscape' && h > w) { $('bfcPrintW').value = h; $('bfcPrintH').value = w; }
      printW = parseFloat($('bfcPrintW').value); printH = parseFloat($('bfcPrintH').value);
      if (cropper) cropper.setAspectRatio(printW / printH);
      updateAll();
    });
  });

  /* ═══════════ MANUAL SIZE ═══════════ */
  [$('bfcPrintW'), $('bfcPrintH')].forEach(inp => {
    inp.addEventListener('input', () => {
      printW = parseFloat($('bfcPrintW').value) || 1;
      printH = parseFloat($('bfcPrintH').value) || 1;
      $('bfcRatioGrid').querySelectorAll('.bfc-print__ratio-btn').forEach(b => b.classList.remove('active'));
      if (cropper) cropper.setAspectRatio(printW / printH);
      updateAll();
    });
  });

  /* ═══════════ BORDER ═══════════ */
  $('bfcBorderToggle').addEventListener('click', () => {
    borderOn = !borderOn;
    $('bfcBorderToggle').classList.toggle('on', borderOn);
    $('bfcBorderControls').classList.toggle('visible', borderOn);
    $('bfcBorderPriceRow').style.display = borderOn ? 'flex' : 'none';
    updateAll();
  });

  $('bfcBorderW').addEventListener('input', () => {
    borderW = parseFloat($('bfcBorderW').value);
    const d = borderW % 1 === 0 ? borderW.toFixed(0) : borderW.toFixed(3).replace(/0+$/, '');
    $('bfcBorderWVal').textContent = d + '"';
    updateAll();
  });

  document.querySelectorAll('.bfc-print__swatch').forEach(s => {
    s.addEventListener('click', () => {
      document.querySelectorAll('.bfc-print__swatch').forEach(x => x.classList.remove('active'));
      s.classList.add('active');
      borderC = s.dataset.c;
      updateAll();
    });
  });

  $('bfcCustomColor').addEventListener('input', e => {
    document.querySelectorAll('.bfc-print__swatch').forEach(x => x.classList.remove('active'));
    borderC = e.target.value;
    updateAll();
  });

  /* ═══════════ PRICING ═══════════ */
  function calcPrice() {
    const wS = Math.ceil(printW / STEP_SIZE);
    const hS = Math.ceil(printH / STEP_SIZE);
    const base = (wS + hS) * PRICE_PER_STEP;
    let bs = 0;
    if (borderOn) {
      const tw = printW + borderW * 2, th = printH + borderW * 2;
      bs = (Math.ceil(tw / STEP_SIZE) + Math.ceil(th / STEP_SIZE)) * PRICE_PER_STEP - base;
    }
    return { base, bs, total: base + bs };
  }

  /* ═══════════ UPDATE ALL ═══════════ */
  function updateAll() {
    updatePreview();
    updateDPI();
    updatePricing();
  }

  function updatePreview() {
    if (!cropper) return;
    const d = cropper.getData(true);
    if (!d || !d.width) return;
    $('bfcPrevEmpty').style.display = 'none';
    $('bfcPrevFrame').style.display = 'block';

    const maxS = 320;
    const tW = borderOn ? printW + borderW * 2 : printW;
    const tH = borderOn ? printH + borderW * 2 : printH;
    const r = tW / tH;
    let cw, ch;
    if (r >= 1) { cw = maxS; ch = maxS / r; } else { ch = maxS; cw = maxS * r; }

    const cvs = $('bfcPrevCanvas'), ctx = cvs.getContext('2d');
    cvs.width = cw * 2; cvs.height = ch * 2;
    cvs.style.width = cw + 'px'; cvs.style.height = ch + 'px';
    ctx.scale(2, 2);

    if (borderOn) { ctx.fillStyle = borderC; ctx.fillRect(0, 0, cw, ch); }
    const bX = borderOn ? (borderW / tW) * cw : 0;
    const bY = borderOn ? (borderW / tH) * ch : 0;
    const iW = cw - bX * 2, iH = ch - bY * 2;

    try {
      const cc = cropper.getCroppedCanvas({
        width: 800,
        height: 800 / (d.width / d.height),
        imageSmoothingEnabled: true,
        imageSmoothingQuality: 'high'
      });
      if (cc) ctx.drawImage(cc, bX, bY, iW, iH);
      else {
        const imgEl = $('bfcCropImg');
        ctx.drawImage(imgEl, d.x, d.y, d.width, d.height, bX, bY, iW, iH);
      }
    } catch(e) {
      try { ctx.drawImage($('bfcCropImg'), d.x, d.y, d.width, d.height, bX, bY, iW, iH); } catch(e2) {}
    }

    if (borderOn) {
      ctx.strokeStyle = 'rgba(0,0,0,0.06)';
      ctx.lineWidth = 0.5;
      ctx.strokeRect(bX, bY, iW, iH);
    }
  }

  function updateDPI() {
    if (!cropper) { $('bfcDpiBar').className = 'bfc-print__dpi'; return; }
    const d = cropper.getData(true);
    if (!d || !d.width) return;
    const dpi = Math.min(d.width / printW, d.height / printH);
    const bar = $('bfcDpiBar');
    if (dpi < 150) {
      bar.className = 'bfc-print__dpi warn';
      bar.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><span>Low resolution \u2014 ' + Math.round(dpi) + ' DPI at ' + printW + '"&times;' + printH + '". May appear pixelated.</span>';
    } else {
      bar.className = 'bfc-print__dpi ok';
      const label = dpi >= 300 ? 'Excellent' : 'Acceptable';
      bar.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>' + label + ' \u2014 ' + Math.round(dpi) + ' DPI at ' + printW + '"&times;' + printH + '".</span>';
    }
  }

  function updatePricing() {
    const p = calcPrice();
    $('bfcBasePrice').textContent = '$' + p.base.toFixed(2);
    $('bfcBorderPrice').textContent = '+$' + p.bs.toFixed(2);
    $('bfcTotalPrice').textContent = '$' + p.total.toFixed(2);
  }

  /* ═══════════ ADD TO CART ═══════════ */
  $('bfcAtcBtn').addEventListener('click', () => {
    if (!cropper || !fileUrl) return;
    const d = cropper.getData(true);
    if (!d) return;
    const p = calcPrice();
    const dpi = Math.round(Math.min(d.width / printW, d.height / printH));

    const cropData = JSON.stringify({
      x: d.x, y: d.y, width: d.width, height: d.height,
      rotate: d.rotate || 0, scaleX: d.scaleX || 1, scaleY: d.scaleY || 1
    });

    $('bfcAtcBtn').disabled = true;
    $('bfcAtcBtn').textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: VARIANT_ID,
        quantity: 1,
        properties: {
          'Print Size': printW + '" \u00D7 ' + printH + '"',
          'Border': borderOn ? borderW + '" ' + (borderC === '#FFFFFF' ? 'White' : borderC === '#202009' ? 'Black' : borderC) : 'None',
          '_file_url': fileUrl,
          '_file_name': fileName,
          '_original_px': natW + ' \u00D7 ' + natH,
          '_crop_data': cropData,
          '_effective_dpi': String(dpi),
          '_border_width': String(borderOn ? borderW : 0),
          '_border_color': borderC,
          '_print_w': String(printW),
          '_print_h': String(printH),
          '_price_calculated': '$' + p.total.toFixed(2)
        }
      })
    })
    .then(r => {
      if (!r.ok) throw new Error('Cart error');
      return r.json();
    })
    .then(() => {
      $('bfcAtcBtn').textContent = 'Added to Cart';
      $('bfcAtcBtn').style.background = '#2D8A4E';
      /* Optional: redirect to cart or update cart drawer */
      setTimeout(() => {
        $('bfcAtcBtn').textContent = 'Add to Cart';
        $('bfcAtcBtn').style.background = '';
        $('bfcAtcBtn').disabled = false;
        /* Uncomment to redirect to cart: */
        /* window.location.href = '/cart'; */
      }, 2000);
    })
    .catch(err => {
      console.error('Add to cart failed:', err);
      $('bfcAtcBtn').textContent = 'Error - Try Again';
      $('bfcAtcBtn').style.background = '#E65100';
      setTimeout(() => {
        $('bfcAtcBtn').textContent = 'Add to Cart';
        $('bfcAtcBtn').style.background = '';
        $('bfcAtcBtn').disabled = false;
      }, 2500);
    });
  });

  /* ═══════════ INIT ═══════════ */
  updatePricing();

  function debounce(fn, ms) {
    let t;
    return function(...a) { clearTimeout(t); t = setTimeout(() => fn.apply(this, a), ms); };
  }

});
</script>

{% schema %}
{
  "name": "Print Configurator",
  "tag": "section",
  "class": "bfc-print-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Custom Print"
    },
    {
      "type": "range",
      "id": "price_per_step",
      "label": "Price per 2.5\" increment ($)",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "cloud_name",
      "label": "Cloudinary Cloud Name",
      "default": "dj20glh2k"
    },
    {
      "type": "text",
      "id": "upload_preset",
      "label": "Cloudinary Upload Preset",
      "default": "bfc-prints"
    }
  ],
  "presets": [
    {
      "name": "Print Configurator"
    }
  ]
}
{% endschema %}
