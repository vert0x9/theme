{%- comment -%} Hidden product form {%- endcomment -%}
{%- assign bfc4_form_id = 'bfc4-form-' | append: section.id -%}
<div style="display:none">
  <product-form class="product-form" data-hide-errors="false" data-section-id="{{ section.id }}">
    {%- form 'product', product, id: bfc4_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id" id="bfc4-variant-input"/>
      <div class="product-form__buttons" data-display-quantity="false" data-display-layout="seperate" data-display-dynamics="false">
        <button id="ProductSubmitButton-{{ section.id }}" type="submit" name="add" class="product-form__submit button button--filled">
          <span>Add to Cart</span>
          <div class="loading__spinner hidden">
            <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66"><circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
          </div>
        </button>
      </div>
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <span class="product-form__error-message"></span>
      </div>
    {%- endform -%}
  </product-form>
</div>

</div>{%- comment -%} /bfc4 {%- endcomment -%}

<script>
(function() {
  'use strict';

  // ── XHR helper (bypasses Judge.me monkey-patching of window.fetch) ─────
  function bfc4Xhr(url, opts) {
    opts = opts || {};
    return new Promise(function(resolve, reject) {
      var xhr = new XMLHttpRequest();
      xhr.open(opts.method || 'GET', url, true);
      xhr.withCredentials = true;
      if (opts.headers) Object.keys(opts.headers).forEach(function(k){xhr.setRequestHeader(k, opts.headers[k]);});
      xhr.setRequestHeader('X-Requested-With','XMLHttpRequest');
      xhr.onload = function() {
        resolve({
          ok: xhr.status>=200 && xhr.status<300,
          status: xhr.status,
          json: function(){ try{return Promise.resolve(JSON.parse(xhr.responseText));}catch(e){return Promise.resolve({});} },
          text: function(){ return Promise.resolve(xhr.responseText); }
        });
      };
      xhr.onerror = function(){ reject(new Error('Network error')); };
      xhr.send(opts.body || null);
    });
  }

  var STATE = {
    variantId:    {{ current_variant.id }},
    variantPrice: {{ current_variant.price }},
    film: {},
    extWarranty: null
  };

  // ── Film tile toggle ──────────────────────────
  window.bfc4FilmToggle = function(tile) {
    var id = tile.id;
    var wasSel = tile.classList.contains('is-sel');
    if (wasSel) {
      tile.classList.remove('is-sel');
      delete STATE.film[id];
    } else {
      tile.classList.add('is-sel');
      STATE.film[id] = {
        variantId: tile.dataset.variantId,
        name:      tile.dataset.productTitle,
        orig:      parseInt(tile.dataset.orig, 10),
        sale:      parseInt(tile.dataset.sale, 10),
        disc:      parseInt(tile.dataset.disc, 10),
        img:       tile.dataset.img || null
      };
    }
    bfc4Render();
  };

  // ── Variant selector ──────────────────────────
  window.bfc4SelectVariant = function(btn) {
    document.querySelectorAll('.bfc4-var-btn').forEach(function(b) { b.classList.remove('is-active'); });
    btn.classList.add('is-active');
    STATE.variantId    = parseInt(btn.dataset.variantId, 10);
    STATE.variantPrice = parseInt(btn.dataset.variantPrice, 10);
    var input = document.getElementById('bfc4-variant-input');
    if (input) input.value = btn.dataset.variantId;
    var url = new URL(window.location);
    url.searchParams.set('variant', btn.dataset.variantId);
    window.history.replaceState({}, '', url);
    var stickyGrade = document.getElementById('bfc4-sticky-grade');
    if (stickyGrade) stickyGrade.textContent = btn.textContent.trim();
    bfc4UpdateWarrantyTier(STATE.variantPrice);
  };

  // ── Render total ──────────────────────────────
  function bfc4Render() {
    var total = STATE.variantPrice;
    var filmCount = 0;
    Object.values(STATE.film).forEach(function(sel) {
      total += sel.sale;
      filmCount++;
    });
    if (STATE.extWarranty && !isNaN(STATE.extWarranty.price)) total += STATE.extWarranty.price;
    var totalEl = document.getElementById('bfc4-total');
    if (totalEl) totalEl.textContent = fmt(total);
    var stickyPrice = document.getElementById('bfc4-sticky-price');
    if (stickyPrice) stickyPrice.textContent = fmt(STATE.variantPrice);

    // Update ATC button text
    var textEl = document.getElementById('bfc4-atc-text');
    if (textEl) {
      textEl.textContent = filmCount > 0 ? 'Add Camera + Film' : 'Add to Cart';
    }

    // Show/hide camera-only button
    var camOnly = document.querySelector('.bfc4-cam-only');
    if (camOnly) {
      camOnly.style.display = filmCount > 0 ? 'block' : 'none';
      camOnly.textContent = 'Camera Only \u2014 ' + fmt(STATE.variantPrice);
    }
  }

  // ── ATC ─────────────────────────────────────────
  window.bfc4AddToCart = async function() {
    var btn    = document.getElementById('bfc4-atc');
    var textEl = document.getElementById('bfc4-atc-text');
    var stickyBtn  = document.getElementById('bfc4-sticky-btn');
    var stickyText = document.getElementById('bfc4-sticky-btn-text');
    if (btn) { btn.disabled = true; }
    if (stickyBtn) { stickyBtn.disabled = true; }
    if (textEl) { textEl.textContent = 'Adding\u2026'; }
    if (stickyText) { stickyText.textContent = 'Adding\u2026'; }

    var items = [];
    Object.values(STATE.film).forEach(function(sel) {
      if (!sel.variantId) return;
      var vid = parseInt(sel.variantId, 10);
      if (isNaN(vid) || vid === 0) return;
      items.push({ id: vid, quantity: 1, properties: { _s8_bundle: 'true' } });
    });

    // Add extended warranty if selected
    if (STATE.extWarranty && STATE.extWarranty.variantId) {
      items.push({ id: parseInt(STATE.extWarranty.variantId, 10), quantity: 1, properties: { _extended_warranty: 'true' } });
    }

    try {
      if (items.length > 0) {
        var res = await bfc4Xhr('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ items: items })
        });
        if (!res.ok) {
          var errBody = await res.json().catch(function() { return {}; });
          console.error('[BFC4-S8] cart/add.js error:', res.status, errBody);
          throw new Error(res.status);
        }
      }
      // Add the camera via native form submit (triggers cart drawer)
      var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
      if (submitBtn) submitBtn.click();
      if (btn) { btn.classList.add('is-success'); }
      if (textEl) { textEl.textContent = 'Added!'; }
      if (stickyText) { stickyText.textContent = 'Added!'; }
      setTimeout(function() {
        if (btn) { btn.classList.remove('is-success'); btn.disabled = false; }
        if (stickyBtn) { stickyBtn.disabled = false; }
        if (textEl) { textEl.textContent = 'Add to Cart'; }
        if (stickyText) { stickyText.textContent = 'Add to Cart'; }
        bfc4Render();
      }, 2400);
    } catch(e) {
      console.error('[BFC4-S8] ATC error:', e);
      if (btn) { btn.disabled = false; }
      if (stickyBtn) { stickyBtn.disabled = false; }
      if (textEl) { textEl.textContent = 'Add to Cart'; }
      if (stickyText) { stickyText.textContent = 'Add to Cart'; }
      bfc4Render();
    }
  };

  window.bfc4CameraOnly = function() {
    // Clear film selections
    STATE.film = {};
    document.querySelectorAll('.bfc4-film-tile.is-sel').forEach(function(t) { t.classList.remove('is-sel'); });
    bfc4Render();
    var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
    if (submitBtn) submitBtn.click();
  };

  // ── Popup ────────────────────────────────────────
  window.baOpenPopup = function(catId) {
    var data = document.getElementById('ba-popup-data-' + catId);
    if (!data) return;
    document.getElementById('ba-popup-title').textContent = data.dataset.title;
    var desc = data.dataset.desc;
    document.getElementById('ba-popup-desc').innerHTML = desc ? '<p>' + desc.replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br/>') + '</p>' : '';
    var imgs = data.dataset.imgs ? data.dataset.imgs.split('||') : [];
    document.getElementById('ba-popup-imgs').innerHTML = imgs.map(function(src) { return '<img src="' + src + '" loading="lazy"/>'; }).join('');
    document.getElementById('ba-popup-overlay').classList.add('is-open');
    document.body.style.overflow = 'hidden';
  };
  window.baClosePopup = function() {
    document.getElementById('ba-popup-overlay').classList.remove('is-open');
    document.body.style.overflow = '';
  };
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') baClosePopup(); });

  // ── Image slider ─────────────────────────────────
  var bfc4Slide_current = 0;
  var bfc4Slide_total   = document.querySelectorAll('.bfc4-slide').length;
  window.bfc4Slide = function(dir) {
    bfc4GoTo((bfc4Slide_current + dir + bfc4Slide_total) % bfc4Slide_total);
  };
  window.bfc4GoTo = function(idx) {
    bfc4Slide_current = idx;
    var slides = document.getElementById('bfc4-slides');
    if (slides) slides.style.transform = 'translateX(-' + (idx * 100) + '%)';
    document.querySelectorAll('.bfc4-dot').forEach(function(d, i) { d.classList.toggle('is-active', i === idx); });
    var prev = document.querySelector('.bfc4-arrow.is-prev');
    if (prev) prev.style.visibility = idx === 0 ? 'hidden' : 'visible';
  };
  (function() {
    var left = document.querySelector('.bfc4-left');
    if (!left || bfc4Slide_total <= 1) return;
    var startX = 0;
    left.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
    left.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) bfc4Slide(dx < 0 ? 1 : -1);
    });
  })();

  function fmt(cents) { return '$' + (cents / 100).toFixed(2).replace(/\.00$/, ''); }

  // ── Extended Warranty ─────────────────────────
  // Warranty tier table — sourced from snippets/bfc-warranty-tiers-js.liquid.
  // Super 8 uses SLR/Rangefinder pricing (same modal shape, similar risk profile).
  {% render 'bfc-warranty-tiers-js', category: 'slr' %}
  function bfc4GetWarrantyTier(price) {
    for (var i = 0; i < BFC_WARRANTY_TIERS.length; i++) {
      if (price <= BFC_WARRANTY_TIERS[i].max) return BFC_WARRANTY_TIERS[i];
    }
    return BFC_WARRANTY_TIERS[BFC_WARRANTY_TIERS.length - 1];
  }
  function bfc4UpdateWarrantyTier(variantPrice) {
    var tier = bfc4GetWarrantyTier(variantPrice);
    // Super 8 borrows SLR pricing: single +6 month button. Only v12/p12 exists.
    var td = [{ vid: tier.v12, price: tier.p12 }];
    document.querySelectorAll('.ba-ext-w-btn').forEach(function(btn, i) {
      if (!td[i]) return;
      var price = parseInt(td[i].price, 10);
      if (td[i].vid != null && td[i].vid !== '') btn.dataset.variantId = td[i].vid;
      if (!isNaN(price)) {
        btn.dataset.price = price;
        var el = btn.querySelector('.ba-ext-w-price');
        if (el) el.textContent = '+$' + (price / 100).toFixed(0);
      }
      if (btn.classList.contains('is-sel') && STATE.extWarranty) {
        STATE.extWarranty.variantId = btn.dataset.variantId;
        STATE.extWarranty.price = parseInt(btn.dataset.price, 10);
      }
    });
    bfc4Render();
  }
  window.bfc4SelectWarranty = function(btn) {
    var wasSelected = btn.classList.contains('is-sel');
    document.querySelectorAll('.ba-ext-w-btn').forEach(function(b) { b.classList.remove('is-sel'); });
    var clearBtn = document.getElementById('ba-ext-w-clear');
    if (wasSelected) {
      STATE.extWarranty = null;
      if (clearBtn) clearBtn.classList.remove('is-vis');
    } else {
      btn.classList.add('is-sel');
      STATE.extWarranty = {
        months: parseInt(btn.dataset.months, 10),
        total:  parseInt(btn.dataset.total, 10),
        price:  parseInt(btn.dataset.price, 10),
        variantId: btn.dataset.variantId || null
      };
      if (clearBtn) clearBtn.classList.add('is-vis');
    }
    bfc4Render();
  };
  window.bfc4ClearWarranty = function() {
    document.querySelectorAll('.ba-ext-w-btn').forEach(function(b) { b.classList.remove('is-sel'); });
    STATE.extWarranty = null;
    var clearBtn = document.getElementById('ba-ext-w-clear');
    if (clearBtn) clearBtn.classList.remove('is-vis');
    bfc4Render();
  };

  // ── Chapter toggle (process + specs) ──────────────
  window.bfc4ToggleChapter = function() {
    var btn = document.getElementById('bfc4-chapter-toggle');
    var body = document.getElementById('bfc4-chapter-body');
    var txt = btn ? btn.querySelector('.bfc4-chapter-toggle-text') : null;
    if (!btn || !body) return;
    var isOpen = body.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    if (txt) txt.textContent = isOpen ? 'Hide details' : 'View full process & all specs';
  };

  // ── Per-column chapter toggle (mobile only) ──
  window.bfc4ToggleChapterCol = function(btn) {
    if (!btn) return;
    var col = btn.closest('.bfc4-chapter-col');
    if (!col) return;
    var extra = col.querySelector('.bfc4-chapter-extra');
    if (!extra) return;
    var isOpen = extra.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    var label = btn.querySelector('.bfc4-chapter-col-toggle-label');
    if (label) {
      var openLabel   = btn.dataset.openLabel   || 'Hide';
      var closedLabel = btn.dataset.closedLabel || 'Show more';
      label.textContent = isOpen ? openLabel : closedLabel;
    }
  };

  bfc4UpdateWarrantyTier(STATE.variantPrice);

  bfc4Render();

  // ── Sticky Mobile ATC Bar ──────────────────────
  var stickyBar = document.getElementById('bfc4-sticky-bar');
  var mainAtc   = document.getElementById('bfc4-atc');
  if (stickyBar && mainAtc && window.innerWidth <= 900) {
    new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        stickyBar.classList.toggle('is-visible', !e.isIntersecting);
      });
    }, { threshold: 0 }).observe(mainAtc);
  }
})();
</script>

