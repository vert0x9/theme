{{- 'section-product.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'product-variants.js' | asset_url }}" defer="defer"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet"/></noscript>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  assign g1 = product.metafields.custom.gallery_1.value
  assign g2 = product.metafields.custom.gallery_2.value
  assign g3 = product.metafields.custom.gallery_3.value
  assign g4 = product.metafields.custom.gallery_4.value
  assign g5 = product.metafields.custom.gallery_5.value
  assign g6 = product.metafields.custom.gallery_6.value

  assign spec_lens    = product.metafields.custom.spec_lens.value
  assign spec_fps     = product.metafields.custom.spec_fps.value
  assign spec_film    = product.metafields.custom.spec_filmformat.value
  assign spec_sound   = product.metafields.custom.spec_sound.value
  assign spec_battery = product.metafields.custom.spec_battery.value
  assign spec_meter   = product.metafields.custom.spec_meter.value
  assign spec_focus   = product.metafields.custom.spec_focus.value
  assign spec_filter  = product.metafields.custom.spec_filtersize.value
  assign spec_speeds  = product.metafields.custom.spec_shutterspeeds.value
  assign spec_zoom    = product.metafields.custom.spec_zoom.value
  assign spec_weight  = product.metafields.custom.spec_weight.value
  assign spec_cart    = product.metafields.custom.spec_cartridge.value
-%}

<style>
.bfc4 *, .bfc4 *::before, .bfc4 *::after { box-sizing: border-box; margin: 0; padding: 0; }

.bfc4 {
  --or: #E36E15;
  --go: #F4A027;
  --ce: #ABCC99;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sr: 'Cormorant Garamond', Georgia, serif;
  --sn: 'Poppins', sans-serif;
  --t:  0.2s ease;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ── SPLIT LAYOUT ──────────────────────────── */
.bfc4-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: start;
}

/* ── LEFT: STICKY SLIDER ─────────────────── */
.bfc4-left {
  position: sticky;
  top: 0;
  width: 50vw;
  height: 50vw;
  max-height: 100vh;
  overflow: hidden;
  background: var(--gr);
}
.bfc4-slides {
  display: flex;
  width: 100%;
  height: 100%;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}
.bfc4-slide {
  min-width: 100%;
  height: 100%;
  flex-shrink: 0;
  position: relative;
}
.bfc4-slide img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
}
.bfc4-arrow {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  z-index: 10;
  background: rgba(32,32,9,0.3);
  border: none;
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background var(--t);
  backdrop-filter: blur(4px);
}
.bfc4-arrow:hover { background: rgba(32,32,9,0.6); }
.bfc4-arrow.is-prev { left: 16px; visibility: hidden; }
.bfc4-arrow.is-next { right: 16px; }
.bfc4-arrow svg { display: block; }
.bfc4-dots {
  position: absolute;
  bottom: 16px; left: 50%;
  transform: translateX(-50%);
  display: flex; gap: 6px; z-index: 10;
}
.bfc4-dot {
  width: 6px; height: 6px;
  background: rgba(255,255,255,0.4);
  border: none; cursor: pointer; padding: 0;
  transition: background var(--t), transform var(--t);
}
.bfc4-dot.is-active { background: #fff; transform: scale(1.3); }

/* ── RIGHT: SCROLLABLE CONTENT ───────────── */
.bfc4-right {
  background: var(--cv);
  padding: 36px 40px 56px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* ── PRODUCT HEADER ──────────────────────── */
.bfc4-eyebrow {
  font-size: 9px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--ch); margin-bottom: 6px; display: block;
}
.bfc4-title {
  font-family: var(--sn); font-size: 28px; font-weight: 600;
  line-height: 1.1; letter-spacing: -0.3px; margin-bottom: 6px;
}
.bfc4-title em { font-style: normal; color: var(--ch); font-weight: 400; }
.bfc4-warranty {
  font-size: 10px; color: var(--ch); letter-spacing: 0.08em;
  display: flex; align-items: center; gap: 6px;
}
.bfc4-warranty::before {
  content: '';
  width: 16px; height: 1px; background: var(--ch); display: block;
}
.bfc4-kit-desc {
  font-size: 12px; color: var(--ch); line-height: 1.6; margin-top: 4px;
}

/* ── 24FPS BADGE ─────────────────────────── */
.bfc4-fps-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: linear-gradient(135deg, #2a4820 0%, #3a6230 100%);
  padding: 6px 12px; margin-top: 10px;
  font-size: 10px; font-weight: 600; color: #fff;
  letter-spacing: 0.06em;
}
.bfc4-fps-badge svg { flex-shrink: 0; }

/* ── MINI SPECS (right rail) ─────────────── */
.bfc4-mini-specs {
  border-top: 1px solid rgba(32,32,9,0.08);
  padding-top: 16px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 0;
}
.bfc4-mini-spec {
  padding: 8px 0;
  border-bottom: 1px solid rgba(32,32,9,0.06);
  display: flex; flex-direction: column; gap: 2px;
}
.bfc4-mini-spec:nth-child(odd) { padding-right: 16px; }
.bfc4-mini-spec:nth-child(even) { padding-left: 16px; border-left: 1px solid rgba(32,32,9,0.06); }
.bfc4-mini-spec:nth-last-child(-n+2) { border-bottom: none; }
.bfc4-spec-key { font-size: 8px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(32,32,9,0.3); }
.bfc4-spec-val { font-size: 11.5px; font-weight: 500; }

/* ── ADD FILM SECTION ────────────────────── */
.bfc4-film-head {
  border-top: 1px solid rgba(32,32,9,0.1);
  padding-top: 16px;
}
.bfc4-film-eyebrow {
  font-size: 9px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--or); margin-bottom: 4px; display: block;
}
.bfc4-film-note {
  font-size: 11px; color: var(--ch); line-height: 1.5;
}
.bfc4-film-tiles {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;
}
.bfc4-film-tile {
  display: flex; flex-direction: column;
  background: #fff;
  border: 1px solid rgba(32,32,9,0.08);
  overflow: hidden;
  cursor: pointer;
  position: relative;
  transition: border-color var(--t), box-shadow var(--t);
}
.bfc4-film-tile:hover { border-color: rgba(227,110,21,0.3); }
.bfc4-film-tile.is-sel { border: 2px solid var(--or); box-shadow: 0 0 0 1px rgba(227,110,21,0.15); }
.bfc4-film-tile-img {
  aspect-ratio: 1/1;
  overflow: hidden;
  background: var(--gr);
}
.bfc4-film-tile-img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.4s ease;
}
.bfc4-film-tile:hover .bfc4-film-tile-img img { transform: scale(1.04); }
.bfc4-film-tile-body {
  padding: 8px 8px 6px;
  display: flex; flex-direction: column; gap: 2px;
}
.bfc4-film-tile-name {
  font-size: 10px; font-weight: 600; line-height: 1.3;
  overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.bfc4-film-tile-price {
  font-size: 10px; font-weight: 700; color: var(--or);
}
.bfc4-film-tile-sel-check {
  position: absolute; top: 6px; right: 6px;
  width: 18px; height: 18px; background: var(--or); color: #fff;
  font-size: 10px; font-weight: 700; display: none; align-items: center; justify-content: center;
}
.bfc4-film-tile.is-sel .bfc4-film-tile-sel-check { display: flex; }

/* Out of stock — film tiles */
.bfc4-film-tile.is-oos {
  opacity: 0.5; cursor: not-allowed; pointer-events: none;
}
.bfc4-film-tile.is-oos .bfc4-film-tile-img img { filter: grayscale(60%); }
.bfc4-film-tile-oos {
  position: absolute; bottom: 0; left: 0; right: 0;
  font-size: 7px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  background: rgba(32,32,9,0.55); color: rgba(255,255,255,0.8); padding: 2px 0; text-align: center;
}

/* ── GRADE + BUY ─────────────────────────── */
.bfc4-grade-compact {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 4px;
}
.bfc4-grade-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--ch); white-space: nowrap;
}
.bfc4-grade-compact .bfc4-grade-row { flex: 1; }
.bfc4-grade-compact .bfc4-var-btn { padding: 7px 8px; font-size: 10px; }

.bfc4-grade-row {
  display: flex; gap: 6px;
}
.bfc4-var-btn {
  flex: 1; padding: 10px 8px;
  border: 1px solid rgba(32,32,9,0.15);
  background: #fff; cursor: pointer; font-family: var(--sn);
  font-size: 11px; font-weight: 600; color: var(--bk);
  transition: all var(--t); text-align: center;
}
.bfc4-var-btn:hover { border-color: var(--or); }
.bfc4-var-btn.is-active { border: 2px solid var(--or); color: var(--or); background: rgba(227,110,21,0.05); }
.bfc4-var-btn[disabled] {
  opacity: 0.5; cursor: not-allowed;
  border-color: rgba(32,32,9,0.08); color: rgba(32,32,9,0.3);
  background: rgba(32,32,9,0.03);
}
.bfc4-var-btn[disabled]:hover { border-color: rgba(32,32,9,0.08); }
.bfc4-var-btn-oos {
  display: block; font-size: 8px; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: rgba(32,32,9,0.3); margin-top: 2px;
}

.bfc4-price-row {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 6px;
}
.bfc4-price-label { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ch); }
.bfc4-price {
  font-family: var(--sr); font-size: 40px; font-weight: 300; color: var(--bk); line-height: 1;
}

.bfc4-atc {
  width: 100%; padding: 14px;
  background: var(--or); color: #fff; border: none;
  cursor: pointer; font-family: var(--sn); font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  transition: background var(--t); display: block; text-align: center; margin-bottom: 8px;
}
.bfc4-atc:hover:not([disabled]) { background: #c9600f; }
.bfc4-atc[disabled] { opacity: 0.5; cursor: not-allowed; }
.bfc4-atc.is-success { background: #2a4820 !important; }
.bfc4-cam-only {
  width: 100%; font-size: 9px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(32,32,9,0.3); background: none;
  border: none; cursor: pointer; transition: color var(--t); font-family: var(--sn);
  text-align: center; padding: 4px 0; display: block;
}
.bfc4-cam-only:hover { color: var(--bk); }

/* ── KIT SUMMARY ─────────────────────────── */
.bfc4-kit-summary {
  border-top: 1px solid rgba(32,32,9,0.08);
  padding-top: 14px;
  display: flex; flex-direction: column; gap: 4px;
}
.bfc4-ks-label { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ch); margin-bottom: 4px; }
.bfc4-ks-line {
  display: flex; align-items: center; gap: 8px;
}
.bfc4-ks-img { width: 24px; height: 24px; object-fit: cover; background: var(--gr); flex-shrink: 0; }
.bfc4-ks-name { font-size: 10.5px; color: var(--ch); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bfc4-ks-price { font-size: 10.5px; font-weight: 700; color: var(--or); }
.bfc4-ks-remove {
  background: none; border: none; cursor: pointer; color: rgba(32,32,9,0.2);
  font-size: 13px; padding: 0; flex-shrink: 0; transition: color var(--t);
}
.bfc4-ks-remove:hover { color: var(--bk); }

/* ── BELOW FOLD ───────────────────────────── */
.bfc4-below { background: var(--cv); }

/* Shot on */
.bfc4 .ba-shot { background: var(--cv); border-top: 1px solid rgba(32,32,9,0.1); }
.bfc4 .ba-shot-head { padding: 48px 48px 24px; display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid rgba(32,32,9,0.1); }
.bfc4 .ba-shot-title { font-family: var(--sr); font-size: 40px; font-weight: 300; }
.bfc4 .ba-shot-sub { font-size: 11px; color: var(--ch); font-style: italic; }
.bfc4 .ba-shot-grid { display: grid; grid-template-columns: repeat(6, 1fr); }
.bfc4 .ba-shot-grid a { display: block; overflow: hidden; border-right: 1px solid rgba(32,32,9,0.08); line-height: 0; font-size: 0; }
.bfc4 .ba-shot-grid a:last-child { border-right: none; }
.bfc4 .ba-shot-grid img { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; transition: transform 0.4s ease; }
.bfc4 .ba-shot-grid a:hover img { transform: scale(1.04); }

/* ── CHAPTER — Restoration process + specs (combined, dark) — 3-col ── */
.bfc4 .bfc4-chapter {
  background: var(--bk);
  color: #fff;
  position: relative;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-header {
  padding: 64px 48px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}
.bfc4 .bfc4-chapter-title {
  font-family: var(--sr);
  font-size: 30px;
  font-weight: 300;
  color: #fff;
  margin: 0 0 18px;
  line-height: 1.15;
  letter-spacing: -0.005em;
}
.bfc4 .bfc4-chapter-title em { font-style: normal; color: rgba(255,255,255,0.6); font-weight: 300; }
.bfc4 .bfc4-chapter-sub {
  font-size: 13.5px;
  color: rgba(255,255,255,0.7);
  line-height: 1.6;
  margin: 0 0 28px;
}
.bfc4 .bfc4-chapter-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 22px;
  background: transparent;
  border: 1px solid rgba(227,110,21,0.6);
  color: var(--or);
  font-family: var(--sn);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
  align-self: flex-start;
}
.bfc4 .bfc4-chapter-toggle:hover { background: rgba(227,110,21,0.1); border-color: var(--or); }
.bfc4 .bfc4-chapter-toggle-icon { transition: transform 0.3s ease; }
.bfc4 .bfc4-chapter-toggle[aria-expanded="true"] .bfc4-chapter-toggle-icon { transform: rotate(180deg); }

/* Per-column toggle (mobile only) */
.bfc4 .bfc4-chapter-col-toggle {
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  width: 100%;
  margin-top: 22px;
  padding: 11px 16px;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.22);
  color: rgba(255,255,255,0.85);
  font-family: var(--sn);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
}
.bfc4 .bfc4-chapter-col-toggle:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.4); color: #fff; }
.bfc4 .bfc4-chapter-col-toggle-icon { transition: transform 0.3s ease; flex-shrink: 0; }
.bfc4 .bfc4-chapter-col-toggle[aria-expanded="true"] .bfc4-chapter-col-toggle-icon { transform: rotate(180deg); }
.bfc4 .bfc4-chapter-extra.is-open { max-height: 6000px; opacity: 1; margin-top: 28px; }

/* THREE-column grid: header | process | specs */
.bfc4 .bfc4-chapter-grid {
  display: grid;
  grid-template-columns: 1.1fr 1fr 1fr;
  max-width: 1380px;
  margin: 0 auto;
  padding: 0;
}
.bfc4 .bfc4-chapter-col {
  padding: 64px 48px;
  min-width: 0;
  border-left: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-col:first-child { border-left: none; }
.bfc4 .bfc4-chapter-col-head {
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-col-ey {
  display: block;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin-bottom: 12px;
}
.bfc4 .bfc4-chapter-col-title {
  font-family: var(--sr);
  font-size: 26px;
  font-weight: 300;
  color: #fff;
  line-height: 1.15;
  letter-spacing: -0.005em;
  margin: 0;
}
.bfc4 .bfc4-chapter-col-title em { font-style: normal; color: rgba(255,255,255,0.55); font-weight: 300; }
.bfc4 .bfc4-chapter-col-sub {
  font-family: var(--sn);
  font-size: 12.5px;
  color: rgba(255,255,255,0.55);
  line-height: 1.55;
  margin: 12px 0 0;
}

/* Process: short list always visible */
.bfc4 .bfc4-chapter-process-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.bfc4 .bfc4-chapter-process-list li {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 16px;
  align-items: baseline;
  font-family: var(--sn);
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
}
.bfc4 .bfc4-chapter-process-list .num {
  font-family: var(--sr);
  font-size: 20px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  line-height: 1;
}

/* Specs: quick 2x2, always visible */
.bfc4 .bfc4-chapter-specs-quick {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border-top: 1px solid rgba(255,255,255,0.1);
  border-left: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-quick > div {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 18px 20px;
  border-right: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-quick .key { font-size: 9px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
.bfc4 .bfc4-chapter-specs-quick .val { font-family: var(--sr); font-size: 16px; font-weight: 400; color: #fff; line-height: 1.3; }

/* Extras hidden until toggle expands */
.bfc4 .bfc4-chapter-extra {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.6s ease, opacity 0.4s ease, margin-top 0.4s ease;
  margin-top: 0;
}
.bfc4 .bfc4-chapter-body.is-open .bfc4-chapter-extra { max-height: 6000px; opacity: 1; margin-top: 36px; }

/* Header extra: photo + prose */
.bfc4 .bfc4-chapter-header-extra .ba-restore-photo {
  width: 100%;
  aspect-ratio: 4 / 3;
  background: rgba(255,255,255,0.04);
  overflow: hidden;
  margin-bottom: 24px;
}
.bfc4 .bfc4-chapter-header-extra .ba-restore-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose {
  font-family: var(--sn);
  font-size: 13px;
  color: rgba(255,255,255,0.7);
  line-height: 1.7;
  text-align: left;
  margin: 0;
}
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose p { margin-bottom: 12px; }
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose p:last-child { margin-bottom: 0; }

/* Process extra: detail steps */
.bfc4 .bfc4-chapter-process-detail {
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding-top: 24px;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-process-detail-step {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 16px;
  align-items: baseline;
}
.bfc4 .bfc4-chapter-process-detail-step .num { font-family: var(--sr); font-size: 20px; font-weight: 300; color: rgba(255,255,255,0.4); line-height: 1; }
.bfc4 .bfc4-chapter-process-detail-step .body strong { display: block; font-size: 13px; font-weight: 600; color: #fff; margin-bottom: 4px; font-family: var(--sn); }
.bfc4 .bfc4-chapter-process-detail-step .body p { font-size: 12px; color: rgba(255,255,255,0.6); line-height: 1.55; margin: 0; }

/* Specs extra: full table */
.bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full {
  display: grid;
  grid-template-columns: 1fr;
  border-top: 1px solid rgba(255,255,255,0.1);
  border-left: 1px solid rgba(255,255,255,0.1);
  border-right: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full > div {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  align-items: baseline;
}
.bfc4 .bfc4-chapter-specs-extra .key { font-size: 8.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
.bfc4 .bfc4-chapter-specs-extra .val { font-family: var(--sr); font-size: 14px; color: #fff; line-height: 1.3; }

@media (max-width: 900px) {
  .bfc4 .bfc4-chapter-grid { grid-template-columns: 1fr; }
  .bfc4 .bfc4-chapter-col { padding: 36px 24px; border-left: none; }
  .bfc4 .bfc4-chapter-col + .bfc4-chapter-col { border-top: 1px solid rgba(255,255,255,0.08); }
  .bfc4 .bfc4-chapter-header { padding: 44px 24px 32px; }
  .bfc4 .bfc4-chapter-title { font-size: 28px; }
  .bfc4 .bfc4-chapter-col-title { font-size: 24px; }
  .bfc4 .bfc4-chapter-specs-quick { grid-template-columns: 1fr; }
  .bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full { grid-template-columns: 1fr; }
  /* Swap global -> per-column toggles on mobile */
  .bfc4 .bfc4-chapter-toggle { display: none; }
  .bfc4 .bfc4-chapter-col-toggle { display: inline-flex; }
}

/* Extended Warranty */
.bfc4 .ba-ext-warranty { border-top: 1px solid rgba(32,32,9,0.08); padding-top: 16px; }
.bfc4 .ba-ext-w-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.bfc4 .ba-ext-w-eyebrow { font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--or); }
.bfc4 .ba-ext-w-baseline { font-size: 10px; color: var(--ch); margin-bottom: 10px; display: flex; align-items: flex-start; gap: 5px; line-height: 1.5; }
.bfc4 .ba-ext-w-baseline svg { flex-shrink: 0; color: #2a4820; margin-top: 2px; }
.bfc4 .ba-ext-w-baseline strong { color: var(--bk); }
.bfc4 .ba-ext-w-options { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; }
.bfc4 .ba-ext-w-options.ba-ext-w-options--single { grid-template-columns: 1fr; }
.bfc4 .ba-ext-w-btn { border: 1px solid rgba(32,32,9,0.1); background: #fff; padding: 10px 8px; cursor: pointer; font-family: var(--sn); text-align: center; transition: border-color var(--t), box-shadow var(--t); display: flex; flex-direction: column; gap: 3px; position: relative; }
.bfc4 .ba-ext-w-btn:hover { border-color: var(--or); }
.bfc4 .ba-ext-w-btn.is-sel { border: 2px solid var(--or); box-shadow: 0 0 0 1px rgba(227,110,21,0.15); }
.bfc4 .ba-ext-w-btn.is-sel::after { content: '✓'; position: absolute; top: 4px; right: 5px; font-size: 8px; font-weight: 700; color: var(--or); }
.bfc4 .ba-ext-w-extend { font-size: 11px; font-weight: 700; color: var(--or); line-height: 1; }
.bfc4 .ba-ext-w-months { font-size: 9px; color: var(--ch); letter-spacing: 0.04em; line-height: 1; }
.bfc4 .ba-ext-w-price { font-size: 11px; font-weight: 700; color: var(--bk); margin-top: 2px; }
.bfc4 .ba-ext-w-acc { font-size: 7.5px; color: #2a4820; font-weight: 600; letter-spacing: 0.04em; margin-top: 1px; }
.bfc4 .ba-ext-w-none { font-size: 8.5px; color: rgba(32,32,9,0.4); margin-top: 8px; text-align: left; cursor: pointer; background: none; border: none; font-family: var(--sn); transition: color var(--t); padding: 0; display: none; }
.bfc4 .ba-ext-w-none.is-vis { display: block; }
.bfc4 .ba-ext-w-none:hover { color: var(--bk); }

/* Warranty Policy (single column) */
.bfc4 .ba-policy { display: grid; grid-template-columns: 1fr; background: var(--cv); border-top: 1px solid rgba(32,32,9,0.06); }
.bfc4 .ba-policy-col { padding: 48px; }
.bfc4 .ba-policy-ey { font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--go); display: block; margin-bottom: 12px; }
.bfc4 .ba-policy-title { font-family: var(--sr); font-size: 28px; font-weight: 300; color: var(--bk); line-height: 1.1; margin: 0 0 16px; }
.bfc4 .ba-policy-pill { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; background: rgba(171,204,153,0.2); color: var(--or); font-size: 10px; font-weight: 600; letter-spacing: 0.06em; margin-bottom: 20px; }
.bfc4 .ba-policy-body { font-size: 13px; line-height: 1.6; color: var(--ch); }
.bfc4 .ba-policy-body p { margin: 0; }
.bfc4 .ba-policy-body strong { color: var(--bk); }

/* Popup */
.bfc4 .ba-popup-overlay {
  position: fixed; inset: 0;
  background: rgba(32,32,9,0.55); z-index: 200; display: none;
  align-items: center; justify-content: center; backdrop-filter: blur(3px);
}
.bfc4 .ba-popup-overlay.is-open { display: flex; }
.bfc4 .ba-popup { background: #fff; max-width: 680px; width: 90%; max-height: 85vh; display: flex; flex-direction: column; overflow: hidden; animation: bfc4-popup-in 0.2s ease; }
@keyframes bfc4-popup-in { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform: translateY(0); } }
.bfc4 .ba-popup-head { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid rgba(32,32,9,0.1); flex-shrink: 0; }
.bfc4 .ba-popup-title { font-size: 14px; font-weight: 700; }
.bfc4 .ba-popup-close { background: none; border: none; cursor: pointer; padding: 4px; color: var(--ch); display: flex; align-items: center; }
.bfc4 .ba-popup-body { overflow-y: auto; flex: 1; }
.bfc4 .ba-popup-imgs { display: grid; grid-template-columns: repeat(3, 1fr); }
.bfc4 .ba-popup-imgs img { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; border-right: 1px solid rgba(32,32,9,0.07); border-bottom: 1px solid rgba(32,32,9,0.07); }
.bfc4 .ba-popup-desc { padding: 20px; font-size: 12.5px; color: var(--ch); line-height: 1.7; border-top: 1px solid rgba(32,32,9,0.08); }
.bfc4 .ba-popup-desc p { margin-bottom: 10px; }

/* ── MOBILE ───────────────────────────────── */
@media (max-width: 900px) {
  .bfc4-split { grid-template-columns: 1fr; min-height: 0; }
  .bfc4-left { position: relative; width: 100%; height: 100vw; max-height: 520px; }
  .bfc4-arrow { display: none; }
  .bfc4-right { padding: 28px 20px 48px; gap: 24px; overflow-y: visible; }
  .bfc4-title { font-size: 36px; }
  .bfc4-film-tiles { grid-template-columns: repeat(2, 1fr); gap: 6px; }
  .bfc4-film-tile-body { padding: 6px 6px 5px; }
  .bfc4-film-tile-name { font-size: 9px; }
  .bfc4-film-tile-price { font-size: 9px; }
  .bfc4-mini-specs { grid-template-columns: 1fr; }
  .bfc4-mini-spec:nth-child(odd) { padding-right: 0; }
  .bfc4-mini-spec:nth-child(even) { padding-left: 0; border-left: none; }
  .bfc4 .ba-shot-head { padding: 36px 20px 16px; flex-direction: column; gap: 4px; }
  .bfc4 .ba-shot-title { font-size: 28px; }
  .bfc4 .ba-shot-grid { grid-template-columns: repeat(3, 1fr); }
  .bfc4 .ba-policy { grid-template-columns: 1fr; }
  .bfc4 .ba-policy-col { padding: 32px 20px; }
  .bfc4 .ba-policy-title { font-size: 22px; }
}

/* ── Sticky Mobile ATC Bar ────────────────── */
.bfc4-sticky-bar { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--cv); border-top: 1px solid rgba(32,32,9,0.15); padding: 10px 16px; z-index: 100; align-items: center; gap: 12px; box-shadow: 0 -2px 12px rgba(0,0,0,0.08); }
.bfc4-sticky-info { flex: 1; min-width: 0; }
.bfc4-sticky-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--bk); }
.bfc4-sticky-meta { display: flex; align-items: center; gap: 6px; margin-top: 1px; }
.bfc4-sticky-grade { font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ch); }
.bfc4-sticky-price { font-size: 13px; font-weight: 700; color: var(--or); }
.bfc4-sticky-btn { background: var(--or); color: #fff; border: none; padding: 12px 24px; font-size: 10px; font-weight: 700; font-family: var(--sn); text-transform: uppercase; letter-spacing: 0.14em; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
.bfc4-sticky-btn:disabled { opacity: 0.5; cursor: not-allowed; }
@media (max-width: 900px) {
  .bfc4-sticky-bar.is-visible { display: flex; }
}
</style>

<div class="bfc4">

{%- comment -%} ── Collect film add-on blocks ── {%- endcomment -%}
{%- assign film_blocks = section.blocks | where: 'type', 'film_item' -%}

{%- comment -%} ── SPLIT: left image + right content ── {%- endcomment -%}
<div class="bfc4-split">

  {%- comment -%} LEFT: sticky slider {%- endcomment -%}
  <div class="bfc4-left" id="bfc4-top">
    {%- assign has_section_imgs = false -%}
    {%- for i in (1..5) -%}
      {%- assign img_key = 'slide_' | append: i -%}
      {%- if section.settings[img_key] != blank -%}{%- assign has_section_imgs = true -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_section_imgs -%}
      {%- assign slide_images = '' -%}
      {%- for i in (1..5) -%}
        {%- assign img_key = 'slide_' | append: i -%}
        {%- if section.settings[img_key] != blank -%}{%- assign slide_images = slide_images | append: '1' -%}{%- endif -%}
      {%- endfor -%}
      {%- assign total_slides = slide_images | size -%}

      <div class="bfc4-slides" id="bfc4-slides">
        {%- for i in (1..5) -%}
          {%- assign img_key = 'slide_' | append: i -%}
          {%- assign img_mob_key = 'slide_' | append: i | append: '_mobile' -%}
          {%- assign img_val = section.settings[img_key] -%}
          {%- assign img_mob = section.settings[img_mob_key] -%}
          {%- if img_val != blank -%}
            <div class="bfc4-slide">
              <picture>
                {%- if img_mob != blank -%}
                  <source media="(max-width: 767px)" srcset="{{ img_mob | image_url: width: 900 }}"/>
                {%- endif -%}
                <img
                  src="{{ img_val | image_url: width: 900 }}"
                  srcset="{{ img_val | image_url: width: 600 }} 600w, {{ img_val | image_url: width: 900 }} 900w, {{ img_val | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 900px) 100vw, 50vw"
                  alt="{{ product.title | escape }}"
                  width="900" height="900"
                  {%- if i == 1 -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
                />
              </picture>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- assign media_images = product.media | where: 'media_type', 'image' -%}
      {%- assign total_slides = media_images | size -%}

      <div class="bfc4-slides" id="bfc4-slides">
        {%- for media in media_images limit: 8 -%}
          <div class="bfc4-slide">
            <img
              src="{{ media | image_url: width: 900 }}"
              srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 900px) 100vw, 50vw"
              alt="{{ product.title | escape }}"
              width="900" height="900"
              {%- if forloop.first -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
            />
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if total_slides > 1 -%}
      <button class="bfc4-arrow is-prev" onclick="bfc4Slide(-1)" aria-label="Previous">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8L10 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
      <button class="bfc4-arrow is-next" onclick="bfc4Slide(1)" aria-label="Next">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 3L11 8L6 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
      <div class="bfc4-dots" id="bfc4-dots">
        {%- for i in (1..total_slides) -%}
          <button class="bfc4-dot{% if forloop.first %} is-active{% endif %}" onclick="bfc4GoTo({{ forloop.index0 }})"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} RIGHT: product content {%- endcomment -%}
  <div class="bfc4-right">

    {%- comment -%} 1. Product header {%- endcomment -%}
    <div class="bfc4-header">
      <span class="bfc4-eyebrow">Super 8 Camera — Professionally Refurbished &middot; 6-Month Warranty</span>
      <h1 class="bfc4-title">{{ product.title }}</h1>
      {%- liquid
        assign desc_text = ''
        assign desc_full = ''
        if product.description contains 'bfc-desc-specs__desc'
          assign desc_full = product.description | split: 'bfc-desc-specs__desc">' | last | split: '</div>' | first | strip_html | strip
        endif
        if desc_full == blank
          assign desc_full = product.description | split: 'bfc-desc-specs__grid' | first | strip_html | strip
        endif
        if desc_full == blank
          assign desc_full = product.description | strip_html | strip
        endif

        assign desc_text = desc_full

        comment
          Parse inline spec values from description as fallbacks.
          Format: "Label: value" terminated by next "Label:" or end of string.
        endcomment

        assign d_film_type = ''
        if desc_full contains 'Film Type:'
          assign d_film_type = desc_full | split: 'Film Type:' | last
          assign d_chop = 'FPS:,Lens:,Shutter Speed:,Aperture:,Focus:,Battery:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_film_type contains c
              assign d_film_type = d_film_type | split: c | first
            endif
          endfor
          assign d_film_type = d_film_type | strip
        endif

        assign d_fps = ''
        if desc_full contains 'FPS:'
          assign d_fps = desc_full | split: 'FPS:' | last
          assign d_chop = 'Lens:,Shutter Speed:,Aperture:,Focus:,Battery:,Film Type:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_fps contains c
              assign d_fps = d_fps | split: c | first
            endif
          endfor
          assign d_fps = d_fps | strip
        endif

        assign d_lens = ''
        if desc_full contains 'Lens:'
          assign d_lens = desc_full | split: 'Lens:' | last
          assign d_chop = 'FPS:,Shutter Speed:,Aperture:,Focus:,Battery:,Film Type:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_lens contains c
              assign d_lens = d_lens | split: c | first
            endif
          endfor
          assign d_lens = d_lens | strip
        endif

        assign d_shutter = ''
        if desc_full contains 'Shutter Speed:'
          assign d_shutter = desc_full | split: 'Shutter Speed:' | last
          assign d_chop = 'FPS:,Lens:,Aperture:,Focus:,Battery:,Film Type:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_shutter contains c
              assign d_shutter = d_shutter | split: c | first
            endif
          endfor
          assign d_shutter = d_shutter | strip
        endif

        assign d_aperture = ''
        if desc_full contains 'Aperture:'
          assign d_aperture = desc_full | split: 'Aperture:' | last
          assign d_chop = 'FPS:,Lens:,Shutter Speed:,Focus:,Battery:,Film Type:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_aperture contains c
              assign d_aperture = d_aperture | split: c | first
            endif
          endfor
          assign d_aperture = d_aperture | strip
        endif

        assign d_focus = ''
        if desc_full contains 'Focus:'
          assign d_focus = desc_full | split: 'Focus:' | last
          assign d_chop = 'FPS:,Lens:,Shutter Speed:,Aperture:,Battery:,Film Type:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_focus contains c
              assign d_focus = d_focus | split: c | first
            endif
          endfor
          assign d_focus = d_focus | strip
        endif

        assign d_battery = ''
        if desc_full contains 'Battery:'
          assign d_battery = desc_full | split: 'Battery:' | last
          assign d_chop = 'FPS:,Lens:,Shutter Speed:,Aperture:,Focus:,Film Type:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_battery contains c
              assign d_battery = d_battery | split: c | first
            endif
          endfor
          assign d_battery = d_battery | strip
        endif

        assign d_metering = ''
        if desc_full contains 'Metering:'
          assign d_metering = desc_full | split: 'Metering:' | last
          assign d_chop = 'FPS:,Lens:,Shutter Speed:,Aperture:,Focus:,Battery:,Film Type:,Frame Rate:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_metering contains c
              assign d_metering = d_metering | split: c | first
            endif
          endfor
          assign d_metering = d_metering | strip
        endif

        assign d_zoom = ''
        if desc_full contains 'Zoom:'
          assign d_zoom = desc_full | split: 'Zoom:' | last
          assign d_chop = 'FPS:,Lens:,Shutter Speed:,Aperture:,Focus:,Battery:,Film Type:,Frame Rate:,Metering:,Filter Size:,Weight:,Sound:,Cartridge:' | split: ','
          for c in d_chop
            if d_zoom contains c
              assign d_zoom = d_zoom | split: c | first
            endif
          endfor
          assign d_zoom = d_zoom | strip
        endif

        assign d_sound = ''
        if desc_full contains 'Sound:'
          assign d_sound = desc_full | split: 'Sound:' | last
          assign d_chop = 'FPS:,Lens:,Shutter Speed:,Aperture:,Focus:,Battery:,Film Type:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Cartridge:' | split: ','
          for c in d_chop
            if d_sound contains c
              assign d_sound = d_sound | split: c | first
            endif
          endfor
          assign d_sound = d_sound | strip
        endif

        comment
          Now apply fallbacks: if metafield is blank, use parsed value
        endcomment
        if spec_lens == blank and d_lens != ''
          assign spec_lens = d_lens
        endif
        if spec_fps == blank and d_fps != ''
          assign spec_fps = d_fps
        endif
        if spec_film == blank and d_film_type != ''
          assign spec_film = d_film_type
        endif
        if spec_sound == blank and d_sound != ''
          assign spec_sound = d_sound
        endif
        if spec_battery == blank and d_battery != ''
          assign spec_battery = d_battery
        endif
        if spec_meter == blank and d_metering != ''
          assign spec_meter = d_metering
        endif
        if spec_focus == blank and d_focus != ''
          assign spec_focus = d_focus
        endif
        if spec_zoom == blank and d_zoom != ''
          assign spec_zoom = d_zoom
        endif
        if spec_speeds == blank and d_shutter != ''
          assign spec_speeds = d_shutter
        endif

        comment
          Also store aperture parsed from desc (no metafield for it by default)
        endcomment
        assign spec_aperture = d_aperture

        comment
          Trim desc_text at the first spec label so only prose shows
        endcomment
        assign trim_labels = 'Film Type:,FPS:,Lens:,Shutter Speed:,Aperture:,Focus:,Battery:,Frame Rate:,Metering:,Filter Size:,Weight:,Zoom:,Sound:,Cartridge:,Film Format:' | split: ','
        for label in trim_labels
          if desc_text contains label
            assign desc_text = desc_text | split: label | first | strip
          endif
        endfor
      -%}
      <p class="bfc4-kit-desc">{{ desc_text }}</p>
      <div class="bfc4-fps-badge">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="#fff" stroke-width="1"/><circle cx="8" cy="8" r="2" fill="#fff"/><path d="M8 1.5V4M8 12V14.5M1.5 8H4M12 8H14.5" stroke="#fff" stroke-width="0.8"/></svg>
        True 24 FPS &mdash; Modified &amp; calibrated for cinema-standard frame rate
      </div>
    </div>

    {%- comment -%} 2. Add Film section — compact tiles {%- endcomment -%}
    {%- if film_blocks.size > 0 -%}
      <div class="bfc4-film-head">
        <span class="bfc4-film-eyebrow">Add Film</span>
        <span class="bfc4-film-note">Grab a cartridge so you're ready to shoot on arrival.</span>
      </div>

      <div class="bfc4-film-tiles" id="bfc4-film-tiles">
        {%- for block in film_blocks -%}
          {%- if block.settings.product == blank -%}{% continue %}{%- endif -%}
          {%- assign fp = block.settings.product -%}
          {%- assign fv = fp.variants.first -%}
          {%- unless fv.available -%}
            {%- for v in fp.variants -%}
              {%- if v.available -%}{%- assign fv = v -%}{%- break -%}{%- endif -%}
            {%- endfor -%}
          {%- endunless -%}
          {%- assign f_disc = block.settings.discount_percent -%}
          {%- if f_disc > 0 -%}
            {%- assign f_df = f_disc | times: 1.0 | divided_by: 100 -%}
            {%- assign f_sv = fv.price | times: f_df | floor -%}
            {%- assign f_sale = fv.price | minus: f_sv -%}
          {%- else -%}
            {%- assign f_sale = fv.price -%}
          {%- endif -%}
          {%- assign f_tile_id = 'bfc4-film-' | append: forloop.index -%}
          {%- assign f_popup_imgs = '' -%}
          {%- for media in fp.media limit: 4 -%}
            {%- if media.media_type == 'image' -%}
              {%- assign f_img_url = media | image_url: width: 600 -%}
              {%- if f_popup_imgs == '' -%}{%- assign f_popup_imgs = f_img_url -%}
              {%- else -%}{%- assign f_popup_imgs = f_popup_imgs | append: '||' | append: f_img_url -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          <div class="bfc4-film-tile{% unless fv.available %} is-oos{% endunless %}"
            id="{{ f_tile_id }}"
            data-variant-id="{{ fv.id }}"
            data-product-title="{{ fp.title | escape }}"
            data-orig="{{ fv.price | default: 0 }}"
            data-sale="{{ f_sale | default: 0 }}"
            data-disc="{{ f_disc | default: 0 }}"
            data-img="{{ fp.featured_image | image_url: width: 400 }}"
            {% if fv.available %}onclick="bfc4FilmToggle(this)"{% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="bfc4-film-tile-img">
              {%- if fp.featured_image -%}
                <img src="{{ fp.featured_image | image_url: width: 400 }}" alt="{{ fp.title | escape }}" loading="lazy"/>
              {%- endif -%}
              {%- unless fv.available -%}<span class="bfc4-film-tile-oos">Out of Stock</span>{%- endunless -%}
            </div>
            <div class="bfc4-film-tile-body">
              <span class="bfc4-film-tile-name">{{ block.settings.custom_label | default: fp.title }}</span>
              <span class="bfc4-film-tile-price">{{ fv.price | money }}</span>
            </div>
            <div class="bfc4-film-tile-sel-check">&#10003;</div>
          </div>
          <div id="ba-popup-data-{{ f_tile_id }}" style="display:none"
            data-title="{{ fp.title | escape }}"
            data-desc="{{ fp.description | strip_html | escape }}"
            data-imgs="{{ f_popup_imgs | escape }}"
          ></div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} 4. Grade selector + price + ATC {%- endcomment -%}
    <div class="bfc4-buy">
      {%- if product.variants.size > 1 -%}
        <div class="bfc4-grade-compact">
          <span class="bfc4-grade-label">Grade</span>
          <div class="bfc4-grade-row">
            {%- for variant in product.variants -%}
              <button
                class="bfc4-var-btn{% if variant.id == current_variant.id %} is-active{% endif %}"
                data-variant-id="{{ variant.id }}"
                data-variant-price="{{ variant.price }}"
                data-variant-price-fmt="{{ variant.price | money }}"
                data-variant-available="{{ variant.available }}"
                onclick="bfc4SelectVariant(this)"
                {%- unless variant.available -%}disabled{%- endunless -%}
              >{{ variant.title }}{%- unless variant.available -%}<span class="bfc4-var-btn-oos">Out of Stock</span>{%- endunless -%}</button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
      <div class="bfc4-price-row">
        <span class="bfc4-price-label">Total</span>
        <span class="bfc4-price" id="bfc4-total">{{ current_variant.price | money }}</span>
      </div>

      <button class="bfc4-atc" id="bfc4-atc" onclick="bfc4AddToCart()">
        <span id="bfc4-atc-text">Add to Cart</span>
      </button>
      {%- if film_blocks.size > 0 -%}
        <button class="bfc4-cam-only" onclick="bfc4CameraOnly()">Camera Only &mdash; {{ current_variant.price | money }}</button>
      {%- endif -%}
    </div>

    {%- comment -%} Extended Warranty
        Tier pricing/variant IDs from snippets/bfc-warranty-tiers.liquid.
        Super 8 borrows SLR/Rangefinder pricing — base warranty is already
        6 months, so cameras now offer a single +6 month extension (1 year total). {%- endcomment -%}
    {%- assign cam_price = current_variant.price -%}
    {% include 'bfc-warranty-tiers', category: 'slr', cam_price: cam_price %}
    {%- liquid
      assign w12_vid = w_w12_vid
      assign w12_price = w_w12_price
    -%}
    <div class="ba-ext-warranty">
      <div class="ba-ext-w-head">
        <span class="ba-ext-w-eyebrow">Extended Warranty</span>
        <button class="bfc4-tile-info" onclick="baOpenPopup('ba-ext-w-popup')" aria-label="Extended warranty details" style="position:relative;bottom:auto;right:auto;flex-shrink:0;">
          <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg>
        </button>
      </div>
      <div class="ba-ext-w-baseline">
        <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>Your camera includes a <strong>6-month warranty</strong> &mdash; extend to a full year below:</span>
      </div>
      <div class="ba-ext-w-options ba-ext-w-options--single">
        <button class="ba-ext-w-btn" data-months="6" data-total="12" data-price="{{ w12_price }}" data-variant-id="{{ w12_vid }}" onclick="bfc4SelectWarranty(this)">
          <span class="ba-ext-w-extend">+6 months</span>
          <span class="ba-ext-w-months">1 year total</span>
          <span class="ba-ext-w-price">+{{ w12_price | money_without_trailing_zeros }}</span>
          <span class="ba-ext-w-acc">+ Accidental</span>
        </button>
      </div>
      <button class="ba-ext-w-none" id="ba-ext-w-clear" onclick="bfc4ClearWarranty()">&times; Remove Extended Warranty</button>
    </div>
    <div id="ba-popup-data-ba-ext-w-popup" style="display:none"
      data-title="Extended Warranty"
      data-desc="Your camera includes a 6-month warranty. Extended warranty adds 6 months on top, for a full year of coverage from your purchase date. Extended warranty covers any issues including accidental damage, which the standard warranty does not cover. Approved claims are repaired at no cost. If the camera cannot be repaired, you will receive a BFC gift card at the value you paid, redeemable on any camera in our shop. Warranties are non-transferable and apply to the original purchaser only. Must be purchased within 30 days of your camera purchase."
      data-imgs=""
    ></div>

  </div>{%- comment -%} /bfc4-right {%- endcomment -%}
</div>{%- comment -%} /bfc4-split {%- endcomment -%}

<div class="bfc4-below">

  {%- comment -%} Shot on / filmed with {%- endcomment -%}
  {%- if g1 or g2 or g3 -%}
  <div class="ba-shot">
    <div class="ba-shot-head">
      <h2 class="ba-shot-title">Filmed with {{ product.title }}</h2>
      <span class="ba-shot-sub">Stills from Super 8 footage shot on this model</span>
    </div>
    <div class="ba-shot-grid">
      {%- if g1 -%}<a href="{{ g1 | image_url: width: 1200 }}" target="_blank"><img src="{{ g1 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g2 -%}<a href="{{ g2 | image_url: width: 1200 }}" target="_blank"><img src="{{ g2 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g3 -%}<a href="{{ g3 | image_url: width: 1200 }}" target="_blank"><img src="{{ g3 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g4 -%}<a href="{{ g4 | image_url: width: 1200 }}" target="_blank"><img src="{{ g4 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g5 -%}<a href="{{ g5 | image_url: width: 1200 }}" target="_blank"><img src="{{ g5 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g6 -%}<a href="{{ g6 | image_url: width: 1200 }}" target="_blank"><img src="{{ g6 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ════════════════════════════════════════════════
       CHAPTER — Restoration process + Camera specs (combined, dark).
       Matches the v4 below-fold design.
       ════════════════════════════════════════════════ {%- endcomment -%}
  <div class="bfc4-chapter" id="bfc4-chapter">
    <div class="bfc4-chapter-body" id="bfc4-chapter-body">
      <div class="bfc4-chapter-grid">

        {%- comment -%} ── LEFT: HEADER ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-header">
          <h2 class="bfc4-chapter-title">{{ product.title | escape }}</h2>
          <p class="bfc4-chapter-sub">We started Brooklyn Film Camera to take the guesswork out of buying a Super 8 camera. Most decades-old movie cameras were never built to run at cinema-standard 24fps, and a wipe-down is never enough to make one shoot like it did the day it left the factory. So we do the real work.</p>
          <button type="button" class="bfc4-chapter-toggle" id="bfc4-chapter-toggle" aria-expanded="false" aria-controls="bfc4-chapter-body" onclick="bfc4ToggleChapter()">
            <span class="bfc4-chapter-toggle-text">View full process &amp; all specs</span>
            <svg class="bfc4-chapter-toggle-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {%- comment -%} Per-column toggle (mobile only) {%- endcomment -%}
          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide story" data-closed-label="View full story" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View full story</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="bfc4-chapter-extra bfc4-chapter-header-extra">
            {%- if section.settings.restoration_photo != blank -%}
              <div class="ba-restore-photo">
                <img src="{{ section.settings.restoration_photo | image_url: width: 1200 }}" alt="Restoration in progress at Brooklyn Film Camera" loading="lazy"/>
              </div>
            {%- endif -%}

            {%- if section.settings.restoration_prose != blank -%}
              <div class="ba-restore-prose">{{ section.settings.restoration_prose }}</div>
            {%- else -%}
              <div class="ba-restore-prose">
                <p>Every Super 8 camera we sell passes through our in-house technicians. We modify and calibrate the mechanism to true 24fps, service the motor and metering, replace seals and aged components, and bench-test every function before anything ships.</p>
                <p>You're not gambling on whether the camera works. You're getting a tool brought back to pristine condition by people who've spent careers learning how.</p>
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ── MIDDLE: PROCESS ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-process" id="ba-restore">
          <div class="bfc4-chapter-col-head">
            <span class="bfc4-chapter-col-ey">Our Process</span>
            <h3 class="bfc4-chapter-col-title">Restored &amp; 24fps calibrated</h3>
            <p class="bfc4-chapter-col-sub">Each camera goes through four checkpoints before it ships.</p>
          </div>

          <ul class="bfc4-chapter-process-list">
            <li><span class="num">01</span><span>Complete disassembly &amp; cleaning</span></li>
            <li><span class="num">02</span><span>True 24fps modification</span></li>
            <li><span class="num">03</span><span>Full mechanical &amp; electrical inspection</span></li>
            <li><span class="num">04</span><span>Tested on professional bench equipment</span></li>
          </ul>

          {%- comment -%} Per-column toggle (mobile only) {%- endcomment -%}
          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide steps" data-closed-label="View all steps" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View all steps</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="bfc4-chapter-extra bfc4-chapter-process-extra">
            <div class="bfc4-chapter-process-detail">
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">01</span>
                <div class="body"><strong>Complete Disassembly &amp; Cleaning</strong><p>Every camera is fully taken apart, cleaned inside and out, and carefully reassembled. No spot-checks, no shortcuts.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">02</span>
                <div class="body"><strong>True 24fps Modification</strong><p>Most vintage Super 8 cameras were never built to shoot at cinema-standard 24fps. We modify and calibrate every camera so yours does.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">03</span>
                <div class="body"><strong>Full Mechanical &amp; Electrical Inspection</strong><p>Motor, metering, optics, film path. Every component is tested and verified, and fixed before it ships.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">04</span>
                <div class="body"><strong>Final QC</strong><p>Frame rate, exposure, and film path are all verified on professional bench equipment before we pack and ship.</p></div>
              </div>
            </div>
          </div>
        </div>

        {%- comment -%} ── RIGHT: SPECS ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-specs">
          <div class="bfc4-chapter-col-head">
            <h3 class="bfc4-chapter-col-title">Specifications</h3>
            <p class="bfc4-chapter-col-sub">The exact technical details of this camera.</p>
          </div>

          <div class="bfc4-chapter-specs-quick">
            {%- assign qs_count = 0 -%}
            {%- if spec_lens != blank and qs_count < 4 -%}
              <div><span class="key">Lens</span><span class="val">{{ spec_lens }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_fps != blank and qs_count < 4 -%}
              <div><span class="key">Frame Rate</span><span class="val">{{ spec_fps }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_film != blank and qs_count < 4 -%}
              <div><span class="key">Film Format</span><span class="val">{{ spec_film }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if qs_count < 4 -%}
              <div><span class="key">Condition</span><span class="val">24fps Calibrated</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_zoom != blank and qs_count < 4 -%}
              <div><span class="key">Zoom</span><span class="val">{{ spec_zoom }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_cart != blank and qs_count < 4 -%}
              <div><span class="key">Cartridge</span><span class="val">{{ spec_cart }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_sound != blank and qs_count < 4 -%}
              <div><span class="key">Sound</span><span class="val">{{ spec_sound }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_meter != blank and qs_count < 4 -%}
              <div><span class="key">Metering</span><span class="val">{{ spec_meter }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
          </div>

          {%- comment -%} Per-column toggle (mobile only) {%- endcomment -%}
          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide specs" data-closed-label="View all specs" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View all specs</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="bfc4-chapter-extra bfc4-chapter-specs-extra">
            <div class="bfc4-chapter-specs-full">
              {%- if spec_lens    != blank -%}<div><span class="key">Lens</span><span class="val">{{ spec_lens }}</span></div>{%- endif -%}
              {%- if spec_zoom    != blank -%}<div><span class="key">Zoom</span><span class="val">{{ spec_zoom }}</span></div>{%- endif -%}
              {%- if spec_fps     != blank -%}<div><span class="key">Frame Rate</span><span class="val">{{ spec_fps }}</span></div>{%- endif -%}
              {%- if spec_film    != blank -%}<div><span class="key">Film Format</span><span class="val">{{ spec_film }}</span></div>{%- endif -%}
              {%- if spec_cart    != blank -%}<div><span class="key">Cartridge</span><span class="val">{{ spec_cart }}</span></div>{%- endif -%}
              {%- if spec_sound   != blank -%}<div><span class="key">Sound</span><span class="val">{{ spec_sound }}</span></div>{%- endif -%}
              {%- if spec_speeds  != blank -%}<div><span class="key">Shutter</span><span class="val">{{ spec_speeds }}</span></div>{%- endif -%}
              {%- if spec_meter   != blank -%}<div><span class="key">Metering</span><span class="val">{{ spec_meter }}</span></div>{%- endif -%}
              {%- if spec_focus   != blank -%}<div><span class="key">Focus</span><span class="val">{{ spec_focus }}</span></div>{%- endif -%}
              {%- if spec_filter  != blank -%}<div><span class="key">Filter Size</span><span class="val">{{ spec_filter }}</span></div>{%- endif -%}
              {%- if spec_battery != blank -%}<div><span class="key">Battery</span><span class="val">{{ spec_battery }}</span></div>{%- endif -%}
              {%- if spec_weight  != blank -%}<div><span class="key">Weight</span><span class="val">{{ spec_weight }}</span></div>{%- endif -%}
              <div><span class="key">Condition</span><span class="val">Professionally Refurbished, 24fps Calibrated</span></div>
            </div>
          </div>
        </div>

      </div>
    </div>{%- comment -%} /bfc4-chapter-body {%- endcomment -%}
  </div>{%- comment -%} /bfc4-chapter {%- endcomment -%}

  {%- comment -%} Warranty policy (single column, matches v4) {%- endcomment -%}
  <div class="ba-policy" id="bfc4-policy-section">
    <div class="ba-policy-col">
      <span class="ba-policy-ey">Warranty</span>
      <h2 class="ba-policy-title">We stand behind every camera.</h2>
      <div class="ba-policy-pill">
        <svg width="10" height="10" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        6-Month Warranty Included
      </div>
      <div class="ba-policy-body">
        <p>Every Super 8 camera we sell includes a <strong>6-month warranty</strong> covering mechanical and electrical defects. If something goes wrong, we'll repair it or replace it at no cost.</p>
        <p style="margin-top:10px">To open a claim, visit the Shipping Label tab in your <a href="https://account.brooklynfilmcamera.com" style="color:inherit;text-decoration:underline;text-underline-offset:2px;">BFC account</a>, or come into the store anytime.</p>
        <p style="margin-top:10px;color:rgba(78,71,65,0.6);font-size:11px">Return shipping is covered by BFC within the first 30 days. After 30 days, the buyer is responsible for return shipping on warranty claims.</p>
        <p style="margin-top:12px"><a href="https://brooklynfilmcamera.com/pages/warranty" style="font-size:11px;color:var(--or);font-weight:600;letter-spacing:0.06em;text-decoration:underline;text-underline-offset:2px;">View full warranty policy &rsaquo;</a></p>
      </div>
    </div>
  </div>

</div>{%- comment -%} /bfc4-below {%- endcomment -%}

{%- comment -%} Sticky Mobile ATC Bar {%- endcomment -%}
