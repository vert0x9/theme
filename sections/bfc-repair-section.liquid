{% comment %} BFC Repair Section v2 — redesigned for CRO {% endcomment %}
<section class="bfc-repair" data-section-id="{{ section.id }}">

{%- style -%}
/* ============================================================
   BFC REPAIR SECTION v2 — Brand Tokens & Base
   ============================================================ */
.bfc-repair {
  --or:          #E36E15;
  --go:          #F4A027;
  --cv:          #F8F6EE;
  --ce:          #ABCC99;
  --bk:          #202009;
  --ch:          #4E4741;
  --db:          #5A3E2D;
  --mg:          #E3DDDA;
  --mn:          #FFEACC;
  --sr:          'Cormorant Garamond', serif;
  --sn:          'Poppins', sans-serif;
  --ease:        cubic-bezier(.22, 1, .36, 1);

  font-family:   var(--sn);
  color:         var(--bk);
  background:    var(--cv);
}

.bfc-repair *,
.bfc-repair *::before,
.bfc-repair *::after { box-sizing: border-box; }

.bfc-repair .bfc-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
}
@media (max-width: 768px) {
  .bfc-repair .bfc-inner { padding: 0 20px; }
}

/* ── Labels ── */
.bfc-repair .bfc-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--or);
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}
.bfc-repair .bfc-label::before {
  content: '';
  display: block;
  width: 24px;
  height: 1.5px;
  background: var(--or);
  flex-shrink: 0;
}
.bfc-repair .bfc-label--light { color: var(--go); }
.bfc-repair .bfc-label--light::before { background: var(--go); }

/* ── Typography ── */
.bfc-repair h2.bfc-h2 {
  font-family: var(--sr);
  font-weight: 500;
  font-size: clamp(32px, 3.8vw, 52px);
  line-height: 1.05;
  color: var(--bk);
  margin: 0 0 16px;
}
.bfc-repair h3.bfc-h3 {
  font-family: var(--sr);
  font-weight: 500;
  font-size: clamp(20px, 2.4vw, 28px);
  line-height: 1.15;
  margin: 0 0 8px;
}

/* ── Buttons ── */
.bfc-repair .bfc-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--sn);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 14px 32px;
  min-height: 44px;
  border: 2px solid currentColor;
  cursor: pointer;
  transition: background 180ms var(--ease), color 180ms var(--ease), border-color 180ms var(--ease);
  white-space: nowrap;
}
.bfc-repair .bfc-btn--primary {
  background: var(--or);
  color: #fff;
  border-color: var(--or);
}
.bfc-repair .bfc-btn--primary:hover {
  background: var(--db);
  border-color: var(--db);
}
.bfc-repair .bfc-btn--outline {
  background: transparent;
  color: var(--bk);
  border-color: var(--bk);
}
.bfc-repair .bfc-btn--outline:hover {
  background: var(--bk);
  color: var(--cv);
}
.bfc-repair .bfc-btn--outline-light {
  background: transparent;
  color: var(--cv);
  border-color: var(--cv);
}
.bfc-repair .bfc-btn--outline-light:hover {
  background: var(--cv);
  color: var(--bk);
}

/* ── Scroll reveal ── */
.bfc-repair .bfc-reveal {
  opacity: 0;
  transform: translateY(14px);
  transition:
    opacity 600ms var(--ease) var(--bfc-delay, 0ms),
    transform 600ms var(--ease) var(--bfc-delay, 0ms);
  will-change: opacity, transform;
}
.bfc-repair .bfc-reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}
@media (prefers-reduced-motion: reduce) {
  .bfc-repair .bfc-reveal {
    transition: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
}


/* ============================================================
   0. HERO
   ============================================================ */
.bfc-hero {
  position: relative;
  overflow: hidden;
  min-height: 560px;
  display: flex;
  align-items: center;
  background: #000;
}

.bfc-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.bfc-hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center right;
  display: block;
}
.bfc-hero__bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, rgba(0,0,0,0.88) 35%, rgba(0,0,0,0.4) 65%, rgba(0,0,0,0.05) 100%);
}

.bfc-hero__inner {
  position: relative;
  z-index: 1;
  max-width: 580px;
  padding: 96px 0;
}

.bfc-hero__content h1 {
  font-family: var(--sr);
  font-weight: 500;
  font-size: clamp(40px, 5vw, 68px);
  line-height: 1.0;
  color: var(--cv);
  margin: 0 0 20px;
}

.bfc-hero__tagline {
  font-size: 16px;
  line-height: 1.65;
  color: rgba(248, 246, 238, 0.7);
  margin: 0 0 36px;
  white-space: pre-line;
}

.bfc-hero__actions {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.bfc-hero__proof {
  font-size: 11px;
  color: rgba(248, 246, 238, 0.32);
  letter-spacing: 0.05em;
  margin-top: 24px;
}

@media (max-width: 900px) {
  .bfc-hero {
    min-height: 420px;
  }
  .bfc-hero__bg::after {
    background: linear-gradient(to bottom, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.8) 60%, rgba(0,0,0,0.95) 100%);
  }
  .bfc-hero__inner {
    padding: 56px 0;
    max-width: 100%;
  }
}


/* ============================================================
   TRUST BAR
   ============================================================ */
.bfc-trust {
  background: var(--mg);
  border-bottom: 1px solid rgba(90, 62, 45, 0.1);
}

.bfc-trust__inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  divide-color: transparent;
}

.bfc-trust__item {
  padding: 22px 28px;
  display: flex;
  align-items: center;
  gap: 14px;
  border-right: 1px solid rgba(90, 62, 45, 0.1);
}
.bfc-trust__item:last-child { border-right: 0; }

.bfc-trust__icon {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  color: var(--or);
}

.bfc-trust__text strong {
  display: block;
  font-family: var(--sn);
  font-weight: 600;
  font-size: 12px;
  color: var(--bk);
  letter-spacing: 0.02em;
}

.bfc-trust__text span {
  font-size: 11px;
  color: var(--ch);
  line-height: 1.4;
}

@media (max-width: 900px) {
  .bfc-trust__inner {
    grid-template-columns: repeat(2, 1fr);
  }
  .bfc-trust__item:nth-child(2) { border-right: 0; }
  .bfc-trust__item:nth-child(3) { border-top: 1px solid rgba(90, 62, 45, 0.1); }
  .bfc-trust__item:nth-child(4) { border-top: 1px solid rgba(90, 62, 45, 0.1); border-right: 0; }
}
@media (max-width: 540px) {
  .bfc-trust__inner { grid-template-columns: 1fr; }
  .bfc-trust__item { border-right: 0 !important; border-top: 1px solid rgba(90, 62, 45, 0.1); }
  .bfc-trust__item:first-child { border-top: 0; }
}


/* ============================================================
   1. HOW IT WORKS — Condensed 3-step
   ============================================================ */
.bfc-steps {
  padding: 80px 0;
  background: var(--cv);
  border-bottom: 1px solid var(--mg);
}

.bfc-steps__head {
  text-align: center;
  max-width: 560px;
  margin: 0 auto 56px;
}
.bfc-steps__head .bfc-label {
  justify-content: center;
}
.bfc-steps__head .bfc-label::before { display: none; }

.bfc-steps__track {
  display: grid;
  grid-template-columns: 1fr 32px 1fr 32px 1fr;
  align-items: start;
  gap: 0;
  margin-bottom: 48px;
}

.bfc-step-v2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 0 16px;
  min-width: 0;
}

.bfc-step-v2 > div {
  width: 100%;
}

.bfc-step-v2__num {
  width: 48px;
  height: 48px;
  background: var(--bk);
  color: var(--cv);
  font-family: var(--sr);
  font-size: 20px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.bfc-step-v2__title {
  font-family: var(--sn);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--bk);
  margin-bottom: 10px;
}

.bfc-step-v2__body {
  font-size: 13px;
  line-height: 1.7;
  color: var(--ch);
}

/* Connector lines */
.bfc-steps__connector {
  display: flex;
  align-items: flex-start;
  padding-top: 48px; /* half of 48px num box = vertically centers with number */
}
.bfc-steps__connector::before {
  content: '';
  display: block;
  width: 100%;
  height: 1px;
  background: var(--mg);
}

.bfc-steps__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 12px;
  text-align: center;
}

.bfc-steps__cta-note {
  font-size: 12px;
  color: var(--ch);
}

/* Sub-steps detail — collapsible */
.bfc-steps__detail {
  margin-top: 48px;
  padding-top: 40px;
  border-top: 1px solid var(--mg);
}

.bfc-steps__detail-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: none;
  border: 0;
  font-family: var(--sn);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ch);
  cursor: pointer;
  padding: 0;
  width: 100%;
  margin-bottom: 0;
}
.bfc-steps__detail-toggle svg {
  width: 14px;
  height: 14px;
  transition: transform 240ms var(--ease);
  color: var(--or);
}
.bfc-steps__detail-toggle.is-open svg {
  transform: rotate(180deg);
}

.bfc-steps__substeps {
  overflow: hidden;
  max-height: 0;
  transition: max-height 360ms var(--ease), opacity 280ms ease;
  opacity: 0;
}
.bfc-steps__substeps.is-open {
  max-height: 800px;
  opacity: 1;
}

.bfc-substeps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--mg);
  border: 1px solid var(--mg);
  margin-top: 28px;
}

.bfc-substep {
  background: var(--cv);
  padding: 22px 24px;
  display: grid;
  grid-template-columns: 28px 1fr;
  column-gap: 12px;
  row-gap: 4px;
  align-items: start;
  position: relative;
  overflow: hidden;
}
.bfc-substep::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 3px;
  background: var(--or);
  transform: scaleY(0);
  transform-origin: top;
  transition: transform 260ms var(--ease);
}
.bfc-substep:hover::before { transform: scaleY(1); }

.bfc-substep__num {
  font-family: var(--sr);
  font-size: 22px;
  font-weight: 500;
  color: var(--or);
  opacity: 0.5;
  grid-column: 1;
  grid-row: 1 / 3;
  padding-top: 2px;
}
.bfc-substep__title {
  font-family: var(--sn);
  font-weight: 600;
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--bk);
  grid-column: 2;
}
.bfc-substep__body {
  font-size: 12px;
  line-height: 1.6;
  color: var(--ch);
  grid-column: 2;
}

@media (max-width: 900px) {
  .bfc-steps__track {
    grid-template-columns: 1fr;
    gap: 0;
  }
  .bfc-steps__connector { display: none; }
  .bfc-step-v2 {
    flex-direction: row;
    text-align: left;
    align-items: flex-start;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--mg);
  }
  .bfc-step-v2:last-child { border-bottom: 0; }
  .bfc-step-v2__num {
    margin-bottom: 0;
    flex-shrink: 0;
  }
  .bfc-substeps-grid {
    grid-template-columns: 1fr;
  }
}


/* ============================================================
   2. WHAT WE REPAIR — Unified camera grid with capability tags
   ============================================================ */
.bfc-what {
  padding: 80px 0;
  background: var(--bk);
}

.bfc-what__head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: end;
  margin-bottom: 56px;
}

.bfc-what__head h2.bfc-h2 { color: var(--cv); margin-bottom: 8px; }
.bfc-what__head .bfc-label { color: var(--go); }
.bfc-what__head .bfc-label::before { background: var(--go); }

.bfc-what__desc {
  font-size: 14px;
  line-height: 1.75;
  color: rgba(248, 246, 238, 0.55);
  margin: 0;
  align-self: end;
}

/* Unified grid */
.bfc-camera-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.06);
  margin-bottom: 40px;
}

.bfc-camera-card {
  background: rgba(248, 246, 238, 0.03);
  padding: 28px 24px;
  position: relative;
  transition: background 200ms;
}
.bfc-camera-card:hover {
  background: rgba(248, 246, 238, 0.07);
}

.bfc-camera-card__title {
  font-family: var(--sr);
  font-weight: 500;
  font-size: 20px;
  color: var(--cv);
  margin: 0 0 8px;
  padding-right: 60px; /* room for badge */
}

.bfc-camera-card__body {
  font-size: 12px;
  line-height: 1.65;
  color: rgba(248, 246, 238, 0.5);
  margin-bottom: 14px;
}

/* Capability badges */
.bfc-camera-card__badges {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.bfc-badge {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 3px 8px;
  border: 1px solid currentColor;
}
.bfc-badge--cla {
  color: var(--go);
  border-color: rgba(244, 160, 39, 0.4);
}
.bfc-badge--seal {
  color: var(--ce);
  border-color: rgba(171, 204, 153, 0.35);
}
.bfc-badge--mech {
  color: rgba(248, 246, 238, 0.4);
  border-color: rgba(248, 246, 238, 0.15);
}

/* Service matrix — à la carte */
.bfc-services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.06);
  margin-bottom: 40px;
}

.bfc-service-card {
  background: rgba(248, 246, 238, 0.03);
  padding: 24px;
}

.bfc-service-card__title {
  font-family: var(--sn);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--cv);
  margin-bottom: 6px;
}

.bfc-service-card__note {
  font-size: 12px;
  color: rgba(248, 246, 238, 0.45);
  line-height: 1.6;
}

.bfc-what__cta {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.bfc-what__cta-note {
  font-size: 12px;
  color: rgba(248, 246, 238, 0.4);
}

@media (max-width: 900px) {
  .bfc-what__head {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .bfc-camera-grid,
  .bfc-services-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 540px) {
  .bfc-camera-grid,
  .bfc-services-grid {
    grid-template-columns: 1fr;
  }
}


/* ============================================================
   3. PRICING
   ============================================================ */
.bfc-pricing {
  padding: 96px 0;
  background: var(--cv);
  border-top: 1px solid var(--mg);
  border-bottom: 1px solid var(--mg);
}

.bfc-pricing__head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: end;
  margin-bottom: 12px;
}

.bfc-pricing__head h2.bfc-h2 { margin-bottom: 0; }

.bfc-pricing__note-inline {
  font-size: 14px;
  line-height: 1.7;
  color: var(--ch);
  align-self: end;
}

/* Trust callout above grid */
.bfc-pricing__assurance {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 12px;
  color: var(--ch);
  margin-bottom: 40px;
  padding: 14px 18px;
  background: var(--mn);
  border-left: 3px solid var(--or);
}
.bfc-pricing__assurance svg {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  color: var(--or);
}

.bfc-pricing__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--mg);
  border: 1px solid var(--mg);
  margin-bottom: 32px;
}

.bfc-price-card {
  background: var(--cv);
  padding: 36px 28px;
  border-top: 3px solid var(--mg);
  transition: border-color 200ms;
}
.bfc-price-card:hover { border-color: var(--or); }

.bfc-price-card__price {
  font-family: var(--sr);
  font-weight: 500;
  font-size: 38px;
  line-height: 1;
  color: var(--bk);
  margin-bottom: 10px;
}

.bfc-price-card__service {
  font-family: var(--sn);
  font-weight: 600;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ch);
}

.bfc-pricing__cta {
  display: flex;
  align-items: center;
  gap: 20px;
}

@media (max-width: 900px) {
  .bfc-pricing__head { grid-template-columns: 1fr; gap: 16px; }
  .bfc-pricing__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .bfc-pricing__grid { grid-template-columns: 1fr; }
}


/* ============================================================
   4. REVIEWS STRIP
   ============================================================ */
.bfc-reviews {
  padding: 80px 0;
  background: var(--mg);
}

.bfc-reviews__head {
  text-align: center;
  margin-bottom: 48px;
}

.bfc-reviews__head .bfc-label {
  justify-content: center;
}
.bfc-reviews__head .bfc-label::before { display: none; }

.bfc-reviews__head h2.bfc-h2 { margin-bottom: 0; }

.bfc-reviews__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(90, 62, 45, 0.12);
  border: 1px solid rgba(90, 62, 45, 0.12);
}

.bfc-review {
  background: var(--cv);
  padding: 32px 28px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.bfc-review__stars {
  display: flex;
  gap: 3px;
}

.bfc-review__stars svg {
  width: 13px;
  height: 13px;
  color: var(--go);
  fill: currentColor;
}

.bfc-review__body {
  font-size: 14px;
  line-height: 1.75;
  color: var(--ch);
  flex: 1;
}

.bfc-review__body::before {
  content: open-quote;
  font-family: var(--sr);
  font-size: 28px;
  line-height: 0;
  vertical-align: -12px;
  color: var(--or);
  margin-right: 2px;
}

.bfc-review__author {
  font-family: var(--sn);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--bk);
  border-top: 1px solid var(--mg);
  padding-top: 14px;
}

.bfc-review__meta {
  font-size: 11px;
  font-weight: 400;
  color: var(--ch);
  text-transform: none;
  letter-spacing: 0;
  display: block;
  margin-top: 2px;
}

.bfc-reviews__cta {
  text-align: center;
  margin-top: 40px;
}

@media (max-width: 900px) {
  .bfc-reviews__grid { grid-template-columns: 1fr; }
}


/* ============================================================
   5. FAQ — repositioned closer to conversion
   ============================================================ */
.bfc-faq {
  padding: 96px 0;
  background: var(--cv);
}

.bfc-faq__layout {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 80px;
  align-items: start;
}

.bfc-faq__sidebar {
  position: sticky;
  top: 32px;
}

.bfc-faq__sidebar h2.bfc-h2 { margin-bottom: 12px; }

.bfc-faq__sidebar-note {
  font-size: 14px;
  line-height: 1.7;
  color: var(--ch);
  margin-bottom: 28px;
}

.bfc-faq__sidebar-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: flex-start;
}

/* Bench fee highlight — surfaces key anxiety early */
.bfc-faq__bench-callout {
  background: var(--mn);
  border-left: 3px solid var(--or);
  padding: 14px 16px;
  font-size: 13px;
  line-height: 1.6;
  color: var(--ch);
  margin-bottom: 28px;
}
.bfc-faq__bench-callout strong {
  color: var(--bk);
  display: block;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 4px;
}

.bfc-accordion { border-top: 1px solid var(--mg); }

.bfc-accordion__item {
  border-bottom: 1px solid var(--mg);
}

.bfc-accordion__trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  width: 100%;
  background: none;
  border: 0;
  padding: 20px 0;
  text-align: left;
  cursor: pointer;
  color: var(--bk);
}

.bfc-accordion__question {
  font-family: var(--sn);
  font-weight: 600;
  font-size: 14px;
  line-height: 1.4;
  color: var(--bk);
}

.bfc-accordion__icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  color: var(--or);
  transition: transform 220ms var(--ease);
}
.bfc-accordion__item.is-open .bfc-accordion__icon { transform: rotate(45deg); }

.bfc-accordion__body {
  overflow: hidden;
  max-height: 0;
  transition: max-height 300ms var(--ease), padding 260ms var(--ease);
}
.bfc-accordion__item.is-open .bfc-accordion__body { max-height: 800px; }

.bfc-accordion__answer {
  padding: 0 0 20px;
  font-size: 14px;
  line-height: 1.75;
  color: var(--ch);
}

@media (max-width: 900px) {
  .bfc-faq__layout { grid-template-columns: 1fr; gap: 40px; }
  .bfc-faq__sidebar { position: static; }
}


/* ============================================================
   6. SHIPPING — canvas bg, stronger CTA
   ============================================================ */
.bfc-shipping {
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 500px;
  background: var(--cv);
  border-top: 1px solid var(--mg);
}

.bfc-shipping__image {
  position: relative;
  overflow: hidden;
}
.bfc-shipping__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.bfc-shipping__copy {
  background: var(--bk);
  color: var(--cv);
  padding: 80px 64px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.bfc-shipping__copy h2.bfc-h2 {
  color: var(--cv);
  margin-bottom: 20px;
}

.bfc-shipping__copy p {
  font-size: 14px;
  line-height: 1.75;
  color: rgba(248, 246, 238, 0.6);
  margin-bottom: 0;
}

.bfc-shipping__callouts {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin: 28px 0 32px;
  padding: 24px 0;
  border-top: 1px solid rgba(248, 246, 238, 0.1);
  border-bottom: 1px solid rgba(248, 246, 238, 0.1);
}

.bfc-shipping__callout {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.bfc-shipping__callout svg {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  color: var(--go);
  margin-top: 2px;
}

.bfc-shipping__callout div {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.bfc-shipping__callout strong {
  font-family: var(--sn);
  font-weight: 600;
  font-size: 12px;
  color: var(--cv);
  letter-spacing: 0.02em;
}

.bfc-shipping__callout span {
  font-size: 11px;
  color: rgba(248, 246, 238, 0.5);
  line-height: 1.5;
}

.bfc-shipping__actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: flex-start;
}

.bfc-shipping__label-note {
  font-size: 11px;
  color: rgba(248, 246, 238, 0.35);
  letter-spacing: 0.03em;
}

@media (max-width: 900px) {
  .bfc-shipping {
    grid-template-columns: 1fr;
    min-height: auto;
  }
  .bfc-shipping__image { aspect-ratio: 16/9; }
  .bfc-shipping__copy { padding: 48px 24px; }
}

{%- endstyle -%}

