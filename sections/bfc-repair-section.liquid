<!-- ══════════════════════════════════════════════════════════
     JAVASCRIPT — Accordion + Scroll Reveal (no external deps)
     ══════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  const EASE = 'cubic-bezier(.22, 1, .36, 1)';
  const MQ   = window.matchMedia('(max-width: 900px)');

  /* ─── Scroll Reveal ───────────────────────────────────── */
  function initReveal() {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els    = document.querySelectorAll('.bfc-repair .bfc-reveal');

    if (reduce) {
      els.forEach(el => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });

    els.forEach(el => {
      // Immediately reveal anything already in viewport
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.95) {
        el.classList.add('is-visible');
      } else {
        io.observe(el);
      }
    });
  }

  /* ─── FAQ Accordion ───────────────────────────────────── */
  function initFaqAccordion() {
    const container = document.querySelector('.bfc-repair .bfc-accordion');
    if (!container) return;

    container.querySelectorAll('.bfc-accordion__item').forEach(item => {
      const trigger = item.querySelector('.bfc-accordion__trigger');
      const body    = item.querySelector('.bfc-accordion__body');
      if (!trigger || !body) return;

      trigger.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');

        // Close all siblings
        container.querySelectorAll('.bfc-accordion__item.is-open').forEach(open => {
          if (open !== item) {
            open.classList.remove('is-open');
            open.querySelector('.bfc-accordion__trigger')?.setAttribute('aria-expanded', 'false');
          }
        });

        // Toggle current
        item.classList.toggle('is-open', !isOpen);
        trigger.setAttribute('aria-expanded', String(!isOpen));
      });
    });
  }

  /* ─── Steps Accordion (mobile only) ──────────────────── */
  function initStepsAccordion() {
    const grid = document.querySelector('.bfc-repair .bfc-steps__grid');
    if (!grid) return;

    grid.querySelectorAll('.bfc-step').forEach(step => {
      const header = step.querySelector('.bfc-step__header');
      const body   = step.querySelector('.bfc-step__body');
      if (!header || !body) return;

      header.addEventListener('click', () => {
        if (!MQ.matches) return; // desktop: no-op

        const isOpen = step.classList.contains('is-open');

        // Close siblings
        grid.querySelectorAll('.bfc-step.is-open').forEach(s => {
          if (s !== step) s.classList.remove('is-open');
        });

        step.classList.toggle('is-open', !isOpen);
        header.setAttribute('aria-expanded', String(!isOpen));
      });

      // Allow keyboard activation
      header.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          header.click();
        }
      });
    });
  }

  /* ─── Boot ────────────────────────────────────────────── */
  function boot() {
    initReveal();
    initFaqAccordion();
    initStepsAccordion();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

})();
</script>

</section>

