{% comment %} BFC Repair Section — self-contained (CSS + JS inline, no Instant dependency) {% endcomment %}
<section class="bfc-repair" data-section-id="{{ section.id }}">

{%- style -%}
/* ============================================================
   BFC REPAIR SECTION — Brand Tokens & Base
   ============================================================ */
.bfc-repair {
  --orange:      #E36E15;
  --golden:      #F4A027;
  --canvas:      #F8F6EE;
  --dusty-brown: #5A3E2D;
  --blank-black: #202009;
  --celadon:     #ABCC99;
  --charcoal:    #4E4741;
  --mech-gray:   #E3DDDA;
  --manila:      #FFEACC;
  --deep-olive:  #525741;
  --ease:        cubic-bezier(.22, 1, .36, 1);

  font-family: 'Poppins', sans-serif;
  color: var(--blank-black);
  background: var(--canvas);
}

.bfc-repair *,
.bfc-repair *::before,
.bfc-repair *::after { box-sizing: border-box; }

/* ── Shared layout helpers ── */
.bfc-repair .bfc-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
}

@media (max-width: 768px) {
  .bfc-repair .bfc-inner { padding: 0 24px; }
}

.bfc-repair .bfc-section-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--orange);
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}
.bfc-repair .bfc-section-label::before {
  content: '';
  display: block;
  width: 28px;
  height: 1.5px;
  background: var(--orange);
  flex-shrink: 0;
}

.bfc-repair h2.bfc-h2 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 500;
  font-size: clamp(34px, 4vw, 52px);
  line-height: 1.05;
  color: var(--blank-black);
  margin: 0 0 16px;
}

.bfc-repair h3.bfc-h3 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 500;
  font-size: clamp(22px, 2.5vw, 30px);
  line-height: 1.15;
  margin: 0 0 8px;
}

.bfc-repair p.bfc-body {
  font-size: 15px;
  line-height: 1.75;
  color: var(--charcoal);
  margin: 0;
}

/* ── Buttons ── */
.bfc-repair .bfc-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 14px 32px;
  min-height: 44px;
  border: 2px solid currentColor;
  cursor: pointer;
  transition: background 180ms var(--ease), color 180ms var(--ease);
  white-space: nowrap;
}
.bfc-repair .bfc-btn--primary {
  background: var(--orange);
  color: #fff;
  border-color: var(--orange);
}
.bfc-repair .bfc-btn--primary:hover {
  background: var(--dusty-brown);
  border-color: var(--dusty-brown);
}
.bfc-repair .bfc-btn--outline {
  background: transparent;
  color: var(--blank-black);
  border-color: var(--blank-black);
}
.bfc-repair .bfc-btn--outline:hover {
  background: var(--blank-black);
  color: var(--canvas);
}
.bfc-repair .bfc-btn--outline-light {
  background: transparent;
  color: var(--canvas);
  border-color: var(--canvas);
}
.bfc-repair .bfc-btn--outline-light:hover {
  background: var(--canvas);
  color: var(--blank-black);
}

/* ── Scroll reveal ── */
.bfc-repair .bfc-reveal {
  opacity: 0;
  transform: translateY(16px);
  transition:
    opacity 650ms var(--ease) var(--bfc-delay, 0ms),
    transform 650ms var(--ease) var(--bfc-delay, 0ms);
  will-change: opacity, transform;
}
.bfc-repair .bfc-reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}
@media (prefers-reduced-motion: reduce) {
  .bfc-repair .bfc-reveal {
    transition: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
}

/* ============================================================
   1. HOW IT WORKS — Steps
   ============================================================ */
.bfc-steps {
  padding: 56px 0;
  background: var(--canvas);
  color: var(--blank-black);
  border-bottom: 1px solid var(--mech-gray);
}

/* ── Desktop grid: 2 columns × 3 rows ── */
.bfc-steps__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--mech-gray);
  border: 1px solid var(--mech-gray);
}

/* ── Desktop step card — compact two-column layout ── */
.bfc-step {
  background: var(--canvas);
  padding: 22px 24px;
  position: relative;
  overflow: hidden;
  display: grid;
  grid-template-columns: 36px 1fr;
  column-gap: 14px;
  row-gap: 4px;
  align-items: start;
}

/* Orange left-border reveal on hover */
.bfc-step::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 3px;
  background: var(--orange);
  transform: scaleY(0);
  transform-origin: top;
  transition: transform 280ms var(--ease);
}
.bfc-step:hover::before { transform: scaleY(1); }

/* Number — left column, spans both text rows */
.bfc-step__num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 26px;
  font-weight: 500;
  line-height: 1;
  color: var(--orange);
  opacity: 0.6;
  display: block;
  grid-column: 1;
  grid-row: 1 / 3;
  padding-top: 3px;
}

.bfc-step__title {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--blank-black);
  display: block;
  grid-column: 2;
  align-self: end;
}

.bfc-step__body {
  font-size: 12px;
  line-height: 1.6;
  color: var(--charcoal);
  display: block;
  grid-column: 2;
}

/* Desktop: accordion trigger hidden — not needed */
.bfc-step__header { display: none; }

.bfc-steps__cta {
  margin-top: 28px;
  padding-top: 24px;
  border-top: 1px solid var(--mech-gray);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}

.bfc-steps__cta-note {
  font-size: 12px;
  color: var(--charcoal);
}

/* ── Mobile: single column accordion ── */
@media (max-width: 900px) {
  .bfc-steps {
    padding: 40px 0;
  }

  .bfc-steps__grid {
    grid-template-columns: 1fr;
    background: none;
    border: none;
    gap: 0;
  }

  /* Reset the desktop inner grid back to plain block */
  .bfc-step {
    display: block;
    padding: 0;
    border-top: 1px solid var(--mech-gray);
    background: transparent;
  }
  .bfc-step:first-child { border-top: 0; }
  .bfc-step::before { display: none; }

  /* Show the accordion trigger on mobile */
  .bfc-step__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 0;
    cursor: pointer;
    background: none;
    border: 0;
    width: 100%;
    text-align: left;
    color: var(--blank-black);
  }

  .bfc-step__header-left {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  /* Num in header */
  .bfc-step__header .bfc-step__num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 500;
    line-height: 1;
    color: var(--orange);
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* Title in header */
  .bfc-step__header .bfc-step__title {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--blank-black);
    white-space: normal;
    line-height: 1.3;
  }

  .bfc-step__toggle {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    transition: transform 220ms var(--ease);
    color: var(--orange);
  }
  .bfc-step.is-open .bfc-step__toggle {
    transform: rotate(45deg);
  }

  /* Hide the standalone desktop num/title/body — header handles them */
  .bfc-step > .bfc-step__num,
  .bfc-step > .bfc-step__title { display: none; }

  /* Body: collapsed by default */
  .bfc-step__body {
    display: block;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    padding: 0;
    font-size: 14px;
    line-height: 1.7;
    color: var(--charcoal);
    transition:
      max-height 300ms var(--ease),
      opacity    220ms ease,
      padding    220ms var(--ease);
  }
  .bfc-step.is-open .bfc-step__body {
    max-height: 500px;
    opacity: 1;
    padding-bottom: 18px;
  }
}

/* ============================================================
   2. WHAT WE REPAIR — Capability Matrix + Image
   ============================================================ */
.bfc-what {
  padding: 64px 0;
  background: var(--canvas);
}

.bfc-what__layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

.bfc-what__desc {
  font-size: 14px;
  line-height: 1.75;
  color: var(--charcoal);
  margin: 0 0 32px;
}

/* Clean service list */
.bfc-service-list {
  list-style: none;
  margin: 0;
  padding: 0;
  border-top: 1px solid var(--mech-gray);
}

.bfc-service-list__item {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 24px;
  padding: 14px 0;
  border-bottom: 1px solid var(--mech-gray);
}

.bfc-service-list__name {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 13px;
  color: var(--blank-black);
  flex-shrink: 0;
}

.bfc-service-list__note {
  font-size: 12px;
  color: var(--charcoal);
  text-align: right;
}

/* Right image — square-ish, self-sizing to match text height */
.bfc-what__image {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  max-height: 420px;
  width: 100%;
  justify-self: end;
}
.bfc-what__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

@media (max-width: 900px) {
  .bfc-what__layout {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .bfc-what__image {
    aspect-ratio: 4/3;
    max-height: 280px;
    order: -1;
  }
  .bfc-service-list__item {
    flex-direction: column;
    gap: 4px;
  }
  .bfc-service-list__note { text-align: left; }
}

/* ============================================================
   3 & 4. CAMERA CARDS — Full CLA + Other Repairs
   ============================================================ */
.bfc-cameras {
  padding: 80px 0;
  border-top: 1px solid var(--mech-gray);
}

.bfc-cameras__head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 48px;
  flex-wrap: wrap;
  gap: 16px;
}

.bfc-cameras__head h2.bfc-h2 { margin: 0; }

.bfc-card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: var(--mech-gray);
  border: 1px solid var(--mech-gray);
}

.bfc-card {
  background: var(--canvas);
  padding: 32px 28px;
}

.bfc-card__title {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 500;
  font-size: 22px;
  margin: 0 0 10px;
  color: var(--blank-black);
}

.bfc-card__body {
  font-size: 13px;
  line-height: 1.7;
  color: var(--charcoal);
}

@media (max-width: 900px) {
  .bfc-card-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 540px) {
  .bfc-card-grid {
    grid-template-columns: 1fr;
  }
}

/* Alt cameras block — subtle mech-gray tint to visually separate from Full CLA */
.bfc-cameras--alt {
  background: var(--mech-gray);
}
.bfc-cameras--alt .bfc-card {
  background: var(--canvas);
}

/* ── Camera section CTA ── */
.bfc-cameras__cta {
  margin-top: 40px;
  padding-top: 32px;
  border-top: 1px solid var(--mech-gray);
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.bfc-cameras--alt .bfc-cameras__cta {
  border-top-color: rgba(255,255,255,0.5);
}

/* ============================================================
   5. PRICING
   ============================================================ */
.bfc-pricing {
  padding: 96px 0;
  background: var(--blank-black);
  color: var(--canvas);
}

.bfc-pricing__head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: end;
  margin-bottom: 56px;
}

.bfc-pricing__head .bfc-section-label { color: var(--golden); }
.bfc-pricing__head .bfc-section-label::before { background: var(--golden); }
.bfc-pricing__head h2.bfc-h2 { color: var(--canvas); margin-bottom: 0; }

.bfc-pricing__note {
  font-size: 14px;
  line-height: 1.7;
  color: rgba(248, 246, 238, 0.6);
  align-self: end;
}

.bfc-pricing__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
  margin-bottom: 40px;
  background: rgba(255,255,255,0.06);
}

.bfc-price-card {
  background: rgba(248, 246, 238, 0.04);
  padding: 36px 28px;
  border-top: 3px solid rgba(255,255,255,0.08);
  transition: border-color 200ms;
}
.bfc-price-card:hover {
  border-color: var(--orange);
}

.bfc-price-card__price {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 500;
  font-size: 40px;
  line-height: 1;
  color: var(--golden);
  margin-bottom: 12px;
}

.bfc-price-card__service {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--canvas);
}

.bfc-pricing__cta {
  display: flex;
  justify-content: flex-start;
}

@media (max-width: 900px) {
  .bfc-pricing__head {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .bfc-pricing__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 480px) {
  .bfc-pricing__grid {
    grid-template-columns: 1fr;
  }
}

/* ============================================================
   6. FAQ
   ============================================================ */
.bfc-faq {
  padding: 96px 0;
  background: var(--canvas);
}

.bfc-faq__layout {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 80px;
  align-items: start;
}

.bfc-faq__sidebar {
  position: sticky;
  top: 32px;
}

.bfc-faq__sidebar h2.bfc-h2 { margin-bottom: 16px; }

.bfc-faq__sidebar-note {
  font-size: 14px;
  line-height: 1.7;
  color: var(--charcoal);
  margin-bottom: 32px;
}

.bfc-accordion { border-top: 1px solid var(--mech-gray); }

.bfc-accordion__item {
  border-bottom: 1px solid var(--mech-gray);
}

.bfc-accordion__trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  width: 100%;
  background: none;
  border: 0;
  padding: 22px 0;
  text-align: left;
  cursor: pointer;
  color: var(--blank-black);
}

.bfc-accordion__question {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 15px;
  line-height: 1.4;
  color: var(--blank-black);
}

.bfc-accordion__icon {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
  color: var(--orange);
  transition: transform 220ms var(--ease);
}
.bfc-accordion__item.is-open .bfc-accordion__icon {
  transform: rotate(45deg);
}

.bfc-accordion__body {
  overflow: hidden;
  max-height: 0;
  transition: max-height 300ms var(--ease), padding 260ms var(--ease);
}
.bfc-accordion__item.is-open .bfc-accordion__body {
  max-height: 800px;
}

.bfc-accordion__answer {
  padding: 0 0 22px;
  font-size: 14px;
  line-height: 1.75;
  color: var(--charcoal);
}

@media (max-width: 900px) {
  .bfc-faq__layout {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .bfc-faq__sidebar { position: static; }
}

/* ============================================================
   7. SHIPPING
   ============================================================ */
.bfc-shipping {
  padding: 0;
  overflow: hidden;
  position: relative;
  min-height: 480px;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.bfc-shipping__image {
  position: relative;
  overflow: hidden;
}
.bfc-shipping__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.bfc-shipping__copy {
  background: var(--dusty-brown);
  color: var(--canvas);
  padding: 80px 72px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.bfc-shipping__copy .bfc-section-label { color: var(--golden); }
.bfc-shipping__copy .bfc-section-label::before { background: var(--golden); }

.bfc-shipping__copy h2.bfc-h2 {
  color: var(--canvas);
  margin-bottom: 24px;
}

.bfc-shipping__copy p {
  font-size: 15px;
  line-height: 1.75;
  color: rgba(248, 246, 238, 0.75);
  margin-bottom: 16px;
}
.bfc-shipping__copy p:last-of-type { margin-bottom: 0; }

/* ── Shipping callouts ── */
.bfc-shipping__callouts {
  display: flex;
  flex-direction: column;
  gap: 18px;
  margin: 32px 0 36px;
  padding: 28px 0;
  border-top: 1px solid rgba(248, 246, 238, 0.15);
  border-bottom: 1px solid rgba(248, 246, 238, 0.15);
}

.bfc-shipping__callout {
  display: flex;
  align-items: flex-start;
  gap: 14px;
}

.bfc-shipping__callout svg {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
  color: var(--golden);
  margin-top: 2px;
}

.bfc-shipping__callout div {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.bfc-shipping__callout strong {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 13px;
  color: var(--canvas);
  letter-spacing: 0.02em;
}

.bfc-shipping__callout span {
  font-size: 12px;
  color: rgba(248, 246, 238, 0.6);
  line-height: 1.5;
}

.bfc-shipping__label-btn {
  margin-top: 4px;
}

@media (max-width: 900px) {
  .bfc-shipping {
    grid-template-columns: 1fr;
    min-height: auto;
  }
  .bfc-shipping__image {
    aspect-ratio: 16/9;
  }
  .bfc-shipping__copy {
    padding: 48px 28px;
  }
}
{%- endstyle -%}

{%- liquid
  assign preload = true
  if section.location == 'footer'
    assign preload = false
  elsif section.location == 'template' and section.index > 2
    assign preload = false
  endif
-%}

{%- liquid
  assign repair_handle = '35mm-and-medium-format-repair'
  assign repair_url = all_products[repair_handle].url | default: '/products/35mm-and-medium-format-repair'
  assign repair_btn_text = section.settings['text_OGVmSdENOpRpSm1q-1'] | strip_html | default: 'Start a Repair'
  assign repair_btn_url = section.settings.url_44r2z7TSjcGHkDEt-1 | default: repair_url
-%}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Poppins:wght@400;600&display=swap" rel="stylesheet">

<!-- ══════════════════════════════════════════════════════════
     1. HOW IT WORKS
     ══════════════════════════════════════════════════════════ -->
<div class="bfc-steps">
  <div class="bfc-inner">

    <div class="bfc-steps__grid">

      <!-- Step 1 -->
      <div class="bfc-step bfc-reveal" style="--bfc-delay:60ms">
        <button class="bfc-step__header" type="button" aria-expanded="false">
          <div class="bfc-step__header-left">
            <span class="bfc-step__num">01</span>
            <span class="bfc-step__title">{{ section.settings['text_b1ethHm88r6HXMAG-1'] | strip_html | replace: 'Step 1: ', '' }}</span>
          </div>
          <svg class="bfc-step__toggle" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
            <path d="M224,128a8,8,0,0,1-8,8H136v80a8,8,0,0,1-16,0V136H40a8,8,0,0,1,0-16h80V40a8,8,0,0,1,16,0v80h80A8,8,0,0,1,224,128Z"/>
          </svg>
        </button>
        <div class="bfc-step__num">01</div>
        <div class="bfc-step__title">{{ section.settings['text_b1ethHm88r6HXMAG-1'] | strip_html | replace: 'Step 1: ', '' }}</div>
        <div class="bfc-step__body">{{ section.settings['text_zK5b4fQevS7bQERJ-1'] }}</div>
      </div>

      <!-- Step 2 -->
      <div class="bfc-step bfc-reveal" style="--bfc-delay:120ms">
        <button class="bfc-step__header" type="button" aria-expanded="false">
