<!-- ══════════════════════════════════════════════════════════
     JAVASCRIPT
     ══════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  const MQ = window.matchMedia('(max-width: 900px)');

  /* ─── Scroll Reveal ── */
  function initReveal() {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els    = document.querySelectorAll('.bfc-repair .bfc-reveal');

    if (reduce) { els.forEach(el => el.classList.add('is-visible')); return; }

    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -6% 0px' });

    els.forEach(el => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.98) {
        el.classList.add('is-visible');
      } else {
        io.observe(el);
      }
    });
  }

  /* ─── FAQ Accordion ── */
  function initFaqAccordion() {
    const container = document.querySelector('.bfc-repair .bfc-accordion');
    if (!container) return;

    container.querySelectorAll('.bfc-accordion__item').forEach(item => {
      const trigger = item.querySelector('.bfc-accordion__trigger');
      const body    = item.querySelector('.bfc-accordion__body');
      if (!trigger || !body) return;

      trigger.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');
        container.querySelectorAll('.bfc-accordion__item.is-open').forEach(open => {
          if (open !== item) {
            open.classList.remove('is-open');
            open.querySelector('.bfc-accordion__trigger')?.setAttribute('aria-expanded', 'false');
          }
        });
        item.classList.toggle('is-open', !isOpen);
        trigger.setAttribute('aria-expanded', String(!isOpen));
      });
    });
  }

  /* ─── Steps detail expand/collapse ── */
  function initStepsDetail() {
    const toggle   = document.getElementById('bfc-steps-toggle');
    const substeps = document.getElementById('bfc-steps-substeps');
    if (!toggle || !substeps) return;

    toggle.addEventListener('click', () => {
      const isOpen = substeps.classList.contains('is-open');
      substeps.classList.toggle('is-open', !isOpen);
      toggle.classList.toggle('is-open', !isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
      substeps.setAttribute('aria-hidden', String(isOpen));
    });
  }

  /* ─── Boot ── */
  function boot() {
    initReveal();
    initFaqAccordion();
    initStepsDetail();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
})();
</script>

</section>

