  // ── ATC ─────────────────────────────────────────
  window.bfc4AddToCart = async function() {
    var btn    = document.getElementById('bfc4-atc');
    var textEl = document.getElementById('bfc4-atc-text');
    var stickyBtn  = document.getElementById('bfc4-sticky-btn');
    var stickyText = document.getElementById('bfc4-sticky-btn-text');
    // Guard: if the main camera variant is OOS, bail before any cart calls.
    if (!{{ current_variant.available | json }}) {
      if (btn) btn.disabled = true;
      if (stickyBtn) stickyBtn.disabled = true;
      return;
    }

    function setStatus(s) {
      if (textEl) textEl.textContent = s;
      if (stickyText) stickyText.textContent = s;
      console.log('[BFC4-V4]', s);
    }
    function fail(msg) {
      console.error('[BFC4-V4] FAIL:', msg);
      setStatus(String(msg).slice(0, 35));
      if (btn) { btn.disabled = false; btn.style.background = '#a33'; }
      if (stickyBtn) { stickyBtn.disabled = false; }
      setTimeout(function() {
        setStatus('Add Starter Kit');
        if (btn) btn.style.background = '';
      }, 5000);
    }

    if (btn) { btn.disabled = true; }
    if (stickyBtn) { stickyBtn.disabled = true; }
    setStatus('Adding\u2026');

    var items = [];
    var filmCount = 0;
    Object.values(STATE.kit).forEach(function(sel) {
      if (!sel.variantId) return;
      var vid = parseInt(sel.variantId, 10);
      if (isNaN(vid) || vid === 0) return;
      if (sel.isFilm) filmCount++;
      var props = { _kit_bundle: 'true' };
      if (sel.isDev) {
        props._free_developing      = 'true';
        props._bundle_discount_type = 'free_developing';
      }
      items.push({ id: vid, quantity: 1, properties: props });
    });

    if (!STATE.variantId) return fail('No variant ID');

    var allItems = [{ id: STATE.variantId, quantity: 1 }];
    items.forEach(function(i) { allItems.push(i); });
    if (STATE.extWarranty && STATE.extWarranty.variantId) {
      allItems.push({ id: STATE.extWarranty.variantId, quantity: 1, properties: { _warranty_months: STATE.extWarranty.total, _warranty_type: 'extended' } });
    }
    console.log('[BFC4-V4] allItems:', allItems);

    try {
      // Fire-and-forget cart attrs (don't await)
      var cartAttrs = { attributes: { '_kit_bundle': 'true', '_kit_camera': '{{ product.title | escape }}', '_free_developing_credit': filmCount >= 2 ? 'true' : 'false' } };
      bfc4Xhr('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(cartAttrs) });

      // Add kit items via XHR (if any)
      if (items.length > 0) {
        var res = await bfc4Xhr('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: items }) });
        if (!res.ok) {
          var errBody = await res.json().catch(function() { return {}; });
          return fail(errBody.description || 'Kit add failed: ' + res.status);
        }
      }
      // Add warranty via XHR (if selected)
      if (STATE.extWarranty && STATE.extWarranty.variantId) {
        await bfc4Xhr('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: [{ id: STATE.extWarranty.variantId, quantity: 1, properties: { _warranty_months: STATE.extWarranty.total, _warranty_type: 'extended' } }] }) });
      }

      // Add camera via hidden Shopify form — this also opens the cart drawer
      var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
      if (submitBtn) submitBtn.click();

      if (btn) { btn.classList.add('is-success'); }
      setStatus('Added!');
      if (stickyText) stickyText.textContent = 'Added!';
      setTimeout(function() {
        if (btn) { btn.classList.remove('is-success'); btn.disabled = false; }
        if (stickyBtn) { stickyBtn.disabled = false; }
        setStatus('Add Starter Kit');
        if (stickyText) stickyText.textContent = 'Add to Cart';
      }, 2400);
    } catch(e) {
      fail(e.message || 'Add error');
    }
  };

  window.bfc4CameraOnly = function() {
    // Guard: don't try to add an unavailable camera.
    if (!{{ current_variant.available | json }}) return;
    var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
    if (submitBtn) submitBtn.click();
  };

