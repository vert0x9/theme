    // ── Re-evaluate developing credit whenever cart changes ──────────────
  // Handles case where user adds 2 film rolls, then removes one from cart drawer
  function bfc4SyncDevCredit() {
    bfc4Xhr('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var filmCount = 0;
        (cart.items || []).forEach(function(item) {
          var props = item.properties || {};
          if (props._kit_bundle === 'true' && props._bundle_discount_type !== 'free_developing') {
            // Check if this item is a film item by looking for _kit_bundle without free_developing flag
            // We use the line item's product type or title as fallback
            var title = (item.product_title || '').toLowerCase();
            var type = (item.product_type || '').toLowerCase();
            if (title.indexOf('film') >= 0 || type.indexOf('film') >= 0) filmCount++;
          }
        });
        var shouldHaveCredit = filmCount >= 2 ? 'true' : 'false';
        // Only update if it needs to change
        var currentCredit = (cart.attributes || {})['_free_developing_credit'];
        if (currentCredit !== shouldHaveCredit) {
          bfc4Xhr('/cart/update.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ attributes: { '_free_developing_credit': shouldHaveCredit } })
          });
        }
      })
      .catch(function() {}); // silent fail
  }

  // Listen for cart updates from theme (drawer, quantity changes, removals)
  document.addEventListener('cart:updated', bfc4SyncDevCredit);
  document.addEventListener('cart:refresh', bfc4SyncDevCredit);
  // Also poll on visibility change (user returns to tab after cart changes)
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden) bfc4SyncDevCredit();
  });

  // ── Sticky ATC Bar (all viewports) ──────────────
  var stickyBar = document.getElementById('bfc4-sticky-bar');
  var mainAtc   = document.getElementById('bfc4-atc');
  if (stickyBar && mainAtc) {
    new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        stickyBar.classList.toggle('is-visible', !e.isIntersecting);
      });
    }, { threshold: 0 }).observe(mainAtc);
  }
})();

/* ─── STICKY TOC — section tracking + smooth scroll ─── */
(function() {
  var toc = document.getElementById('bfc4-toc');
  if (!toc) return;
  var anchors = ['top', 'chapter', 'custom', 'reviews'];
  var sections = anchors
    .map(function(id) { return { id: id, el: document.getElementById('bfc4-' + id) }; })
    .filter(function(s) { return s.el; });

  function setActive(id) {
    toc.querySelectorAll('a[data-toc]').forEach(function(a) {
      a.classList.toggle('is-active', a.dataset.toc === id);
    });
  }

  // Detect theme header height so we can sit BELOW it (not over it). The theme's
  // sticky header is typically 50-80px tall and uses position: fixed/sticky.
  function getThemeHeaderHeight() {
    var selectors = [
      'sticky-header', '.shopify-section-header-sticky',
      'header.shopify-section', 'header.site-header',
      '.header-wrapper', 'header[role="banner"]', '.section-header'
    ];
    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (el) {
        var pos = getComputedStyle(el).position;
        if (pos === 'fixed' || pos === 'sticky') {
          var h = el.offsetHeight;
          if (h > 0 && h < 200) return h;
        }
      }
    }
    return 0;
  }

  var themeHeaderHeight = 0;
  function refreshHeaderOffset() {
    themeHeaderHeight = getThemeHeaderHeight();
    // Subtract 1px to close the sub-pixel gap between the header's bottom and our top
    toc.style.top = (themeHeaderHeight > 0 ? themeHeaderHeight - 1 : 0) + 'px';
  }

  // Smooth scroll with TOC + theme-header offset (so target isn't hidden behind both)
  toc.querySelectorAll('a[data-toc]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.getElementById('bfc4-' + a.dataset.toc);
      if (!target) return;
      e.preventDefault();
      var offset = (toc.offsetHeight || 48) + themeHeaderHeight + 12;
      var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: top, behavior: 'smooth' });
    });
  });

  // Show TOC after user has scrolled past the buy box. Hide while drawer/modal open.
  var topEl = document.getElementById('bfc4-top');

  function isOverlayOpen() {
    var bodyClasses = document.body.className || '';
    if (/\b(cart-drawer-open|drawer-open|is-cart-open|drawer--open|overlay-open|modal-open|js-drawer-open|cart-open)\b/.test(bodyClasses)) return true;
    var drawer = document.querySelector(
      'cart-drawer[open], cart-notification[open], .cart-drawer.is-open, .cart-drawer.active, ' +
      '.cart-drawer.drawer--active, .drawer.is-active, .drawer.is-open, [data-cart-drawer].is-open, ' +
      'cart-drawer.active'
    );
    if (drawer) return true;
    return false;
  }

  function updateTocVisibility() {
    if (isOverlayOpen()) {
      toc.classList.remove('is-visible');
      return;
    }
    if (!topEl) {
      toc.classList.toggle('is-visible', window.pageYOffset > 200);
      return;
    }
    var rect = topEl.getBoundingClientRect();
    // Show when buy box has scrolled mostly out of view (with a grace zone for the theme header)
    toc.classList.toggle('is-visible', rect.bottom < themeHeaderHeight + 80);
  }

  // Active section tracking — section whose top is closest to TOC bottom
  function updateActiveSection() {
    if (!sections.length) return;
    var threshold = themeHeaderHeight + (toc.offsetHeight || 48) + 20;
    var current = sections[0].id;
    sections.forEach(function(s) {
      var rect = s.el.getBoundingClientRect();
      if (rect.top <= threshold) current = s.id;
    });
    setActive(current);
  }

  function onScroll() {
    updateTocVisibility();
    updateActiveSection();
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', function() { refreshHeaderOffset(); onScroll(); });
  // React to drawer/modal open/close via body class mutations (no scroll needed)
  if ('MutationObserver' in window) {
    new MutationObserver(onScroll).observe(document.body, { attributes: true, attributeFilter: ['class', 'style'] });
  }
  refreshHeaderOffset();
  onScroll();
  // Re-check header after a delay (some themes lazy-init their sticky headers)
  setTimeout(function() { refreshHeaderOffset(); onScroll(); }, 600);
})();

window.bfc4TocAddToCart = function() {
  // Mirror the main ATC click — feedback (Adding…/Added!) flows through the main flow.
  if (typeof window.bfc4AddToCart === 'function') {
    window.bfc4AddToCart();
  }
};

/* ─── PHOTO LIGHTBOX — hero slider + Shot On gallery ─── */
(function() {
  window.__bfc4Lb = window.__bfc4Lb || { srcs: [], cur: 0 };
  var grid = document.getElementById('ba-shot-grid');
  if (grid) {
    var anchors = grid.querySelectorAll('a[data-lightbox="gallery"]');
    anchors.forEach(function(a) { window.__bfc4Lb.srcs.push(a.getAttribute('href')); });
  }

  window.bfc4Lightbox = function(event, idx) {
    if (event) { event.preventDefault(); event.stopPropagation(); }
    var lb = window.__bfc4Lb;
    if (!lb.srcs.length) return;
    lb.cur = idx;
    var box = document.getElementById('ba-lightbox');
    var img = document.getElementById('ba-lightbox-img');
    var wrap = document.getElementById('ba-lightbox-imgwrap');
    var counter = document.getElementById('ba-lightbox-counter');
    if (img) {
      img.classList.remove('is-zoomed');
      img.src = lb.srcs[lb.cur];
    }
    if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
    if (counter) counter.textContent = (lb.cur + 1) + ' / ' + lb.srcs.length;
    if (box) box.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    // Preload all srcs so arrow nav is instant
    lb.srcs.forEach(function(src) { var pre = new Image(); pre.src = src; });
  };

  window.bfc4LightboxClose = function(event, force) {
    if (force !== true) {
      if (!event || !event.target) return;
      var t = event.target;
      if (t.tagName === 'IMG') return;
      if (t.closest('button')) return;
    }
    var box = document.getElementById('ba-lightbox');
    var img = document.getElementById('ba-lightbox-img');
    var wrap = document.getElementById('ba-lightbox-imgwrap');
    if (img) img.classList.remove('is-zoomed');
    if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
    if (box) box.classList.remove('is-open');
    document.body.style.overflow = '';
  };

  window.bfc4LightboxNav = function(event, dir) {
    if (event) event.stopPropagation();
    var lb = window.__bfc4Lb;
    if (!lb.srcs.length) return;
    lb.cur = (lb.cur + dir + lb.srcs.length) % lb.srcs.length;
    var img = document.getElementById('ba-lightbox-img');
    var wrap = document.getElementById('ba-lightbox-imgwrap');
    var counter = document.getElementById('ba-lightbox-counter');
    if (img) {
      img.classList.remove('is-zoomed');
      img.src = lb.srcs[lb.cur];
    }
    if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
    if (counter) counter.textContent = (lb.cur + 1) + ' / ' + lb.srcs.length;
  };

  // Click image → toggle 2.5x zoom. While zoomed, the wrapper's overflow:auto
  // lets the user pan via scroll/swipe. Click position is preserved as the focal point.
  window.bfc4LightboxToggleZoom = function(event) {
    event.stopPropagation();
    var img = document.getElementById('ba-lightbox-img');
    var wrap = document.getElementById('ba-lightbox-imgwrap');
    if (!img || !wrap) return;
    if (img.classList.contains('is-zoomed')) {
      img.classList.remove('is-zoomed');
      wrap.scrollLeft = 0;
      wrap.scrollTop = 0;
    } else {
      var rect = img.getBoundingClientRect();
      var fracX = (event.clientX - rect.left) / rect.width;
      var fracY = (event.clientY - rect.top) / rect.height;
      img.classList.add('is-zoomed');
      requestAnimationFrame(function() {
        var newW = img.offsetWidth;
        var newH = img.offsetHeight;
        var ww = wrap.clientWidth;
        var wh = wrap.clientHeight;
        wrap.scrollLeft = Math.max(0, fracX * newW - ww / 2);
        wrap.scrollTop  = Math.max(0, fracY * newH - wh / 2);
      });
    }
  };

  // Wire lightbox image to toggle zoom on click
  (function() {
    var img = document.getElementById('ba-lightbox-img');
    if (img) img.addEventListener('click', window.bfc4LightboxToggleZoom);
  })();

  // Hero click → repopulate srcs from hero <img> data-zoom attrs, then open
  window.bfc4OpenHeroLightbox = function(idx) {
    var slideImgs = document.querySelectorAll('.bfc4-slide img');
    if (!slideImgs.length) return;
    window.__bfc4Lb.srcs = Array.prototype.map.call(slideImgs, function(img) {
      return img.dataset.zoom || img.currentSrc || img.src;
    });
    bfc4Lightbox(null, idx || 0);
  };

  // Shot On grid click → repopulate srcs from grid anchors (necessary because
  // srcs is shared with the hero lightbox — a prior hero open would have
  // overwritten them).
  window.bfc4OpenShotLightbox = function(event, idx) {
    if (event) { event.preventDefault(); event.stopPropagation(); }
    var g = document.getElementById('ba-shot-grid');
    if (!g) return;
    var anchors = g.querySelectorAll('a[data-lightbox="gallery"]');
    if (!anchors.length) return;
    window.__bfc4Lb.srcs = Array.prototype.map.call(anchors, function(a) {
      return a.getAttribute('href');
    });
    bfc4Lightbox(null, idx || 0);
  };

  document.addEventListener('keydown', function(e) {
    var box = document.getElementById('ba-lightbox');
    if (!box || !box.classList.contains('is-open')) return;
    if (e.key === 'Escape') bfc4LightboxClose(null, true);
    else if (e.key === 'ArrowLeft') bfc4LightboxNav(null, -1);
    else if (e.key === 'ArrowRight') bfc4LightboxNav(null, 1);
  });

  // Wire hero slide images so clicking opens the lightbox
  document.querySelectorAll('.bfc4-slide img').forEach(function(img, i) {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', function(e) {
      e.preventDefault();
      bfc4OpenHeroLightbox(i);
    });
  });
})();
</script>

