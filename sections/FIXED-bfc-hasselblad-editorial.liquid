
{% liquid
  assign base_text = section.settings.text_color | default: '#111111'
  assign base_bg = section.settings.background_color | default: '#F7F4F0'
  assign page_width_px = settings.page_width | default: 1200
  assign horizontal_pad = section.settings.horizontal_padding | default: 24
  assign heading_size_preset = section.settings.heading_size_preset | default: 'default'
  case heading_size_preset
    when 'sm'
      assign header_size_mobile = '1.4'
      assign header_size_desktop = '2.0'
    when 'md'
      assign header_size_mobile = '1.6'
      assign header_size_desktop = '2.4'
    when 'lg'
      assign header_size_mobile = '2.0'
      assign header_size_desktop = '3.2'
    when 'xl'
      assign header_size_mobile = '2.4'
      assign header_size_desktop = '3.8'
    when 'xxl'
      assign header_size_mobile = '2.8'
      assign header_size_desktop = '4.4'
    else
      assign header_size_mobile = '1.75'
      assign header_size_desktop = '2.75'
  endcase
  assign header_weight = section.settings.header_font_weight | default: 600
  assign body_weight = section.settings.body_font_weight | default: 400
  assign body_size = section.settings.body_font_size | default: 16
  assign body_size_small = section.settings.body_font_size_small | default: 12
  assign header_line_height = section.settings.header_line_height | default: '1.05'
  assign header_letter_spacing = section.settings.header_letter_spacing | default: 0
  assign heading_color = section.settings.heading_color | default: base_text
  assign body_line_height = section.settings.body_line_height | default: '1.5'
  assign body_letter_spacing = section.settings.body_letter_spacing | default: 0
  assign section_pad_top = section.settings.section_padding_top | default: 40
  assign section_pad_bottom = section.settings.section_padding_bottom | default: 40
  assign accent_color = section.settings.accent_color | default: '#E36E15'
  assign secondary_text_color = section.settings.secondary_text_color | default: '#82906B'
  assign item_title_font = section.settings.item_title_font
%}
<section id="bfc-hasselblad-editorial-{{ section.id }}" class="bfc-combined" aria-label="{{ section.settings.section_label | default: 'BFC Hasselblad Editorial' }}">
  <style>
    {{ item_title_font | font_face: font_display: 'swap' }}

    /* Fix shopify-section wrapper background & spacing */
    #shopify-section-{{ section.id }} {
      background-color: {{ base_bg }};
      margin: 0;
      padding: {{ section_pad_top }}px 0 {{ section_pad_bottom }}px;
      width: 100%;
    }
    #bfc-hasselblad-editorial-{{ section.id }}{
      --bfc-header-family: var(--font-heading-family, inherit);
      --bfc-body-family: var(--font-body-family, inherit);
      --bfc-header-weight: {{ header_weight }};
      --bfc-body-weight: {{ body_weight }};
      --bfc-header-size-mobile: {{ header_size_mobile }}rem;
      --bfc-header-size-desktop: {{ header_size_desktop }}rem;
      --bfc-horizontal-pad: {{ horizontal_pad }}px;
      --bfc-page-width: {{ page_width_px }}px;
      --bfc-align-pad: clamp(
        var(--bfc-horizontal-pad),
        calc((100vw - min(100vw, var(--bfc-page-width))) / 2 + var(--bfc-horizontal-pad)),
        120px
      );
      --bfc-body-size: {{ body_size }}px;
      --bfc-body-size-small: {{ body_size_small }}px;
      --bfc-text: {{ base_text }};
      --bfc-bg: {{ base_bg }};
      --bfc-heading-color: {{ heading_color }};
      --bfc-header-letter-spacing: {{ header_letter_spacing }}px;
      --bfc-header-line-height: {{ header_line_height }};
      --bfc-body-letter-spacing: {{ body_letter_spacing }}px;
      --bfc-body-line-height: {{ body_line_height }};
      --bfc-accent: {{ accent_color }};
      --bfc-secondary-text: {{ secondary_text_color }};
      --bfc-item-title-family: {{ item_title_font.family | default: 'Poppins' }}, {{ item_title_font.fallback_families | default: 'sans-serif' }};
      --bfc-item-title-weight: {{ item_title_font.weight | default: 500 }};
      color: var(--bfc-text);
      background: var(--bfc-bg);
      font-family: var(--bfc-body-family);
      font-weight: var(--bfc-body-weight);
      font-size: var(--bfc-body-size);
    }
    #bfc-hasselblad-editorial-{{ section.id }} .bfc-heading{
      font-family: var(--bfc-header-family, inherit);
      font-size: clamp(var(--bfc-header-size-mobile, 1.75rem), 3.5vw, var(--bfc-header-size-desktop, 2.75rem));
      font-weight: var(--bfc-header-weight, 300);
      line-height: var(--bfc-header-line-height, 1.05);
      letter-spacing: var(--bfc-header-letter-spacing, -0.02em);
      margin: 0;
      color: var(--bfc-heading-color, #111111);
    }
        #bfc-hasselblad-editorial-{{ section.id }} .bfc-block{
      margin: 0 auto;
    }
    #bfc-hasselblad-editorial-{{ section.id }} .bfc-block + .bfc-block{
      margin-top: 24px;
    }
    #bfc-hasselblad-editorial-{{ section.id }} .visually-hidden{
      position: absolute;width: 1px;height: 1px;padding: 0;margin: -1px;overflow: hidden;clip: rect(0,0,0,0);white-space: nowrap;border: 0;
    }
    #bfc-hasselblad-editorial-{{ section.id }} a:focus-visible,
    #bfc-hasselblad-editorial-{{ section.id }} button:focus-visible,
    #bfc-hasselblad-editorial-{{ section.id }} input:focus-visible{
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }
    @media (prefers-reduced-motion: reduce){
      #bfc-hasselblad-editorial-{{ section.id }} *{
        animation-duration: .01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: .01ms !important;
      }
    }
  
    #bfc-hasselblad-editorial-{{ section.id }} .bfc-eyebrow{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bfc-secondary-text);
      margin: 0 0 10px;
    }
    #bfc-hasselblad-editorial-{{ section.id }} .bfc-item-title{
      font-family: var(--bfc-item-title-family);
      font-weight: var(--bfc-item-title-weight);
      font-size: var(--bfc-body-size);
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--bfc-text);
    }

    #bfc-hasselblad-editorial-{{ section.id }} .bfc-detail-text{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: var(--bfc-body-weight);
      letter-spacing: var(--bfc-body-letter-spacing);
      line-height: var(--bfc-body-line-height);
      color: var(--bfc-secondary-text);
      margin: 0;
    }

  </style>
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'hasselblad_editorial' %}
        {% liquid
          assign hb_id = 'bfc-hb-' | append: section.id | append: '-' | append: block.id
          assign hb_has_image = false
          if block.settings.image != blank
            assign hb_has_image = true
          endif
        %}
        <section
          id="{{ hb_id }}"
          class="bfc-block bfc-hb"
          style="
            --hb-bg: {{ block.settings.bg }};
            --hb-fg: {{ block.settings.fg }};
            --hb-accent: {{ block.settings.accent }};
            --hb-border: {{ block.settings.border_color }};
            --hb-max: {{ page_width_px }}px;
            --hb-pt: {{ block.settings.padding_top }}px;
            --hb-pb: {{ block.settings.padding_bottom }}px;
            --bfc-block-pad: calc(var(--bfc-align-pad) + {{ block.settings.side_padding_vw }}vw);
          "
          {{ block.shopify_attributes }}
        >
          <div class="bfc-hb__wrap">
            <div class="bfc-hb__copy">
              {% if block.settings.eyebrow != blank %}
                <p class="bfc-hb__eyebrow">{{ block.settings.eyebrow | escape }}</p>
              {% endif %}
              {% if block.settings.kicker != blank %}
                <p class="bfc-hb__kicker">{{ block.settings.kicker | escape }}</p>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="bfc-hb__heading">{{ block.settings.heading | escape }}</h2>
              {% endif %}
              {% if block.settings.body != blank %}
                <p class="bfc-hb__body">{{ block.settings.body | escape }}</p>
              {% endif %}
              <div class="bfc-hb__ctas">
                {% if block.settings.cta_label != blank and block.settings.cta_url != blank %}
                  <a class="bfc-hb__cta bfc-hb__cta--primary" href="{{ block.settings.cta_url }}" aria-label="{{ block.settings.cta_label | escape }}">{{ block.settings.cta_label | escape }}</a>
                {% endif %}
                {% if block.settings.cta2_label != blank and block.settings.cta2_url != blank %}
                  <a class="bfc-hb__cta bfc-hb__cta--ghost" href="{{ block.settings.cta2_url }}" aria-label="{{ block.settings.cta2_label | escape }}">{{ block.settings.cta2_label | escape }}</a>
                {% endif %}
              </div>
            </div>
            <div class="bfc-hb__media">
              {% if hb_has_image %}
                <img
                  src="{{ block.settings.image | image_url: width: 2000 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 700 }} 700w,
                    {{ block.settings.image | image_url: width: 1100 }} 1100w,
                    {{ block.settings.image | image_url: width: 1600 }} 1600w,
                    {{ block.settings.image | image_url: width: 2000 }} 2000w
                  "
                  sizes="(min-width: 990px) 55vw, 100vw"
                  alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {% else %}
                <div class="bfc-hb__placeholder" aria-hidden="true"></div>
              {% endif %}
            </div>
          </div>
          <style>
            #{{ hb_id }}{
              background: var(--hb-bg);
              color: var(--hb-fg);
              padding: var(--hb-pt) 0 var(--hb-pb);
              overflow: hidden;
            }
            #{{ hb_id }} .bfc-hb__wrap{
              display: grid;
              grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
              align-items: center;
              padding: 0 0 0 max(var(--bfc-block-pad), calc((100vw - var(--hb-max)) / 2));
            }
            #{{ hb_id }} .bfc-hb__copy{
              padding-right: clamp(32px, 5vw, 80px);
              max-width: 48ch;
            }
            #{{ hb_id }} .bfc-hb__eyebrow{
              margin: 0 0 6px;
              font-size: var(--bfc-body-size-small);
              letter-spacing: .18em;
              text-transform: uppercase;
              opacity: .6;
            }
            #{{ hb_id }} .bfc-hb__kicker{
              margin: 0 0 12px;
              font-family: var(--font-heading-family, serif);
              font-size: clamp(13px, 1.5vw, 17px);
              font-style: italic;
              letter-spacing: .02em;
              opacity: .7;
            }
            #{{ hb_id }} .bfc-hb__heading{
              font-family: var(--font-heading-family, serif);
              font-size: clamp(2.4rem, 5.5vw, 5.2rem);
              font-weight: 400;
              line-height: .98;
              letter-spacing: -0.03em;
              margin: 0 0 22px;
              color: var(--hb-fg);
            }
            #{{ hb_id }} .bfc-hb__body{
              font-size: var(--bfc-body-size);
              line-height: 1.55;
              opacity: .82;
              margin: 0 0 28px;
            }
            #{{ hb_id }} .bfc-hb__ctas{
              display: flex;
              flex-wrap: wrap;
              gap: 14px;
              align-items: center;
            }
            #{{ hb_id }} .bfc-hb__cta{
              text-decoration: none;
              font-size: var(--bfc-body-size-small);
              letter-spacing: .10em;
              text-transform: uppercase;
              display: inline-flex;
              align-items: center;
              transition: opacity .15s ease;
            }
            #{{ hb_id }} .bfc-hb__cta--primary{
              background: var(--hb-fg);
              color: var(--hb-bg);
              padding: 13px 24px;
            }
            #{{ hb_id }} .bfc-hb__cta--ghost{
              color: var(--hb-fg);
              opacity: .72;
              border-bottom: 1px solid currentColor;
              padding-bottom: 2px;
            }
            #{{ hb_id }} .bfc-hb__cta:hover{ opacity: .68; }
            #{{ hb_id }} .bfc-hb__media{
              overflow: hidden;
              background: rgba(0,0,0,.06);
              aspect-ratio: {{ block.settings.media_aspect }};
              min-height: 480px;
            }
            #{{ hb_id }} .bfc-hb__media img{
              width: 100%;
              height: 100%;
              object-fit: cover;
              display: block;
            }
            #{{ hb_id }} .bfc-hb__placeholder{
              width: 100%;
              height: 100%;
              min-height: 480px;
              background: rgba(0,0,0,.08);
            }
            @media (max-width: 900px){
              #{{ hb_id }} .bfc-hb__wrap{
                grid-template-columns: 1fr;
                padding: 0 var(--bfc-block-pad);
                gap: 32px;
              }
              #{{ hb_id }} .bfc-hb__copy{ max-width: none; padding-right: 0; }
              #{{ hb_id }} .bfc-hb__media{ min-height: 300px; }
              {% if block.settings.ignore_padding_mobile %}
                #{{ hb_id }}{ --bfc-block-pad: var(--bfc-horizontal-pad); }
              {% endif %}
            }
          </style>
        </section>
    {% endcase %}
  {% endfor %}
</section>
{% schema %}
{
  "name": "BFC Hasselblad Editorial",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "header_font_weight",
      "label": "Header font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "SemiBold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "body_font_weight",
      "label": "Body font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "body_font_size_small",
      "label": "Small text size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Base text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Base background color",
      "default": "#F7F4F0"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_size_preset",
      "label": "Heading size",
      "info": "Controls heading size at all screen widths consistently.",
      "options": [
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "xl",
          "label": "X-Large"
        },
        {
          "value": "xxl",
          "label": "XX-Large"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "header_line_height",
      "label": "Heading line height",
      "options": [
        {
          "value": "1.0",
          "label": "1.0 (Tightest)"
        },
        {
          "value": "1.05",
          "label": "1.05 (Default)"
        },
        {
          "value": "1.1",
          "label": "1.1"
        },
        {
          "value": "1.2",
          "label": "1.2"
        },
        {
          "value": "1.3",
          "label": "1.3"
        },
        {
          "value": "1.4",
          "label": "1.4 (Loose)"
        }
      ],
      "default": "1.05"
    },
    {
      "type": "range",
      "id": "header_letter_spacing",
      "label": "Heading letter spacing",
      "min": -2,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": -2
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "info": "Falls back to base text color if unset",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Body Typography"
    },
    {
      "type": "select",
      "id": "body_line_height",
      "label": "Body line height",
      "options": [
        {
          "value": "1.3",
          "label": "1.3 (Tight)"
        },
        {
          "value": "1.4",
          "label": "1.4"
        },
        {
          "value": "1.5",
          "label": "1.5 (Default)"
        },
        {
          "value": "1.6",
          "label": "1.6"
        },
        {
          "value": "1.8",
          "label": "1.8 (Loose)"
        }
      ],
      "default": "1.5"
    },
    {
      "type": "range",
      "id": "body_letter_spacing",
      "label": "Body letter spacing",
      "min": -1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Used for links and highlights",
      "default": "#E36E15"
    },
    {
      "type": "color",
      "id": "secondary_text_color",
      "label": "Secondary text color",
      "info": "Used for eyebrows and small detail text",
      "default": "#82906B"
    },
    {
      "type": "font_picker",
      "id": "item_title_font",
      "label": "Item title font",
      "info": "Font used for product/item titles (e.g. the old best-seller title font)",
      "default": "poppins_n5"
    }
  ],
  "blocks": [
    {
      "type": "hasselblad_editorial",
      "name": "Hasselblad Editorial",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Medium Format"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker (italic sub-line)",
          "default": "Designed in Gothenburg, 1957"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The last camera you'll ever need."
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "The 500 C/M. Modular, repairable, and unchanged because it never needed to change."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Primary CTA",
          "default": "Shop Hasselblad"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Primary CTA link"
        },
        {
          "type": "text",
          "id": "cta2_label",
          "label": "Secondary CTA"
        },
        {
          "type": "url",
          "id": "cta2_url",
          "label": "Secondary CTA link"
        },
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (right column)"
        },
        {
          "type": "select",
          "id": "media_aspect",
          "label": "Image aspect",
          "default": "1 / 1",
          "options": [
            {
              "value": "1 / 1",
              "label": "Square (1:1)"
            },
            {
              "value": "4 / 5",
              "label": "Portrait (4:5)"
            },
            {
              "value": "3 / 4",
              "label": "Tall (3:4)"
            },
            {
              "value": "4 / 3",
              "label": "Landscape (4:3)"
            }
          ]
        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "bg",
          "label": "Background",
          "default": "#111111"
        },
        {
          "type": "color",
          "id": "fg",
          "label": "Text",
          "default": "#f5f0eb"
        },
        {
          "type": "color",
          "id": "accent",
          "label": "Accent",
          "default": "#f5f0eb"
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border",
          "default": "#333333"
        },
        {
          "type": "header",
          "content": "Spacing"
        },
        {
          "type": "range",
          "id": "padding_top",
          "label": "Padding top",
          "min": 0,
          "max": 160,
          "step": 4,
          "default": 72
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "label": "Padding bottom",
          "min": 0,
          "max": 160,
          "step": 4,
          "default": 72
        },
        {
          "type": "range",
          "id": "side_padding_vw",
          "label": "Side padding add-on (vw)",
          "min": 0,
          "max": 10,
          "step": 0.5,
          "unit": "vw",
          "default": 0
        },
        {
          "type": "checkbox",
          "id": "ignore_padding_mobile",
          "label": "Ignore side padding on mobile",
          "default": false
        }
      ]
