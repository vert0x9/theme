    {
      "type": "range",
      "id": "best_sellers_count",
      "label": "Number of best sellers",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "BFC Default PDP"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
