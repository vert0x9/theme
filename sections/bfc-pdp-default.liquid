  "settings": [
    {
      "type": "header",
      "content": "Recommendations"
    },
    {
      "type": "checkbox",
      "id": "show_recs",
      "label": "Show 'You might also like' grid",
      "default": true,
      "info": "Shows up to N products from this product's first collection."
    },
    {
      "type": "range",
      "id": "rec_count",
      "label": "Number of recommendations",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Best Sellers"
    },
    {
      "type": "checkbox",
      "id": "show_best_sellers",
      "label": "Show 'Shop our best sellers' grid",
      "default": true,
      "info": "Renders below 'You might also like'. Falls back to the 'best-sellers' collection handle if none picked."
    },
    {
      "type": "collection",
      "id": "best_sellers_collection",
      "label": "Best sellers collection",
      "info": "Pick which collection to show. Leave blank to auto-use a collection with handle 'best-sellers'."
