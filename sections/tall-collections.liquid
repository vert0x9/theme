{%- comment -%}
  SECTION: New Card Carousel
  - Fresh start, no old code carried over.
  - 3 columns desktop, 1.5 columns mobile.
  - Defaults to 4:5 portrait aspect ratio.
  - Option for full bleed (no side padding).
  - Option to remove item gap.
  - Option for "auto height" on mobile.
  - Option for button alignment (H & V) per block.
  - Smaller mobile buttons.
  - UPDATED: Added header font controls (Serif/Sans, size, weight)
{%- endcomment -%}

{%- liquid
  assign header_align_class = 'text-left'
  if section.settings.header_align == 'center'
    assign header_align_class = 'text-center'
  elsif section.settings.header_align == 'right'
    assign header_align_class = 'text-right'
  endif

  # --- NEW: Header Font Logic ---
  assign sans_font_stack = '"Univers", "Helvetica Neue", Helvetica, Arial, sans-serif'
  assign serif_font_stack = '"Adobe Garamond Pro", "Garamond", "Times New Roman", serif'
  assign header_font_family = sans_font_stack
  if section.settings.header_font_style == 'serif'
    assign header_font_family = serif_font_stack
  endif

  case section.settings.image_aspect_ratio
    when 'portrait_4_5'
      assign aspect_ratio = '125%'
      assign aspect_height_for_img_tag = 1250
    when 'square_1_1'
      assign aspect_ratio = '100%'
      assign aspect_height_for_img_tag = 1000
    else
      assign aspect_ratio = '125%'
      assign aspect_height_for_img_tag = 1250
  endcase

  assign mobile_item_width = 100.0 | divided_by: section.settings.mobile_items_per_view
-%}

{%- style -%}
  #new-card-carousel-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --header-text-color: {{ section.settings.header_text_color }};
    --bg-color: {{ section.settings.bg_color }};
    
    /* --- NEW: Header Font Variables --- */
    --header-font-family: {{ header_font_family }};
    --header-font-size-mobile: {{ section.settings.header_font_size_mobile }}rem;
    --header-font-size-desktop: {{ section.settings.header_font_size_desktop }}rem;
    --header-font-weight: {{ section.settings.header_font_weight }};

    --card-title-color: {{ section.settings.card_title_color }};
    --button-bg-color: {{ section.settings.button_bg_color }};
    --button-text-color: {{ section.settings.button_text_color }};

    --item-width-mobile: {{ mobile_item_width }}%;
    --desktop-columns: {{ section.settings.columns_desktop }};
    
    --item-gap: {%- if section.settings.remove_item_gap -%}0px{%- else -%}{{ section.settings.item_gap }}px{%- endif -%};
    
    --image-aspect-ratio: {{ aspect_ratio }}; 
    --image-radius: {{ section.settings.image_radius }}px;

    {%- if section.settings.full_bleed -%}
      --side-padding-mobile: 0rem;
      --side-padding-desktop: 0rem;
    {%- else -%}
      --side-padding-mobile: 1rem;
      --side-padding-desktop: 2rem;
    {%- endif -%}

    background-color: var(--bg-color);
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    box-sizing: border-box; 
  }

  /* Header styles */
  #new-card-carousel-{{ section.id }} .carousel-header-wrapper {
    margin-bottom: 24px;
    padding-left: var(--side-padding-mobile);
    padding-right: var(--side-padding-mobile);
  }
  
  /* --- UPDATED: Use Font Variables --- */
  #new-card-carousel-{{ section.id }} .carousel-header-wrapper h2 {
    font-family: var(--header-font-family);
    font-size: var(--header-font-size-mobile); /* Mobile-first */
    font-weight: var(--header-font-weight);
    margin: 0;
    color: var(--header-text-color);
  }

  /* Carousel Scroller - enables horizontal scrolling on mobile */
  #new-card-carousel-{{ section.id }} .carousel-scroller {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none; 
    -ms-overflow-style: none; 
    -webkit-overflow-scrolling: touch; 
  }
  #new-card-carousel-{{ section.id }} .carousel-scroller::-webkit-scrollbar {
    display: none; 
  }

  /* List of carousel items */
  #new-card-carousel-{{ section.id }} .carousel-list {
    display: flex;
    flex-wrap: nowrap;
    list-style: none;
    margin: 0;
    padding-left: var(--side-padding-mobile);
    padding-right: var(--side-padding-mobile);
    gap: var(--item-gap);
  }
  
  /* Individual carousel item */
  #new-card-carousel-{{ section.id }} .carousel-item {
    flex-shrink: 0;
    width: var(--item-width-mobile);
  }

  /* Card container */
  #new-card-carousel-{{ section.id }} .carousel-card {
    position: relative;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    border-radius: var(--image-radius);
  }
  #new-card-carousel-{{ section.id }} .carousel-card:hover .carousel-media img {
    transform: scale(1.05);
  }

  /* Image wrapper */
  #new-card-carousel-{{ section.id }} .carousel-media {
    position: relative;
    overflow: hidden;
    background-color: #f0f0f0; 
    border-radius: var(--image-radius);
  }
  
  /* Gradient overlay for text readability */
  #new-card-carousel-{{ section.id }} .carousel-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0,0,0,0) 0%,
      rgba(0,0,0,0.1) 50%,
      rgba(0,0,0,0.6) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* --- Aspect Ratio Control --- */
  
  /* Default: Force Aspect Ratio (for Desktop & Mobile fallback) */
  #new-card-carousel-{{ section.id }} .carousel-media::before {
    content: '';
    display: block;
    padding-top: var(--image-aspect-ratio);
  }
  #new-card-carousel-{{ section.id }} .carousel-media img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  /* Mobile-only override for Auto Height */
  {%- if section.settings.auto_height_mobile -%}
    @media (max-width: 749px) {
      #new-card-carousel-{{ section.id }} .carousel-media::before {
        display: none; 
      }
      #new-card-carousel-{{ section.id }} .carousel-media img {
        position: static; 
        display: block;
        width: 100%;
        height: auto; 
      }
    }
  {%- endif -%}

  
  /* Caption (Text & Button) - Positioned over the image */
  #new-card-carousel-{{ section.id }} .carousel-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.25rem;
    z-index: 2;
    color: var(--card-title-color); 
    display: flex;
    flex-direction: column;
    justify-content: flex-end; 
    min-height: 50%; 
    box-sizing: border-box;
  }

  #new-card-carousel-{{ section.id }} .carousel-caption h3 {
    font-size: 1.125rem; 
    font-weight: 600;
    line-height: 1.3;
  }

  /* Button styles */
  #new-card-carousel-{{ section.id }} .card-button {
    display: inline-block;
    background-color: var(--button-bg-color);
    color: var(--button-text-color);
    padding: 8px 20px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    border-radius: 24px; 
    transition: all 0.2s ease;
    margin-top: auto; 
    
    /* --- Per-block alignment --- */
    align-self: var(--button-align); 
  }
  #new-card-carousel-{{ section.id }} .card-button:hover {
    filter: brightness(0.9);
  }
  
  /* --- Mobile Button Size Fix --- */
  @media (max-width: 749px) {
    #new-card-carousel-{{ section.id }} .card-button {
      padding: 4px 14px;
      font-size: 0.75rem;
      font-weight: 500;
    }
    #new-card-carousel-{{ section.id }} .carousel-caption h3 {
      font-size: 1rem;
    }
  }

  /* --- Desktop overrides --- */
  @media (min-width: 750px) {
    /* --- NEW: Desktop font size override --- */
    #new-card-carousel-{{ section.id }} .carousel-header-wrapper h2 {
      font-size: var(--header-font-size-desktop);
    }
    
    #new-card-carousel-{{ section.id }} .carousel-header-wrapper {
      padding-left: var(--side-padding-desktop);
      padding-right: var(--side-padding-desktop);
    }
    
    #new-card-carousel-{{ section.id }} .carousel-scroller {
      overflow-x: hidden; 
    }
    
    #new-card-carousel-{{ section.id }} .carousel-list {
      display: grid;
      grid-template-columns: repeat(var(--desktop-columns), 1fr);
      padding-left: var(--side-padding-desktop);
      padding-right: var(--side-padding-desktop);
    }
    
    #new-card-carousel-{{ section.id }} .carousel-item {
      width: 100%; 
    }

    #new-card-carousel-{{ section.id }} .carousel-caption h3 {
      font-size: 1.25rem; 
    }

    /* Remove border radius on outer edges if full bleed */
    {%- if section.settings.full_bleed -%}
      #new-card-carousel-{{ section.id }} .carousel-item:first-child .carousel-card {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
      }
      #new-card-carousel-{{ section.id }} .carousel-item:last-child .carousel-card {
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
      }
      #new-card-carousel-{{ section.id }} .carousel-item:first-child .carousel-media {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
      }
      #new-card-carousel-{{ section.id }} .carousel-item:last-child .carousel-media {
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
      }
    {%- endif -%}
  }
{%- endstyle -%}

<section id="new-card-carousel-{{ section.id }}" class="new-card-carousel-section">
  
  {%- if section.settings.title != blank -%}
    <header class="carousel-header-wrapper {{ header_align_class }}">
      <h2>{{ section.settings.title | escape }}</h2>
    </header>
  {%- endif -%}

  <div class="carousel-scroller">
    <ul class="carousel-list">
      {%- for block in section.blocks -%}
        <li class="carousel-item" {{ block.shopify_attributes }}>
          
          <div class="carousel-card" style="--button-align: {{ block.settings.button_alignment }};">
            <div class="carousel-media">
              {%- if block.settings.image != blank -%}
                <img 
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 300 }} 300w,
                    {{ block.settings.image | image_url: width: 450 }} 450w,
                    {{ block.settings.image | image_url: width: 600 }} 600w,
                    {{ block.settings.image | image_url: width: 800 }} 800w
                  "
                  sizes="
                    (min-width: 750px) calc(100vw / {{ section.settings.columns_desktop }}),
                    {{ mobile_item_width }}vw
                  "
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  loading="lazy"
                  width="1000"
                  height="{{ aspect_height_for_img_tag }}"
                >
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            
            <div class="carousel-caption">
              {%- if block.settings.button_vertical_position == 'above_title' -%}
                {%- if block.settings.button_label != blank -%}
                  <a href="{{ block.settings.button_link | default: '#' }}" class="card-button" style="margin-bottom: 0.75rem;">
                    {{ block.settings.button_label | escape }}
                  </a>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3>{{ block.settings.title | escape }}</h3>
                {%- endif -%}
              {%- else -%}
                {%- if block.settings.title != blank -%}
                  <h3 style="margin-bottom: 0.75rem;">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.button_label != blank -%}
                  <a href="{{ block.settings.button_link | default: '#' }}" class="card-button">
                    {{ block.settings.button_label | escape }}
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>
            
            {%- comment -%}
              This main link wraps the whole card for accessibility
              and is "behind" the buttons/links.
            {%- endcomment -%}
            {%- if block.settings.main_link != blank -%}
              <a href="{{ block.settings.main_link }}" 
                 aria-label="{{ block.settings.title | escape }}"
                 style="position:absolute; inset:0; z-index:0;">
              </a>
            {%- endif -%}
          </div>
          
        </li>
      {%- endfor -%}
    </ul>
  </div>
  
  {%- if section.blocks.size == 0 -%}
    <div style="text-align: center; padding: 2rem; color: var(--header-text-color);">
      <p>Add card slides in the theme editor.</p>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "New Card Carousel",
  "tag": "section",
  "class": "section-new-card-carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "header_font_style",
      "label": "Header font style",
      "options": [
        { "value": "sans", "label": "Sans (Univers-like)" },
        { "value": "serif", "label": "Serif (Garamond-like)" }
      ],
      "default": "sans"
    },
    {
      "type": "range",
      "id": "header_font_size_mobile",
      "label": "Header title size (Mobile)",
      "min": 1.2,
      "max": 3,
      "step": 0.1,
      "unit": "rem",
      "default": 1.5
    },
    {
      "type": "range",
      "id": "header_font_size_desktop",
      "label": "Header title size (Desktop)",
      "min": 1.5,
      "max": 4.5,
      "step": 0.1,
      "unit": "rem",
      "default": 1.8
    },
    {
      "type": "select",
      "id": "header_font_weight",
      "label": "Header font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Layout Options"
    },
    {
      "type": "checkbox",
      "id": "full_bleed",
      "label": "Enable full bleed (no side padding)",
      "info": "Uncheck for standard small side padding.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "remove_item_gap",
      "label": "Remove gap between items",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "auto_height_mobile",
      "label": "Conform card height to image (Mobile)",
      "info": "On mobile, card height will be set by the image. Best if all images have a similar shape.",
      "default": false
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "info": "Used on desktop, and on mobile if 'Conform card height' is unchecked.",
      "options": [
        { "value": "portrait_4_5", "label": "Portrait (4:5)" },
        { "value": "square_1_1", "label": "Square (1:1)" }
      ],
      "default": "portrait_4_5"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3,
      "info": "The number of items to show side-by-side on desktop."
    },
    {
      "type": "range",
      "id": "desktop_max_width",
      "label": "Card max width (Desktop)",
      "min": 300,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 450,
      "info": "Caps the width of cards on desktop. This also controls the max height proportionally. NOTE: This setting is currently overridden by the layout."
    },
    {
      "type": "range",
      "id": "mobile_items_per_view",
      "label": "Items to show (Mobile)",
      "min": 1.2,
      "max": 2.2,
      "step": 0.1,
      "default": 1.5,
      "info": "Set to 1.5 to show one full item and half of the next."
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap between items",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors & Button Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "header_text_color",
      "label": "Header Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Carousel Card",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Shop Category"
        },
        {
          "type": "url",
          "id": "main_link",
          "label": "Main Card Link (covers entire card)"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "button_alignment",
          "label": "Button Alignment (Horizontal)",
          "options": [
            { "value": "flex-start", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Right" }
          ],
          "default": "flex-start"
        },
        {
          "type": "select",
          "id": "button_vertical_position",
          "label": "Button Position (Vertical)",
          "options": [
            { "value": "bottom", "label": "Bottom of Card" },
            { "value": "above_title", "label": "Above Title" }
          ],
          "default": "bottom"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New Card Carousel",
      "blocks": [
        { "type": "card" },
        { "type": "card", "settings": { "title": "Shop Training", "button_label": "Explore Training" } },
        { "type": "card", "settings": { "title": "Shop Basketball", "button_label": "Discover Hoops" } }
      ]
    }
  ]
}
{% endschema %}