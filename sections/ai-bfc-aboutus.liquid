{% comment %}
  BFC Team — Shopify Section
  - Alternating rows on desktop, stacked on mobile
  - NO rounded edges
  - Image fit: contain (no crop) or cover (crop)
  - Defaults: NO blanks / no " " — every setting has a real default string/value
{% endcomment %}

<section
  id="bfc-emp-{{ section.id }}"
  class="bfc-emp-wrap bfc-emp-fit--{{ section.settings.image_fit }}"
>
  <div class="bfc-emp-list">
    {% if section.settings.heading != blank %}
      <header class="bfc-emp-header">
        <h2 class="bfc-emp-heading">{{ section.settings.heading | escape }}</h2>
      </header>
    {% endif %}

    {% for block in section.blocks %}
      {% if block.type == 'member' %}
        {%- assign mod = forloop.index0 | modulo: 2 -%}
        {%- assign is_even = false -%}

        {%- if section.settings.start_right -%}
          {%- if mod == 0 -%}{%- assign is_even = true -%}{%- endif -%}
        {%- else -%}
          {%- if mod == 1 -%}{%- assign is_even = true -%}{%- endif -%}
        {%- endif -%}

        <article class="bfc-emp{% if is_even %} is-even{% endif %}" {{ block.shopify_attributes }}>
          <div class="bfc-emp-grid">
            <div class="bfc-emp-media">
              <div class="bfc-emp-square">
                {% if block.settings.photo != blank %}
                  <img
                    class="bfc-emp-photo"
                    src="{{ block.settings.photo | image_url: width: 1400 }}"
                    alt="{{ block.settings.name | escape }}"
                    loading="lazy"
                    width="{{ block.settings.photo.width }}"
                    height="{{ block.settings.photo.height }}"
                  >
                {% elsif block.settings.photo_url != blank %}
                  {% # theme-check-disable-next-line RemoteAsset %}
                  <img
                    class="bfc-emp-photo"
                    src="{{ block.settings.photo_url | escape }}"
                    alt="{{ block.settings.name | escape }}"
                    loading="lazy"
                    width="{{ block.settings.photo_width }}"
                    height="{{ block.settings.photo_height }}"
                  >
                {% else %}
                  <div class="bfc-emp-photo bfc-emp-photo--placeholder" aria-hidden="true"></div>
                {% endif %}
              </div>
            </div>

            <div class="bfc-emp-copy">
              <h3 class="bfc-emp-name">{{ block.settings.name | escape }}</h3>

              <p class="bfc-emp-role">
                {{ block.settings.role | escape }}
                {% if block.settings.email != blank %}
                  · <a href="mailto:{{ block.settings.email | escape }}">{{ block.settings.email | escape }}</a>
                {% endif %}
              </p>

              <div class="bfc-emp-bio">
                {{ block.settings.bio }}
              </div>

              {% assign has_links = false %}
              {% if block.settings.link_1_url != blank and block.settings.link_1_label != blank %}{% assign has_links = true %}{% endif %}
              {% if block.settings.link_2_url != blank and block.settings.link_2_label != blank %}{% assign has_links = true %}{% endif %}
              {% if block.settings.link_3_url != blank and block.settings.link_3_label != blank %}{% assign has_links = true %}{% endif %}

              {% if has_links %}
                <div class="bfc-links" aria-label="Links for {{ block.settings.name | escape }}">
                  {% assign printed = false %}

                  {% if block.settings.link_1_url != blank and block.settings.link_1_label != blank %}
                    <a href="{{ block.settings.link_1_url }}" target="_blank" rel="noopener">{{ block.settings.link_1_label | escape }}</a>
                    {% assign printed = true %}
                  {% endif %}

                  {% if block.settings.link_2_url != blank and block.settings.link_2_label != blank %}
                    {% if printed %}<span aria-hidden="true">·</span>{% endif %}
                    <a href="{{ block.settings.link_2_url }}" target="_blank" rel="noopener">{{ block.settings.link_2_label | escape }}</a>
                    {% assign printed = true %}
                  {% endif %}

                  {% if block.settings.link_3_url != blank and block.settings.link_3_label != blank %}
                    {% if printed %}<span aria-hidden="true">·</span>{% endif %}
                    <a href="{{ block.settings.link_3_url }}" target="_blank" rel="noopener">{{ block.settings.link_3_label | escape }}</a>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  #bfc-emp-{{ section.id }}{
    --emp-max-w: {{ section.settings.max_width }}px;
    --emp-gap: clamp(14px, 2.2vw, 28px);
    --emp-radius: 0px;
    --emp-shadow: 0 10px 24px rgba(17,24,39,.06);
    --ink:#111;
    --muted:#6b7280;
    --card:#fff;
    --border:#e5e7eb;
    --img-bg: {{ section.settings.image_bg }};
    --contain-pad: {{ section.settings.contain_padding }}px;

    color:var(--ink);
    padding:clamp(18px, 3vw, 32px) 0;
    background: {{ section.settings.background_color }};
  }

  #bfc-emp-{{ section.id }} .bfc-emp-list{
    max-width:var(--emp-max-w);
    margin:0 auto;
    display:grid;
    gap:var(--emp-gap);
    padding:0 clamp(16px, 3vw, 20px);
  }

  #bfc-emp-{{ section.id }} .bfc-emp-header{ margin-bottom: clamp(6px, 1.6vw, 14px); }
  #bfc-emp-{{ section.id }} .bfc-emp-heading{
    margin:0;
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  #bfc-emp-{{ section.id }} .bfc-emp{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:var(--emp-radius);
    {% if section.settings.enable_shadow %} box-shadow:var(--emp-shadow); {% endif %}
    overflow:hidden;
  }

  #bfc-emp-{{ section.id }} .bfc-emp-grid{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap:var(--emp-gap);
    align-items:stretch;
  }

  #bfc-emp-{{ section.id }} .bfc-emp.is-even .bfc-emp-media{order:2}
  #bfc-emp-{{ section.id }} .bfc-emp.is-even .bfc-emp-copy{order:1}

  #bfc-emp-{{ section.id }} .bfc-emp-square{
    position:relative;
    width:100%;
    aspect-ratio:1/1;
    overflow:hidden;
    border-radius:0;
    background: var(--img-bg);
  }

  #bfc-emp-{{ section.id }}.bfc-emp-fit--cover .bfc-emp-photo{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    object-fit:cover;
    object-position:center;
    display:block;
    border-radius:0;
  }

  #bfc-emp-{{ section.id }}.bfc-emp-fit--contain .bfc-emp-square{
    display:flex;
    align-items:center;
    justify-content:center;
    padding: var(--contain-pad);
    box-sizing:border-box;
  }
  #bfc-emp-{{ section.id }}.bfc-emp-fit--contain .bfc-emp-photo{
    position:static;
    width:auto;
    height:auto;
    max-width:100%;
    max-height:100%;
    display:block;
    border-radius:0;
  }

  #bfc-emp-{{ section.id }} .bfc-emp-photo--placeholder{
    background:linear-gradient(135deg,#f4f4f4,#e9e9e9);
    position:absolute;
    inset:0;
    border-radius:0;
  }

  #bfc-emp-{{ section.id }} .bfc-emp-copy{
    display:flex;
    flex-direction:column;
    justify-content:center;
    padding:clamp(14px,2.5vw,28px);
  }

  #bfc-emp-{{ section.id }} .bfc-emp-name{
    margin:0 0 2px;
    font-size:clamp(20px,2.4vw,26px);
    font-weight:800;
  }

  #bfc-emp-{{ section.id }} .bfc-emp-role{
    margin:0 0 10px;
    color:var(--muted);
    font-weight:600;
  }
  #bfc-emp-{{ section.id }} .bfc-emp-role a{ color:inherit; text-decoration:underline; }

  #bfc-emp-{{ section.id }} .bfc-emp-bio{ line-height:1.7; }
  #bfc-emp-{{ section.id }} .bfc-links{ margin-top:10px; display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
  #bfc-emp-{{ section.id }} .bfc-links a{ font-weight:600; text-decoration:underline; }
  #bfc-emp-{{ section.id }} .bfc-links span{ margin:0 2px; color:var(--muted); }

  @media (max-width: 767px){
    #bfc-emp-{{ section.id }} .bfc-emp-grid{grid-template-columns:1fr}
    #bfc-emp-{{ section.id }} .bfc-emp-media{order:1}
    #bfc-emp-{{ section.id }} .bfc-emp-copy{order:2}
    #bfc-emp-{{ section.id }} .bfc-emp-square{ aspect-ratio:auto; height:clamp(260px, 55vh, 620px); }
  }
</style>

{% schema %}
{
  "name": "BFC Team (No Rounded)",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Team" },
    { "type": "checkbox", "id": "start_right", "label": "Start with photo on right (first row)", "default": true },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 720, "max": 1400, "step": 20, "default": 1100 },
    { "type": "checkbox", "id": "enable_shadow", "label": "Enable card shadow", "default": true },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#ffffff" },

    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "default": "contain",
      "options": [
        { "value": "contain", "label": "Contain (fit, no crop)" },
        { "value": "cover", "label": "Cover (crop to fill)" }
      ]
    },
    { "type": "color", "id": "image_bg", "label": "Image background (for contain)", "default": "#ffffff" },
    { "type": "range", "id": "contain_padding", "label": "Contain padding (px)", "min": 0, "max": 60, "step": 2, "default": 0 }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team member",
      "settings": [
        { "type": "image_picker", "id": "photo", "label": "Photo (optional)" },
        { "type": "text", "id": "photo_url", "label": "Photo URL fallback (used if Photo is empty)", "default": "https://cdn.shopify.com/s/files/1/0575/8638/5068/files/BFC_Taylor.jpg?v=1757179560" },

        { "type": "number", "id": "photo_width", "label": "Photo width attribute (for URL fallback)", "default": 1200 },
        { "type": "number", "id": "photo_height", "label": "Photo height attribute (for URL fallback)", "default": 1200 },

        { "type": "text", "id": "name", "label": "Name", "default": "Team Member Name" },
        { "type": "text", "id": "role", "label": "Role / title", "default": "Role / Title" },
        { "type": "text", "id": "email", "label": "Email (optional)", "default": "hello@brooklynfilmcamera.com" },
        { "type": "richtext", "id": "bio", "label": "Bio", "default": "<p>Add a short bio here.</p>" },

        { "type": "text", "id": "link_1_label", "label": "Link 1 label", "default": "Link" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },

        { "type": "text", "id": "link_2_label", "label": "Link 2 label", "default": "Link" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },

        { "type": "text", "id": "link_3_label", "label": "Link 3 label", "default": "Link" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BFC Team (No Rounded)",
      "blocks": [
        {
          "type": "member",
          "settings": {
            "photo_url": "https://cdn.shopify.com/s/files/1/0575/8638/5068/files/BFC_Taylor.jpg?v=1757179560",
            "photo_width": 1200,
            "photo_height": 1200,
            "name": "Taylor",
            "role": "Camera Tech · Lens Specialist",
            "email": "taylor@brooklynfilmcamera.com",
            "bio": "<p>Taylor is a freelance camera assistant, graphic designer, and lens tech at BFC. Her path through the film world started behind the camera, but eventually she also found herself drawn to what’s inside the gear. There’s an art to fixing something broken, restoring a lens, cleaning out the years, and revealing its history. It is not just repair, it is giving new life to gear that has captured so many moments and will continue to capture more.</p>",
            "link_1_label": "Instagram",
            "link_1_url": "https://www.instagram.com/filmsbytaylor/?hl=en",
            "link_2_label": "Extra link label",
            "link_3_label": "Extra link label"
          }
        }
      ]
    }
  ]
}
{% endschema %}
