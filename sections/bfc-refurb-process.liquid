  {%- assign step1_p_default       = 'Battery, capacitor, LCD, modes.' -%}
  {%- assign step2_h_default       = 'Optics and AF' -%}
  {%- assign step2_p_default       = 'Lens cleaned, AF tested at all ranges.' -%}
  {%- assign step3_h_default       = 'Flash and meter' -%}
