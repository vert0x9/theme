<script>
(function(){
  var sec = document.querySelector('.bfc-rp[data-section-id="{{ section.id }}"]');
  if (!sec || sec.getAttribute('data-mobile-sticky') !== 'true') return;
  var details = sec.querySelector('.bfc-rp-details');
  var summary = sec.querySelector('.bfc-rp-summary');
  var scrim = sec.querySelector('[data-rp-scrim]');
  if (!details || !summary) return;

  var mq = window.matchMedia('(max-width: 768px)');

  /* Reserve space at the bottom of the page so the fixed bar never covers the
     footer. Only while sticky is active (mobile). Uses the collapsed bar height. */
  function setOffset(){
    if (mq.matches){
      // measure the summary bar height (the always-visible part)
      var h = summary.getBoundingClientRect().height || 64;
      document.body.style.paddingBottom = Math.ceil(h) + 'px';
    } else {
      document.body.style.paddingBottom = '';
    }
  }

  function syncOpen(){
    var open = details.hasAttribute('open') && mq.matches;
    sec.classList.toggle('is-open', open);
    // lock page scroll behind the drawer on mobile when open
    if (open){ document.documentElement.style.overflow = 'hidden'; }
    else { document.documentElement.style.overflow = ''; }
  }

  details.addEventListener('toggle', syncOpen);

  // Tapping the dimmed scrim closes the drawer
  if (scrim){
    scrim.addEventListener('click', function(){
      details.removeAttribute('open');
      syncOpen();
    });
  }

  // In the editor, don't trap scroll
  if (window.Shopify && window.Shopify.designMode){
    details.removeAttribute('open');
  }

  setOffset();
  syncOpen();
  window.addEventListener('resize', function(){ setOffset(); syncOpen(); });
  if (mq.addEventListener) mq.addEventListener('change', function(){ setOffset(); syncOpen(); });
})();
</script>

<style>
  .bfc-rp {
    --rp-or: #E36E15;
    --rp-go: #F4A027;
    --rp-ce: #ABCC99;
    --rp-cv: #F8F6EE;
    --rp-bk: #202009;
    --rp-ch: #4E4741;
    --rp-gr: #E3DDDA;
    font-family: 'Poppins', sans-serif;
    color: var(--rp-bk);
    background: var(--rp-cv);
  }
  .bfc-rp, .bfc-rp * {
    word-break: normal;
    overflow-wrap: break-word;
    hyphens: none;
    box-sizing: border-box;
  }

  .bfc-rp-details {
    border-top: 1px solid var(--rp-bk);
    border-bottom: 1px solid var(--rp-bk);
  }

  /* ── Collapsed bar ── */
  .bfc-rp-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 22px 32px;
    cursor: pointer;
    list-style: none;
    transition: background 0.2s ease;
    user-select: none;
  }
  .bfc-rp-summary::-webkit-details-marker { display: none; }
  .bfc-rp-summary:hover { background: rgba(227, 110, 21, 0.04); }
  .bfc-rp-summary-text {
    display: flex;
    align-items: baseline;
    gap: 20px;
    min-width: 0;
    flex: 1 1 auto;
  }
  .bfc-rp-summary-ey {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--rp-or);
    flex: 0 0 auto;
    white-space: nowrap;
  }
  .bfc-rp-summary-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--rp-bk);
    min-width: 0;
  }
  .bfc-rp-summary-toggle {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 0 0 auto;
  }
  .bfc-rp-summary-cta-open,
  .bfc-rp-summary-cta-close {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rp-ch);
    white-space: nowrap;
  }
  .bfc-rp-summary-cta-close { display: none; }
  .bfc-rp-details[open] .bfc-rp-summary-cta-open { display: none; }
  .bfc-rp-details[open] .bfc-rp-summary-cta-close { display: inline; }
  .bfc-rp-summary-icon {
    position: relative;
    display: inline-block;
    width: 14px; height: 14px;
    color: var(--rp-bk);
  }
  .bfc-rp-summary-icon::before,
  .bfc-rp-summary-icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    transition: transform 0.3s ease;
  }
  .bfc-rp-summary-icon::before {
    top: 50%; left: 0; right: 0; height: 1px;
    transform: translateY(-50%);
  }
  .bfc-rp-summary-icon::after {
    top: 0; bottom: 0; left: 50%; width: 1px;
    transform: translateX(-50%);
  }
  .bfc-rp-details[open] .bfc-rp-summary-icon::after {
    transform: translateX(-50%) scaleY(0);
  }

  /* ── Body ── */
  .bfc-rp-body {
    border-top: 1px solid var(--rp-gr);
    animation: bfcRpReveal 0.35s ease-out;
  }
  @keyframes bfcRpReveal {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .bfc-rp-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 56px 32px 64px;
  }

  /* ── Hero ── */
  .bfc-rp-hero {
    padding: 40px 40px;
    background: var(--rp-bk);
    color: var(--rp-cv);
    margin-bottom: 40px;
  }
  .bfc-rp-hero-ey {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rp-or);
    margin: 0 0 12px;
  }
  .bfc-rp-hero-h {
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 16px;
    color: var(--rp-cv);
    letter-spacing: -0.005em;
  }
  .bfc-rp-hero-h em {
    font-style: italic;
    color: var(--rp-go);
  }
  .bfc-rp-hero-p {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(248, 246, 238, 0.85);
    margin: 0;
    max-width: 640px;
  }

  /* ── Pillars ── */
  .bfc-rp-pillars {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: var(--rp-gr);
    border: 1px solid var(--rp-gr);
    margin-bottom: 48px;
  }
  .bfc-rp-pillar {
    background: var(--rp-cv);
    padding: 24px 22px 26px;
    min-width: 0;
  }
  .bfc-rp-pillar-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px;
    font-weight: 300;
    color: var(--rp-or);
    line-height: 1;
    margin: 0 0 14px;
  }
  .bfc-rp-pillar-h {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 10px;
    color: var(--rp-bk);
  }
  .bfc-rp-pillar-p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--rp-ch);
    margin: 0;
  }

  /* ── BFC vs stranger online ── */
  .bfc-rp-vs {
    background: #fff;
    border: 1px solid var(--rp-gr);
    margin-bottom: 48px;
  }
  .bfc-rp-vs-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .bfc-rp-vs-head > div { padding: 14px 18px; }
  .bfc-rp-vs-head > div:first-child {
    background: var(--rp-bk);
    color: var(--rp-go);
  }
  .bfc-rp-vs-head > div:last-child {
    background: var(--rp-gr);
    color: var(--rp-ch);
  }
  .bfc-rp-vs-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    border-top: 1px solid var(--rp-gr);
  }
  .bfc-rp-vs-row > div {
    padding: 16px 18px;
    font-size: 13px;
    line-height: 1.55;
  }
  .bfc-rp-vs-row > div:first-child {
    border-right: 1px solid var(--rp-gr);
    color: var(--rp-bk);
    font-weight: 500;
  }
  .bfc-rp-vs-row > div:last-child {
    color: var(--rp-ch);
    background: rgba(82, 87, 65, 0.025);
  }

  /* ── Process steps ── */
  .bfc-rp-process { margin-bottom: 48px; }
  .bfc-rp-process-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--rp-gr);
  }
  .bfc-rp-process-h {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 400;
    margin: 0;
    color: var(--rp-bk);
  }
  .bfc-rp-process-tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rp-or);
  }
  .bfc-rp-process-intro {
    font-size: 13px;
    line-height: 1.65;
    color: var(--rp-ch);
    margin: 0 0 22px;
    max-width: 640px;
  }
  .bfc-rp-steps {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1px;
    background: var(--rp-gr);
    border: 1px solid var(--rp-gr);
  }
  .bfc-rp-step {
    background: var(--rp-cv);
    padding: 20px 18px 22px;
    min-width: 0;
  }
  .bfc-rp-step-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--rp-or);
    margin: 0 0 12px;
    text-transform: uppercase;
  }
  .bfc-rp-step-h {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 6px;
    color: var(--rp-bk);
  }
  .bfc-rp-step-p {
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--rp-ch);
    margin: 0;
  }

  /* ── Guarantee band ── */
  .bfc-rp-guarantee {
    background: var(--rp-bk);
    color: var(--rp-cv);
    padding: 36px 40px;
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: 40px;
    align-items: center;
  }
  .bfc-rp-guarantee-ey {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rp-ce);
    margin: 0 0 10px;
  }
  .bfc-rp-guarantee-h {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 300;
    line-height: 1.2;
    color: var(--rp-cv);
    margin: 0 0 12px;
    letter-spacing: -0.005em;
  }
  .bfc-rp-guarantee-p {
    font-size: 13.5px;
    line-height: 1.65;
    color: rgba(248, 246, 238, 0.85);
    margin: 0;
  }
  .bfc-rp-guarantee-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .bfc-rp-guarantee-list li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 13px;
    color: rgba(248, 246, 238, 0.92);
    padding: 10px 0;
    border-bottom: 1px solid rgba(248, 246, 238, 0.12);
  }
  .bfc-rp-guarantee-list li:last-child { border-bottom: none; }
  .bfc-rp-guarantee-list li svg {
    flex-shrink: 0;
    color: var(--rp-ce);
    margin-top: 2px;
  }

  /* ── Optional CTA ── */
  .bfc-rp-footer {
    text-align: center;
    margin-top: 40px;
  }
  .bfc-rp-cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rp-bk);
    text-decoration: none;
    padding: 14px 28px;
    border: 1px solid var(--rp-bk);
    background: transparent;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .bfc-rp-cta:hover {
    background: var(--rp-bk);
    color: var(--rp-cv);
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .bfc-rp-pillars { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .bfc-rp-steps { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 768px) {
    .bfc-rp-summary { padding: 18px 20px; }
    .bfc-rp-summary-text { flex-direction: column; align-items: flex-start; gap: 4px; }
    .bfc-rp-summary-title { font-size: 18px; }
    .bfc-rp-summary-cta-open,
    .bfc-rp-summary-cta-close { display: none !important; }
    .bfc-rp-inner { padding: 40px 20px 48px; }
    .bfc-rp-hero { padding: 28px 24px; margin-bottom: 32px; }
    .bfc-rp-hero-h { font-size: 26px; }
    .bfc-rp-pillars {
      grid-template-columns: minmax(0, 1fr);
      margin-bottom: 36px;
    }
    .bfc-rp-pillar { padding: 22px 20px; }
    .bfc-rp-vs-head > div,
    .bfc-rp-vs-row > div { padding: 12px 14px; font-size: 12px; }
    .bfc-rp-process { margin-bottom: 36px; }
    .bfc-rp-process-h { font-size: 20px; }
    .bfc-rp-steps { grid-template-columns: minmax(0, 1fr); }
    .bfc-rp-step { padding: 18px 18px 20px; }
    .bfc-rp-guarantee {
      grid-template-columns: minmax(0, 1fr);
      padding: 28px 24px;
      gap: 24px;
    }
    .bfc-rp-guarantee-h { font-size: 22px; }
  }

  /* ── Mobile sticky bottom bar (opt-in via "Mobile: dock to bottom of screen") ──
     On phones, the whole details element fixes to the bottom of the viewport like
     a sticky ATC. The summary stays visible; tapping expands the body upward as a
     scrollable drawer. Desktop and the non-sticky case are unaffected. */
  @media (max-width: 768px) {
    .bfc-rp--sticky .bfc-rp-details {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 9990;
      background: var(--rp-cv);
      border-top: 1px solid var(--rp-bk);
      border-bottom: none;
      box-shadow: 0 -6px 24px rgba(32, 32, 9, 0.16);
      max-height: 85vh;
      display: flex;
      flex-direction: column;
    }
    /* Summary pinned as the bar; body scrolls above it when open */
    .bfc-rp--sticky .bfc-rp-summary {
      flex: 0 0 auto;
      order: 2;                 /* bar sits at the bottom of the fixed element */
      border-top: 1px solid var(--rp-gr);
    }
    .bfc-rp--sticky .bfc-rp-body {
      order: 1;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      flex: 1 1 auto;
      border-top: none;
    }
    /* Collapsed: only the bar shows. Open: drawer reveals above it. */
    .bfc-rp--sticky .bfc-rp-details:not([open]) .bfc-rp-body { display: none; }
    /* Re-show the open/close CTA label on the sticky bar (it's hidden by default on mobile) */
    .bfc-rp--sticky .bfc-rp-summary-cta-open { display: inline !important; }
    .bfc-rp--sticky .bfc-rp-details[open] .bfc-rp-summary-cta-open { display: none !important; }
    .bfc-rp--sticky .bfc-rp-details[open] .bfc-rp-summary-cta-close { display: inline !important; }
    .bfc-rp--sticky .bfc-rp-summary-toggle { flex-direction: row; align-items: center; }
    /* Dim the page behind the open drawer */
    .bfc-rp--sticky .bfc-rp-scrim {
      position: fixed;
      inset: 0;
      background: rgba(32, 32, 9, 0.4);
      z-index: 9989;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s ease, visibility 0.25s ease;
    }
    .bfc-rp--sticky.is-open .bfc-rp-scrim { opacity: 1; visibility: visible; }
  }
  /* Scrim never shows on desktop or when not sticky */
  .bfc-rp-scrim { display: none; }
  @media (max-width: 768px) { .bfc-rp--sticky .bfc-rp-scrim { display: block; } }
</style>

