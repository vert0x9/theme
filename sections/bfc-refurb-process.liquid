  {%- assign step5_h_default       = 'QC and warranty' -%}
  {%- assign step5_p_default       = 'Second tech, photos, warranty card.' -%}
{%- elsif t == 'ps' -%}
  {%- assign bar_title_default     = 'How we refurbish every point & shoot' -%}
  {%- assign hero_h_default        = 'Plastic fantastic, <em>actually working.</em>' -%}
  {%- assign hero_p_default        = 'Point & shoots are mostly electronic, which means most camera shops will not touch them. Ours will.' -%}
  {%- assign proc_h_default        = 'The point & shoot refurb process' -%}
  {%- assign proc_intro_default    = 'Compact cameras are full of electronics other shops will not service. We do.' -%}
