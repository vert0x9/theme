  {%- assign bar_title_default     = 'How we refurbish every camera' -%}
  {%- assign hero_h_default        = 'Every camera, <em>checked.</em>' -%}
  {%- assign hero_p_default        = 'Every camera in our shop — SLR, rangefinder, medium format, TLR, point & shoot — goes through our bench before it goes on the shelf.' -%}
  {%- assign proc_h_default        = 'Our refurb process' -%}
  {%- assign proc_intro_default    = 'The specifics vary by camera type, but the principle is the same: nothing ships until it is ready to shoot.' -%}
  {%- assign step1_h_default       = 'Open and inspect' -%}
  {%- assign step1_p_default       = 'Logged against our reference checklist.' -%}
  {%- assign step2_h_default       = 'Service mechanism' -%}
  {%- assign step2_p_default       = 'Clean, lube, re-tension as needed.' -%}
  {%- assign step3_h_default       = 'Calibrate' -%}
  {%- assign step3_p_default       = 'Pro test gear, not eyeball-and-hope.' -%}
  {%- assign step4_h_default       = 'Replace what is worn' -%}
  {%- assign step4_p_default       = 'Foams, seals, contacts. Standard, not upsell.' -%}
  {%- assign step5_h_default       = 'QC and warranty' -%}
