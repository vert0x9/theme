  {%- assign step3_h_default       = 'Lens service' -%}
  {%- assign step3_p_default       = 'Aperture, helicoid, leaf shutter.' -%}
  {%- assign step4_h_default       = 'System calibration' -%}
  {%- assign step4_p_default       = 'Body + back + lens, tested together.' -%}
  {%- assign step5_h_default       = 'QC and warranty' -%}
  {%- assign step5_p_default       = 'Second tech, photos, warranty card.' -%}
{%- elsif t == 'tlr' -%}
  {%- assign bar_title_default     = 'How we refurbish every TLR' -%}
  {%- assign hero_h_default        = 'Twin lenses, <em>matched.</em>' -%}
  {%- assign hero_p_default        = 'A TLR only works when the taking lens and viewing lens see the same thing. Every TLR we sell is collimated, focus-checked, and tested for light leaks before it leaves.' -%}
