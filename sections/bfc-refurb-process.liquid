{%- else -%}
  {%- comment -%} Default = SLR {%- endcomment -%}
  {%- assign bar_title_default     = 'How we refurbish every SLR' -%}
  {%- assign hero_h_default        = 'A working camera, <em>guaranteed.</em>' -%}
  {%- assign hero_p_default        = 'Every SLR in our shop has been through our bench, tested with professional equipment, and given a six-month warranty.' -%}
  {%- assign proc_h_default        = 'The SLR refurb process' -%}
