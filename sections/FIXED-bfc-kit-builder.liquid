<script>(function(){
var sec=document.getElementById('{{ kb_id }}');
if(!sec) return;
var step=1;
var sel={type:null,cam:null,addons:{}};
var pendingPill=null;
function showStep(n){
step=n;
sec.querySelectorAll('.bfc-kb__step').forEach(function(el){
el.classList.toggle('is-active',parseInt(el.dataset.step)===n);
});
sec.querySelectorAll('.bfc-kb__crumb').forEach(function(el){
var s=parseInt(el.dataset.step);
el.classList.toggle('is-active', s===n);
el.classList.toggle('is-done', s<n);
el.setAttribute('aria-current', s===n ? 'step' : 'false');
el.querySelector('.bfc-kb__crumb-num').textContent=s<n?'✓':s;
});
renderDoneRows();
}
function renderDoneRows(){
var c=sec.querySelector('.bfc-kb__done-rows');
c.innerHTML='';
[[1,'Style',sel.type?{ps:'Point & Shoot',slr:'35mm SLR',pol:'Polaroid'}[sel.type]:null],
[2,'Camera',sel.cam?sel.cam.name:null],
[3,'Extras',Object.keys(sel.addons).length?Object.values(sel.addons).map(function(a){return a.name;}).join(', '):null]
].forEach(function(r){
if(r[0]>=step||!r[2])return;
var d=document.createElement('div');
d.className='bfc-kb__done-row';
d.innerHTML='<span class="bfc-kb__done-row-lbl">'+r[1]+'</span><span class="bfc-kb__done-row-val">'+r[2]+'</span>';
d.onclick=(function(s){return function(){goBack(s);};})(r[0]);
c.appendChild(d);
});
}
function goBack(n){
if(n<=1){sel.type=null;sel.cam=null;sel.addons={};}
if(n<=2){sel.cam=null;sel.addons={};}
if(n<=3){sel.addons={};}
showStep(n);
}
sec.querySelectorAll('[data-pick-style]').forEach(function(btn){
btn.onclick=function(){
sec.querySelectorAll('[data-pick-style]').forEach(function(b){b.setAttribute('aria-pressed','false');});
btn.setAttribute('aria-pressed','true');
sel.type=btn.dataset.pickStyle;
sel.cam=null; sel.addons={};
sec.querySelectorAll('.bfc-kb__cam-group').forEach(function(g){
g.hidden=g.dataset.camGroup!==sel.type;
});
showStep(2);
};
});
sec.querySelectorAll('.bfc-kb__cam-card').forEach(function(card){
if(card.dataset.camAvail==='false'){card.classList.add('is-oos');var t=card.dataset.camCamtype,b=card.querySelector('.bfc-kb__cam-body');if(b){var s=document.createElement('span');s.className='bfc-kb__cam-oos';s.innerHTML='OOS — <a href="'+(card.dataset.camOosUrl||'#')+'" onclick="event.stopPropagation()">See other →</a>';b.appendChild(s);}return;}
card.onclick=function(){
sec.querySelectorAll('.bfc-kb__cam-card').forEach(function(c){c.classList.remove('is-sel');c.setAttribute('aria-pressed','false');});
card.classList.add('is-sel');
card.setAttribute('aria-pressed','true');
sel.cam={name:card.dataset.camName,price:card.dataset.camPrice,priceRaw:parseFloat(card.dataset.camPriceRaw)||0,vid:card.dataset.camVid,format:card.dataset.camFormat,warranty:card.dataset.camWarranty,type:card.dataset.camCamtype,url:card.dataset.camUrl||''};
filterAddons();
setTimeout(function(){showStep(3);},220);
};
});
function filterAddons(){var fmt=sel.cam?sel.cam.format:'any',type=sel.cam?sel.cam.type:'';if(type==='ps'||type==='slr')fmt='35mm';sec.querySelectorAll('.bfc-kb__pill').forEach(function(pill){var pf=pill.dataset.addonFormat||'any',sf=(pill.dataset.addonShowFor||'').trim();var ef=sf||'ps,slr,';var fmtOk;if(fmt==='sx70'){fmtOk=(pf==='any'||pf==='sx70'||pf==='600');}else{fmtOk=(pf==='any'||fmt==='any'||pf===fmt);}var typeOk=(!type||ef.indexOf(type+',')>=0);pill.hidden=!fmtOk||!typeOk;if(pill.hidden)pill.classList.remove('is-on');});sec.querySelectorAll('.bfc-kb__grp').forEach(function(g){g.hidden=g.querySelectorAll('.bfc-kb__pill:not([hidden])').length===0;});var isPol=type==='pol';var devBlk=sec.querySelector('.bfc-kb__dev-credits');if(devBlk){devBlk.hidden=isPol;if(isPol){var devCnt=sec.querySelector('[data-dev-count]');if(devCnt)devCnt.textContent='0';}}var memBlk=sec.querySelector('.bfc-kb__membership-upsell');if(memBlk)memBlk.hidden=isPol;}
sec.querySelectorAll('.bfc-kb__pill').forEach(function(pill){
pill.querySelector('[data-info]').addEventListener('click',function(e){
e.stopPropagation();
openModal(pill);
});
pill.addEventListener('click',function(e){
if(e.target.closest('[data-info]')) return;
var grp=pill.dataset.addonGroup;
var wasOn=pill.classList.contains('is-on');
if(grp==='film_color'||grp==='strap'||grp==='case'){
pill.classList.toggle('is-on');
var key=grp+'_'+pill.dataset.addonVid;
if(!wasOn){sel.addons[key]={name:pill.dataset.addonName,price:pill.dataset.addonPrice,priceRaw:parseFloat(pill.dataset.addonPriceRaw)||0,vid:pill.dataset.addonVid,group:grp};}
else{delete sel.addons[key];}
} else {
sec.querySelectorAll('.bfc-kb__pill[data-addon-group="'+grp+'"]').forEach(function(p){p.classList.remove('is-on');});
if(!wasOn){
pill.classList.add('is-on');
sel.addons[grp]={name:pill.dataset.addonName,price:pill.dataset.addonPrice,priceRaw:parseFloat(pill.dataset.addonPriceRaw)||0,vid:pill.dataset.addonVid,group:grp};
} else {
delete sel.addons[grp];
}
}
});
});
sec.querySelectorAll('[data-go-back]').forEach(function(btn){
btn.onclick=function(){goBack(step-1);};
});
sec.querySelector('[data-go-next]').onclick=function(){
buildReview();
showStep(4);
sec.scrollIntoView({behavior:'smooth'});
};
sec.querySelectorAll('.bfc-kb__pill-row-wrap').forEach(function(wrap){
var row=wrap.querySelector('.bfc-kb__pill-row');
var btnL=wrap.querySelector('.bfc-kb__scroll-btn--left');
var btnR=wrap.querySelector('.bfc-kb__scroll-btn--right');
if(!row) return;
function updateBtns(){
var atLeft=row.scrollLeft<=4;
var atRight=row.scrollLeft+row.clientWidth>=row.scrollWidth-4;
if(btnL) btnL.classList.toggle('is-hidden',atLeft);
if(btnR) btnR.classList.toggle('is-hidden',atRight);
}
updateBtns();
row.addEventListener('scroll',updateBtns,{passive:true});
if(btnL) btnL.onclick=function(){row.scrollBy({left:-row.clientWidth*0.75,behavior:'smooth'});};
if(btnR) btnR.onclick=function(){row.scrollBy({left:row.clientWidth*0.75,behavior:'smooth'});};
var dn=0,sx=0,ss=0;row.addEventListener('mousedown',function(e){dn=1;sx=e.pageX;ss=row.scrollLeft;row.style.cursor='grabbing';});['mouseleave','mouseup'].forEach(function(v){row.addEventListener(v,function(){dn=0;row.style.cursor='';});});row.addEventListener('mousemove',function(e){if(!dn)return;e.preventDefault();row.scrollLeft=ss-(e.pageX-sx)*1.2;});
});
function buildReview(){
var lines=sec.querySelector('.bfc-kb__review-lines');
lines.innerHTML='';
var total=0;
var lm={film_bw:'B&W film',strap:'Strap','case':'Case'};
if(sel.cam){
total+=sel.cam.priceRaw||parsePrice(sel.cam.price);
lines.innerHTML+='<div class="bfc-kb__rline"><span class="bfc-kb__rline-lbl">Camera</span><span class="bfc-kb__rline-name">'+sel.cam.name+'</span><span class="bfc-kb__rline-price">'+sel.cam.price+'</span></div>';
}
var filmItems=Object.keys(sel.addons).filter(function(k){return k.indexOf('film_color')===0;}).map(function(k){return sel.addons[k];});
if(filmItems.length){
var filmTotal=filmItems.reduce(function(s,a){return s+(a.priceRaw||parsePrice(a.price));},0);total+=filmTotal;
var filmNames=filmItems.map(function(a){return a.name;}).join(', ');
lines.innerHTML+='<div class="bfc-kb__rline"><span class="bfc-kb__rline-lbl">Film</span><span class="bfc-kb__rline-name">'+filmNames+'</span><span class="bfc-kb__rline-price">'+filmItems.map(function(a){return a.price;}).join(' + ')+'</span></div>';
}
Object.keys(sel.addons).filter(function(k){return k.indexOf('film_color')!==0;}).forEach(function(k){
var a=sel.addons[k];total+=a.priceRaw||parsePrice(a.price);
var lbl=lm[k]||(k.indexOf('strap')===0?'Strap':k.indexOf('case')===0?'Case':k);
lines.innerHTML+='<div class="bfc-kb__rline"><span class="bfc-kb__rline-lbl">'+lbl+'</span><span class="bfc-kb__rline-name">'+a.name+'</span><span class="bfc-kb__rline-price">'+a.price+'</span></div>';
});
if(devVidEl&&devCountEl){
var devQty=parseInt(devCountEl.textContent)||0;
if(devQty>0){
var devUnit=parseFloat(devVidEl.dataset.devUnitPrice)||0;
var devTotal=devQty*devUnit;total+=devTotal;
lines.innerHTML+='<div class="bfc-kb__rline"><span class="bfc-kb__rline-lbl">Developing</span><span class="bfc-kb__rline-name">'+devQty+' credit'+(devQty>1?'s':'')+'</span><span class="bfc-kb__rline-price">$'+devTotal.toFixed(2).replace(/\.00$/,'')+'</span></div>';
}
}
sec.querySelector('.bfc-kb__total-price').textContent='$'+total.toFixed(2).replace(/\.00$/,'');
sec.querySelector('.bfc-kb__warranty').textContent=(sel.cam&&sel.cam.warranty?sel.cam.warranty:'6')+' month warranty included';
var pdpLink=sec.querySelector('[data-pdp-link]');
if(pdpLink){if(sel.cam&&sel.cam.url){pdpLink.href=sel.cam.url;pdpLink.hidden=false;}else{pdpLink.hidden=true;}}
}
function parsePrice(s){
if(!s) return 0;
return parseFloat(String(s).replace(/[^0-9.]/g,''))||0;
}
var devVidEl=sec.querySelector('[data-dev-vid]');
var devCountEl=sec.querySelector('[data-dev-count]');
var devCard=sec.querySelector('.bfc-kb__dev-card');
if(devVidEl&&devCountEl){
sec.querySelector('[data-dev-minus]').onclick=function(){
var n=Math.max(0,parseInt(devCountEl.textContent)-1);
devCountEl.textContent=n;
};
sec.querySelector('[data-dev-plus]').onclick=function(){
var n=Math.min(12,parseInt(devCountEl.textContent)+1);
devCountEl.textContent=n;
};
}
sec.querySelector('[data-atc]').onclick=function(){
var btn=this;
var items=[];
var camVid=parseInt(sel.cam&&sel.cam.vid);
if(sel.cam&&!isNaN(camVid)&&camVid>0) items.push({id:camVid,quantity:1,properties:{_source:'kit-builder'}});
Object.values(sel.addons).forEach(function(a){var vid=parseInt(a.vid);if(!isNaN(vid)&&vid>0)items.push({id:vid,quantity:1,properties:{_source:'kit-builder'}});});
if(devVidEl&&devCountEl){
var devQty=parseInt(devCountEl.textContent)||0;
if(devQty>0) items.push({id:parseInt(devVidEl.value),quantity:devQty,properties:{_source:'kit-builder','Developing Credits':devQty}});
}
if(!items.length){btn.textContent='—';return;}
console.log('BFC kit items:',items);
btn.disabled=true;
fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:items})})
.then(function(r){if(!r.ok)throw new Error(r.status);return r.json();})
.then(function(){
return fetch('/cart/update.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({updates:{},sections:['cart-drawer']})});
}).then(function(r){return r.json();}).then(function(state){
var drawer=document.querySelector('cart-drawer');
if(drawer&&typeof drawer.renderContents==='function')drawer.renderContents(state);
if(drawer&&typeof drawer.open==='function')drawer.open();
if(!drawer)window.location.href='/cart';
})
.catch(function(){});
};
function openModal(pill){
pendingPill=pill;
var modal=sec.querySelector('.bfc-kb__modal-wrap');
var imgs=[pill.dataset.addonImg0,pill.dataset.addonImg1,pill.dataset.addonImg2].filter(Boolean);
var imgEl=sec.querySelector('.bfc-kb__modal-imgs');
imgEl.innerHTML='';
if(imgs[0]){var d=document.createElement('div');d.className='bfc-kb__modal-img is-main';d.innerHTML='<img src="'+imgs[0]+'" loading="lazy">';imgEl.appendChild(d);}
for(var i=1;i<Math.min(imgs.length,3);i++){var d2=document.createElement('div');d2.className='bfc-kb__modal-img';d2.innerHTML='<img src="'+imgs[i]+'" loading="lazy">';imgEl.appendChild(d2);}
sec.querySelector('.bfc-kb__modal-eyebrow').textContent={film_color:'Color film',film_bw:'B&W film',strap:'Strap','case':'Case'}[pill.dataset.addonGroup]||'';
sec.querySelector('.bfc-kb__modal-name').textContent=pill.dataset.addonName;
sec.querySelector('.bfc-kb__modal-desc').textContent=pill.dataset.addonDesc||'';
sec.querySelector('.bfc-kb__modal-price').textContent=pill.dataset.addonPrice;
modal.classList.add('is-open');
}
sec.querySelector('.bfc-kb__modal-wrap').onclick=function(e){if(e.target===this)closeModal();};
sec.querySelector('[data-modal-close]').onclick=closeModal;
sec.querySelector('[data-modal-add]').onclick=function(){
if(pendingPill){
var grp=pendingPill.dataset.addonGroup;
pendingPill.classList.add('is-on');
if(grp==='film_color'||grp==='strap'||grp==='case'){
var key=grp+'_'+pendingPill.dataset.addonVid;
sel.addons[key]={name:pendingPill.dataset.addonName,price:pendingPill.dataset.addonPrice,vid:pendingPill.dataset.addonVid,group:grp};
} else {
sec.querySelectorAll('.bfc-kb__pill[data-addon-group="'+grp+'"]').forEach(function(p){p.classList.remove('is-on');});
pendingPill.classList.add('is-on');
sel.addons[grp]={name:pendingPill.dataset.addonName,price:pendingPill.dataset.addonPrice,vid:pendingPill.dataset.addonVid,group:grp};
}
}
closeModal();
};
function closeModal(){sec.querySelector('.bfc-kb__modal-wrap').classList.remove('is-open');pendingPill=null;}
})();</script>
        </section>
    {% endcase %}
  {% endfor %}
</section>
