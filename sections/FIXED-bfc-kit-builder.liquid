
{% liquid
  assign base_text = section.settings.text_color | default: '#111111'
  assign base_bg = section.settings.background_color | default: '#F7F4F0'
  assign page_width_px = settings.page_width | default: 1200
  assign horizontal_pad = section.settings.horizontal_padding | default: 24
  assign heading_size_preset = section.settings.heading_size_preset | default: 'default'
  case heading_size_preset
    when 'sm'
      assign header_size_mobile = '1.4'
      assign header_size_desktop = '2.0'
    when 'md'
      assign header_size_mobile = '1.6'
      assign header_size_desktop = '2.4'
    when 'lg'
      assign header_size_mobile = '2.0'
      assign header_size_desktop = '3.2'
    when 'xl'
      assign header_size_mobile = '2.4'
      assign header_size_desktop = '3.8'
    when 'xxl'
      assign header_size_mobile = '2.8'
      assign header_size_desktop = '4.4'
    else
      assign header_size_mobile = '1.75'
      assign header_size_desktop = '2.75'
  endcase
  assign header_weight = section.settings.header_font_weight | default: 600
  assign body_weight = section.settings.body_font_weight | default: 400
  assign body_size = section.settings.body_font_size | default: 16
  assign body_size_small = section.settings.body_font_size_small | default: 12
  assign header_line_height = section.settings.header_line_height | default: '1.05'
  assign header_letter_spacing = section.settings.header_letter_spacing | default: 0
  assign heading_color = section.settings.heading_color | default: base_text
  assign body_line_height = section.settings.body_line_height | default: '1.5'
  assign body_letter_spacing = section.settings.body_letter_spacing | default: 0
  assign section_pad_top = section.settings.section_padding_top | default: 40
  assign section_pad_bottom = section.settings.section_padding_bottom | default: 40
  assign accent_color = section.settings.accent_color | default: '#E36E15'
  assign secondary_text_color = section.settings.secondary_text_color | default: '#82906B'
  assign item_title_font = section.settings.item_title_font
%}
<section id="bfc-kit-builder-mini-{{ section.id }}" class="bfc-combined" aria-label="{{ section.settings.section_label | default: 'BFC Kit Builder' }}">
  <style>
    {{ item_title_font | font_face: font_display: 'swap' }}

    /* Fix shopify-section wrapper background & spacing */
    #shopify-section-{{ section.id }} {
      background-color: {{ base_bg }};
      margin: 0;
      padding: {{ section_pad_top }}px 0 {{ section_pad_bottom }}px;
      width: 100%;
    }
    #bfc-kit-builder-mini-{{ section.id }}{
      --bfc-header-family: var(--font-heading-family, inherit);
      --bfc-body-family: var(--font-body-family, inherit);
      --bfc-header-weight: {{ header_weight }};
      --bfc-body-weight: {{ body_weight }};
      --bfc-header-size-mobile: {{ header_size_mobile }}rem;
      --bfc-header-size-desktop: {{ header_size_desktop }}rem;
      --bfc-horizontal-pad: {{ horizontal_pad }}px;
      --bfc-page-width: {{ page_width_px }}px;
      --bfc-align-pad: clamp(
        var(--bfc-horizontal-pad),
        calc((100vw - min(100vw, var(--bfc-page-width))) / 2 + var(--bfc-horizontal-pad)),
        120px
      );
      --bfc-body-size: {{ body_size }}px;
      --bfc-body-size-small: {{ body_size_small }}px;
      --bfc-text: {{ base_text }};
      --bfc-bg: {{ base_bg }};
      --bfc-heading-color: {{ heading_color }};
      --bfc-header-letter-spacing: {{ header_letter_spacing }}px;
      --bfc-header-line-height: {{ header_line_height }};
      --bfc-body-letter-spacing: {{ body_letter_spacing }}px;
      --bfc-body-line-height: {{ body_line_height }};
      --bfc-accent: {{ accent_color }};
      --bfc-secondary-text: {{ secondary_text_color }};
      --bfc-item-title-family: {{ item_title_font.family | default: 'Poppins' }}, {{ item_title_font.fallback_families | default: 'sans-serif' }};
      --bfc-item-title-weight: {{ item_title_font.weight | default: 500 }};
      color: var(--bfc-text);
      background: var(--bfc-bg);
      font-family: var(--bfc-body-family);
      font-weight: var(--bfc-body-weight);
      font-size: var(--bfc-body-size);
    }
    #bfc-kit-builder-mini-{{ section.id }} .bfc-heading{
      font-family: var(--bfc-header-family, inherit);
      font-size: clamp(var(--bfc-header-size-mobile, 1.75rem), 3.5vw, var(--bfc-header-size-desktop, 2.75rem));
      font-weight: var(--bfc-header-weight, 300);
      line-height: var(--bfc-header-line-height, 1.05);
      letter-spacing: var(--bfc-header-letter-spacing, -0.02em);
      margin: 0;
      color: var(--bfc-heading-color, #111111);
    }
        #bfc-kit-builder-mini-{{ section.id }} .bfc-block{
      margin: 0 auto;
    }
    #bfc-kit-builder-mini-{{ section.id }} .bfc-block + .bfc-block{
      margin-top: 24px;
    }
    #bfc-kit-builder-mini-{{ section.id }} .visually-hidden{
      position: absolute;width: 1px;height: 1px;padding: 0;margin: -1px;overflow: hidden;clip: rect(0,0,0,0);white-space: nowrap;border: 0;
    }
    #bfc-kit-builder-mini-{{ section.id }} a:focus-visible,
    #bfc-kit-builder-mini-{{ section.id }} button:focus-visible,
    #bfc-kit-builder-mini-{{ section.id }} input:focus-visible{
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }
    @media (prefers-reduced-motion: reduce){
      #bfc-kit-builder-mini-{{ section.id }} *{
        animation-duration: .01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: .01ms !important;
      }
    }
  
    #bfc-kit-builder-mini-{{ section.id }} .bfc-eyebrow{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bfc-secondary-text);
      margin: 0 0 10px;
    }
    #bfc-kit-builder-mini-{{ section.id }} .bfc-item-title{
      font-family: var(--bfc-item-title-family);
      font-weight: var(--bfc-item-title-weight);
      font-size: var(--bfc-body-size);
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--bfc-text);
    }

    #bfc-kit-builder-mini-{{ section.id }} .bfc-detail-text{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: var(--bfc-body-weight);
      letter-spacing: var(--bfc-body-letter-spacing);
      line-height: var(--bfc-body-line-height);
      color: var(--bfc-secondary-text);
      margin: 0;
    }

  </style>
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'kit_builder_mini' %}
      {% when 'camera_bundle_hero' %}
        {% liquid
          assign cbh_id = 'bfc-cbh-' | append: section.id | append: '-' | append: block.id
          assign cbh_product_a = block.settings.product_a
          assign cbh_product_b = block.settings.product_b
          assign cbh_has_a = false
          assign cbh_has_b = false
          if cbh_product_a != blank
            assign cbh_has_a = true
          endif
          if cbh_product_b != blank
            assign cbh_has_b = true
          endif
        %}
        <section
          id="{{ cbh_id }}"
          class="bfc-block bfc-cbh"
          style="
            --cbh-bg: {{ block.settings.bg }};
            --cbh-fg: {{ block.settings.fg }};
            --cbh-border: {{ block.settings.border_color }};
            --cbh-accent: {{ block.settings.accent_color }};
            --cbh-card-bg: {{ block.settings.card_bg }};
            --cbh-max: {{ page_width_px }}px;
            --cbh-pt: {{ block.settings.padding_top }}px;
            --cbh-pb: {{ block.settings.padding_bottom }}px;
            --bfc-block-pad: calc(var(--bfc-align-pad) + {{ block.settings.side_padding_vw }}vw);
          "
          {{ block.shopify_attributes }}
        >
          <div class="bfc-cbh__wrap">
            <div class="bfc-cbh__header">
              {% if block.settings.eyebrow != blank %}
                <p class="bfc-cbh__eyebrow">{{ block.settings.eyebrow | escape }}</p>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="bfc-cbh__heading bfc-heading">{{ block.settings.heading | escape }}</h2>
              {% endif %}
              {% if block.settings.subheading != blank %}
                <p class="bfc-cbh__subheading">{{ block.settings.subheading | escape }}</p>
              {% endif %}
            </div>
            <div class="bfc-cbh__grid">
              <div class="bfc-cbh__camera">
                <div class="bfc-cbh__img-wrap">
                  {% if cbh_has_a and cbh_product_a.featured_image %}
                    <img
                      src="{{ cbh_product_a.featured_image | image_url: width: 800 }}"
                      srcset="
                        {{ cbh_product_a.featured_image | image_url: width: 400 }} 400w,
                        {{ cbh_product_a.featured_image | image_url: width: 600 }} 600w,
                        {{ cbh_product_a.featured_image | image_url: width: 800 }} 800w
                      "
                      sizes="(min-width: 990px) 30vw, 80vw"
                      alt="{{ cbh_product_a.featured_image.alt | default: cbh_product_a.title | escape }}"
                      loading="lazy"
                      width="{{ cbh_product_a.featured_image.width }}"
                      height="{{ cbh_product_a.featured_image.height }}"
                    >
                  {% elsif block.settings.image_a != blank %}
                    <img
                      src="{{ block.settings.image_a | image_url: width: 800 }}"
                      alt="{{ block.settings.image_a.alt | default: block.settings.name_a | escape }}"
                      loading="lazy"
                      width="{{ block.settings.image_a.width }}"
                      height="{{ block.settings.image_a.height }}"
                    >
                  {% else %}
                    <div class="bfc-cbh__img-placeholder" aria-hidden="true"></div>
                  {% endif %}
                </div>
                <div class="bfc-cbh__camera-info">
                  {% if cbh_has_a %}
                    <h3 class="bfc-cbh__camera-name"><a href="{{ cbh_product_a.url }}">{{ cbh_product_a.title | escape }}</a></h3>
                    <p class="bfc-cbh__camera-price">{{ cbh_product_a.price | money }}</p>
                  {% else %}
                    <h3 class="bfc-cbh__camera-name">{{ block.settings.name_a | escape }}</h3>
                    <p class="bfc-cbh__camera-price">{{ block.settings.price_a | escape }}</p>
                  {% endif %}
                  {% if block.settings.note_a != blank %}
                    <p class="bfc-cbh__camera-note">{{ block.settings.note_a | escape }}</p>
                  {% endif %}
                </div>
              </div>
              <div class="bfc-cbh__plus" aria-hidden="true">
                <span class="bfc-cbh__plus-sign">+</span>
                {% if block.settings.savings_label != blank %}
                  <span class="bfc-cbh__savings">{{ block.settings.savings_label | escape }}</span>
                {% endif %}
              </div>
              <div class="bfc-cbh__camera">
                <div class="bfc-cbh__img-wrap">
                  {% if cbh_has_b and cbh_product_b.featured_image %}
                    <img
                      src="{{ cbh_product_b.featured_image | image_url: width: 800 }}"
                      srcset="
                        {{ cbh_product_b.featured_image | image_url: width: 400 }} 400w,
                        {{ cbh_product_b.featured_image | image_url: width: 600 }} 600w,
                        {{ cbh_product_b.featured_image | image_url: width: 800 }} 800w
                      "
                      sizes="(min-width: 990px) 30vw, 80vw"
                      alt="{{ cbh_product_b.featured_image.alt | default: cbh_product_b.title | escape }}"
                      loading="lazy"
                      width="{{ cbh_product_b.featured_image.width }}"
                      height="{{ cbh_product_b.featured_image.height }}"
                    >
                  {% elsif block.settings.image_b != blank %}
                    <img
                      src="{{ block.settings.image_b | image_url: width: 800 }}"
                      alt="{{ block.settings.image_b.alt | default: block.settings.name_b | escape }}"
                      loading="lazy"
                      width="{{ block.settings.image_b.width }}"
                      height="{{ block.settings.image_b.height }}"
                    >
                  {% else %}
                    <div class="bfc-cbh__img-placeholder" aria-hidden="true"></div>
                  {% endif %}
                </div>
                <div class="bfc-cbh__camera-info">
                  {% if cbh_has_b %}
                    <h3 class="bfc-cbh__camera-name"><a href="{{ cbh_product_b.url }}">{{ cbh_product_b.title | escape }}</a></h3>
                    <p class="bfc-cbh__camera-price">{{ cbh_product_b.price | money }}</p>
                  {% else %}
                    <h3 class="bfc-cbh__camera-name">{{ block.settings.name_b | escape }}</h3>
                    <p class="bfc-cbh__camera-price">{{ block.settings.price_b | escape }}</p>
                  {% endif %}
                  {% if block.settings.note_b != blank %}
                    <p class="bfc-cbh__camera-note">{{ block.settings.note_b | escape }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
            <div class="bfc-cbh__footer">
              {% if block.settings.footer_copy != blank %}
                <p class="bfc-cbh__footer-copy">{{ block.settings.footer_copy | escape }}</p>
              {% endif %}
              <div class="bfc-cbh__ctas">
                {% if block.settings.cta_label != blank and block.settings.cta_url != blank %}
                  <a class="bfc-cbh__cta bfc-cbh__cta--primary" href="{{ block.settings.cta_url }}" aria-label="{{ block.settings.cta_label | escape }}">{{ block.settings.cta_label | escape }}</a>
                {% endif %}
                {% if block.settings.cta2_label != blank and block.settings.cta2_url != blank %}
                  <a class="bfc-cbh__cta bfc-cbh__cta--ghost" href="{{ block.settings.cta2_url }}" aria-label="{{ block.settings.cta2_label | escape }}">{{ block.settings.cta2_label | escape }}</a>
                {% endif %}
              </div>
            </div>
          </div>
          <style>
            #{{ cbh_id }}{
              background: var(--cbh-bg);
              color: var(--cbh-fg);
              padding: var(--cbh-pt) 0 var(--cbh-pb);
            }
            #{{ cbh_id }} .bfc-cbh__wrap{
              max-width: var(--cbh-max);
              margin: 0 auto;
              padding: 0 var(--bfc-block-pad);
            }
            #{{ cbh_id }} .bfc-cbh__header{
              margin-bottom: clamp(28px, 4vw, 52px);
              max-width: 60ch;
            }
            #{{ cbh_id }} .bfc-cbh__eyebrow{
              margin: 0 0 8px;
              font-size: var(--bfc-body-size-small);
              letter-spacing: .16em;
              text-transform: uppercase;
              opacity: .65;
            }
            #{{ cbh_id }} .bfc-cbh__heading{ margin: 0 0 10px; letter-spacing: -0.02em; line-height: 1.04; }
            #{{ cbh_id }} .bfc-cbh__subheading{ margin: 0; font-size: var(--bfc-body-size); line-height: 1.5; opacity: .8; }
            #{{ cbh_id }} .bfc-cbh__grid{
              display: grid;
              grid-template-columns: 1fr auto 1fr;
              gap: clamp(16px, 3vw, 48px);
              align-items: center;
              margin-bottom: clamp(28px, 4vw, 48px);
            }
            #{{ cbh_id }} .bfc-cbh__camera{
              background: var(--cbh-card-bg);
              overflow: hidden;
              display: grid;
              grid-template-rows: 1fr auto;
            }
            #{{ cbh_id }} .bfc-cbh__img-wrap{
              aspect-ratio: 4 / 3;
              overflow: hidden;
              background: color-mix(in srgb, var(--cbh-fg) 5%, transparent);
            }
            #{{ cbh_id }} .bfc-cbh__img-wrap img{
              width: 100%;
              height: 100%;
              object-fit: cover;
              display: block;
              transform: scale(1.001);
              transition: transform .25s ease;
            }
            #{{ cbh_id }} .bfc-cbh__camera:hover .bfc-cbh__img-wrap img{ transform: scale(1.04); }
            #{{ cbh_id }} .bfc-cbh__img-placeholder{ width: 100%; height: 100%; background: rgba(0,0,0,.06); }
            #{{ cbh_id }} .bfc-cbh__camera-info{
              padding: 16px 18px 18px;
              border-top: 1px solid var(--cbh-border);
            }
            #{{ cbh_id }} .bfc-cbh__camera-name{
              margin: 0 0 4px;
              font-size: var(--bfc-body-size);
              font-weight: 600;
              letter-spacing: -0.01em;
              font-family: var(--bfc-body-family);
            }
            #{{ cbh_id }} .bfc-cbh__camera-name a{ color: inherit; text-decoration: none; }
            #{{ cbh_id }} .bfc-cbh__camera-name a:hover{ text-decoration: underline; }
            #{{ cbh_id }} .bfc-cbh__camera-price{
              margin: 0 0 4px;
              font-family: var(--font-heading-family, serif);
              font-size: clamp(1.1rem, 2.5vw, 1.5rem);
              letter-spacing: -0.01em;
            }
            #{{ cbh_id }} .bfc-cbh__camera-note{ margin: 0; font-size: var(--bfc-body-size-small); opacity: .6; line-height: 1.35; }
            #{{ cbh_id }} .bfc-cbh__plus{
              display: flex;
              flex-direction: column;
              align-items: center;
              gap: 12px;
            }
            #{{ cbh_id }} .bfc-cbh__plus-sign{
              font-family: var(--font-heading-family, serif);
              font-size: clamp(2rem, 5vw, 4rem);
              line-height: 1;
              opacity: .2;
              letter-spacing: -0.02em;
            }
            #{{ cbh_id }} .bfc-cbh__savings{
              background: var(--cbh-accent);
              color: var(--cbh-bg);
              font-size: 11px;
              letter-spacing: .12em;
              text-transform: uppercase;
              padding: 6px 10px;
              text-align: center;
              white-space: nowrap;
            }
            #{{ cbh_id }} .bfc-cbh__footer{
              display: flex;
              align-items: center;
              gap: 24px;
              flex-wrap: wrap;
              padding-top: clamp(20px, 3vw, 32px);
              border-top: 1px solid var(--cbh-border);
            }
            #{{ cbh_id }} .bfc-cbh__footer-copy{ margin: 0; font-size: var(--bfc-body-size); opacity: .75; flex: 1; min-width: 180px; }
            #{{ cbh_id }} .bfc-cbh__ctas{ display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
            #{{ cbh_id }} .bfc-cbh__cta{
              text-decoration: none;
              font-size: var(--bfc-body-size-small);
              letter-spacing: .08em;
              text-transform: uppercase;
              display: inline-flex;
              align-items: center;
              transition: opacity .15s ease;
            }
            #{{ cbh_id }} .bfc-cbh__cta--primary{ background: var(--cbh-fg); color: var(--cbh-bg); padding: 13px 24px; }
            #{{ cbh_id }} .bfc-cbh__cta--ghost{ color: var(--cbh-fg); border-bottom: 1px solid currentColor; opacity: .7; padding-bottom: 2px; }
            #{{ cbh_id }} .bfc-cbh__cta:hover{ opacity: .72; }
            @media (max-width: 700px){
              #{{ cbh_id }} .bfc-cbh__grid{ grid-template-columns: 1fr; gap: 0; }
              #{{ cbh_id }} .bfc-cbh__plus{ flex-direction: row; padding: 16px 0; justify-content: center; }
              #{{ cbh_id }} .bfc-cbh__footer{ flex-direction: column; align-items: flex-start; }
              {% if block.settings.ignore_padding_mobile %}
                #{{ cbh_id }}{ --bfc-block-pad: var(--bfc-horizontal-pad); }
              {% endif %}
            }
          </style>
        </section>
                          {% when 'kit_builder_mini' %}
          {%- assign kb_id = 'kb-' | append: block.id -%}
          {%- assign kb_seamless = block.settings.seamless_mode -%}
        <section class="bfc-block bfc-kb{% if kb_seamless %} bfc-kb--seamless{% endif %}" id="{{ kb_id }}" aria-label="Kit builder" {{ block.shopify_attributes }}>
          <div class="bfc-kb__head">
            <p class="bfc-kb__eyebrow">{{ block.settings.eyebrow | default: "Build your kit" | escape }}</p>
            <h2 class="bfc-kb__title">{{ block.settings.headline | default: "We'll pick your perfect setup." }}</h2>
          </div>
          <div class="bfc-kb__body">
            <div class="bfc-kb__sidebar">
              <nav class="bfc-kb__nav-bar" aria-label="Kit builder steps">
            <div class="bfc-kb__crumb is-active" data-step="1" aria-current="step"><span class="bfc-kb__crumb-num" aria-hidden="true">1</span>Style</div>
            <span class="bfc-kb__crumb-sep" aria-hidden="true">›</span>
            <div class="bfc-kb__crumb" data-step="2"><span class="bfc-kb__crumb-num" aria-hidden="true">2</span>Camera</div>
            <span class="bfc-kb__crumb-sep" aria-hidden="true">›</span>
            <div class="bfc-kb__crumb" data-step="3"><span class="bfc-kb__crumb-num" aria-hidden="true">3</span>Extras</div>
            <span class="bfc-kb__crumb-sep" aria-hidden="true">›</span>
            <div class="bfc-kb__crumb" data-step="4"><span class="bfc-kb__crumb-num" aria-hidden="true">4</span>Review</div>
              </nav>
              <div class="bfc-kb__done-rows"></div>
            </div>
            <div class="bfc-kb__content">
          {%- comment -%} STEP 1 — Style {%- endcomment -%}
          <div class="bfc-kb__step is-active" data-step="1" role="group" aria-labelledby="kb-step-lbl-1">
            <p class="bfc-kb__step-lbl" id="kb-step-lbl-1">Step 1</p>
            <p class="bfc-kb__step-hed">How do you want <em>to shoot?</em></p>
            <div class="bfc-kb__style-grid" role="group" aria-label="Choose your shooting style">
              <button class="bfc-kb__style-card" type="button" data-pick-style="ps" aria-pressed="false">
                <span class="bfc-kb__style-name">Point &amp; Shoot</span>
                <span class="bfc-kb__style-hint">Auto everything · Great for beginners</span>
              </button>
              <button class="bfc-kb__style-card" type="button" data-pick-style="slr" aria-pressed="false">
                <span class="bfc-kb__style-name">35mm SLR</span>
                <span class="bfc-kb__style-hint">Full manual control · Learn as you shoot</span>
              </button>
              <button class="bfc-kb__style-card" type="button" data-pick-style="pol" aria-pressed="false">
                <span class="bfc-kb__style-name">Polaroid</span>
                <span class="bfc-kb__style-hint">Instant prints · Share straight away</span>
              </button>
            </div>
          </div>
          {%- comment -%} STEP 2 — Camera {%- endcomment -%}
          <div class="bfc-kb__step" data-step="2" role="group" aria-labelledby="kb-step-lbl-2">
            <p class="bfc-kb__step-lbl" id="kb-step-lbl-2">Step 2</p>
            <p class="bfc-kb__step-hed">Choose your <em>camera</em></p>
          {%- assign kb_types = 'ps,slr,pol' | split: ',' -%}
          {%- for kb_type in kb_types -%}
              <div class="bfc-kb__cam-group" data-cam-group="{{ kb_type }}" hidden>
                <div class="bfc-kb__cam-grid">
          {%- if kb_type == 'pol' -%}
            {%- comment -%} Polaroid: pull from collections, in-stock only. One box camera + up to 2 SX-70. {%- endcomment -%}
            {%- assign pol_cams_rendered = '' -%}

            {%- comment -%} --- Box camera (600 film) — first in-stock from collection --- {%- endcomment -%}
