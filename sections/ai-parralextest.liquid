{% comment %}
  Drop this in: sections/repair-process-parallax.liquid
{% endcomment %}
<section id="repair-parallax-{{ section.id }}" class="repair-parallax{% if section.settings.mobile_static %} is-mobile-static{% endif %}">
  <style>
    #repair-parallax-{{ section.id }}{
      --wrap: {{ section.settings.max_width_percent }}%;
      --pad: {{ section.settings.section_pad }}px;
      --min-h: {{ section.settings.min_height }}px;
      --min-h-mobile: {{ section.settings.min_height_mobile }}px;
      --bg: {{ section.settings.bg }};
      --line: {{ section.settings.line_color }};
      --text: {{ section.settings.text_color }};
      --line-w: {{ section.settings.line_width }}px;
      --line-gap: {{ section.settings.line_gap }}px;
      --parallax-depth: {{ section.settings.parallax_depth }}px;
      background: var(--bg);
      color: var(--text);
      padding: 0 !important;
      margin: 0 !important;
    }

    #repair-parallax-{{ section.id }} .wrap{
      max-width: var(--wrap);
      margin: 0 auto;
      padding: 0;
    }

    #repair-parallax-{{ section.id }} .stage{
      position: relative;
      min-height: var(--min-h);
      aspect-ratio: {{ section.settings.aspect_ratio }};
      border-radius: {{ section.settings.radius }}px;
      overflow: hidden;
      background: {{ section.settings.fallback_bg }};
    }

    #repair-parallax-{{ section.id }} .media{
      position: absolute;
      inset: 0;
      overflow: hidden;
      z-index: 1;
    }

    #repair-parallax-{{ section.id }} .media img{
      width: 100%;
      height: 100%;
      object-fit: {{ section.settings.fit_mode }};
      object-position: {{ section.settings.image_focus }};
      transform: translateY(calc(var(--parallax, 0) * var(--parallax-depth)));
      transition: transform 0.2s ease-out;
      will-change: transform;
    }

    #repair-parallax-{{ section.id }} .overlay{
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
    }

    #repair-parallax-{{ section.id }} .mobile-static{
      display: none;
      position: absolute;
      inset: 0;
      z-index: 3;
    }

    #repair-parallax-{{ section.id }} .mobile-static img{
      width: 100%;
      height: 100%;
      object-fit: {{ section.settings.fit_mode }};
      object-position: {{ section.settings.mobile_image_focus }};
    }

    #repair-parallax-{{ section.id }} .annotation{
      position: absolute;
      left: var(--x);
      top: var(--y);
      transform: translate(-50%, -50%) translateY(16px);
      opacity: 0;
      transition: opacity 0.6s ease, transform 0.6s ease;
      transition-delay: var(--delay, 0ms);
      width: min(calc(var(--max-w, 100%) * 1%), 100%);
      color: var(--label-color, var(--text));
    }

    #repair-parallax-{{ section.id }} .annotation.is-visible{
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0);
    }

    #repair-parallax-{{ section.id }} .repair-title-block{
      position: absolute;
      left: 0;
      top: var(--y);
      transform: translateY(16px);
      opacity: 0;
      transition: opacity 0.6s ease, transform 0.6s ease;
      transition-delay: var(--delay, 0ms);
      width: 100%;
      text-align: var(--align, left);
      color: var(--label-color, var(--text));
      padding: 0 16px;
      box-sizing: border-box;
    }

    #repair-parallax-{{ section.id }} .repair-title-block.is-visible{
      opacity: 1;
      transform: translateY(0);
    }

    #repair-parallax-{{ section.id }} .repair-paragraph-block{
      position: absolute;
      left: var(--x);
      top: var(--y);
      transform: translate(-50%, -50%) translateY(16px);
      opacity: 0;
      transition: opacity 0.6s ease, transform 0.6s ease;
      transition-delay: var(--delay, 0ms);
      width: calc(var(--block-w, 100) * 1%);
      height: calc(var(--block-h, 100) * 1%);
      text-align: var(--align, left);
      color: var(--text-color, var(--text));
      overflow: hidden;
    }

    #repair-parallax-{{ section.id }} .repair-paragraph-block.is-visible{
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0);
    }

    #repair-parallax-{{ section.id }} .repair-paragraph-block .paragraph-text{
      font-size: var(--size, 16px);
      font-weight: var(--weight, 400);
      letter-spacing: var(--tracking, 0px);
      text-transform: var(--transform, none);
    }

    #repair-parallax-{{ section.id }} .repair-paragraph-block .paragraph-text p{
      margin: 0;
    }

    #repair-parallax-{{ section.id }} .line-wrap{
      display: flex;
      align-items: center;
      gap: var(--line-gap);
      width: 100%;
      transform: rotate(var(--angle));
      transform-origin: left center;
    }

    #repair-parallax-{{ section.id }} .line-wrap.is-reversed{
      flex-direction: row-reverse;
      transform-origin: right center;
    }

    #repair-parallax-{{ section.id }} .line{
      height: var(--line-w);
      width: var(--length);
      background: var(--line-color, var(--line));
      display: block;
      flex: 0 0 auto;
    }

    #repair-parallax-{{ section.id }} .line.is-hidden{
      display: none;
    }

    #repair-parallax-{{ section.id }} .label{
      font-size: var(--size, 16px);
      font-weight: var(--weight, 500);
      letter-spacing: var(--tracking, 10px);
      text-transform: var(--transform, none);
      transform: rotate(calc(var(--angle) * -1));
      transform-origin: left center;
      white-space: normal;
      max-width: 100%;
      flex: 1 1 auto;
      min-width: 0;
      width: 100%;
      text-align: var(--label-align, left);
    }

    #repair-parallax-{{ section.id }} .repair-title-block .label{
      display: flex;
      flex-direction: column;
      align-items: var(--align-items, flex-start);
      transform: none;
      transform-origin: center;
      text-align: inherit;
      width: 100%;
    }

    #repair-parallax-{{ section.id }} .repair-title-block .label-title,
    #repair-parallax-{{ section.id }} .repair-title-block .label-title p,
    #repair-parallax-{{ section.id }} .repair-title-block .label p{
      text-align: inherit !important;
    }

    #repair-parallax-{{ section.id }} .label-title{
      margin: 0 0 8px;
    }

    #repair-parallax-{{ section.id }} .label-body{
      margin: 0;
      font-size: var(--body-size, 14px);
      font-weight: var(--body-weight, 400);
      letter-spacing: normal;
      text-transform: none;
    }

    #repair-parallax-{{ section.id }} .label p{
      margin: 0;
    }

    #repair-parallax-{{ section.id }} .label em{
      font-style: italic;
    }

    #repair-parallax-{{ section.id }} .label strong{
      font-weight: 700;
    }

    @media (max-width: 768px){
      #repair-parallax-{{ section.id }} .stage{
        min-height: var(--min-h-mobile);
        aspect-ratio: {{ section.settings.aspect_ratio_mobile }};
      }

      #repair-parallax-{{ section.id }} .annotation{
        width: min(calc(var(--max-w, 100%) * 1%), 100%);
      }

      #repair-parallax-{{ section.id }}.is-mobile-static .overlay{
        display: none;
      }

      #repair-parallax-{{ section.id }}.is-mobile-static .media{
        display: none;
      }

      #repair-parallax-{{ section.id }}.is-mobile-static .mobile-static{
        display: block;
      }
    }

    @media (prefers-reduced-motion: reduce){
      #repair-parallax-{{ section.id }} .media img{
        transform: none;
        transition: none;
      }

      #repair-parallax-{{ section.id }} .annotation{
        opacity: 1;
        transform: translate(-50%, -50%);
        transition: none;
      }
    }
  </style>

  <div class="wrap">
    <div class="stage" data-repair-parallax>
      <div class="media">
        {% if section.settings.image != blank %}
          <picture>
            {% if section.settings.mobile_image != blank %}
              <source
                media="(max-width: 768px)"
                srcset="{{ section.settings.mobile_image | image_url: width: 1600 }}"
              >
            {% endif %}
            <img
              src="{{ section.settings.image | image_url: width: 2400 }}"
              alt="{{ section.settings.image.alt | escape }}"
              loading="lazy"
            >
          </picture>
        {% else %}
          <img
            src="https://cdn.shopify.com/s/files/1/0266/6276/4597/files/placeholder-hero.png"
            alt="Placeholder"
            loading="lazy"
          >
        {% endif %}
      </div>

      <div class="mobile-static" aria-hidden="true">
        {% if section.settings.mobile_image != blank %}
          <img
            src="{{ section.settings.mobile_image | image_url: width: 1600 }}"
            alt=""
            loading="lazy"
          >
        {% elsif section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1600 }}"
            alt=""
            loading="lazy"
          >
        {% endif %}
      </div>

      <div class="overlay">
        {% for block in section.blocks %}
        {% if block.type == 'title' %}
          {% assign title_text = block.settings.text | default: '' %}
          <div
            class="repair-title-block"
            style="
              --y: {{ block.settings.y }}%;
                --size: {{ block.settings.text_size }}px;
                --weight: {{ block.settings.text_weight }};
                --tracking: {{ block.settings.tracking }}px;
                --transform: {{ block.settings.text_transform }};
                --delay: {{ block.settings.delay }}ms;
                --label-color: {{ block.settings.text_color }};
                --align: {{ block.settings.text_align }};
                --align-items: {% if block.settings.text_align == 'center' %}center{% elsif block.settings.text_align == 'right' %}flex-end{% else %}flex-start{% endif %};
              "
              {{ block.shopify_attributes }}
              data-repair-reveal
            >
              <div class="label">
                <div class="label-title">{{ title_text }}</div>
              </div>
            </div>
          {% elsif block.type == 'paragraph' %}
            {% assign paragraph_text = block.settings.text | default: '' %}
            <div
              class="repair-paragraph-block"
              style="
                --x: {{ block.settings.x }}%;
                --y: {{ block.settings.y }}%;
                --size: {{ block.settings.text_size }}px;
                --weight: {{ block.settings.text_weight }};
                --tracking: {{ block.settings.tracking }}px;
                --transform: {{ block.settings.text_transform }};
                --delay: {{ block.settings.delay }}ms;
                --text-color: {{ block.settings.text_color }};
                --align: {{ block.settings.text_align }};
                --block-w: {{ block.settings.block_width_percent }};
                --block-h: {{ block.settings.block_height_percent }};
              "
              {{ block.shopify_attributes }}
              data-repair-reveal
            >
              <div class="paragraph-text">{{ paragraph_text }}</div>
            </div>
          {% else %}
            {% assign label_text = block.settings.text | default: '' %}
            {% assign body_text = block.settings.body_text | default: '' %}
            {% assign label_align = 'left' %}
            {% if block.settings.reverse_line %}
              {% if block.settings.text_position == 'start' %}
                {% assign label_align = 'right' %}
              {% else %}
                {% assign label_align = 'left' %}
              {% endif %}
            {% else %}
              {% if block.settings.text_position == 'end' %}
                {% assign label_align = 'right' %}
              {% endif %}
            {% endif %}
            <div
              class="annotation"
              style="
                --x: {{ block.settings.x }}%;
                --y: {{ block.settings.y }}%;
                --length: {{ block.settings.line_length }}px;
                --angle: {{ block.settings.line_angle }}deg;
                --size: {{ block.settings.text_size }}px;
                --weight: {{ block.settings.text_weight }};
                --tracking: {{ block.settings.tracking }}px;
                --transform: {{ block.settings.text_transform }};
                --delay: {{ block.settings.delay }}ms;
                --line-color: {{ block.settings.line_color }};
                --label-color: {{ block.settings.text_color }};
                --max-w: {{ block.settings.max_width_percent }}%;
                --body-size: {{ block.settings.body_text_size }}px;
                --body-weight: {{ block.settings.body_text_weight }};
                --label-align: {{ label_align }};
              "
              {{ block.shopify_attributes }}
              data-repair-reveal
            >
              <div class="line-wrap{% if block.settings.reverse_line %} is-reversed{% endif %}">
                <span class="line{% unless block.settings.show_line %} is-hidden{% endunless %}"></span>
                <div class="label">
                  <div class="label-title">{{ label_text }}</div>
                  {% if body_text != blank %}
                    <div class="label-body">{{ body_text }}</div>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <script>
    (() => {
      const section = document.getElementById('repair-parallax-{{ section.id }}');
      if (!section) return;

      const stage = section.querySelector('[data-repair-parallax]');
      const revealItems = section.querySelectorAll('[data-repair-reveal]');
      if (!stage || !revealItems.length) return;

      if (section.classList.contains('is-mobile-static') && window.matchMedia('(max-width: 768px)').matches) {
        revealItems.forEach(item => item.classList.add('is-visible'));
        return;
      }

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const setParallax = () => {
        if (prefersReduced) return;
        const rect = stage.getBoundingClientRect();
        const viewHeight = window.innerHeight || document.documentElement.clientHeight;
        const progress = Math.min(1, Math.max(0, (viewHeight - rect.top) / (viewHeight + rect.height)));
        stage.style.setProperty('--parallax', (progress - 0.5).toFixed(3));
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(() => {
          setParallax();
          ticking = false;
        });
      };

      setParallax();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);

      const observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        },
        { threshold: 0.4 }
      );

      revealItems.forEach(item => observer.observe(item));
    })();
  </script>
</section>

