
<section id="nyt-editorial-{{ section.id }}" class="nyt-root">
  <style>
    /*
  Removes all vertical padding and margins from the 
  full-bleed image's wrapping container.
*/
.block-main-image--full-bleed {
  padding-top: 0 !important;
  margin-top: 0 !important;
  padding-bottom: 0 !important;
  margin-bottom: 0 !important;
}

/*
  Hides the <hr class="rule"> that immediately 
  follows the full-bleed image block.
*/
.block-main-image--full-bleed + .wrap > .rule {
  display: none;
}
   

    /* === NEW: three columns + photo-left-rows === */
#nyt-editorial-{{ section.id }} .three-cols{display:grid;grid-template-columns:1fr 1fr 1fr;gap:var(--g);align-items:start;position:relative}
#nyt-editorial-{{ section.id }} .three-cols .col{display:flex;flex-direction:column;gap:10px}
#nyt-editorial-{{ section.id }} .three-cols figure{margin:0}
#nyt-editorial-{{ section.id }} .three-cols img{width:100%;height:auto;border-radius:{{ section.settings.radius }}px}

    #nyt-editorial-{{ section.id }} .stack-split{display:grid;grid-template-columns:minmax(0, var(--left, 50%)) 1fr;gap:var(--g);align-items:stretch;position:relative;min-height:var(--stack-min-height, auto);height:var(--stack-height, auto);max-height:var(--stack-max-height, none)}
#nyt-editorial-{{ section.id }} .stack-split.is-photo-right{grid-template-columns:1fr minmax(0, var(--left, 50%))}
#nyt-editorial-{{ section.id }} .stack-split.is-photo-right .media{order:2}
#nyt-editorial-{{ section.id }} .stack-split.is-photo-right .right{order:1}
    #nyt-editorial-{{ section.id }} .stack-split .media{display:flex;flex-direction:column;min-height:0;height:100%}
    #nyt-editorial-{{ section.id }} .stack-split .media > a{display:flex;flex:1 1 auto}
    #nyt-editorial-{{ section.id }} .stack-split .media-asset{display:flex;flex:1 1 auto;min-height:var(--media-min-height, auto);height:var(--media-height, auto);max-height:var(--media-max-height, none);overflow:hidden}
    #nyt-editorial-{{ section.id }} .stack-split .right{display:grid;gap:var(--g);align-content:stretch;height:100%;max-height:var(--stack-right-max-height, none);min-height:0}
    #nyt-editorial-{{ section.id }} .stack-split .right.is-match-rows{grid-template-rows:1fr 1fr}
    #nyt-editorial-{{ section.id }} .stack-split .right.is-content-rows{grid-template-rows:auto auto;height:auto}
    #nyt-editorial-{{ section.id }} .stack-split .right.is-custom-rows{grid-template-rows:minmax(0, var(--row1-fr, 1fr)) minmax(0, var(--row2-fr, 1fr))}
    #nyt-editorial-{{ section.id }} .stack-split .copy,
    #nyt-editorial-{{ section.id }} .split .copy,
    #nyt-editorial-{{ section.id }} .triple .copy{display:flex;flex-direction:column;gap:var(--g);height:100%}
    #nyt-editorial-{{ section.id }} .copy.has-cta .cta{margin-top:auto}
    #nyt-editorial-{{ section.id }} .copy.is-vert-middle,
    #nyt-editorial-{{ section.id }} .copy.is-vert-center{justify-content:center}
    #nyt-editorial-{{ section.id }} .copy.is-vert-bottom{justify-content:flex-end}
    #nyt-editorial-{{ section.id }} .copy.is-vert-middle.has-cta .cta,
    #nyt-editorial-{{ section.id }} .copy.is-vert-center.has-cta .cta,
    #nyt-editorial-{{ section.id }} .copy.is-vert-bottom.has-cta .cta{margin-top:var(--g, 20px)}
    #nyt-editorial-{{ section.id }} .copy-stack{display:flex;flex-direction:column;gap:var(--g);justify-content:flex-start;flex:0 0 auto;width:100%}
    #nyt-editorial-{{ section.id }} .box{display:flex;flex-direction:column;gap:var(--g);padding:var(--desktop-padding, 0);min-height:var(--desktop-min-height, auto);height:var(--desktop-height, auto);max-height:var(--desktop-max-height, none);position:relative}
    #nyt-editorial-{{ section.id }} .box.has-cta .cta{margin-top:auto}
    #nyt-editorial-{{ section.id }} .stack-split .media-asset img{width:100%;height:100%;object-fit:cover;object-position:center;border-radius:{{ section.settings.radius }}px;flex:1 1 auto}

@media (max-width: 900px){
  #nyt-editorial-{{ section.id }} .three-cols{grid-template-columns:1fr}
  #nyt-editorial-{{ section.id }} .stack-split{grid-template-columns:1fr;min-height:var(--stack-mobile-min-height, auto);height:var(--stack-mobile-height, auto);max-height:var(--stack-mobile-max-height, none)}
  #nyt-editorial-{{ section.id }} .stack-split.is-photo-right{grid-template-columns:1fr}
  #nyt-editorial-{{ section.id }} .stack-split.is-photo-right .media{order:initial}
  #nyt-editorial-{{ section.id }} .stack-split.is-photo-right .right{order:initial}
  #nyt-editorial-{{ section.id }} .stack-split .right{height:auto;max-height:none}
  #nyt-editorial-{{ section.id }} .stack-split .right.is-match-rows{grid-template-rows:auto auto}
  #nyt-editorial-{{ section.id }} .stack-split .right.is-content-rows{grid-template-rows:auto auto}
  #nyt-editorial-{{ section.id }} .stack-split .right.is-custom-rows{grid-template-rows:minmax(0, var(--row1-fr, 1fr)) minmax(0, var(--row2-fr, 1fr))}
  #nyt-editorial-{{ section.id }} .stack-split .media{align-items:center}
  #nyt-editorial-{{ section.id }} .stack-split .media-asset{justify-content:center}
  #nyt-editorial-{{ section.id }} .stack-split .media-asset img{margin-inline:auto}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-photo-last .media{order:2}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-photo-last .right{order:1}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-two-column{grid-template-columns:minmax(0, var(--left, 50%)) 1fr}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-two-column.is-photo-right{grid-template-columns:1fr minmax(0, var(--left, 50%))}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-two-column.is-photo-right .media{order:2}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-two-column.is-photo-right .right{order:1}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-two-column:not(.is-photo-right) .media{order:initial}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-two-column:not(.is-photo-right) .right{order:initial}
  #nyt-editorial-{{ section.id }} .stack-split .media-asset{min-height:var(--media-mobile-min-height, auto);height:var(--media-mobile-height, auto);max-height:var(--media-mobile-max-height, none)}
  #nyt-editorial-{{ section.id }} .box{padding:var(--mobile-padding, var(--desktop-padding, 0));min-height:var(--mobile-min-height, auto);height:var(--mobile-height, auto);max-height:var(--mobile-max-height, var(--desktop-max-height, none))}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-friendly{grid-template-columns:1fr}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-friendly.is-mobile-two-column{grid-template-columns:1fr}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-friendly .right{display:flex;flex-direction:column;gap:var(--g);order:1;height:auto;max-height:none}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-friendly .box{width:100%;min-height:auto;height:auto;max-height:none;padding:var(--mobile-padding, var(--desktop-padding, 0))}
  #nyt-editorial-{{ section.id }} .stack-split.is-mobile-friendly .media{order:2}
}

    #nyt-editorial-{{ section.id }}{--wrap:{{ section.settings.max_width }};--g:{{ section.settings.gap }}px;--pad:{{ section.settings.section_pad }}px;--text:#111827;--muted:#6b7280;--rule:#e5e7eb;--bg:{{ section.settings.bg }};--accent:{{ section.settings.accent }};--sans:"{{ section.settings.sans_font | default: '"Univers", "Univers Condensed", "Univers Bold Condensed", "Helvetica Neue", Arial, sans-serif' }}";--serif:"{{ section.settings.serif_font | default: 'Garamond Standard, Garamond, serif' }}";background:var(--bg);color:var(--text);font-family:var(--sans)}
    #nyt-editorial-{{ section.id }} .wrap{max-width:var(--wrap);margin-inline:auto;padding:var(--pad) 16px}
    #nyt-editorial-{{ section.id }} .rule{border:0;border-top:1px solid var(--rule);margin:24px 0}
    #nyt-editorial-{{ section.id }} .eyebrow{font:600 12px/1 var(--sans);letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    #nyt-editorial-{{ section.id }} .hed{font-family:var(--serif);font-weight:700;line-height:1.1;margin:.3em 0 .2em}
    #nyt-editorial-{{ section.id }} .dek{font:400 18px/1.6 var(--sans);color:var(--muted);margin:0}
    #nyt-editorial-{{ section.id }} p,#nyt-editorial-{{ section.id }} .copy div{font:400 17px/1.7 var(--sans);margin:0}
    #nyt-editorial-{{ section.id }} .byline{font:600 13px/1 var(--sans);color:var(--muted)}
    #nyt-editorial-{{ section.id }} .grid{display:grid;gap:var(--g)}
    #nyt-editorial-{{ section.id }} img{display:block;width:100%;height:auto;border-radius:{{ section.settings.radius }}px}
    #nyt-editorial-{{ section.id }} figure{margin:0}
    #nyt-editorial-{{ section.id }} .main-image{margin:0;position:relative}
    #nyt-editorial-{{ section.id }} .main-image.has-max-height{overflow:hidden}
    #nyt-editorial-{{ section.id }} .main-image.has-max-height img{height:var(--h);width:100%;object-fit:cover}
    #nyt-editorial-{{ section.id }} figcaption{font:400 13px/1.4 var(--sans);color:var(--muted);margin-top:6px}
    #nyt-editorial-{{ section.id }} .lede{display:grid;grid-template-columns:1.15fr .85fr;gap:var(--g);align-items:center;position:relative}
    #nyt-editorial-{{ section.id }} .lede .copy{padding:8px 0}
    #nyt-editorial-{{ section.id }} .lede .media{display:flex;flex-direction:column;min-height:0;height:100%}
    #nyt-editorial-{{ section.id }} .lede .media-asset{display:flex;flex:1 1 auto;align-items:stretch;justify-content:stretch;min-height:var(--lede-media-min-height, auto);height:var(--lede-media-height, auto);max-height:var(--lede-media-max-height, none);overflow:hidden}
    #nyt-editorial-{{ section.id }} .lede .media-asset img{width:100%;height:100%;object-fit:cover;object-position:center;border-radius:{{ section.settings.radius }}px;flex:1 1 auto}
    #nyt-editorial-{{ section.id }} .lede .hed{font-size:clamp(36px,5vw,64px)}
    #nyt-editorial-{{ section.id }} .lede .dek{margin-top:.4em}
    #nyt-editorial-{{ section.id }} .text-only{position:relative}
    #nyt-editorial-{{ section.id }} .split{display:grid;grid-template-columns:minmax(0, var(--split-photo, 1fr)) minmax(0, 1fr);gap:var(--g);align-items:stretch;position:relative;min-height:var(--split-min-height, auto);height:var(--split-height, auto);max-height:var(--split-max-height, none)}
    #nyt-editorial-{{ section.id }} .split.is-photo-right{grid-template-columns:1fr minmax(0, var(--split-photo, 1fr))}
    #nyt-editorial-{{ section.id }} .split.is-photo-right .media{order:2}
    #nyt-editorial-{{ section.id }} .split.is-photo-right .copy{order:1}
    #nyt-editorial-{{ section.id }} .split .media{display:flex;flex-direction:column;min-height:0;height:100%}
    #nyt-editorial-{{ section.id }} .split .media > a{display:flex;flex:1 1 auto}
    #nyt-editorial-{{ section.id }} .split .media-asset{display:flex;flex:1 1 auto;min-height:var(--split-media-min-height, auto);height:var(--split-media-height, auto);max-height:var(--split-media-max-height, none);overflow:hidden}
    #nyt-editorial-{{ section.id }} .split .media-asset img{width:100%;height:100%;object-fit:cover;object-position:center;border-radius:{{ section.settings.radius }}px;flex:1 1 auto}
    #nyt-editorial-{{ section.id }} .split .copy{height:100%;max-height:var(--split-copy-max-height, none)}
    #nyt-editorial-{{ section.id }} .split .copy.is-content-height{height:auto}
    #nyt-editorial-{{ section.id }} .split .hed{font-size:clamp(26px,3vw,40px)}
    #nyt-editorial-{{ section.id }} .split .kicker{font:600 12px/1 var(--sans);color:var(--accent);letter-spacing:.06em;text-transform:uppercase}
    #nyt-editorial-{{ section.id }} .meta{display:flex;gap:12px;align-items:center;color:var(--muted);font:400 13px/1 var(--sans)}
    #nyt-editorial-{{ section.id }} .links{columns:{{ section.settings.link_cols }};column-gap:var(--g)}
    #nyt-editorial-{{ section.id }} .links a{break-inside:avoid;display:block;padding:.35rem 0;color:inherit;text-underline-offset:2px}
    #nyt-editorial-{{ section.id }} .photo-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:var(--g);position:relative}
    #nyt-editorial-{{ section.id }} .photo-grid.is-mobile-stackable{--nyt-grid-masonry-row:8px}
    #nyt-editorial-{{ section.id }} .photo-grid.is-collapsible{--nyt-grid-collapse-height:auto}
    #nyt-editorial-{{ section.id }} .photo-grid__toggle{margin-top:var(--g);display:flex;justify-content:center}
    #nyt-editorial-{{ section.id }} .photo-grid__toggle-button{cursor:pointer}
    #nyt-editorial-{{ section.id }} .photo-grid__toggle-button:focus-visible{outline:2px solid var(--text);outline-offset:3px}
    #nyt-editorial-{{ section.id }} .button.button--size-small{padding:10px 22px;font-size:13px}
    #nyt-editorial-{{ section.id }} .button.button--size-xs{padding:8px 18px;font-size:12px}
    #nyt-editorial-{{ section.id }} .button.button--shape-pill{border-radius:999px}
    #nyt-editorial-{{ section.id }} .button.button--shape-rounded{border-radius:18px}
    #nyt-editorial-{{ section.id }} .button.button--shape-square{border-radius:8px}
    @media (min-width: 901px){
      #nyt-editorial-{{ section.id }} .photo-grid.is-collapsible{overflow:hidden;transition:max-height .3s ease}
      #nyt-editorial-{{ section.id }} .photo-grid.is-collapsible::after{content:"";position:absolute;left:0;right:0;bottom:0;height:120px;background:linear-gradient(to bottom,transparent,var(--bg));pointer-events:none;opacity:0;transition:opacity .3s ease}
      #nyt-editorial-{{ section.id }} .photo-grid.is-collapsible.is-collapsed{max-height:var(--nyt-grid-collapse-height,0px)}
      #nyt-editorial-{{ section.id }} .photo-grid.is-collapsible.is-collapsed::after{opacity:1}
    }
    @media (max-width: 900px){
      #nyt-editorial-{{ section.id }} .photo-grid.is-mobile-first-crop figure:first-child{height:calc((100vw - 32px) * .8);max-height:calc((100vw - 32px) * .8);overflow:hidden}
      #nyt-editorial-{{ section.id }} .photo-grid.is-mobile-first-crop figure:first-child img{height:100%;object-fit:cover}
      #nyt-editorial-{{ section.id }} .photo-grid.is-mobile-stackable.is-mobile-stacked{grid-template-columns:repeat(2,minmax(0,1fr));grid-auto-rows:var(--nyt-grid-masonry-row,8px);grid-auto-flow:dense;align-items:start}
      #nyt-editorial-{{ section.id }} .photo-grid.is-mobile-stackable.is-mobile-stacked > figure{grid-column:span 1}
      #nyt-editorial-{{ section.id }} .photo-grid.is-mobile-stackable.is-mobile-stacked figure{display:flex;flex-direction:column;margin:0}
      #nyt-editorial-{{ section.id }} .photo-grid.is-mobile-stackable.is-mobile-stacked figure > a{display:flex}
      #nyt-editorial-{{ section.id }} .photo-grid.is-mobile-stackable.is-mobile-stacked img{width:100%;height:auto}
    }
    #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip{--strip-card-width:300px;--strip-card-height:200px;--strip-duration:105s;display:flex;overflow:hidden;gap:0;position:relative;padding-block:8px}
    #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip.is-ratio-four-three{--strip-card-height:calc(var(--strip-card-width)*0.75)}
    #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip .photo-grid__track{display:flex;align-items:flex-start;gap:var(--g);width:max-content;animation:nytEditorialStripScroll-{{ section.id }} var(--strip-duration) linear infinite}
    #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip:hover .photo-grid__track,
    #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip:focus-within .photo-grid__track{animation-play-state:paused}
    #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip:hover,
#nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip:focus-within {
    overflow-x: auto;
}
    #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip figure{flex:0 0 auto;display:flex;flex-direction:column;gap:8px;width:var(--strip-card-width)}
    #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip img{width:100%;height:var(--strip-card-height);object-fit:cover;object-position:center}
