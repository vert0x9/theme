      {% endif %}

      {%- comment -%} LINKS {%- endcomment -%}
      {% if t == 'links' %}
        <div class="links" {{ block.shopify_attributes }}>
          {% for i in (1..12) %}
            {% assign label_key = 'label_' | append: i %}
            {% assign url_key   = 'url_'   | append: i %}
            {% assign label = block.settings[label_key] %}
            {% assign url   = block.settings[url_key] %}
            {% if label != blank %}<a href="{{ url }}">{{ label }}</a>{% endif %}
          {% endfor %}
        </div>
        <hr class="rule">
      {% endif %}

      {%- comment -%} DIVIDER {%- endcomment -%}
      {% if t == 'divider' %}
        <hr class="rule" {{ block.shopify_attributes }}>
      {% endif %}

      {%- comment -%} CTA {%- endcomment -%}
      {% if t == 'cta' %}
        {% assign cta_align = block.settings.cta_align | default: 'left' %}
        <div class="cta align-{{ cta_align | escape }}" {{ block.shopify_attributes }}>
          {% assign primary_style = block.settings.cta_primary_style | default: 'primary' %}
          {% if block.settings.cta_primary_label != blank and block.settings.cta_primary_url != blank %}
            {% assign primary_class = 'button button--primary' %}
            {% if primary_style == 'secondary' %}{% assign primary_class = 'button button--secondary' %}{% endif %}
            <a class="{{ primary_class }}" href="{{ block.settings.cta_primary_url }}">{{ block.settings.cta_primary_label }}</a>
          {% endif %}
          {% assign secondary_style = block.settings.cta_secondary_style | default: 'secondary' %}
          {% if block.settings.cta_secondary_label != blank and block.settings.cta_secondary_url != blank %}
            {% assign secondary_class = 'button button--secondary' %}
            {% if secondary_style == 'primary' %}{% assign secondary_class = 'button button--primary' %}{% endif %}
            <a class="{{ secondary_class }}" href="{{ block.settings.cta_secondary_url }}">{{ block.settings.cta_secondary_label }}</a>
          {% endif %}
        </div>
        <hr class="rule">
      {% endif %}

     {%- comment -%} MAIN IMAGE {%- endcomment -%}
     {%- comment -%} MAIN IMAGE {%- endcomment -%}
      {% if t == 'main_image' %}
        {% assign full_bleed = block.settings.full_bleed | default: false %}
        {% assign h = block.settings.height_px | default: 0 %}
        {% assign caption = block.settings.caption %}

        {%- comment -%} Button settings {%- endcomment -%}
        {% assign button_label = block.settings.button_label | strip %}
        {% assign button_url = block.settings.button_url | default: '#' %}
        {% assign button_style = block.settings.button_style | default: 'primary' %}
        {% assign button_size = block.settings.button_size | default: 'normal' %}
        {% assign button_align = block.settings.button_align | default: 'center' %}
        {% assign button_loading = block.settings.button_loading %}
        {% assign button_smooth_scroll = block.settings.button_smooth_scroll %}

        {% assign has_button = false %}
        {% if button_label != blank %}
          {% assign has_button = true %}
          {% assign button_classes = 'button' %}
          {% assign button_classes = button_classes | append: ' button--' | append: button_style %}
          {% if button_size == 'small' %}
            {% assign button_classes = button_classes | append: ' button--small' %}
          {% endif %}
          {% if button_loading %}
            {% assign button_classes = button_classes | append: ' is-loading' %}
          {% endif %}
        {% endif %}
        
        {%- comment -%} Button HTML {%- endcomment -%}
        {% capture button_html %}
          {% if has_button %}
            <div class="main-image-cta align-{{ button_align | escape }}">
              <a href="{{ button_url }}"
                 class="{{ button_classes }}"
                 {% if button_smooth_scroll %}data-smooth-scroll="true"{% endif %}
                 {% if button_url contains '#' %}aria-label="Scroll to section"{% endif %}>
                {{ button_label | escape }}
              </a>
            </div>
          {% endif %}
        {% endcapture %}

        {% if full_bleed %}
          </div> <div class="block-main-image--full-bleed" {{ block.shopify_attributes }}>
            <figure class.="main-image is-full-bleed{% if h > 0 %} has-max-height{% endif %}" style="{% if h > 0 %}--h:{{ h }}px;{% endif %}">
              {% if block.settings.block_url != blank %}<a class="block-link" href="{{ block.settings.block_url }}" aria-label="Open"></a>{% endif %}
              
              {% if block.settings.image != blank %}
                {% assign img_w = 2000 %}
                {% assign img_ar = block.settings.image.aspect_ratio | default: 1 %}
                {% assign img_h = img_w | divided_by: img_ar | ceil %}
                {% if block.settings.block_url == blank and block.settings.image_url != blank %}<a href="{{ block.settings.image_url }}">{% endif %}
                <img src="{{ block.settings.image | image_url: width: img_w }}" alt="{{ block.settings.image.alt | default: '' | escape }}" width="{{ img_w }}" height="{{ h }}" loading="lazy" decoding="async">
                {% if block.settings.block_url == blank and block.settings.image_url != blank %}</a>{% endif %}
              {% endif %}
              
              {% if caption != blank %}
                <div class="wrap"> <figcaption class="tx-left">{{ caption }}</figcaption>
                </div>
              {% endif %}

              {{ button_html }}
            </figure>
          </div>
          <div class="wrap"> <hr class="rule">

        {% else %}
          
          {% assign w = block.settings.width_percent | default: 100 %}
          <figure class="main-image{% if h > 0 %} has-max-height{% endif %}" style="max-width:{{ w }}%;{% if h > 0 %}--h:{{ h }}px;{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.block_url != blank %}<a class="block-link" href="{{ block.settings.block_url }}" aria-label="Open"></a>{% endif %}
            {% if block.settings.image != blank %}
              {% assign img_w = 2000 %}
              {% assign img_ar = block.settings.image.aspect_ratio | default: 1 %}
              {% assign img_h = img_w | divided_by: img_ar | ceil %}
              {% if block.settings.block_url == blank and block.settings.image_url != blank %}<a href="{{ block.settings.image_url }}">{% endif %}
              <img src="{{ block.settings.image | image_url: width: img_w }}" alt="{{ block.settings.image.alt | default: '' | escape }}" width="{{ img_w }}" height="{{ h }}" loading="lazy" decoding="async">
              {% if block.settings.block_url == blank and block.settings.image_url != blank %}</a>{% endif %}
              {% if caption != blank %}<figcaption class="tx-left">{{ caption }}</figcaption>{% endif %}
            {% endif %}
            
            {{ button_html }}
          </figure>
          <hr class="rule">
          
        {% endif %}
      {% endif %}

      {%- comment -%} GALLERY LARGE {%- endcomment -%}
      {% if t == 'gallery_large' %}
        {% assign gallery_classes = 'photo-grid is-mobile-stackable' %}
        {% assign gallery_collapse_enabled = block.settings.desktop_collapse | default: false %}
        {% if gallery_collapse_enabled %}{% assign gallery_classes = gallery_classes | append: ' is-collapsible is-collapsed' %}{% endif %}
        {% if block.settings.mobile_first_image_crop %}{% assign gallery_classes = gallery_classes | append: ' is-mobile-first-crop' %}{% endif %}
        <div id="photo-grid-{{ block.id }}" class="{{ gallery_classes }}" data-photo-grid-id="{{ block.id }}"{% if gallery_collapse_enabled %} data-photo-grid-collapse="true"{% endif %} {{ block.shopify_attributes }}>
