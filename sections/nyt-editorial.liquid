  endif
%}
      <div class="copy box {% if block.settings.font_choice == 'header' %}font-header{% else %}font-body{% endif %}{% if block.settings.justify %} tx-justify{% endif %}{% if col2_has_button %} has-cta{% else %} has-no-cta{% endif %}"{% if col2_styles != '' %} style="{{ col2_styles | strip }}"{% endif %}>
