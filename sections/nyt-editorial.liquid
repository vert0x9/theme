    @media (prefers-reduced-motion: reduce){
      #nyt-editorial-{{ section.id }} .photo-grid.is-horizontal-strip .photo-grid__track{animation:none}
    }
    #nyt-editorial-{{ section.id }} .pg-6{grid-column:span 6}
