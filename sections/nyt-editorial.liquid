            {% assign col2_styles = col2_styles | append: '--desktop-height:' | append: col2_height | append: 'px;' %}
          {% endif %}
          {% if col2_mobile_min_height > 0 %}
            {% assign col2_styles = col2_styles | append: '--mobile-min-height:' | append: col2_mobile_min_height | append: 'px;' %}
