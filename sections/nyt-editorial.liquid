          {% assign col2_button_label = block.settings.col2_button_label | strip %}
          {% assign col2_button_url = block.settings.col2_button_url %}
          {% assign col2_button_style = block.settings.col2_button_style | default: 'primary' %}
          {% assign col2_button_align = block.settings.col2_button_align | default: 'left' %}
{% liquid
  assign col2_has_button = false
  assign label_clean = col2_button_label
  if label_clean != ''
