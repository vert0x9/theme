</section>

<script>
  (function(){
    const root=document.getElementById('nyt-editorial-{{ section.id }}');
    if(!root)return;
    const collapseGrids=Array.from(root.querySelectorAll('.photo-grid[data-photo-grid-collapse]'));
    const stackableGrids=Array.from(root.querySelectorAll('.photo-grid.is-mobile-stackable'));
    const allGrids=Array.from(new Set([...collapseGrids,...stackableGrids]));
    if(!allGrids.length)return;
    const gridButtonMap=new Map();
    const stackableSet=new Set(stackableGrids);
    const scheduled=new Set();
    const updateButton=(button,expanded)=>{
      const showLabel=button.dataset.labelShow||'Show more';
      const hideLabel=button.dataset.labelHide||'Show less';
      const textEl=button.querySelector('.photo-grid__toggle-text');
      if(textEl){textEl.textContent=expanded?hideLabel:showLabel;}
      button.setAttribute('aria-expanded',expanded?'true':'false');
    };
    const computeHeight=(grid,button)=>{
      const viewportWidth=window.innerWidth||document.documentElement.clientWidth||0;
      if(viewportWidth<=900){
        button.style.display='none';
        grid.classList.remove('is-collapsible');
        grid.classList.remove('is-collapsed');
        grid.style.removeProperty('--nyt-grid-collapse-height');
        return;
      }
      const figures=Array.from(grid.querySelectorAll('figure'));
      if(!figures.length){
        button.style.display='none';
        grid.classList.remove('is-collapsible');
        grid.classList.remove('is-collapsed');
        grid.style.removeProperty('--nyt-grid-collapse-height');
        return;
      }
      const rowTops=Array.from(new Set(figures.map((figure)=>figure.offsetTop))).sort((a,b)=>a-b);
      if(rowTops.length<=1){
        button.style.display='none';
        grid.classList.remove('is-collapsible');
        grid.classList.remove('is-collapsed');
        grid.style.removeProperty('--nyt-grid-collapse-height');
        return;
      }
      button.style.display='';
      grid.classList.add('is-collapsible');
      const shouldCollapse=button.getAttribute('aria-expanded')!=='true';
      grid.classList.remove('is-collapsed');
      const rowHeight=rowTops[1]-rowTops[0];
      const collapseHeight=rowTops[0]+rowHeight*1.5;
      grid.style.setProperty('--nyt-grid-collapse-height',Math.max(collapseHeight,0)+'px');
      if(shouldCollapse){
        grid.classList.add('is-collapsed');
      }
    };
    const layoutStack=(grid)=>{
      const figures=Array.from(grid.querySelectorAll('figure'));
      if(!figures.length){
        grid.classList.remove('is-mobile-stacked');
        return;
      }
      const viewportWidth=window.innerWidth||document.documentElement.clientWidth||0;
      if(viewportWidth<=760||viewportWidth>900){
        if(grid.classList.contains('is-mobile-stacked')){
          grid.classList.remove('is-mobile-stacked');
          figures.forEach((figure)=>figure.style.removeProperty('grid-row-end'));
        }
        return;
      }
      const style=getComputedStyle(grid);
      let baseRow=parseFloat(style.getPropertyValue('--nyt-grid-masonry-row'));
      if(Number.isNaN(baseRow)||baseRow<=0){
        baseRow=parseFloat(style.getPropertyValue('grid-auto-rows'));
      }
      if(Number.isNaN(baseRow)||baseRow<=0){
        baseRow=8;
      }
      let rowGap=parseFloat(style.getPropertyValue('row-gap'));
      if(Number.isNaN(rowGap)){
        rowGap=0;
      }
      grid.classList.add('is-mobile-stacked');
      figures.forEach((figure)=>figure.style.removeProperty('grid-row-end'));
      figures.forEach((figure)=>{
        const rect=figure.getBoundingClientRect();
        const span=Math.max(Math.ceil((rect.height+rowGap)/(baseRow+rowGap)),1);
        figure.style.gridRowEnd='span '+span;
      });
    };
    const updateGrid=(grid)=>{
      if(gridButtonMap.has(grid)){
        const button=gridButtonMap.get(grid);
        if(button){
          computeHeight(grid,button);
        }
      }
      if(stackableSet.has(grid)){
        layoutStack(grid);
      }
    };
    const requestUpdate=(grid)=>{
      if(scheduled.has(grid))return;
      scheduled.add(grid);
      requestAnimationFrame(()=>{
        scheduled.delete(grid);
        updateGrid(grid);
      });
    };
    collapseGrids.forEach((grid)=>{
      const button=root.querySelector('[data-photo-grid-toggle][data-target="'+grid.dataset.photoGridId+'"]');
      if(!button)return;
      gridButtonMap.set(grid,button);
      updateButton(button,false);
      button.addEventListener('click',(event)=>{
        event.preventDefault();
        const expanded=button.getAttribute('aria-expanded')==='true';
        const next=!expanded;
        updateButton(button,next);
        if(next){
          grid.classList.remove('is-collapsed');
        }else{
          grid.classList.add('is-collapsed');
        }
        requestUpdate(grid);
      });
    });
    allGrids.forEach((grid)=>{
      grid.querySelectorAll('img').forEach((img)=>{
        if(img.complete){
          return;
        }
        img.addEventListener('load',()=>requestUpdate(grid));
        img.addEventListener('error',()=>requestUpdate(grid));
      });
      requestUpdate(grid);
    });
    window.addEventListener('resize',()=>{
      allGrids.forEach((grid)=>{
        requestUpdate(grid);
      });
    });
  })();
</script>

