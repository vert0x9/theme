{% comment %}
  ============================================================
  BFC Collection Intro  (v2 — orient + start here + quick nav)
  ------------------------------------------------------------
  Orients a cold shopper on a collection page:
    LEFT  → eyebrow + serif title + "is this for you" paragraph
            + trust row (restored / warrantied / shipping)
    RIGHT → a hand-picked "Start here" camera card, plus a set
            of quick-nav links (added as blocks) to route deeper.

  Type the copy per collection (place this section on each
  collection template). All fields have defaults wired for
  Point & Shoots as an example.

  No featured-camera engine — this is a static, fast intro.
  ============================================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/></noscript>

{%- liquid
  assign theme = section.settings.theme
  assign sp = section.settings.start_product
  assign sp_label = section.settings.start_label | default: 'Start here'
  assign sp_cta = section.settings.start_cta | default: 'Shop this camera'
-%}

<style>
#bfc-ci-{{ section.id }} *, #bfc-ci-{{ section.id }} *::before, #bfc-ci-{{ section.id }} *::after { box-sizing: border-box; margin: 0; padding: 0; }

#shopify-section-{{ section.id }} { width: 100%; }

#bfc-ci-{{ section.id }} {
  --or: #E36E15;
  --ce: #ABCC99;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sr: 'Cormorant Garamond', Georgia, serif;
  --sn: 'Poppins', sans-serif;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
}
#bfc-ci-{{ section.id }}.is-dark { background: var(--bk); color: #fff; }

#bfc-ci-{{ section.id }} .ci-wrap {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 48px;
  align-items: start;
  max-width: 1240px;
  margin: 0 auto;
  padding: 56px 32px;
}

/* ── LEFT: intro ── */
#bfc-ci-{{ section.id }} .ci-ey {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 9px; font-weight: 700; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--or); margin-bottom: 14px;
}
#bfc-ci-{{ section.id }} .ci-ey::before { content: ''; width: 16px; height: 1px; background: var(--or); display: block; }
#bfc-ci-{{ section.id }} .ci-title {
  font-family: var(--sr); font-size: clamp(28px, 4vw, 44px); font-weight: 300;
  line-height: 1.12; letter-spacing: -0.01em; margin-bottom: 16px;
}
#bfc-ci-{{ section.id }}.is-dark .ci-title { color: #fff; }
#bfc-ci-{{ section.id }} .ci-body {
  font-size: 15px; line-height: 1.7; color: var(--ch); max-width: 56ch;
}
#bfc-ci-{{ section.id }}.is-dark .ci-body { color: rgba(255,255,255,0.74); }
#bfc-ci-{{ section.id }} .ci-trust {
  list-style: none; display: flex; flex-wrap: wrap; gap: 12px 26px; margin-top: 24px;
}
#bfc-ci-{{ section.id }} .ci-trust li {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--ch);
}
#bfc-ci-{{ section.id }} .ci-trust svg { color: #2a4820; flex-shrink: 0; }
#bfc-ci-{{ section.id }}.is-dark .ci-trust li { color: rgba(255,255,255,0.74); }
#bfc-ci-{{ section.id }}.is-dark .ci-trust svg { color: var(--ce); }

/* ── RIGHT: start-here card + quick nav ── */
#bfc-ci-{{ section.id }} .ci-aside { display: flex; flex-direction: column; gap: 22px; }

#bfc-ci-{{ section.id }} .ci-start {
  display: grid;
  grid-template-columns: 96px 1fr;
  gap: 16px;
  align-items: center;
  text-decoration: none;
  color: inherit;
  background: #fff;
  padding: 14px;
  border: 1px solid var(--gr);
  transition: border-color 0.2s ease;
}
#bfc-ci-{{ section.id }}.is-dark .ci-start { background: #18180a; border-color: rgba(255,255,255,0.12); }
#bfc-ci-{{ section.id }} .ci-start:hover { border-color: var(--or); }
#bfc-ci-{{ section.id }} .ci-start-img {
  width: 96px; height: 96px; object-fit: contain; display: block;
}
#bfc-ci-{{ section.id }} .ci-start-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--or); margin-bottom: 6px;
  display: inline-flex; align-items: center; gap: 6px;
}
#bfc-ci-{{ section.id }} .ci-start-name {
  font-family: var(--sr); font-size: 20px; font-weight: 400;
  line-height: 1.15; margin-bottom: 4px;
}
#bfc-ci-{{ section.id }}.is-dark .ci-start-name { color: #fff; }
#bfc-ci-{{ section.id }} .ci-start-price {
  font-size: 13px; font-weight: 600; color: var(--bk);
}
#bfc-ci-{{ section.id }}.is-dark .ci-start-price { color: rgba(255,255,255,0.85); }
#bfc-ci-{{ section.id }} .ci-start-cta {
  margin-top: 8px;
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--or);
}

/* Quick-nav links */
#bfc-ci-{{ section.id }} .ci-nav-title {
  font-size: 9px; font-weight: 700; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--ch); margin-bottom: 2px;
}
#bfc-ci-{{ section.id }}.is-dark .ci-nav-title { color: rgba(255,255,255,0.55); }
#bfc-ci-{{ section.id }} .ci-nav { display: flex; flex-direction: column; }
#bfc-ci-{{ section.id }} .ci-nav-link {
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  text-decoration: none; color: var(--bk);
  font-size: 14px; font-weight: 500;
  padding: 13px 2px;
  border-bottom: 1px solid var(--gr);
  transition: color 0.15s ease, padding-left 0.15s ease;
}
#bfc-ci-{{ section.id }} .ci-nav-link:first-child { border-top: 1px solid var(--gr); }
#bfc-ci-{{ section.id }}.is-dark .ci-nav-link { color: #fff; border-color: rgba(255,255,255,0.12); }
#bfc-ci-{{ section.id }}.is-dark .ci-nav-link:first-child { border-top-color: rgba(255,255,255,0.12); }
#bfc-ci-{{ section.id }} .ci-nav-link:hover { color: var(--or); padding-left: 8px; }
#bfc-ci-{{ section.id }} .ci-nav-link svg { flex-shrink: 0; color: currentColor; }
#bfc-ci-{{ section.id }} .ci-nav-sub {
  font-size: 11px; font-weight: 400; color: var(--ch); letter-spacing: 0;
}
#bfc-ci-{{ section.id }}.is-dark .ci-nav-sub { color: rgba(255,255,255,0.55); }

@media (max-width: 860px) {
  #bfc-ci-{{ section.id }} .ci-wrap {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 40px 20px;
  }
  #bfc-ci-{{ section.id }} .ci-trust { gap: 10px 18px; margin-top: 18px; }
  #bfc-ci-{{ section.id }} .ci-trust li { font-size: 9.5px; }
}
</style>

<section id="bfc-ci-{{ section.id }}" class="{% if theme == 'dark' %}is-dark{% endif %}" aria-label="{{ section.settings.intro_title | default: 'Collection intro' | escape }}">
  <div class="ci-wrap">

    {%- comment -%} ── LEFT: intro ── {%- endcomment -%}
    <div class="ci-intro">
      {%- if section.settings.intro_eyebrow != blank -%}
        <p class="ci-ey">{{ section.settings.intro_eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.intro_title != blank -%}
        <h2 class="ci-title">{{ section.settings.intro_title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.intro_body != blank -%}
        <p class="ci-body">{{ section.settings.intro_body | escape | newline_to_br }}</p>
      {%- endif -%}
      {%- if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank -%}
        <ul class="ci-trust">
          {%- if section.settings.trust_1 != blank -%}
            <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>{{ section.settings.trust_1 | escape }}</li>
          {%- endif -%}
          {%- if section.settings.trust_2 != blank -%}
            <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>{{ section.settings.trust_2 | escape }}</li>
          {%- endif -%}
          {%- if section.settings.trust_3 != blank -%}
            <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>{{ section.settings.trust_3 | escape }}</li>
          {%- endif -%}
        </ul>
      {%- endif -%}
    </div>

    {%- comment -%} ── RIGHT: start-here + quick nav ── {%- endcomment -%}
    <div class="ci-aside">

      {%- if sp != blank -%}
        <a class="ci-start" href="{{ sp.url }}" aria-label="{{ sp_label }}: {{ sp.title | escape }}">
          {%- if sp.featured_image -%}
            <img class="ci-start-img" src="{{ sp.featured_image | image_url: width: 280 }}" alt="{{ sp.title | escape }}" loading="lazy" width="96" height="96"/>
          {%- endif -%}
          <div>
            <span class="ci-start-label">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
              {{ sp_label }}
            </span>
            <p class="ci-start-name">{{ sp.title | escape }}</p>
            {%- if sp.available -%}
              <p class="ci-start-price">{% if sp.price_varies %}From {% endif %}{{ sp.price | money }}</p>
            {%- else -%}
              <p class="ci-start-price">Sold out</p>
            {%- endif -%}
            <span class="ci-start-cta">
              {{ sp_cta }}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
            </span>
          </div>
        </a>
      {%- endif -%}

      {%- assign nav_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'quick_nav' and block.settings.label != blank -%}{%- assign nav_count = nav_count | plus: 1 -%}{%- endif -%}
      {%- endfor -%}
      {%- if nav_count > 0 -%}
        {%- if section.settings.nav_title != blank -%}
          <p class="ci-nav-title">{{ section.settings.nav_title | escape }}</p>
        {%- endif -%}
        <nav class="ci-nav" aria-label="{{ section.settings.nav_title | default: 'Quick links' | escape }}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'quick_nav' and block.settings.label != blank -%}
              <a class="ci-nav-link" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
                <span>
                  {{ block.settings.label | escape }}
                  {%- if block.settings.sublabel != blank -%}<br><span class="ci-nav-sub">{{ block.settings.sublabel | escape }}</span>{%- endif -%}
                </span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      {%- endif -%}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "BFC Collection Intro",
  "tag": "section",
  "class": "bfc-collection-intro-section",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Intro (left side)" },
    { "type": "paragraph", "content": "Type a version per collection. Orients a cold shopper: where they are, whether it's for them, why to buy here." },
    { "type": "text", "id": "intro_eyebrow", "label": "Eyebrow", "default": "Shop by type" },
    { "type": "text", "id": "intro_title", "label": "Title", "default": "Point & Shoot Cameras" },
    { "type": "textarea", "id": "intro_body", "label": "Paragraph", "default": "The whole point is that there is no point. No focusing, no settings, no fuss. The camera does the thinking so you just press the button. If you want real film photos without the learning curve, start here." },
    { "type": "text", "id": "trust_1", "label": "Trust point 1", "default": "Restored & bench-tested in Brooklyn" },
    { "type": "text", "id": "trust_2", "label": "Trust point 2", "default": "Warrantied" },
    { "type": "text", "id": "trust_3", "label": "Trust point 3", "default": "Free shipping over $400" },

    { "type": "header", "content": "Start here camera (right side)" },
    { "type": "paragraph", "content": "Pick one camera as the safe default for shoppers who don't know where to begin. Leave blank to hide." },
    { "type": "product", "id": "start_product", "label": "Start here camera" },
    { "type": "text", "id": "start_label", "label": "Label", "default": "Start here" },
    { "type": "text", "id": "start_cta", "label": "Link text", "default": "Shop this camera" },

    { "type": "header", "content": "Quick links (right side)" },
    { "type": "paragraph", "content": "Add Quick Nav Link blocks below to route shoppers deeper (e.g. 'Under $150', 'With flash'). Drag to reorder." },
    { "type": "text", "id": "nav_title", "label": "Quick links heading", "default": "Or browse by" },

    { "type": "header", "content": "Theme" },
    {
      "type": "select", "id": "theme", "label": "Theme", "default": "light",
      "options": [
        { "value": "light", "label": "Light (cream)" },
        { "value": "dark", "label": "Dark" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "quick_nav",
      "name": "Quick Nav Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Under $150" },
        { "type": "text", "id": "sublabel", "label": "Sub-label (optional)", "info": "Small text below the label." },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BFC Collection Intro",
      "blocks": [
        { "type": "quick_nav", "settings": { "label": "Under $150" } },
        { "type": "quick_nav", "settings": { "label": "Premium compacts" } },
        { "type": "quick_nav", "settings": { "label": "Best for beginners" } }
      ]
    }
  ]
}
{% endschema %}
