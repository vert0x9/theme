{% comment %}
  ============================================================
  BFC Collection Intro  (v5 — All Cameras, curated-collection nav)
  ------------------------------------------------------------
  Orients a cold shopper. Intro copy is baked in as defaults
  (edit in the theme editor if needed). The "browse by" links
  route to curated collections you build in admin, so NOTHING
  is added to the filter sidebar — you fully control each list.

  Each Quick Nav Link block: a label + a collection picker
  (or a custom URL fallback). Build the target collections in
  admin with automated conditions (e.g. tag = beginner-friendly)
  so membership stays current without manual upkeep.

  Renders wherever the section is placed.
  ============================================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/></noscript>

{%- liquid
  assign theme = section.settings.theme
  assign sub_mode = section.settings.sub_mode

  comment # Resolve the displayed eyebrow/title/body. In Sub Collection mode, use the
    sub_* fields so subset copy is independent of the All Cameras defaults. #
  endcomment
  if sub_mode
    assign ci_eyebrow = section.settings.sub_eyebrow
    assign ci_title = section.settings.sub_title
    assign ci_body = section.settings.sub_body
  else
    assign ci_eyebrow = section.settings.intro_eyebrow
    assign ci_title = section.settings.intro_title
    assign ci_body = section.settings.intro_body
  endif

  comment # Sub-mode back link target, falling back to the current collection. #
  endcomment
  assign back_url = section.settings.back_collection.url
  if back_url == blank
    assign back_url = collection.url
  endif
-%}

{%- comment -%} Renders wherever placed; links are explicit collection pickers. {%- endcomment -%}
<style>
#bfc-ci-{{ section.id }} *, #bfc-ci-{{ section.id }} *::before, #bfc-ci-{{ section.id }} *::after { box-sizing: border-box; margin: 0; padding: 0; }

#shopify-section-{{ section.id }} { width: 100%; }

#bfc-ci-{{ section.id }} {
  --or: #E36E15;
  --ce: #ABCC99;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sr: 'Cormorant Garamond', Georgia, serif;
  --sn: 'Poppins', sans-serif;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
}
#bfc-ci-{{ section.id }}.is-dark { background: var(--bk); color: #fff; }

#bfc-ci-{{ section.id }} {
  --ci-pad: clamp(20px, calc((100vw - min(100vw, 1240px)) / 2 + 32px), 120px);
}
#bfc-ci-{{ section.id }} .ci-wrap {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 48px;
  align-items: start;
  padding: 56px var(--ci-pad);
}
/* Sub-collection mode: text fills the row, back link hugs the right */
#bfc-ci-{{ section.id }} .ci-wrap--sub {
  grid-template-columns: 1fr auto;
}

/* ── LEFT: intro ── */
#bfc-ci-{{ section.id }} .ci-ey {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 9px; font-weight: 700; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--or); margin-bottom: 14px;
}
#bfc-ci-{{ section.id }} .ci-ey::before { content: ''; width: 16px; height: 1px; background: var(--or); display: block; }
#bfc-ci-{{ section.id }} .ci-title {
  font-family: var(--sr); font-size: clamp(28px, 4vw, 44px); font-weight: 300;
  line-height: 1.12; letter-spacing: -0.01em; margin-bottom: 16px;
}
#bfc-ci-{{ section.id }}.is-dark .ci-title { color: #fff; }
#bfc-ci-{{ section.id }} .ci-body {
  font-size: 15px; line-height: 1.7; color: var(--ch); max-width: 56ch;
}
#bfc-ci-{{ section.id }}.is-dark .ci-body { color: rgba(255,255,255,0.74); }
#bfc-ci-{{ section.id }} .ci-trust {
  list-style: none; display: flex; flex-wrap: wrap; gap: 12px 26px; margin-top: 24px;
}
#bfc-ci-{{ section.id }} .ci-trust li {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--ch);
}
#bfc-ci-{{ section.id }} .ci-trust svg { color: #2a4820; flex-shrink: 0; }
#bfc-ci-{{ section.id }}.is-dark .ci-trust li { color: rgba(255,255,255,0.74); }
#bfc-ci-{{ section.id }}.is-dark .ci-trust svg { color: var(--ce); }

/* ── RIGHT: quick nav ── */
#bfc-ci-{{ section.id }} .ci-aside { display: flex; flex-direction: column; gap: 22px; }
#bfc-ci-{{ section.id }} .ci-nav-title {
  font-size: 9px; font-weight: 700; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--ch); margin-bottom: 2px;
}
#bfc-ci-{{ section.id }}.is-dark .ci-nav-title { color: rgba(255,255,255,0.55); }
#bfc-ci-{{ section.id }} .ci-nav { display: flex; flex-direction: column; }
#bfc-ci-{{ section.id }} .ci-nav-link {
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  text-decoration: none; color: var(--bk);
  font-size: 15px; font-weight: 500;
  padding: 15px 2px;
  border-bottom: 1px solid var(--gr);
  transition: color 0.15s ease, padding-left 0.15s ease;
}
#bfc-ci-{{ section.id }} .ci-nav-link:first-child { border-top: 1px solid var(--gr); }
#bfc-ci-{{ section.id }}.is-dark .ci-nav-link { color: #fff; border-color: rgba(255,255,255,0.12); }
#bfc-ci-{{ section.id }}.is-dark .ci-nav-link:first-child { border-top-color: rgba(255,255,255,0.12); }
#bfc-ci-{{ section.id }} .ci-nav-link:hover { color: var(--or); padding-left: 8px; }
#bfc-ci-{{ section.id }} .ci-nav-link svg { flex-shrink: 0; color: currentColor; }
#bfc-ci-{{ section.id }} .ci-nav-sub {
  font-size: 11px; font-weight: 400; color: var(--ch); letter-spacing: 0;
}
#bfc-ci-{{ section.id }}.is-dark .ci-nav-sub { color: rgba(255,255,255,0.55); }

/* Image-square grid */
#bfc-ci-{{ section.id }} .ci-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
#bfc-ci-{{ section.id }} .ci-tile {
  display: block;
  text-decoration: none;
  color: var(--bk);
}
#bfc-ci-{{ section.id }} .ci-tile-img {
  display: block;
  position: relative;
  aspect-ratio: 1 / 1;
  background: #fff;
  border: 1px solid var(--gr);
  overflow: hidden;
}
#bfc-ci-{{ section.id }}.is-dark .ci-tile-img { background: #18180a; border-color: rgba(255,255,255,0.12); }
#bfc-ci-{{ section.id }} .ci-tile-img img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.3s ease;
}
#bfc-ci-{{ section.id }} .ci-tile:hover .ci-tile-img { border-color: var(--or); }
#bfc-ci-{{ section.id }} .ci-tile:hover .ci-tile-img img { transform: scale(1.04); }
#bfc-ci-{{ section.id }} .ci-tile-ph {
  position: absolute; inset: 0;
  background: var(--gr);
}
#bfc-ci-{{ section.id }} .ci-tile-label {
  display: block;
  margin-top: 8px;
  font-size: 12px; font-weight: 500;
  line-height: 1.25;
  color: var(--bk);
}
#bfc-ci-{{ section.id }}.is-dark .ci-tile-label { color: #fff; }
#bfc-ci-{{ section.id }} .ci-tile:hover .ci-tile-label { color: var(--or); }

/* Sub-collection back link */
#bfc-ci-{{ section.id }} .ci-aside--sub { justify-content: flex-start; align-items: flex-start; }
#bfc-ci-{{ section.id }} .ci-back {
  display: inline-flex; align-items: center; gap: 8px;
  align-self: flex-start;
  text-decoration: none; color: var(--bk);
  font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 12px 16px;
  border: 1px solid var(--gr);
  transition: border-color 0.15s ease, color 0.15s ease;
}
#bfc-ci-{{ section.id }} .ci-back:hover { border-color: var(--or); color: var(--or); }
#bfc-ci-{{ section.id }} .ci-back svg { flex-shrink: 0; color: currentColor; }
#bfc-ci-{{ section.id }}.is-dark .ci-back { color: #fff; border-color: rgba(255,255,255,0.2); }
#bfc-ci-{{ section.id }}.is-dark .ci-back:hover { border-color: var(--or); color: var(--or); }

@media (max-width: 860px) {
  #bfc-ci-{{ section.id }} .ci-wrap,
  #bfc-ci-{{ section.id }} .ci-wrap--sub {
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 40px var(--ci-pad);
  }
  #bfc-ci-{{ section.id }} .ci-trust { gap: 10px 18px; margin-top: 18px; }
  #bfc-ci-{{ section.id }} .ci-trust li { font-size: 9.5px; }
  /* On mobile the back link reads better at the top, before the title */
  #bfc-ci-{{ section.id }} .ci-wrap--sub .ci-aside--sub { order: -1; }
  /* Keep the back link compact (hug content), not a full-width box */
  #bfc-ci-{{ section.id }} .ci-back {
    align-self: flex-start;
    width: auto;
    padding: 8px 12px;
    font-size: 10px;
    letter-spacing: 0.06em;
    gap: 6px;
  }
  #bfc-ci-{{ section.id }} .ci-back svg { width: 12px; height: 12px; }
  /* Image grid: 3 across on phones */
  #bfc-ci-{{ section.id }} .ci-grid { grid-template-columns: repeat(3, 1fr); gap: 10px; }
  #bfc-ci-{{ section.id }} .ci-tile-label { font-size: 11px; margin-top: 6px; }
}

/* "More" toggle is desktop-hidden; all links always show on desktop. */
#bfc-ci-{{ section.id }} .ci-more-toggle { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
#bfc-ci-{{ section.id }} .ci-more-label { display: none; }

@media (max-width: 860px) {
  /* Compact the intro: drop the paragraph and trust row, shrink the title */
  #bfc-ci-{{ section.id }} .ci-body { display: none; }
  #bfc-ci-{{ section.id }} .ci-trust { display: none; }
  #bfc-ci-{{ section.id }} .ci-title { font-size: 30px; margin-bottom: 4px; }
  #bfc-ci-{{ section.id }} .ci-ey { margin-bottom: 10px; }
  #bfc-ci-{{ section.id }} .ci-wrap { gap: 18px; padding: 28px var(--ci-pad); }

  /* Tighter link rows */
  #bfc-ci-{{ section.id }} .ci-nav-link { padding: 13px 2px; font-size: 15px; }
  #bfc-ci-{{ section.id }} .ci-nav-title { margin-bottom: 0; }

  /* Show only the first 3 links; reveal the rest on tap */
  #bfc-ci-{{ section.id }} .ci-nav-link--extra { display: none; }
  #bfc-ci-{{ section.id }} .ci-more-toggle:checked ~ .ci-nav .ci-nav-link--extra { display: flex; }
  #bfc-ci-{{ section.id }} .ci-more-label {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 12px; cursor: pointer;
    font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ch);
  }
  #bfc-ci-{{ section.id }} .ci-more-label svg { transition: transform 0.2s ease; }
  #bfc-ci-{{ section.id }} .ci-more-toggle:checked ~ .ci-more-label svg { transform: rotate(180deg); }
  #bfc-ci-{{ section.id }} .ci-more-close { display: none; }
  #bfc-ci-{{ section.id }} .ci-more-toggle:checked ~ .ci-more-label .ci-more-open { display: none; }
  #bfc-ci-{{ section.id }} .ci-more-toggle:checked ~ .ci-more-label .ci-more-close { display: inline; }
}
</style>

<section id="bfc-ci-{{ section.id }}" class="{% if theme == 'dark' %}is-dark{% endif %}" aria-label="{{ ci_title | default: 'Collection intro' | escape }}">
  <div class="ci-wrap{% if sub_mode %} ci-wrap--sub{% endif %}">

    {%- comment -%} ── LEFT: intro ── {%- endcomment -%}
    <div class="ci-intro">
      {%- if ci_eyebrow != blank -%}
        <p class="ci-ey">{{ ci_eyebrow | escape }}</p>
      {%- endif -%}
      {%- if ci_title != blank -%}
        <h2 class="ci-title">{{ ci_title | escape }}</h2>
      {%- endif -%}
      {%- if ci_body != blank -%}
        <p class="ci-body">{{ ci_body | escape | newline_to_br }}</p>
      {%- endif -%}
      {%- if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank -%}
        <ul class="ci-trust">
          {%- if section.settings.trust_1 != blank -%}
            <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>{{ section.settings.trust_1 | escape }}</li>
          {%- endif -%}
          {%- if section.settings.trust_2 != blank -%}
            <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>{{ section.settings.trust_2 | escape }}</li>
          {%- endif -%}
          {%- if section.settings.trust_3 != blank -%}
            <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>{{ section.settings.trust_3 | escape }}</li>
          {%- endif -%}
        </ul>
      {%- endif -%}
    </div>

    {%- comment -%} ── RIGHT: sub-collection back link, or browse-by nav ── {%- endcomment -%}
    {%- if sub_mode -%}
      <div class="ci-aside ci-aside--sub">
        <a class="ci-back" href="{{ back_url | default: '#' }}">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11 7H3M7 3L3 7l4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
          {{ section.settings.back_label | default: 'Back to All Cameras' | escape }}
        </a>
      </div>
    {%- else -%}
      {%- assign nav_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'quick_nav' and block.settings.label != blank -%}{%- assign nav_count = nav_count | plus: 1 -%}{%- endif -%}
      {%- endfor -%}
      {%- if nav_count > 0 -%}
        {%- assign nav_style = section.settings.nav_style -%}
        <div class="ci-aside">
          {%- if section.settings.nav_title != blank -%}
            <p class="ci-nav-title">{{ section.settings.nav_title | escape }}</p>
          {%- endif -%}

          {%- if nav_style == 'grid' -%}
            {%- comment -%} ── Image-square grid ── {%- endcomment -%}
            <div class="ci-grid" role="list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'quick_nav' and block.settings.label != blank -%}
                  {%- liquid
                    assign href = '#'
                    if block.settings.link_collection != blank
                      assign href = block.settings.link_collection.url
                    elsif block.settings.custom_url != blank
                      assign href = block.settings.custom_url
                    endif
                    assign tile_img = block.settings.image
                    if tile_img == blank and block.settings.link_collection != blank
                      assign tile_img = block.settings.link_collection.featured_image
                    endif
                  -%}
                  <a class="ci-tile" href="{{ href }}" role="listitem" {{ block.shopify_attributes }}>
                    <span class="ci-tile-img">
                      {%- if tile_img != blank -%}
                        <img src="{{ tile_img | image_url: width: 320 }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="160" height="160">
                      {%- else -%}
                        <span class="ci-tile-ph" aria-hidden="true"></span>
                      {%- endif -%}
                    </span>
                    <span class="ci-tile-label">{{ block.settings.label | escape }}</span>
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>

          {%- else -%}
            {%- comment -%} ── Text list (with mobile "more" toggle) ── {%- endcomment -%}
            <input type="checkbox" id="ci-more-{{ section.id }}" class="ci-more-toggle" aria-hidden="true">
            <nav class="ci-nav" aria-label="{{ section.settings.nav_title | default: 'Browse by' | escape }}">
              {%- assign shown = 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'quick_nav' and block.settings.label != blank -%}
                  {%- assign shown = shown | plus: 1 -%}
                  {%- liquid
                    assign href = '#'
                    if block.settings.link_collection != blank
                      assign href = block.settings.link_collection.url
                    elsif block.settings.custom_url != blank
                      assign href = block.settings.custom_url
                    endif
                  -%}
                  <a class="ci-nav-link{% if shown > 3 %} ci-nav-link--extra{% endif %}" href="{{ href }}" {{ block.shopify_attributes }}>
                    <span>
                      {{ block.settings.label | escape }}
                      {%- if block.settings.sublabel != blank -%}<br><span class="ci-nav-sub">{{ block.settings.sublabel | escape }}</span>{%- endif -%}
                    </span>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </nav>
            {%- if nav_count > 3 -%}
              <label for="ci-more-{{ section.id }}" class="ci-more-label">
                <span class="ci-more-open">More ({{ nav_count | minus: 3 }})</span>
                <span class="ci-more-close">Less</span>
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </label>
            {%- endif -%}
          {%- endif -%}

        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "BFC Collection Intro",
  "tag": "section",
  "class": "bfc-collection-intro-section",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Intro (left side)" },
    { "type": "text", "id": "intro_eyebrow", "label": "Eyebrow", "default": "Shop all" },
    { "type": "text", "id": "intro_title", "label": "Title", "default": "Every Camera, Restored" },
    { "type": "textarea", "id": "intro_body", "label": "Paragraph", "default": "Film cameras, brought back to life and ready to shoot. Every body here has been serviced, cleaned, and bench-tested by our techs in Brooklyn, then backed by a warranty. New to film or coming back to it, this is the whole shelf. Not sure where to start? Use the links to browse by what matters to you." },
    { "type": "text", "id": "trust_1", "label": "Trust point 1", "default": "Restored & bench-tested in Brooklyn" },
    { "type": "text", "id": "trust_2", "label": "Trust point 2", "default": "Warrantied" },
    { "type": "text", "id": "trust_3", "label": "Trust point 3", "default": "Free shipping over $400" },

    { "type": "header", "content": "Sub Collection mode" },
    { "type": "paragraph", "content": "Turn this ON when the section sits on a curated sub-collection page (e.g. Beginner Friendly). It uses the copy below and replaces the browse-by links with a single 'Back' link." },
    { "type": "checkbox", "id": "sub_mode", "label": "Sub Collection mode", "default": false },
    { "type": "text", "id": "sub_eyebrow", "label": "Sub eyebrow", "default": "A subset of All Cameras" },
    { "type": "text", "id": "sub_title", "label": "Sub title", "default": "Beginner Friendly" },
    { "type": "textarea", "id": "sub_body", "label": "Sub paragraph", "default": "Simple, reliable cameras that are easy to learn on. No fiddly settings, no surprises. Every one restored, bench-tested, and warrantied." },
    { "type": "collection", "id": "back_collection", "label": "Back link goes to", "info": "e.g. the All Cameras collection. Falls back to the current collection if blank." },
    { "type": "text", "id": "back_label", "label": "Back link text", "default": "Back to All Cameras" },

    { "type": "header", "content": "Browse by (links)" },
    { "type": "paragraph", "content": "Each link points to a curated collection you build in admin (e.g. a 'Beginner Friendly' collection with automated conditions). This keeps these out of the filter sidebar entirely. Add Quick Nav Link blocks below." },
    { "type": "text", "id": "nav_title", "label": "Heading", "default": "Browse by" },
    {
      "type": "select", "id": "nav_style", "label": "Nav style", "default": "list",
      "options": [
        { "value": "list", "label": "Text list" },
        { "value": "grid", "label": "Image grid (squares)" }
      ]
    },

    { "type": "header", "content": "Theme" },
    {
      "type": "select", "id": "theme", "label": "Theme", "default": "light",
      "options": [
        { "value": "light", "label": "Light (cream)" },
        { "value": "dark", "label": "Dark" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "quick_nav",
      "name": "Quick Nav Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Beginner friendly" },
        { "type": "text", "id": "sublabel", "label": "Sub-label (optional)" },
        { "type": "image_picker", "id": "image", "label": "Tile image", "info": "Shown when the section's nav style is Image grid. Square works best." },
        { "type": "collection", "id": "link_collection", "label": "Links to collection", "info": "The curated collection this routes to. Build it in admin with automated conditions so it stays current." },
        { "type": "url", "id": "custom_url", "label": "Custom URL (optional)", "info": "Used only if no collection is chosen above." }
      ]
    }
  ],
  "presets": [
    {
      "name": "BFC Collection Intro",
      "blocks": [
        { "type": "quick_nav", "settings": { "label": "Beginner friendly" } },
        { "type": "quick_nav", "settings": { "label": "Point & shoots" } },
        { "type": "quick_nav", "settings": { "label": "Premium compacts" } }
      ]
    }
  ]
}
{% endschema %}
