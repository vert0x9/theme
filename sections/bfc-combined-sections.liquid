      {% when 'hasselblad_editorial' %}
        {% liquid
          assign hb_id = 'bfc-hb-' | append: section.id | append: '-' | append: block.id
          assign hb_has_image = false
          if block.settings.image != blank
            assign hb_has_image = true
          endif
        %}
        <section
          id="{{ hb_id }}"
          class="bfc-block bfc-hb"
          style="
            --hb-bg: {{ block.settings.bg }};
            --hb-fg: {{ block.settings.fg }};
            --hb-accent: {{ block.settings.accent }};
            --hb-border: {{ block.settings.border_color }};
            --hb-max: {{ page_width_px }}px;
            --hb-pt: {{ block.settings.padding_top }}px;
            --hb-pb: {{ block.settings.padding_bottom }}px;
            --bfc-block-pad: calc(var(--bfc-align-pad) + {{ block.settings.side_padding_vw }}vw);
          "
          {{ block.shopify_attributes }}
        >
          <div class="bfc-hb__wrap">
            <div class="bfc-hb__copy">
              {% if block.settings.eyebrow != blank %}
                <p class="bfc-hb__eyebrow">{{ block.settings.eyebrow | escape }}</p>
              {% endif %}
              {% if block.settings.kicker != blank %}
                <p class="bfc-hb__kicker">{{ block.settings.kicker | escape }}</p>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="bfc-hb__heading">{{ block.settings.heading | escape }}</h2>
              {% endif %}
              {% if block.settings.body != blank %}
                <p class="bfc-hb__body">{{ block.settings.body | escape }}</p>
              {% endif %}
              <div class="bfc-hb__ctas">
                {% if block.settings.cta_label != blank and block.settings.cta_url != blank %}
                  <a class="bfc-hb__cta bfc-hb__cta--primary" href="{{ block.settings.cta_url }}" aria-label="{{ block.settings.cta_label | escape }}">{{ block.settings.cta_label | escape }}</a>
                {% endif %}
                {% if block.settings.cta2_label != blank and block.settings.cta2_url != blank %}
                  <a class="bfc-hb__cta bfc-hb__cta--ghost" href="{{ block.settings.cta2_url }}" aria-label="{{ block.settings.cta2_label | escape }}">{{ block.settings.cta2_label | escape }}</a>
                {% endif %}
              </div>
            </div>
            <div class="bfc-hb__media">
              {% if hb_has_image %}
                <img
                  src="{{ block.settings.image | image_url: width: 2000 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 700 }} 700w,
                    {{ block.settings.image | image_url: width: 1100 }} 1100w,
                    {{ block.settings.image | image_url: width: 1600 }} 1600w,
                    {{ block.settings.image | image_url: width: 2000 }} 2000w
                  "
                  sizes="(min-width: 990px) 55vw, 100vw"
                  alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {% else %}
                <div class="bfc-hb__placeholder" aria-hidden="true"></div>
              {% endif %}
            </div>
          </div>
          <style>
            #{{ hb_id }}{
              background: var(--hb-bg);
              color: var(--hb-fg);
              padding: var(--hb-pt) 0 var(--hb-pb);
              overflow: hidden;
            }
            #{{ hb_id }} .bfc-hb__wrap{
              display: grid;
              grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
              align-items: center;
              padding: 0 0 0 max(var(--bfc-block-pad), calc((100vw - var(--hb-max)) / 2));
            }
            #{{ hb_id }} .bfc-hb__copy{
              padding-right: clamp(32px, 5vw, 80px);
              max-width: 48ch;
            }
            #{{ hb_id }} .bfc-hb__eyebrow{
              margin: 0 0 6px;
              font-size: var(--bfc-body-size-small);
              letter-spacing: .18em;
              text-transform: uppercase;
              opacity: .6;
            }
            #{{ hb_id }} .bfc-hb__kicker{
              margin: 0 0 12px;
              font-family: var(--font-heading-family, serif);
              font-size: clamp(13px, 1.5vw, 17px);
              font-style: italic;
              letter-spacing: .02em;
              opacity: .7;
            }
            #{{ hb_id }} .bfc-hb__heading{
              font-family: var(--font-heading-family, serif);
              font-size: clamp(2.4rem, 5.5vw, 5.2rem);
              font-weight: 400;
              line-height: .98;
              letter-spacing: -0.03em;
              margin: 0 0 22px;
              color: var(--hb-fg);
            }
            #{{ hb_id }} .bfc-hb__body{
              font-size: var(--bfc-body-size);
              line-height: 1.55;
              opacity: .82;
              margin: 0 0 28px;
            }
            #{{ hb_id }} .bfc-hb__ctas{
              display: flex;
              flex-wrap: wrap;
              gap: 14px;
              align-items: center;
            }
            #{{ hb_id }} .bfc-hb__cta{
              text-decoration: none;
              font-size: var(--bfc-body-size-small);
              letter-spacing: .10em;
              text-transform: uppercase;
              display: inline-flex;
              align-items: center;
              transition: opacity .15s ease;
            }
            #{{ hb_id }} .bfc-hb__cta--primary{
              background: var(--hb-fg);
              color: var(--hb-bg);
              padding: 13px 24px;
            }
            #{{ hb_id }} .bfc-hb__cta--ghost{
              color: var(--hb-fg);
              opacity: .72;
              border-bottom: 1px solid currentColor;
              padding-bottom: 2px;
            }
            #{{ hb_id }} .bfc-hb__cta:hover{ opacity: .68; }
            #{{ hb_id }} .bfc-hb__media{
              overflow: hidden;
              background: rgba(0,0,0,.06);
              aspect-ratio: {{ block.settings.media_aspect }};
              min-height: 480px;
            }
            #{{ hb_id }} .bfc-hb__media img{
              width: 100%;
              height: 100%;
              object-fit: cover;
              display: block;
            }
            #{{ hb_id }} .bfc-hb__placeholder{
              width: 100%;
              height: 100%;
              min-height: 480px;
              background: rgba(0,0,0,.08);
            }
            @media (max-width: 900px){
              #{{ hb_id }} .bfc-hb__wrap{
                grid-template-columns: 1fr;
                padding: 0 var(--bfc-block-pad);
                gap: 32px;
              }
              #{{ hb_id }} .bfc-hb__copy{ max-width: none; padding-right: 0; }
              #{{ hb_id }} .bfc-hb__media{ min-height: 300px; }
              {% if block.settings.ignore_padding_mobile %}
                #{{ hb_id }}{ --bfc-block-pad: var(--bfc-horizontal-pad); }
              {% endif %}
            }
          </style>
        </section>
