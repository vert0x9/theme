ad,24px);border-right:1px solid #E3DDDA;background:#F0EDE5}.bfc-kb__content{padding:0 var(--bfc-align-pad,24px) 0 36px;min-width:0}.bfc-kb__crumb{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#C8C4BC;display:flex;align-items:center;gap:8px;cursor:default;padding:8px 0}.bfc-kb__crumb.is-done{color:#82906B;cursor:pointer}.bfc-kb__crumb.is-done:hover{color:#202009}.bfc-kb__crumb.is-active{color:#202009}.bfc-kb__crumb-num{width:20px;height:20px;border-radius:50%;border:1px solid currentColor;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0}.bfc-kb__crumb.is-active .bfc-kb__crumb-num{background:#202009;border-color:#202009;color:#F8F6EE}.bfc-kb__crumb.is-done .bfc-kb__crumb-num{background:#ABCC99;border-color:#ABCC99;color:#202009}@media(max-width:700px){.bfc-kb__body{grid-template-columns:1fr}.bfc-kb__sidebar{border-right:none;border-bottom:1px solid #E3DDDA;padding:20px var(--bfc-align-pad,24px)}.bfc-kb__nav-bar{flex-direction:row;flex-wrap:wrap;gap:6px}.bfc-kb__crumb-sep{display:inline;color:#D9D5CC;font-size:12px}.bfc-kb__content{padding:0 var(--bfc-align-pad,24px)}}.bfc-kb__cam-card.is-oos{opacity:.5;cursor:not-allowed}.bfc-kb__cam-oos{font-size:10px;font-weight:600;text-transform:uppercase;color:#82906B;margin-top:6px;display:block}.bfc-kb__cam-oos a{color:#E36E15;text-decoration:underline}.bfc-kb__crumb-sep{display:none}.bfc-kb__pill[hidden]{display:none!important}.bfc-kb__grp[hidden]{display:none!important}</style>
<script>(function(){
var sec=document.getElementById('{{ kb_id }}');
if(!sec) return;
var step=1;
var sel={type:null,cam:null,addons:{}};
var pendingPill=null;
function showStep(n){
step=n;
sec.querySelectorAll('.bfc-kb__step').forEach(function(el){
el.classList.toggle('is-active',parseInt(el.dataset.step)===n);
});
sec.querySelectorAll('.bfc-kb__crumb').forEach(function(el){
var s=parseInt(el.dataset.step);
el.classList.toggle('is-active', s===n);
el.classList.toggle('is-done', s<n);
el.setAttribute('aria-current', s===n ? 'step' : 'false');
el.querySelector('.bfc-kb__crumb-num').textContent=s<n?'✓':s;
});
renderDoneRows();
}
function renderDoneRows(){
var c=sec.querySelector('.bfc-kb__done-rows');
c.innerHTML='';
[[1,'Style',sel.type?{ps:'Point & Shoot',slr:'35mm SLR',pol:'Polaroid'}[sel.type]:null],
[2,'Camera',sel.cam?sel.cam.name:null],
[3,'Extras',Object.keys(sel.addons).length?Object.values(sel.addons).map(function(a){return a.name;}).join(', '):null]
].forEach(function(r){
if(r[0]>=step||!r[2])return;
var d=document.createElement('div');
d.className='bfc-kb__done-row';
d.innerHTML='<span class="bfc-kb__done-row-lbl">'+r[1]+'</span><span class="bfc-kb__done-row-val">'+r[2]+'</span>';
d.onclick=(function(s){return function(){goBack(s);};})(r[0]);
c.appendChild(d);
});
}
function goBack(n){
if(n<=1){sel.type=null;sel.cam=null;sel.addons={};}
if(n<=2){sel.cam=null;sel.addons={};}
if(n<=3){sel.addons={};}
showStep(n);
}
sec.querySelectorAll('[data-pick-style]').forEach(function(btn){
btn.onclick=function(){
sec.querySelectorAll('[data-pick-style]').forEach(function(b){b.setAttribute('aria-pressed','false');});
btn.setAttribute('aria-pressed','true');
sel.type=btn.dataset.pickStyle;
sel.cam=null; sel.addons={};
sec.querySelectorAll('.bfc-kb__cam-group').forEach(function(g){
g.hidden=g.dataset.camGroup!==sel.type;
});
showStep(2);
};
});
sec.querySelectorAll('.bfc-kb__cam-card').forEach(function(card){
if(card.dataset.camAvail==='false'){card.classList.add('is-oos');var t=card.dataset.camCamtype,b=card.querySelector('.bfc-kb__cam-body');if(b){var s=document.createElement('span');s.className='bfc-kb__cam-oos';s.innerHTML='OOS — <a href="'+(card.dataset.camOosUrl||'#')+'" onclick="event.stopPropagation()">See other →</a>';b.appendChild(s);}return;}
card.onclick=function(){
sec.querySelectorAll('.bfc-kb__cam-card').forEach(function(c){c.classList.remove('is-sel');c.setAttribute('aria-pressed','false');});
card.classList.add('is-sel');
card.setAttribute('aria-pressed','true');
sel.cam={name:card.dataset.camName,price:card.dataset.camPrice,priceRaw:parseFloat(card.dataset.camPriceRaw)||0,vid:card.dataset.camVid,format:card.dataset.camFormat,warranty:card.dataset.camWarranty,type:card.dataset.camCamtype};
filterAddons();
setTimeout(function(){showStep(3);},220);
};
});
function filterAddons(){var fmt=sel.cam?sel.cam.format:'any',type=sel.cam?sel.cam.type:'';sec.querySelectorAll('.bfc-kb__pill').forEach(function(pill){var pf=pill.dataset.addonFormat||'any',sf=(pill.dataset.addonShowFor||'').trim();var ef=sf||'ps,slr,';var fmtOk=(pf==='any'||fmt==='any'||pf===fmt);var typeOk=(!type||ef.indexOf(type+',')>=0);pill.hidden=!fmtOk||!typeOk;if(pill.hidden)pill.classList.remove('is-on');});sec.querySelectorAll('.bfc-kb__grp').forEach(function(g){var at=g.dataset.addonType;if(type==='pol'&&(at==='strap'||at==='case')){g.hidden=true;return;}g.hidden=g.querySelectorAll('.bfc-kb__pill:not([hidden])').length===0;});}
sec.querySelectorAll('.bfc-kb__pill').forEach(function(pill){
pill.querySelector('[data-info]').addEventListener('click',function(e){
e.stopPropagation();
openModal(pill);
});
