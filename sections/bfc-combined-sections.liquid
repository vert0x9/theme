            opacity: calc(var(--overlay-opacity) / 100);pointer-events:none}
          #{{ catstrip_id }} .media[data-tint]::after{
            content:"";position:absolute;inset:0;pointer-events:none;
            background: rgba(0,0,0, calc(var(--tile-tint,0)/100));
