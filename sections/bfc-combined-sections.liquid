          <style>#{{dmc_id}}{background:var(--dmc-bg);color:var(--dmc-fg);padding:var(--dmc-pt,40px) 0 var(--dmc-pb,40px);} .bfc-dmc__inner{max-width:var(--dmc-max);margin:0 auto;padding:0 var(--bfc-block-pad);display:grid;grid-template-columns:minmax(0,1.05fr) minmax(0,1fr);gap:clamp(32px,5vw,80px);align-items:center;} .bfc-dmc__inner--full{grid-template-columns:1fr;max-width:680px;} .bfc-dmc__eyebrow{margin:0 0 10px;font-size:var(--bfc-body-size-small);letter-spacing:.16em;text-transform:uppercase;opacity:.65;} .bfc-dmc__heading{margin:0 0 14px;letter-spacing:-0.02em;line-height:1.04;} .bfc-dmc__body{font-size:var(--bfc-body-size);line-height:1.6;opacity:.82;margin:0 0 24px;} .bfc-dmc__sc-wrap{margin-bottom:24px;} .bfc-dmc__sc-label{font-size:var(--bfc-body-size-small);letter-spacing:.12em;text-transform:uppercase;opacity:.65;margin:0 0 14px;} .bfc-dmc__sc-track{display:flex;align-items:center;gap:16px;margin-bottom:12px;} .bfc-dmc__sc-slider{flex:1;-webkit-appearance:none;appearance:none;height:2px;background:color-mix(in srgb,var(--dmc-fg) 20%,transparent);outline:none;cursor:pointer;border-radius:0;} .bfc-dmc__sc-slider::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:var(--dmc-fg);cursor:pointer;} .bfc-dmc__sc-slider::-moz-range-thumb{width:18px;height:18px;border-radius:50%;background:var(--dmc-fg);cursor:pointer;border:none;} .bfc-dmc__sc-count{font-size:var(--bfc-body-size-small);opacity:.55;white-space:nowrap;min-width:8ch;text-align:right;} .bfc-dmc__sc-result{display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;} .bfc-dmc__sc-save-lbl{font-size:var(--bfc-body-size-small);opacity:.65;letter-spacing:.06em;} .bfc-dmc__sc-amount{font-family:var(--font-heading-family,serif);font-size:clamp(2rem,4vw,2.8rem);font-weight:500;line-height:1;letter-spacing:-0.02em;color:var(--dmc-accent);} .bfc-dmc__sc-suffix{font-size:var(--bfc-body-size-small);opacity:.65;} .bfc-dmc__ctas{display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-bottom:14px;} .bfc-dmc__cta{text-decoration:none;font-size:var(--bfc-body-size-small);letter-spacing:.08em;text-transform:uppercase;display:inline-flex;align-items:center;transition:opacity .15s ease;} .bfc-dmc__cta--primary{background:var(--dmc-fg);color:var(--dmc-bg);padding:13px 24px;} .bfc-dmc__cta--ghost{color:var(--dmc-fg);border-bottom:1px solid currentColor;opacity:.68;padding-bottom:2px;} .bfc-dmc__cta:hover{opacity:.7;} .bfc-dmc__fine-print{margin:0;font-size:11px;opacity:.45;line-height:1.5;} .bfc-dmc__media-wrap{display:flex;align-items:stretch;height:100%;} .bfc-dmc__media{width:100%;overflow:hidden;aspect-ratio:{{block.settings.media_aspect | default:"4 / 5"}};background:rgba(0,0,0,.05);} .bfc-dmc__media img{width:100%;height:100%;object-fit:cover;display:block;}@media (max-width:900px){#{{dmc_id}}.bfc-dmc__inner,#{{dmc_id}}.bfc-dmc--flip .bfc-dmc__inner{grid-template-columns:1fr;padding:0 var(--bfc-block-pad);gap:32px;}{% if block.settings.ignore_padding_mobile %}#{{dmc_id}}{--bfc-block-pad:var(--bfc-horizontal-pad);}{% endif %}}</style>
        </section>
<script>
(function(){
document.querySelectorAll('.bfc-dmc').forEach(function(root){
var sl=root.querySelector('.bfc-dmc__sc-slider'),re=root.querySelector('.bfc-dmc__sc-rolls'),ae=root.querySelector('[id^="bfc-sc-amount"]');
if(!sl||!re||!ae)return;
function c(r){
var plan,inc;
if(r<=2){plan=18;inc=1;}
else if(r<=6){plan=45;inc=3;}
else{plan=99;inc=7;}
var without=r*20;
var with_mem=plan+Math.max(0,r-inc)*16;
re.textContent=r;
ae.textContent='$'+Math.max(0,Math.round((without-with_mem)*12));
}
sl.addEventListener('input',function(){c(+sl.value);});c(+sl.value||4);
});
})();
</script>


