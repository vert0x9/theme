          </div>
          {%- if block.settings.scroll_hint_enable -%}
            <div style="{% case block.settings.header_align %}{% when 'center' %}text-align:center{% when 'right' %}text-align:right{% else %}text-align:left{% endcase %};">
              <a class="scroll-hint" href="#after-{{ catstrip_id }}">
                {{ block.settings.scroll_hint_label }}
              </a>
            </div>
          {%- endif -%}
        </section>
        <span id="after-{{ catstrip_id }}"></span>
        <script>
          (function(){
            var link = document.querySelector('#{{ catstrip_id }} .scroll-hint');
            if (!link) return;
            link.addEventListener('click', function(e){
              var href = link.getAttribute('href');
              if (!href || href.charAt(0) !== '#') return;
              var target = document.querySelector(href);
              if (target){
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            });
          })();
        </script>
      {% when 'icon_menu' %}
        {% liquid
          assign header_align_class = 'text-left'
          if block.settings.header_align == 'center'
            assign header_align_class = 'text-center'
          elsif block.settings.header_align == 'right'
            assign header_align_class = 'text-right'
          endif
          assign icon_id = 'icon-menu-' | append: section.id | append: '-' | append: block.id
          assign icon_group = block.settings.group_id | default: block.id
          assign icon_radius = '12px'
          if block.settings.image_shape == 'circle'
            assign icon_radius = '50%'
          endif
          if block.settings.square_corners
            assign icon_radius = '0'
          endif
        %}
        {%- style -%}
          #{{ icon_id }} {
            --padding-top: {{ block.settings.padding_top }}px;
            --padding-bottom: {{ block.settings.padding_bottom }}px;
            --text-color: {{ block.settings.text_color | default: base_text }};
            --bg-color: {{ block.settings.bg_color | default: base_bg }};
            --item-gap: {{ block.settings.item_gap }}px;
            --icon-radius: {{ icon_radius }};
            --bfc-block-pad: calc(var(--bfc-align-pad) + {{ block.settings.side_padding_vw }}vw);
            background-color: var(--bg-color);
            color: var(--text-color);
            padding-top: var(--padding-top);
            padding-bottom: var(--padding-bottom);
          }
          #{{ icon_id }} .icon-menu__header {
            margin-bottom: 24px;
            padding: 0 var(--bfc-block-pad);
          }
          @media (min-width: 750px) {
            #{{ icon_id }} .icon-menu__header {
              padding: 0 var(--bfc-block-pad);
            }
          }
          @media (max-width: 749px) {
            {% if block.settings.ignore_padding_mobile %}
              #{{ icon_id }}{
                --bfc-block-pad: var(--bfc-horizontal-pad);
              }
            {% endif %}
          }
          #{{ icon_id }} .icon-menu__header h2 {
            margin: 0;
          }
          #{{ icon_id }} .icon-menu__list {
            display: grid;
            grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
            list-style: none;
            margin: 0;
            padding: 0 var(--bfc-block-pad);
            gap: var(--item-gap);
          }
          #{{ icon_id }} .icon-menu__item {
            width: 100%;
          }
          @media (min-width: 750px) {
            #{{ icon_id }} .icon-menu__list {
              grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
              padding: 0 var(--bfc-block-pad);
            }
          }
          #{{ icon_id }} .icon-menu__link {
            display: block;
            text-decoration: none;
            color: inherit;
            text-align: center;
            font-family: var(--bfc-body-family);
          }
          #{{ icon_id }} .icon-menu__link:hover .icon-menu__image {
            transform: scale(1.05);
          }
          #{{ icon_id }} .icon-menu__image-wrapper {
            position: relative;
            overflow: hidden;
            background-color: #f0f0f0;
            margin-bottom: 8px;
            border-radius: var(--icon-radius);
          }
          #{{ icon_id }} .icon-menu__image-wrapper::before {
            content: '';
            display: block;
            padding-top: 100%;
          }
          #{{ icon_id }} .icon-menu__image {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
          }
          #{{ icon_id }} .icon-menu__placeholder {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 10%;
            box-sizing: border-box;
          }
          #{{ icon_id }} .icon-menu__label {
            font-size: var(--bfc-body-size);
            font-weight: var(--bfc-body-weight);
            line-height: 1.4;
          }
        {%- endstyle -%}
        <section id="{{ icon_id }}" class="bfc-block icon-menu-section" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <div class="icon-menu__header {{ header_align_class }}">
              <h2 class="bfc-heading">{{ block.settings.title | escape }}</h2>
            </div>
          {%- endif -%}
          <ul class="icon-menu__list">
            {%- assign icon_count = 0 -%}
            {%- for item in section.blocks -%}
              {%- if item.type == 'icon_item' and item.settings.group_id == icon_group -%}
                {%- assign icon_count = icon_count | plus: 1 -%}
                <li class="icon-menu__item" {{ item.shopify_attributes }}>
                  <a href="{{ item.settings.link | default: '#' }}"
                     class="icon-menu__link">
                    <div class="icon-menu__image-wrapper">
                      {%- if item.settings.image != blank -%}
                        <img
                          src="{{ item.settings.image | image_url: width: 400 }}"
                          alt="{{ item.settings.image.alt | default: item.settings.label | escape }}"
                          class="icon-menu__image"
                          loading="lazy"
                          width="400"
                          height="400">
                      {%- else -%}
                        <div class="icon-menu__placeholder" aria-hidden="true">
                          <span aria-hidden="true">{{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}</span>
                        </div>
                      {%- endif -%}
                    </div>
                    <span class="icon-menu__label">{{ item.settings.label | escape }}</span>
                  </a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
          {%- if icon_count == 0 -%}
            <div style="text-align: center; padding: 2rem;">
              <p>Add icon items in the theme editor.</p>
            </div>
          {%- endif -%}
        </section>
      {% when 'holiday_guides' %}
        {% liquid
          assign holiday_id = 'holiday-gear-guides-' | append: section.id | append: '-' | append: block.id
          assign holiday_group = block.settings.group_id | default: block.id
          assign holiday_use_auto_group = false
          if holiday_group == 'auto'
            assign holiday_use_auto_group = true
          endif
          assign holiday_index = forloop.index0
          assign holiday_use_inline_links = block.settings.use_inline_links
          assign has_holiday_image = false
          assign holiday_media_layout = block.settings.media_layout | default: 'single'
          if block.settings.image != blank
            assign has_holiday_image = true
          endif
          assign holiday_has_grid_images = false
          if holiday_media_layout == 'grid'
            if block.settings.image_grid_1 != blank or block.settings.image_grid_2 != blank or block.settings.image_grid_3 != blank or block.settings.image_grid_4 != blank or block.settings.image_grid_5 != blank or block.settings.image_grid_6 != blank
              assign holiday_has_grid_images = true
            endif
          endif
          assign holiday_radius = block.settings.media_radius
          assign holiday_keep_side_by_side = block.settings.keep_side_by_side_mobile
          assign holiday_full_width_content = block.settings.full_width_content
          assign holiday_lock_media_fit = block.settings.lock_media_fit
          assign holiday_mobile_media_ratio = block.settings.mobile_media_ratio | default: 'third'
          assign holiday_mobile_grid_rows = block.settings.mobile_grid_rows | default: 3
          if block.settings.square_corners
            assign holiday_radius = 0
          endif
        %}
        <section
          id="{{ holiday_id }}"
          class="bfc-block hgg"
          style="
            --hgg-pt: {{ block.settings.padding_top }}px;
            --hgg-pb: {{ block.settings.padding_bottom }}px;
            --hgg-max: {{ page_width_px }}px;
            --hgg-gap: {{ block.settings.gap }}px;
            --hgg-media-ratio: {{ block.settings.media_ratio }};
            --hgg-radius: {{ holiday_radius }}px;
            --hgg-bg: {{ block.settings.bg_color }};
            --hgg-text: {{ block.settings.text_color }};
            --hgg-border: {{ block.settings.border_color }};
          "
          {{ block.shopify_attributes }}
        >
          <div class="hgg__wrap">
            <div class="hgg__grid">
              <div class="hgg__content">
                {% if block.settings.eyebrow != blank %}
                  <p class="hgg__eyebrow">{{ block.settings.eyebrow | escape }}</p>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h2 class="hgg__heading bfc-heading">{{ block.settings.heading | escape }}</h2>
                {% endif %}
                {% if block.settings.body != blank %}
                  <div class="hgg__body rte">
                    {{ block.settings.body }}
                  </div>
                {% endif %}
                {% if block.settings.show_product_grid %}
                  {% assign guide_products = block.settings.products | compact %}
                  {% if guide_products and guide_products.size > 0 %}
                    <div class="hgg__products">
                      {% for product in guide_products %}
                        {% assign grid_image = product.featured_image %}
                        <a class="hgg__product" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                          <div class="hgg__product-media">
                            {% if grid_image %}
                              <img
                                src="{{ grid_image | image_url: width: 600 }}"
                                srcset="
                                  {{ grid_image | image_url: width: 300 }} 300w,
                                  {{ grid_image | image_url: width: 450 }} 450w,
                                  {{ grid_image | image_url: width: 600 }} 600w,
                                  {{ grid_image | image_url: width: 900 }} 900w
                                "
                                sizes="(min-width: 990px) 160px, (min-width: 750px) 140px, 45vw"
                                alt="{{ grid_image.alt | default: product.title | escape }}"
                                loading="lazy"
                                width="{{ grid_image.width }}"
                                height="{{ grid_image.height }}"
                              >
                            {% else %}
                              <div class="hgg__product-placeholder" aria-hidden="true"></div>
                            {% endif %}
                          </div>
                          <div class="hgg__product-meta" aria-hidden="true">
                            <span class="hgg__product-title">{{ product.title | escape }}</span>
                            <span class="hgg__product-price">{{ product.price | money }}</span>
                          </div>
                        </a>
                      {% endfor %}
                    </div>
                  {% endif %}
                {% endif %}
                {% assign guide_count = 0 %}
                {% if holiday_use_inline_links %}
                  {% if block.settings.link_label_1 != blank %}{% assign guide_count = guide_count | plus: 1 %}{% endif %}
                  {% if block.settings.link_label_2 != blank %}{% assign guide_count = guide_count | plus: 1 %}{% endif %}
                  {% if block.settings.link_label_3 != blank %}{% assign guide_count = guide_count | plus: 1 %}{% endif %}
                {% elsif holiday_use_auto_group %}
                  {% for guide in section.blocks %}
                    {% if forloop.index0 > holiday_index %}
                      {% if guide.type == 'holiday_guides' %}
                        {% break %}
                      {% endif %}
                      {% if guide.type == 'holiday_guide_link' %}
                        {% assign guide_count = guide_count | plus: 1 %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                {% else %}
                  {% for guide in section.blocks %}
                    {% if guide.type == 'holiday_guide_link' and guide.settings.group_id == holiday_group %}
                      {% assign guide_count = guide_count | plus: 1 %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
                {% if guide_count > 0 %}
                  <ul class="hgg__links" role="list">
                    {% if holiday_use_inline_links %}
                      {% if block.settings.link_label_1 != blank %}
                        <li class="hgg__link-item">
                          {% assign link_url = block.settings.link_url_1 %}
                          {% assign link_label = block.settings.link_label_1 %}
                          {% if link_label != blank and link_url != blank %}
                            <a class="hgg__link" href="{{ link_url }}">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </a>
                          {% elsif link_label != blank %}
                            <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </span>
                          {% endif %}
                        </li>
                      {% endif %}
                      {% if block.settings.link_label_2 != blank %}
                        <li class="hgg__link-item">
                          {% assign link_url = block.settings.link_url_2 %}
                          {% assign link_label = block.settings.link_label_2 %}
                          {% if link_label != blank and link_url != blank %}
                            <a class="hgg__link" href="{{ link_url }}">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </a>
                          {% elsif link_label != blank %}
                            <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </span>
                          {% endif %}
                        </li>
                      {% endif %}
                      {% if block.settings.link_label_3 != blank %}
                        <li class="hgg__link-item">
                          {% assign link_url = block.settings.link_url_3 %}
                          {% assign link_label = block.settings.link_label_3 %}
                          {% if link_label != blank and link_url != blank %}
                            <a class="hgg__link" href="{{ link_url }}">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </a>
                          {% elsif link_label != blank %}
                            <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </span>
                          {% endif %}
                        </li>
                      {% endif %}
                    {% elsif holiday_use_auto_group %}
                      {% for guide in section.blocks %}
                        {% if forloop.index0 > holiday_index %}
                          {% if guide.type == 'holiday_guides' %}
                            {% break %}
                          {% endif %}
                          {% if guide.type == 'holiday_guide_link' %}
                            <li class="hgg__link-item" {{ guide.shopify_attributes }}>
                              {% assign link_url = guide.settings.link %}
                              {% assign link_label = guide.settings.label %}
                              {% if link_label != blank and link_url != blank %}
                                <a class="hgg__link" href="{{ link_url }}">
                                  <span class="hgg__link-text">{{ link_label | escape }}</span>
                                  <span class="hgg__arrow" aria-hidden="true">→</span>
                                </a>
                              {% elsif link_label != blank %}
                                <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                                  <span class="hgg__link-text">{{ link_label | escape }}</span>
                                  <span class="hgg__arrow" aria-hidden="true">→</span>
                                </span>
                              {% endif %}
                            </li>
                          {% endif %}
                        {% endif %}
                      {% endfor %}
                    {% else %}
                      {% for guide in section.blocks %}
                        {% if guide.type == 'holiday_guide_link' and guide.settings.group_id == holiday_group %}
                          <li class="hgg__link-item" {{ guide.shopify_attributes }}>
                            {% assign link_url = guide.settings.link %}
                            {% assign link_label = guide.settings.label %}
                            {% if link_label != blank and link_url != blank %}
                              <a class="hgg__link" href="{{ link_url }}">
                                <span class="hgg__link-text">{{ link_label | escape }}</span>
                                <span class="hgg__arrow" aria-hidden="true">→</span>
                              </a>
                            {% elsif link_label != blank %}
                              <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                                <span class="hgg__link-text">{{ link_label | escape }}</span>
                                <span class="hgg__arrow" aria-hidden="true">→</span>
                              </span>
                            {% endif %}
                          </li>
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  </ul>
                {% endif %}
              </div>
              <div class="hgg__media{% unless has_holiday_image or holiday_has_grid_images %} is-empty{% endunless %}{% if holiday_lock_media_fit %} hgg__media--contain{% endif %}">
                {% if holiday_media_layout == 'grid' %}
                  <div class="hgg__media-grid">
                    {% for i in (1..6) %}
                      {% liquid
                        assign grid_image = nil
                        case i
                          when 1
                            assign grid_image = block.settings.image_grid_1
                          when 2
                            assign grid_image = block.settings.image_grid_2
                          when 3
                            assign grid_image = block.settings.image_grid_3
                          when 4
                            assign grid_image = block.settings.image_grid_4
                          when 5
                            assign grid_image = block.settings.image_grid_5
                          when 6
                            assign grid_image = block.settings.image_grid_6
                        endcase
                      %}
                      <div class="hgg__media-grid-item">
                        {% if grid_image != blank %}
                          {{
                            grid_image
                            | image_url: width: 800
                            | image_tag:
                              widths: '320, 480, 640, 800',
                              sizes: '(min-width: 990px) 16vw, 30vw',
                              loading: 'lazy',
                              class: 'hgg__img',
                              alt: grid_image.alt | default: block.settings.heading | default: block.settings.eyebrow
                          }}
                        {% else %}
                          <div class="hgg__placeholder" aria-hidden="true"></div>
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                {% else %}
                  <div class="hgg__media-inner">
                    {% if has_holiday_image %}
                      {{
                        block.settings.image
                        | image_url: width: 2400
                        | image_tag:
                          widths: '600, 800, 1000, 1200, 1600, 2000, 2400',
                          sizes: '(min-width: 990px) 52vw, 100vw',
                          loading: 'lazy',
                          class: 'hgg__img',
                          alt: block.settings.image.alt | default: block.settings.heading | default: block.settings.eyebrow
                      }}
                    {% else %}
                      <div class="hgg__placeholder" aria-hidden="true"></div>
                    {% endif %}
                  </div>
                {% endif %}
                {% if block.settings.cta_label != blank and block.settings.cta_link != blank %}
                  <div class="hgg__cta hgg__cta--media">
                    <a class="hgg__btn" href="{{ block.settings.cta_link }}">
                      {{ block.settings.cta_label | escape }}
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
          {%- style -%}
            #{{ holiday_id }}{
              background: var(--hgg-bg);
              color: var(--hgg-text);
              padding-top: var(--hgg-pt);
              padding-bottom: var(--hgg-pb);
              --bfc-block-pad: calc(var(--bfc-align-pad) + {{ block.settings.side_padding_vw }}vw);
            }
            #{{ holiday_id }} .hgg__wrap{
              max-width: var(--hgg-max);
              margin: 0 auto;
              padding-left: var(--bfc-block-pad);
              padding-right: var(--bfc-block-pad);
            }
            #{{ holiday_id }} .hgg__grid{
              display: grid;
              grid-template-columns: minmax(280px, 1fr) minmax(320px, 1.15fr);
              gap: var(--hgg-gap);
              align-items: stretch;
            }
            #{{ holiday_id }} .hgg__content{
              max-width: 40rem;
            }
            {% if holiday_full_width_content %}
              #{{ holiday_id }} .hgg__content{
                max-width: none;
              }
            {% endif %}
            #{{ holiday_id }} .hgg__media{
              display: flex;
              flex-direction: column;
              height: 100%;
              min-height: 0;
            }
            #{{ holiday_id }} .hgg__eyebrow{
              margin: 0 0 10px;
              font-size: var(--bfc-body-size-small);
              letter-spacing: .12em;
              text-transform: uppercase;
              opacity: .85;
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__heading{
              margin: 0 0 14px;
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__body{
              margin: 0 0 18px;
              font-size: var(--bfc-body-size);
              line-height: 1.5;
              opacity: .95;
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__products{
              display: grid;
              gap: 12px;
              grid-template-columns: repeat(2, minmax(0, 1fr));
              margin-bottom: 18px;
            }
            #{{ holiday_id }} .hgg__product{
              text-decoration: none;
              color: inherit;
              display: grid;
              gap: 8px;
            }
            #{{ holiday_id }} .hgg__product-media{
              position: relative;
              background: rgba(0,0,0,0.04);
              aspect-ratio: 1 / 1;
              overflow: hidden;
            }
            #{{ holiday_id }} .hgg__product-media img{
              width: 100%;
              height: 100%;
              object-fit: cover;
              display: block;
            }
            #{{ holiday_id }} .hgg__product-placeholder{
              width: 100%;
              height: 100%;
              background: rgba(0,0,0,0.05);
            }
            #{{ holiday_id }} .hgg__product-meta{
              display: grid;
              gap: 4px;
              font-size: var(--bfc-body-size-small);
            }
            #{{ holiday_id }} .hgg__product-title{
              font-weight: var(--bfc-header-weight);
              font-size: var(--bfc-body-size-small);
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__product-price{
              opacity: 0.8;
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__links{
              margin: 0;
              padding: 0;
              list-style: none;
              border-top: 1px solid var(--hgg-border);
            }
            #{{ holiday_id }} .hgg__link-item{
              margin: 0;
              padding: 0;
              border-bottom: 1px solid var(--hgg-border);
            }
            #{{ holiday_id }} .hgg__link{
              display: flex;
              align-items: center;
              justify-content: space-between;
              gap: 14px;
              padding: 14px 0;
              text-decoration: none;
              color: inherit;
              font-size: var(--bfc-body-size);
              line-height: 1.2;
              transition: opacity .15s ease, transform .15s ease;
            }
            #{{ holiday_id }} .hgg__link:hover{
              opacity: .85;
            }
            #{{ holiday_id }} .hgg__link:focus-visible{
              outline: 2px solid currentColor;
              outline-offset: 4px;
            }
            #{{ holiday_id }} .hgg__arrow{
              flex: 0 0 auto;
              font-size: 1.1em;
              transform: translateY(-1px);
            }
            #{{ holiday_id }} .hgg__cta{
              margin-top: 18px;
            }
            #{{ holiday_id }} .hgg__cta--media{
              margin-top: auto;
            }
            #{{ holiday_id }} .hgg__btn{
              display: inline-flex;
              align-items: center;
              gap: 6px;
              text-decoration: underline;
              text-underline-offset: 0.15em;
              color: inherit;
              font-size: var(--bfc-body-size);
            }
            #{{ holiday_id }} .hgg__media-inner{
              position: relative;
              overflow: hidden;
              border-radius: var(--hgg-radius);
              flex: 1 1 0;
              min-height: 0;
              background: rgba(0,0,0,.06);
            }
            #{{ holiday_id }} .hgg__img{
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
              object-fit: cover;
              display: block;
            }
            #{{ holiday_id }} .hgg__placeholder{
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
            }
            #{{ holiday_id }} .hgg__media--contain .hgg__media-inner,
            #{{ holiday_id }} .hgg__media--contain .hgg__media-grid-item{
              background: var(--hgg-bg);
              padding: 10px;
            }
            #{{ holiday_id }} .hgg__media--contain .hgg__img{
              object-fit: contain;
              inset: 10px;
              width: calc(100% - 20px);
              height: calc(100% - 20px);
            }
            #{{ holiday_id }} .hgg__media--contain .hgg__placeholder{
              inset: 10px;
              width: calc(100% - 20px);
              height: calc(100% - 20px);
            }
            #{{ holiday_id }} .hgg__media-grid{
              display: grid;
              grid-template-columns: repeat(3, minmax(0, 1fr));
              grid-auto-rows: 1fr;
              gap: 12px;
              flex: 1 1 0;
              min-height: 0;
            }
            #{{ holiday_id }} .hgg__media-grid-item{
              position: relative;
              overflow: hidden;
              border-radius: var(--hgg-radius);
              background: rgba(0,0,0,.06);
              min-height: 0;
            }
            #{{ holiday_id }} .hgg__media-grid-item .hgg__img,
            #{{ holiday_id }} .hgg__media-grid-item .hgg__placeholder{
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
            }
            @media (min-width: 990px){
              #{{ holiday_id }}{
                --hgg-bleed: clamp(0px, calc((100vw - var(--hgg-max)) / 2), 120px);
              }
              #{{ holiday_id }} .hgg__media{
                margin-right: calc(-1 * var(--hgg-bleed));
              }
              #{{ holiday_id }} .hgg__media-inner,
              #{{ holiday_id }} .hgg__media-grid{
                width: calc(100% + var(--hgg-bleed));
              }
            }
            @media (min-width: 1440px){
              #{{ holiday_id }} .hgg__media{
                margin-right: 0;
              }
              #{{ holiday_id }} .hgg__media-inner,
              #{{ holiday_id }} .hgg__media-grid{
                width: 100%;
              }
            }
            @media (max-width: 989px){
              {% if block.settings.ignore_padding_mobile %}
                #{{ holiday_id }}{
                  --bfc-block-pad: var(--bfc-horizontal-pad);
                }
              {% endif %}
              #{{ holiday_id }} .hgg__wrap{
                padding-right: var(--bfc-block-pad);
              }
              {% unless holiday_keep_side_by_side %}
                #{{ holiday_id }} .hgg__grid{
                  grid-template-columns: 1fr;
                }
                #{{ holiday_id }} .hgg__media{
                  order: -1;
                }
                #{{ holiday_id }} .hgg__content{
                  max-width: none;
                }
              {% else %}
                #{{ holiday_id }} .hgg__grid{
                  {% if holiday_mobile_media_ratio == 'half' %}
                    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
                  {% else %}
                    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
                  {% endif %}
                  gap: calc(var(--hgg-gap) * 0.6);
                }
                #{{ holiday_id }} .hgg__heading{
                  font-size: var(--bfc-header-size-mobile);
                }
                #{{ holiday_id }} .hgg__body,
                #{{ holiday_id }} .hgg__link,
                #{{ holiday_id }} .hgg__btn{
                  font-size: var(--bfc-body-size-small);
                }
                #{{ holiday_id }} .hgg__media-grid{
                  grid-template-columns: 1fr;
                  gap: 8px;
                }
                #{{ holiday_id }} .hgg__media-grid-item:nth-child(n+{{ holiday_mobile_grid_rows | plus: 1 }}){
                  display: none;
                }
              {% endunless %}
            }
          {%- endstyle -%}
        </section>
      {% when 'new_arrivals' %}
        {% assign items_to_show = block.settings.items_to_show | default: 12 %}
        {% assign initial_items = block.settings.initial_items | default: 12 %}
        {% assign anchor_id = block.settings.anchor_id | strip | default: 'new-arrivals' %}
        {% assign manual_products = block.settings.manual_products | compact %}
        {% assign has_manual = false %}
        {% if manual_products and manual_products.size > 0 %}
          {% assign has_manual = true %}
        {% endif %}
        {% assign selected_collection = block.settings.collection %}
        {% assign has_single_collection = false %}
        {% if selected_collection %}
          {% assign has_single_collection = true %}
        {% endif %}
        {% assign use_newest_from_collection = block.settings.use_newest_from_collection %}
        {% assign full_rows_only = block.settings.full_rows_only %}
        {% assign full_rows_columns_desktop = block.settings.full_rows_columns_desktop | default: 5 %}
        {% assign disable_see_more = block.settings.disable_see_more %}
        {% assign products_to_render = nil %}
        {% assign source_type = '' %}
        {% if has_manual %}
          {% assign products_to_render = manual_products %}
          {% assign source_type = 'products' %}
        {% elsif has_single_collection %}
          {% if use_newest_from_collection %}
            {% assign products_to_render = selected_collection.products | sort: 'created_at' | reverse %}
          {% else %}
            {% assign products_to_render = selected_collection.products %}
          {% endif %}
          {% assign source_type = 'products' %}
        {% else %}
          {% assign product_handles_string = ',' %}
          {% assign product_counter = 0 %}
          {% assign arrivals_group = block.settings.group_id | default: block.id %}
          {% for source in section.blocks %}
            {% if product_counter >= items_to_show %}
              {% break %}
            {% endif %}
            {% if source.type == 'collection_source' and source.settings.group_id == arrivals_group %}
              {% if source.settings.collection %}
                {% assign collection_products = source.settings.collection.products %}
                {% for product in collection_products %}
                  {% if product_counter >= items_to_show %}
                    {% break %}
                  {% endif %}
                  {% assign token = ',' | append: product.handle | append: ',' %}
                  {% unless product_handles_string contains token %}
                    {% assign product_handles_string = product_handles_string | append: product.handle | append: ',' %}
                    {% assign product_counter = product_counter | plus: 1 %}
                  {% endunless %}
                {% endfor %}
              {% endif %}
            {% endif %}
          {% endfor %}
          {% assign products_to_render = product_handles_string | split: ',' | uniq | compact %}
          {% assign source_type = 'handles' %}
        {% endif %}
        {% assign render_limit = items_to_show %}
        {% if full_rows_only %}
          {% assign remainder = render_limit | modulo: full_rows_columns_desktop %}
          {% if remainder != 0 and render_limit > full_rows_columns_desktop %}
            {% assign render_limit = render_limit | minus: remainder %}
          {% endif %}
        {% endif %}
        {% if initial_items > render_limit %}
          {% assign initial_items = render_limit %}
        {% endif %}
        {% if disable_see_more %}
          {% assign initial_items = render_limit %}
        {% endif %}
        {% assign arrivals_radius = block.settings.product_radius %}
        {% if block.settings.square_corners %}
          {% assign arrivals_radius = 0 %}
        {% endif %}
        <section
          id="{{ anchor_id }}"
          class="bfc-block bfc-new-arrivals"
          aria-label="New arrivals"
          {{ block.shopify_attributes }}
        >
          <div class="new-arrivals-inner">
            {% if block.settings.heading != blank %}
              <h2 class="section-heading bfc-heading">{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="section-text rte">
                {{ block.settings.text }}
              </div>
            {% endif %}
            {% assign total_products = products_to_render | size | default: 0 %}
            {% if products_to_render and total_products > 0 %}
              <div class="grid" id="{{ anchor_id }}-grid" role="list">
                {% assign product_index = 0 %}
                {% if source_type == 'products' %}
                  {% for product in products_to_render limit: render_limit %}
                    {% if product == blank %}
                      {% continue %}
                    {% endif %}
                    {% assign product_index = product_index | plus: 1 %}
                    {% assign image = product.featured_image %}
                    {% assign selected_variant = product.selected_or_first_available_variant %}
                    <div
                      class="product-card{% if product_index > initial_items %} product-card--hidden{% endif %}"
                      data-index="{{ product_index }}"
                      role="listitem"
                    >
                      <a href="{{ product.url }}" class="product-link" aria-label="{{ product.title | escape }}">
                        <div class="product-image-wrapper">
                          {% if image %}
                            <img
                              src="{{ image | image_url: width: 800 }}"
                              alt="{{ product.title | escape }}"
                              loading="lazy"
                              class="product-image"
                              width="{{ image.width }}"
                              height="{{ image.height }}"
                            >
                          {% else %}
                            <div class="placeholder" aria-hidden="true">No image available</div>
                          {% endif %}
                        </div>
                        {% if block.settings.info_display == 'below' %}
                          <div class="product-info below">
                            <p class="product-title">{{ product.title }}</p>
                            <p class="product-price">{{ product.price | money }}</p>
                          </div>
                        {% endif %}
                        {% if block.settings.info_display == 'hover' %}
                          <div class="product-info hover" aria-hidden="true">
                            <p class="product-title">{{ product.title }}</p>
                            <p class="product-price">{{ product.price | money }}</p>
                          </div>
                        {% endif %}
                      </a>
                      {% if selected_variant %}
                        <form method="post" action="{{ routes.cart_add_url }}" class="quick-add-form" aria-label="Add {{ product.title | escape }} to cart">
                          <input type="hidden" name="id" value="{{ selected_variant.id }}">
                          <input type="hidden" name="quantity" value="1">
                          <button type="submit" class="quick-add-button" {% unless product.available %}disabled aria-disabled="true"{% endunless %}>
                            <span aria-hidden="true">+</span>
                            <span class="visually-hidden">Add {{ product.title | escape }} to cart</span>
                          </button>
                        </form>
                      {% endif %}
                    </div>
                  {% endfor %}
                {% else %}
                  {% assign rendered_count = 0 %}
                  {% for handle in products_to_render %}
                    {% if rendered_count >= render_limit %}
                      {% break %}
                    {% endif %}
                    {% if handle == '' %}
                      {% continue %}
                    {% endif %}
                    {% assign product = all_products[handle] %}
                    {% if product %}
                      {% assign rendered_count = rendered_count | plus: 1 %}
                      {% assign product_index = product_index | plus: 1 %}
                      {% assign image = product.featured_image %}
                      {% assign selected_variant = product.selected_or_first_available_variant %}
                      <div
                        class="product-card{% if product_index > initial_items %} product-card--hidden{% endif %}"
                        data-index="{{ product_index }}"
                        role="listitem"
                      >
                        <a href="{{ product.url }}" class="product-link" aria-label="{{ product.title | escape }}">
                          <div class="product-image-wrapper">
                            {% if image %}
                              <img
                                src="{{ image | image_url: width: 800 }}"
                                alt="{{ product.title | escape }}"
                                loading="lazy"
                                class="product-image"
                                width="{{ image.width }}"
                                height="{{ image.height }}"
                              >
                            {% else %}
                              <div class="placeholder" aria-hidden="true">No image available</div>
                            {% endif %}
                          </div>
                          {% if block.settings.info_display == 'below' %}
                            <div class="product-info below">
                              <p class="product-title">{{ product.title }}</p>
                              <p class="product-price">{{ product.price | money }}</p>
                            </div>
                          {% endif %}
                          {% if block.settings.info_display == 'hover' %}
                            <div class="product-info hover" aria-hidden="true">
                              <p class="product-title">{{ product.title }}</p>
                              <p class="product-price">{{ product.price | money }}</p>
                            </div>
                          {% endif %}
                        </a>
                        {% if selected_variant %}
                          <form method="post" action="{{ routes.cart_add_url }}" class="quick-add-form" aria-label="Add {{ product.title | escape }} to cart">
                            <input type="hidden" name="id" value="{{ selected_variant.id }}">
                            <input type="hidden" name="quantity" value="1">
                            <button type="submit" class="quick-add-button" {% unless product.available %}disabled aria-disabled="true"{% endunless %}>
                              <span aria-hidden="true">+</span>
                              <span class="visually-hidden">Add {{ product.title | escape }} to cart</span>
                            </button>
                          </form>
                        {% endif %}
                      </div>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>
              {% if disable_see_more == false %}
                {% if product_index > initial_items or block.settings.show_back_to_top %}
                  <div class="show-more-wrapper">
                    <div class="show-more-controls">
                      {% if product_index > initial_items %}
                        <button type="button" class="show-more-button" data-show-more aria-expanded="false" aria-controls="{{ anchor_id }}-grid">
                          {{ block.settings.show_more_label | default: 'Display more' }}
                        </button>
                        <button type="button" class="collapse-button" data-collapse style="display: none;" aria-expanded="true" aria-controls="{{ anchor_id }}-grid">
                          {{ block.settings.collapse_label | default: 'Collapse' }}
                        </button>
                      {% endif %}
                    </div>
                    {% if block.settings.show_back_to_top %}
                      <button type="button" class="back-to-top-button" data-back-to-top>
                        {{ block.settings.back_to_top_label | default: 'Back to top' }}
                      </button>
                    {% endif %}
                  </div>
                {% endif %}
              {% endif %}
            {% endif %}
            {% if block.settings.button_text != blank and block.settings.button_link != blank %}
              <div class="cta-wrapper">
                <a href="{{ block.settings.button_link }}" class="cta-button">{{ block.settings.button_text }}</a>
              </div>
            {% endif %}
          </div>
          {% style %}
            #{{ anchor_id }}{
              --bg: {{ block.settings.background_color }};
              --text: {{ block.settings.text_color }};
              --radius: {{ arrivals_radius }}px;
              --bfc-block-pad: calc(var(--bfc-align-pad) + {{ block.settings.side_padding_vw }}vw);
              color: var(--text);
              background: var(--bg);
              padding: {{ block.settings.padding_top }}px var(--bfc-block-pad) {{ block.settings.padding_bottom }}px;
            }
            #{{ anchor_id }} .new-arrivals-inner {
              margin: 0 auto;
            }
            #{{ anchor_id }} .section-heading {
              margin: 0 0 18px;
              max-width: {{ block.settings.header_max_width | default: 820 }}px;
              width: 100%;
            }
            #{{ anchor_id }} .section-text {
              max-width: {{ block.settings.text_max_width | default: 820 }}px;
              margin: 0 auto 28px;
            }
            {% case block.settings.header_text_align %}
              {% when 'left' %}
                #{{ anchor_id }} .section-heading { text-align: left; margin-left: 0; margin-right: auto; }
              {% when 'right' %}
                #{{ anchor_id }} .section-heading { text-align: right; margin-left: auto; margin-right: 0; }
              {% else %}
                #{{ anchor_id }} .section-heading { text-align: center; margin-left: auto; margin-right: auto; }
            {% endcase %}
            {% case block.settings.text_align %}
              {% when 'left' %}
                #{{ anchor_id }} .section-text { text-align: left; margin-left: 0; margin-right: auto; }
              {% when 'right' %}
                #{{ anchor_id }} .section-text { text-align: right; margin-left: auto; margin-right: 0; }
              {% else %}
                #{{ anchor_id }} .section-text { text-align: center; margin-left: auto; margin-right: auto; }
            {% endcase %}
            #{{ anchor_id }} .grid {
              display: grid;
              gap: 16px;
              {% if full_rows_only %}
                grid-template-columns: repeat({{ full_rows_columns_desktop }}, minmax(0, 1fr));
              {% else %}
                grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
              {% endif %}
            }
            @media (max-width: 768px) {
              {% if block.settings.ignore_padding_mobile %}
                #{{ anchor_id }}{
                  --bfc-block-pad: var(--bfc-horizontal-pad);
                }
              {% endif %}
              #{{ anchor_id }} .grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
              }
            }
            #{{ anchor_id }} .product-card {
              position: relative;
              overflow: hidden;
              background: #fff;
              border-radius: var(--radius);
              transition: transform 0.2s ease;
            }
            #{{ anchor_id }} .product-card:hover { transform: translateY(-4px); }
            {% if disable_see_more %}
              #{{ anchor_id }} .product-card.product-card--hidden { display: block; }
            {% else %}
              #{{ anchor_id }} .product-card.product-card--hidden { display: none; }
            {% endif %}
            #{{ anchor_id }} .product-link {
              display: flex;
              flex-direction: column;
              height: 100%;
              text-decoration: none;
              color: inherit;
            }
            #{{ anchor_id }} .product-image-wrapper {
              position: relative;
              padding-top: 100%;
              background: #f9f9f9;
              overflow: hidden;
              border-top-left-radius: var(--radius);
              border-top-right-radius: var(--radius);
            }
            #{{ anchor_id }} .product-image {
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
              object-fit: contain;
            }
            #{{ anchor_id }} .placeholder {
              position: absolute;
              top: 50%;
              left: 50%;
              transform: translate(-50%, -50%);
              text-align: center;
              color: #666;
              font-size: var(--bfc-body-size-small);
            }
            #{{ anchor_id }} .product-info {
              padding: 12px;
              text-align: center;
              background: #fff;
              transition: opacity 0.2s ease, transform 0.2s ease;
              font-size: var(--bfc-body-size);
            }
            #{{ anchor_id }} .product-info.hover {
              position: absolute;
              left: 0;
              right: 0;
              bottom: 0;
              opacity: 0;
              transform: translateY(8px);
              background: rgba(255, 255, 255, 0.95);
            }
            #{{ anchor_id }} .product-card:hover .product-info.hover {
              opacity: 1;
              transform: translateY(0);
            }
            #{{ anchor_id }} .product-title {
              margin: 0 0 4px;
              font-size: var(--bfc-body-size);
              font-weight: var(--bfc-header-weight);
              letter-spacing: 0.02em;
            }
            #{{ anchor_id }} .product-price {
              margin: 0;
              font-size: var(--bfc-body-size-small);
              color: #444;
            }
            #{{ anchor_id }} .product-info.below { border-top: 0; }
            #{{ anchor_id }} .cta-wrapper { text-align: center; margin-top: 32px; }
            #{{ anchor_id }} .cta-button {
              display: inline-block;
              padding: 12px 36px;
              background: #000;
              color: #fff;
              text-decoration: none;
              letter-spacing: 0.1em;
              font-size: var(--bfc-body-size-small);
              border-radius: var(--radius);
              transition: opacity 0.2s ease;
            }
            #{{ anchor_id }} .cta-button:hover { opacity: 0.85; }
            #{{ anchor_id }} .quick-add-form {
              position: absolute;
              bottom: 8px;
              right: 8px;
              z-index: 2;
            }
            #{{ anchor_id }} .quick-add-button {
              min-width: 24px;
              min-height: 24px;
              border-radius: 0;
              border: none;
              background: transparent;
              color: #111;
              font-size: 20px;
              line-height: 1;
              display: inline-flex;
              align-items: center;
              justify-content: center;
              cursor: pointer;
              padding: 0;
              box-shadow: none;
              transition: color 0.15s ease, transform 0.15s ease;
            }
            #{{ anchor_id }} .quick-add-button:focus-visible { outline: 1px solid currentColor; outline-offset: 2px; }
            #{{ anchor_id }} .quick-add-button:hover { color: #000; transform: translateY(-1px); }
            #{{ anchor_id }} .quick-add-button:disabled { cursor: not-allowed; opacity: 0.45; }
            #{{ anchor_id }} .visually-hidden {
              position: absolute;
              width: 1px;
              height: 1px;
              padding: 0;
              margin: -1px;
              overflow: hidden;
              clip: rect(0, 0, 0, 0);
              white-space: nowrap;
              border: 0;
            }
            #{{ anchor_id }} .show-more-wrapper {
              margin-top: 24px;
              display: flex;
              align-items: center;
              justify-content: space-between;
              gap: 12px;
              flex-wrap: wrap;
            }
            #{{ anchor_id }} .show-more-controls {
              display: flex;
              align-items: center;
              gap: 10px;
            }
            #{{ anchor_id }} .show-more-button,
            #{{ anchor_id }} .collapse-button,
            #{{ anchor_id }} .back-to-top-button {
              padding: 10px 32px;
              border-radius: var(--radius);
              border: 1px solid #111;
              background: #fff;
              font-size: var(--bfc-body-size-small);
              letter-spacing: 0.08em;
              text-transform: uppercase;
              cursor: pointer;
              transition: background-color 0.15s ease, color 0.15s ease;
            }
            #{{ anchor_id }} .show-more-button:hover,
            #{{ anchor_id }} .collapse-button:hover,
            #{{ anchor_id }} .back-to-top-button:hover {
              background: #111;
              color: #fff;
            }
            #{{ anchor_id }} .collapse-button,
            #{{ anchor_id }} .back-to-top-button {
              font-size: var(--bfc-body-size-small);
              padding: 8px 20px;
              opacity: 0.9;
            }
            @media (max-width: 600px) {
              #{{ anchor_id }} .show-more-wrapper { flex-direction: column; align-items: center; }
            }
          {% endstyle %}
          <script>
            (function() {
              var root = document.getElementById('{{ anchor_id }}');
              if (!root) return;
              var initialItems = {{ initial_items | json }};
              var disableSeeMore = {{ disable_see_more | json }};
              root.addEventListener('submit', function(event) {
                var form = event.target;
                if (!form.classList || !form.classList.contains('quick-add-form')) return;
                event.preventDefault();
                var button = form.querySelector('button');
                if (button) {
                  button.disabled = true;
                  button.setAttribute('aria-busy', 'true');
                }
                var formData = new FormData(form);
                if (!formData.get('quantity')) {
                  formData.append('quantity', '1');
                }
                var body = new URLSearchParams(formData).toString();
                fetch('{{ routes.cart_add_url }}.js', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest'
                  },
                  body: body,
                  credentials: 'same-origin'
                })
                  .then(function(res) {
                    if (!res.ok) throw new Error('Add to cart failed');
                    return res.json();
                  })
                  .then(function() {
                    return fetch('/cart/update.js', {
                      method: 'POST',
                      headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                      },
                      body: JSON.stringify({
                        updates: {},
                        sections: ['cart-drawer', 'cart-icon-bubble'],
                        sections_url: window.location.pathname
                      }),
                      credentials: 'same-origin'
                    });
                  })
                  .then(function(res) {
                    if (!res.ok) throw new Error('Cart update fetch failed');
                    return res.json();
                  })
                  .then(function(state) {
                    var drawer = document.querySelector('cart-drawer');
                    if (drawer && typeof drawer.renderContents === 'function') drawer.renderContents(state);
                    if (drawer && typeof drawer.open === 'function') drawer.open();
                  })
                  .catch(function(error) {
                    console.error('Quick add failed', error);
                  })
                  .finally(function() {
                    if (button) {
                      button.disabled = false;
                      button.removeAttribute('aria-busy');
                    }
                  });
              });
              if (disableSeeMore) return;
              var showMoreBtn = root.querySelector('[data-show-more]');
              var collapseBtn = root.querySelector('[data-collapse]');
              if (showMoreBtn && collapseBtn) {
                showMoreBtn.addEventListener('click', function() {
                  var cards = root.querySelectorAll('.product-card');
                  for (var i = 0; i < cards.length; i++) {
                    var idx = parseInt(cards[i].getAttribute('data-index'), 10) || 0;
                    if (idx > initialItems) {
                      cards[i].classList.remove('product-card--hidden');
                      cards[i].style.display = '';
                    }
                  }
                  showMoreBtn.setAttribute('aria-expanded', 'true');
                  showMoreBtn.style.display = 'none';
                  collapseBtn.setAttribute('aria-expanded', 'true');
                  collapseBtn.style.display = 'inline-block';
                });
                collapseBtn.addEventListener('click', function() {
                  var cards = root.querySelectorAll('.product-card');
                  for (var i = 0; i < cards.length; i++) {
                    var idx = parseInt(cards[i].getAttribute('data-index'), 10) || 0;
                    if (idx > initialItems) {
                      cards[i].classList.add('product-card--hidden');
                      cards[i].style.display = 'none';
                    } else {
                      cards[i].classList.remove('product-card--hidden');
                      cards[i].style.display = '';
                    }
                  }
                  collapseBtn.setAttribute('aria-expanded', 'false');
                  collapseBtn.style.display = 'none';
                  showMoreBtn.setAttribute('aria-expanded', 'false');
                  showMoreBtn.style.display = 'inline-block';
                  root.scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
              }
              var backToTopBtn = root.querySelector('[data-back-to-top]');
              if (backToTopBtn) {
                backToTopBtn.addEventListener('click', function() {
                  window.scrollTo({ top: 0, behavior: 'smooth' });
                });
              }
            })();
          </script>
