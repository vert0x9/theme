
{% liquid
  assign base_text = section.settings.text_color | default: '#111111'
  assign base_bg = section.settings.background_color | default: '#ffffff'
  assign page_width_px = settings.page_width | default: 1200
  assign horizontal_pad = section.settings.horizontal_padding | default: 24
  assign header_size_mobile = section.settings.header_font_size_mobile | default: 1.8
  assign header_size_desktop = section.settings.header_font_size_desktop | default: 2.2
  assign header_weight = section.settings.header_font_weight | default: 600
  assign body_weight = section.settings.body_font_weight | default: 400
  assign body_size = section.settings.body_font_size | default: 16
  assign body_size_small = section.settings.body_font_size_small | default: 12
%}
<section id="bfc-combined-{{ section.id }}" class="bfc-combined" aria-label="{{ section.settings.section_label | default: 'Main content sections' }}">
  <style>
    #bfc-combined-{{ section.id }}{
      --bfc-header-family: var(--font-heading-family, inherit);
      --bfc-body-family: var(--font-body-family, inherit);
      --bfc-header-weight: {{ header_weight }};
      --bfc-body-weight: {{ body_weight }};
      --bfc-header-size-mobile: {{ header_size_mobile }}rem;
      --bfc-header-size-desktop: {{ header_size_desktop }}rem;
      --bfc-horizontal-pad: {{ horizontal_pad }}px;
      --bfc-page-width: {{ page_width_px }}px;
      --bfc-align-pad: clamp(
        var(--bfc-horizontal-pad),
        calc((100vw - min(100vw, var(--bfc-page-width))) / 2 + var(--bfc-horizontal-pad)),
        120px
      );
      --bfc-body-size: {{ body_size }}px;
      --bfc-body-size-small: {{ body_size_small }}px;
      --bfc-text: {{ base_text }};
      --bfc-bg: {{ base_bg }};
      color: var(--bfc-text);
      background: var(--bfc-bg);
      font-family: var(--bfc-body-family);
      font-weight: var(--bfc-body-weight);
      font-size: var(--bfc-body-size);
    }
    #bfc-combined-{{ section.id }} .bfc-heading{
      font-family: var(--bfc-header-family);
      font-weight: var(--bfc-header-weight);
      font-size: var(--bfc-header-size-mobile);
      line-height: 1.2;
      margin: 0;
    }
    @media (min-width: 750px){
      #bfc-combined-{{ section.id }} .bfc-heading{
        font-size: var(--bfc-header-size-desktop);
      }
    }
    #bfc-combined-{{ section.id }} .bfc-block{
      margin: 0 auto;
    }
    #bfc-combined-{{ section.id }} .bfc-block + .bfc-block{
      margin-top: 24px;
    }
    #bfc-combined-{{ section.id }} .visually-hidden{
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }
    #bfc-combined-{{ section.id }} a:focus-visible,
    #bfc-combined-{{ section.id }} button:focus-visible,
    #bfc-combined-{{ section.id }} input:focus-visible{
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }
    @media (prefers-reduced-motion: reduce){
      #bfc-combined-{{ section.id }} *{
        animation-duration: .01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: .01ms !important;
      }
    }
  </style>
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'top_sellers' %}
        {% liquid
          assign heading = block.settings.heading | default: 'Top Sellers'
          assign collection = block.settings.collection
          assign limit = block.settings.products_limit | default: 12
          assign section_pad_y = block.settings.section_padding_y | default: 28
          assign block_id = 'bfc-top-sellers-' | append: section.id | append: '-' | append: block.id
          assign ts_radius = 18
          assign ts_mobile_limit = block.settings.mobile_limit_enabled
          assign ts_mobile_limit_count = block.settings.mobile_show_count
          if block.settings.square_corners
            assign ts_radius = 0
          endif
        %}
        <section
          id="{{ block_id }}"
          class="bfc-block bfc-ts"
          aria-label="{{ heading | escape }}"
          style="
            --bfc-ts-page-width: {{ page_width_px }}px;
            --bfc-block-pad: calc(var(--bfc-align-pad) + {{ block.settings.side_padding_vw }}vw);
            --bfc-ts-gutter: var(--bfc-block-pad);
            --bfc-ts-pad-y: {{ section_pad_y }}px;
            --bfc-ts-radius: {{ ts_radius }}px;
          "
          {{ block.shopify_attributes }}
        >
          <div class="bfc-ts__header">
            <div class="bfc-ts__header-row">
              {% if heading != blank %}
                <h2 class="bfc-ts__title bfc-heading">{{ heading | escape }}</h2>
              {% endif %}
              {% if block.settings.show_view_all and collection != blank %}
                <a class="bfc-ts__viewall" href="{{ collection.url }}">
                  {{ block.settings.view_all_label | default: 'Shop all' | escape }}
                </a>
              {% endif %}
            </div>
            {% if block.settings.subheading != blank %}
              <p class="bfc-ts__subheading">{{ block.settings.subheading | escape }}</p>
            {% endif %}
          </div>
          <div class="bfc-ts__rail-wrap" data-bfc-ts>
            {% if block.settings.show_arrows %}
              <button
                class="bfc-ts__arrow bfc-ts__arrow--prev"
                type="button"
                aria-label="Scroll left"
                data-bfc-ts-prev
              >
                ‹
              </button>
              <button
                class="bfc-ts__arrow bfc-ts__arrow--next"
                type="button"
                aria-label="Scroll right"
                data-bfc-ts-next
              >
                ›
              </button>
            {% endif %}
            <div class="bfc-ts__rail" role="list" data-bfc-ts-rail>
              {% if collection != blank %}
                {% assign ts_exclude_handles = block.settings.exclude_handles | remove: ' ' | downcase | split: ',' %}
                {% for product in collection.products limit: limit %}
                  {% if block.settings.hide_oos and product.available == false %}
                    {% continue %}
                  {% endif %}
                  {% if ts_exclude_handles.size > 0 %}
                    {% assign ts_product_handle = product.handle | downcase %}
                    {% if ts_exclude_handles contains ts_product_handle %}
                      {% continue %}
                    {% endif %}
                  {% endif %}
                  {% liquid
                    assign variant = product.selected_or_first_available_variant
                    assign tags_down = product.tags | join: ',' | downcase
                    assign badge = ''
                    assign custom_text = ''
                    if block.settings.enable_badges
                      assign badge_tags_1 = block.settings.badge_tag_1 | downcase | split: ','
                      assign badge_tags_2 = block.settings.badge_tag_2 | downcase | split: ','
                      assign badge_tags_3 = block.settings.badge_tag_3 | downcase | split: ','
                      if badge == ''
                        for tag in badge_tags_1
                          assign clean_tag = tag | strip
                          if clean_tag != '' and tags_down contains clean_tag
                            assign badge = block.settings.badge_label_1
                            break
                          endif
                        endfor
                      endif
                      if badge == ''
                        for tag in badge_tags_2
                          assign clean_tag = tag | strip
                          if clean_tag != '' and tags_down contains clean_tag
                            assign badge = block.settings.badge_label_2
                            break
                          endif
                        endfor
                      endif
                      if badge == ''
                        for tag in badge_tags_3
                          assign clean_tag = tag | strip
                          if clean_tag != '' and tags_down contains clean_tag
                            assign badge = block.settings.badge_label_3
                            break
                          endif
                        endfor
                      endif
                    endif
                    if block.settings.show_custom_text
                      if block.settings.custom_text_use_tags
                        assign custom_text_tags_1 = block.settings.custom_text_tag_1 | downcase | split: ','
                        assign custom_text_tags_2 = block.settings.custom_text_tag_2 | downcase | split: ','
                        assign custom_text_tags_3 = block.settings.custom_text_tag_3 | downcase | split: ','
                        if custom_text == ''
                          for tag in custom_text_tags_1
                            assign clean_tag = tag | strip
                            if clean_tag != '' and tags_down contains clean_tag
                              assign custom_text = block.settings.custom_text_label_1
                              break
                            endif
                          endfor
                        endif
                        if custom_text == ''
                          for tag in custom_text_tags_2
                            assign clean_tag = tag | strip
                            if clean_tag != '' and tags_down contains clean_tag
                              assign custom_text = block.settings.custom_text_label_2
                              break
                            endif
                          endfor
                        endif
                        if custom_text == ''
                          for tag in custom_text_tags_3
                            assign clean_tag = tag | strip
                            if clean_tag != '' and tags_down contains clean_tag
                              assign custom_text = block.settings.custom_text_label_3
                              break
                            endif
                          endfor
                        endif
                      endif
                      if custom_text == ''
                        assign custom_text = block.settings.custom_text
                      endif
                    endif
                  %}
                  <article class="bfc-ts__card" role="listitem">
                    <a class="bfc-ts__img" href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1" aria-hidden="true">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 720 }}"
                          srcset="
                            {{ product.featured_image | image_url: width: 360 }} 360w,
                            {{ product.featured_image | image_url: width: 540 }} 540w,
                            {{ product.featured_image | image_url: width: 720 }} 720w
                          "
                          sizes="(min-width: 990px) 260px, 70vw"
                          alt=""
                          loading="lazy"
                          width="{{ product.featured_image.width }}"
                          height="{{ product.featured_image.height }}"
                        >
                      {% else %}
                        <span aria-hidden="true">{{ 'product-1' | placeholder_svg_tag: 'bfc-ts__placeholder' }}</span>
                      {% endif %}
                      {% if badge != blank %}
                        <span class="bfc-ts__badge" aria-hidden="true">{{ badge }}</span>
                      {% endif %}
                    </a>
                    <div class="bfc-ts__meta">
                      {% if block.settings.show_vendor and product.vendor != blank %}
                        <div class="bfc-ts__vendor">{{ product.vendor | escape }}</div>
                      {% endif %}
                      {% if block.settings.show_custom_text and custom_text != blank %}
                        <div class="bfc-ts__vendor">{{ custom_text | escape }}</div>
                      {% endif %}
                      <a class="bfc-ts__name" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                        {{ product.title | escape }}
                      </a>
                      <div class="bfc-ts__subline">
                        {% if block.settings.show_stock %}
                          <span class="bfc-ts__stock">
                            {% if product.available %}In stock{% else %}Sold out{% endif %}
                          </span>
                        {% endif %}
                        {% if block.settings.show_variant_count %}
                          <span class="bfc-ts__dot" aria-hidden="true">•</span>
                          <span class="bfc-ts__variants">
                            {{ product.variants.size }} option{% if product.variants.size != 1 %}s{% endif %}
                          </span>
                        {% endif %}
                      </div>
                      <div class="bfc-ts__bottom">
                        {% if block.settings.show_price %}
                          <div class="bfc-ts__price">
                            {% if product.compare_at_price_max > product.price %}
                              <span class="bfc-ts__price-now">{{ product.price | money }}</span>
                              <span class="bfc-ts__price-was">{{ product.compare_at_price_max | money }}</span>
                            {% else %}
                              <span class="bfc-ts__price-now">{{ product.price | money }}</span>
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if block.settings.show_quick_add %}
                          {% if block.settings.show_two_variant_adds %}
                            {% assign variant_one = product.variants[0] %}
                            {% assign variant_two = product.variants[1] %}
                            {% if variant_one and variant_two %}
                              <form class="bfc-ts__add" method="post" action="{{ routes.cart_add_url }}" aria-label="Add {{ variant_one.title | escape }} to cart">
                                <input type="hidden" name="id" value="{{ variant_one.id }}">
                                <input type="hidden" name="quantity" value="1">
                                <button
                                  type="submit"
                                  class="bfc-ts__add-btn"
                                  {% unless variant_one.available %}disabled aria-disabled="true"{% endunless %}
                                >
                                  {{ block.settings.variant_add_label | default: 'Add' | escape }} {{ variant_one.title | escape }}
                                </button>
                              </form>
                              <form class="bfc-ts__add" method="post" action="{{ routes.cart_add_url }}" aria-label="Add {{ variant_two.title | escape }} to cart">
                                <input type="hidden" name="id" value="{{ variant_two.id }}">
                                <input type="hidden" name="quantity" value="1">
                                <button
                                  type="submit"
                                  class="bfc-ts__add-btn"
                                  {% unless variant_two.available %}disabled aria-disabled="true"{% endunless %}
                                >
                                  {{ block.settings.variant_add_label | default: 'Add' | escape }} {{ variant_two.title | escape }}
                                </button>
                              </form>
                            {% else %}
                              <form class="bfc-ts__add" method="post" action="{{ routes.cart_add_url }}" aria-label="Add {{ product.title | escape }} to cart">
                                <input type="hidden" name="id" value="{{ variant.id }}">
                                <input type="hidden" name="quantity" value="1">
                                <button
                                  type="submit"
                                  class="bfc-ts__add-btn"
                                  {% unless product.available %}disabled aria-disabled="true"{% endunless %}
                                >
                                  {{ block.settings.add_label | default: 'Add' | escape }}
                                </button>
                              </form>
                            {% endif %}
                          {% else %}
                            <form class="bfc-ts__add" method="post" action="{{ routes.cart_add_url }}" aria-label="Add {{ product.title | escape }} to cart">
                              <input type="hidden" name="id" value="{{ variant.id }}">
                              <input type="hidden" name="quantity" value="1">
                              <button
                                type="submit"
                                class="bfc-ts__add-btn"
                                {% unless product.available %}disabled aria-disabled="true"{% endunless %}
                              >
                                {{ block.settings.add_label | default: 'Add' | escape }}
                              </button>
                            </form>
                          {% endif %}
                        {% endif %}
                      </div>
                    </div>
                  </article>
                {% endfor %}
              {% else %}
                {% for i in (1..6) %}
                  <article class="bfc-ts__card" role="listitem" aria-hidden="true">
                    <div class="bfc-ts__img">
                      <span aria-hidden="true">{{ 'product-1' | placeholder_svg_tag: 'bfc-ts__placeholder' }}</span>
                    </div>
                    <div class="bfc-ts__meta">
                      <div class="bfc-ts__vendor">Vendor</div>
                      {% if block.settings.show_custom_text and block.settings.custom_text != blank %}
                        <div class="bfc-ts__vendor">{{ block.settings.custom_text | escape }}</div>
                      {% endif %}
                      <div class="bfc-ts__name">Choose a collection in the section settings</div>
                      <div class="bfc-ts__bottom">
                        <div class="bfc-ts__price"><span class="bfc-ts__price-now">$0</span></div>
                        <button class="bfc-ts__add-btn" type="button" disabled>Add</button>
                      </div>
                    </div>
                  </article>
                {% endfor %}
              {% endif %}
            </div>
            {% if block.settings.edge_fade %}
              <span class="bfc-ts__fade bfc-ts__fade--left" aria-hidden="true"></span>
              <span class="bfc-ts__fade bfc-ts__fade--right" aria-hidden="true"></span>
            {% endif %}
          </div>
          <style>
            #{{ block_id }}{
              --bfc-ts-fg: var(--bfc-text);
              --bfc-ts-bg: var(--bfc-bg);
              --bfc-ts-border: color-mix(in srgb, var(--bfc-ts-fg) 12%, transparent);
              --bfc-ts-muted: color-mix(in srgb, var(--bfc-ts-fg) 65%, transparent);
              color: var(--bfc-ts-fg);
              background: transparent;
              padding: var(--bfc-ts-pad-y) 0;
            }
            #{{ block_id }} .bfc-ts__header{
              width: min(calc(100% - (2 * var(--bfc-ts-gutter))), var(--bfc-ts-page-width));
              max-width: var(--bfc-ts-page-width);
              margin-left: var(--bfc-ts-gutter);
              margin-right: var(--bfc-ts-gutter);
              padding: 0;
            }
            #{{ block_id }} .bfc-ts__header-row{
              display: flex;
              align-items: baseline;
              justify-content: space-between;
              gap: 16px;
            }
            #{{ block_id }} .bfc-ts__title{
              margin: 0;
              letter-spacing: -0.02em;
            }
            #{{ block_id }} .bfc-ts__viewall{
              color: var(--bfc-ts-fg);
              text-decoration: none;
              font-size: var(--bfc-body-size-small);
              opacity: .85;
            }
            #{{ block_id }} .bfc-ts__viewall:hover{ opacity: 1; text-decoration: underline; }
            #{{ block_id }} .bfc-ts__subheading{
              margin: 10px 0 0;
              color: var(--bfc-ts-muted);
              font-size: var(--bfc-body-size);
              line-height: 1.35;
              max-width: 70ch;
            }
            #{{ block_id }} .bfc-ts__rail-wrap{
              position: relative;
              margin-top: 14px;
              width: 100vw;
              margin-left: calc(50% - 50vw);
              margin-right: calc(50% - 50vw);
              --bfc-ts-left-pad: var(--bfc-block-pad);
            }
            #{{ block_id }} .bfc-ts__rail{
              display: grid;
              grid-auto-flow: column;
              grid-auto-columns: clamp(220px, 24vw, 280px);
              gap: 16px;
              overflow-x: auto;
              overscroll-behavior-x: contain;
              scroll-snap-type: x mandatory;
              scroll-padding-left: var(--bfc-ts-left-pad);
              padding-left: var(--bfc-ts-left-pad);
              padding-right: 0;
              padding-top: 6px;
              padding-bottom: 8px;
              -webkit-overflow-scrolling: touch;
            }
            #{{ block_id }} .bfc-ts__rail{
              scrollbar-width: none;
            }
            #{{ block_id }} .bfc-ts__rail::-webkit-scrollbar{ display: none; }
            #{{ block_id }} .bfc-ts__card{
              scroll-snap-align: start;
              scroll-snap-stop: always;
              background: var(--bfc-ts-bg);
              border: 0;
              border-radius: var(--bfc-ts-radius);
              overflow: hidden;
              display: grid;
              grid-template-rows: auto 1fr;
              min-height: 100%;
            }
            #{{ block_id }} .bfc-ts__img{
              position: relative;
              display: block;
              aspect-ratio: 4 / 3;
              background: color-mix(in srgb, var(--bfc-ts-fg) 6%, transparent);
              overflow: hidden;
              text-decoration: none;
            }
            #{{ block_id }} .bfc-ts__img img{
              width: 100%;
              height: 100%;
              object-fit: cover;
              display: block;
              transform: scale(1);
              transition: transform .25s ease;
            }
            #{{ block_id }} .bfc-ts__card:hover .bfc-ts__img img{
              transform: scale(1.03);
            }
            #{{ block_id }} .bfc-ts__badge{
              position: absolute;
              left: 12px;
              top: 12px;
              font-size: 12px;
              line-height: 1;
              padding: 7px 9px;
              border-radius: var(--bfc-ts-radius);
              background: rgba(0,0,0,.72);
              color: #fff;
              backdrop-filter: blur(6px);
            }
            #{{ block_id }} .bfc-ts__meta{
              padding: 12px 12px 14px;
              display: grid;
              gap: 8px;
            }
            #{{ block_id }} .bfc-ts__vendor{
              font-size: var(--bfc-body-size-small);
              color: var(--bfc-ts-muted);
              text-transform: uppercase;
              letter-spacing: .06em;
            }
            #{{ block_id }} .bfc-ts__name{
              color: var(--bfc-ts-fg);
              text-decoration: none;
              font-size: var(--bfc-body-size);
              line-height: 1.25;
              font-weight: var(--bfc-header-weight);
              letter-spacing: -0.01em;
            }
            #{{ block_id }} .bfc-ts__name:hover{ text-decoration: underline; }
            #{{ block_id }} .bfc-ts__subline{
              display: flex;
              align-items: center;
              gap: 8px;
              color: var(--bfc-ts-muted);
              font-size: var(--bfc-body-size-small);
            }
            #{{ block_id }} .bfc-ts__dot{ opacity: .7; }
            #{{ block_id }} .bfc-ts__bottom{
              margin-top: 4px;
              display: flex;
              align-items: center;
              justify-content: space-between;
              gap: 10px;
            }
            #{{ block_id }} .bfc-ts__price{
              display: flex;
              align-items: baseline;
              gap: 8px;
              min-height: 18px;
            }
            #{{ block_id }} .bfc-ts__price-now{
              font-size: var(--bfc-body-size);
              font-weight: var(--bfc-header-weight);
            }
            #{{ block_id }} .bfc-ts__price-was{
              font-size: var(--bfc-body-size-small);
              color: var(--bfc-ts-muted);
              text-decoration: line-through;
            }
            #{{ block_id }} .bfc-ts__add{ margin: 0; }
            #{{ block_id }} .bfc-ts__add-btn{
              appearance: none;
              border: 0;
              background: transparent;
              color: var(--bfc-ts-fg);
              border-radius: var(--bfc-ts-radius);
              padding: 9px 12px;
              font-size: var(--bfc-body-size-small);
              line-height: 1;
              cursor: pointer;
              transition: background .18s ease, opacity .18s ease;
              white-space: nowrap;
            }
            #{{ block_id }} .bfc-ts__add-btn:hover{
              background: color-mix(in srgb, var(--bfc-ts-fg) 7%, transparent);
            }
            #{{ block_id }} .bfc-ts__add-btn[disabled]{
              opacity: .45;
              cursor: not-allowed;
            }
            #{{ block_id }} .bfc-ts__arrow{
              position: absolute;
              top: 50%;
              transform: translateY(-50%);
              z-index: 3;
              width: 40px;
              height: 40px;
              border-radius: var(--bfc-ts-radius);
              border: 1px solid var(--bfc-ts-border);
              background: rgba(255,255,255,.86);
              backdrop-filter: blur(6px);
              cursor: pointer;
              display: none;
              align-items: center;
              justify-content: center;
              font-size: 22px;
              line-height: 1;
              color: var(--bfc-ts-fg);
            }
            #{{ block_id }} .bfc-ts__arrow--prev{ left: 10px; }
            #{{ block_id }} .bfc-ts__arrow--next{ right: 10px; }
            @media (min-width: 990px){
              #{{ block_id }} .bfc-ts__arrow{ display: flex; }
              #{{ block_id }} .bfc-ts__rail{ padding-bottom: 10px; }
            }
            #{{ block_id }} .bfc-ts__fade{
              position: absolute;
              top: 0;
              bottom: 0;
              width: 44px;
              z-index: 2;
              pointer-events: none;
            }
            #{{ block_id }} .bfc-ts__fade--left{
              left: 0;
              background: linear-gradient(to right, rgba(255,255,255,1), rgba(255,255,255,0));
            }
            #{{ block_id }} .bfc-ts__fade--right{
              right: 0;
              background: linear-gradient(to left, rgba(255,255,255,1), rgba(255,255,255,0));
            }
            @media (max-width: 749px){
              #{{ block_id }} .bfc-ts__rail{
                grid-auto-columns: 78vw;
                gap: 12px;
              }
              {% if block.settings.ignore_padding_mobile %}
                #{{ block_id }}{
                  --bfc-block-pad: var(--bfc-horizontal-pad);
                  --bfc-ts-gutter: var(--bfc-block-pad);
                }
              {% endif %}
              {% if ts_mobile_limit %}
                #{{ block_id }} .bfc-ts__card:nth-child(n+{{ ts_mobile_limit_count | plus: 1 }}){ display:none; }
              {% endif %}
            }
          </style>
          <script>
            (function () {
              const root = document.querySelector('#{{ block_id }} [data-bfc-ts]');
              if (!root) return;
              const rail = root.querySelector('[data-bfc-ts-rail]');
              const prev = root.querySelector('[data-bfc-ts-prev]');
              const next = root.querySelector('[data-bfc-ts-next]');
              if (!rail) return;
              const prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
              const behavior = prefersReduced ? 'auto' : 'smooth';
              function scrollByAmount(dir) {
                const amount = Math.max(240, Math.floor(rail.clientWidth * 0.85));
                rail.scrollBy({ left: dir * amount, behavior });
              }
              function updateArrows() {
                if (!prev || !next) return;
                const max = rail.scrollWidth - rail.clientWidth - 2;
                prev.disabled = rail.scrollLeft <= 2;
                next.disabled = rail.scrollLeft >= max;
                prev.style.opacity = prev.disabled ? '0.35' : '1';
                next.style.opacity = next.disabled ? '0.35' : '1';
              }
              if (prev) prev.addEventListener('click', () => scrollByAmount(-1));
              if (next) next.addEventListener('click', () => scrollByAmount(1));
              root.addEventListener('submit', function(event) {
                const form = event.target;
                if (!form.classList || !form.classList.contains('bfc-ts__add')) return;
                event.preventDefault();
                const button = form.querySelector('button');
                if (button) {
                  button.disabled = true;
                  button.setAttribute('aria-busy', 'true');
                }
                const formData = new FormData(form);
                if (!formData.get('quantity')) {
                  formData.append('quantity', '1');
                }
                const body = new URLSearchParams(formData).toString();
                fetch('{{ routes.cart_add_url }}.js', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest'
                  },
                  body: body,
                  credentials: 'same-origin'
                })
                  .then(function(res) {
                    if (!res.ok) throw new Error('Add to cart failed');
                    return res.json();
                  })
                  .then(function() {
                    return fetch('/cart/update.js', {
                      method: 'POST',
                      headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                      },
                      body: JSON.stringify({
                        updates: {},
                        sections: ['cart-drawer', 'cart-icon-bubble'],
                        sections_url: window.location.pathname
                      }),
                      credentials: 'same-origin'
                    });
                  })
                  .then(function(res) {
                    if (!res.ok) throw new Error('Cart update fetch failed');
                    return res.json();
                  })
                  .then(function(state) {
                    const drawer = document.querySelector('cart-drawer');
                    if (drawer && typeof drawer.renderContents === 'function') drawer.renderContents(state);
                    if (drawer && typeof drawer.open === 'function') drawer.open();
                  })
                  .catch(function(error) {
                    console.error('Quick add failed', error);
                  })
                  .finally(function() {
                    if (button) {
                      button.disabled = false;
                      button.removeAttribute('aria-busy');
                    }
                  });
              });
              rail.addEventListener('scroll', () => window.requestAnimationFrame(updateArrows), { passive: true });
              window.addEventListener('resize', () => window.requestAnimationFrame(updateArrows));
              updateArrows();
            })();
          </script>
        </section>
      {% when 'category_strip' %}
