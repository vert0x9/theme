          #{{ catstrip_id }} .title{ font-family: var(--bfc-body-family); font-weight: var(--title-font-weight); letter-spacing:.2px; }
          #{{ catstrip_id }} .subtitle{ font-size: var(--bfc-body-size-small);opacity:.78;line-height:1.35; }
          #{{ catstrip_id }} .badge{
