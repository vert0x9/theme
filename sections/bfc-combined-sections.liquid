            font-style: normal;
            font-size: var(--bfc-header-size-mobile);
            margin:0;
            line-height:1.15;
            border: none;
          }
          #{{ catstrip_id }} .subhead{
            font-family: var(--bfc-body-family);
            font-size: var(--bfc-body-size); line-height:1.55; opacity:.85; margin:0;
          }
          #{{ catstrip_id }} .header-divider{
