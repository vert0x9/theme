{% comment %}
  ============================================================
  BFC KIT BUILDER — sections/kit-builder.liquid
  ============================================================
  SETUP:
  1. Upload to sections/
  2. Create a page and assign template page.kit-builder
  3. Search VARIANT_ID and swap in real Shopify variant IDs

  GALLERY METAFIELDS:
  Reads custom.gallery_1 / custom.gallery_2 / custom.gallery_3
  from each product. As long as those metafields exist the popup
  will pull them automatically — no manual URL copying needed.

  WARRANTY:  Point & Shoot = 3 month  |  SLR + Polaroid = 6 month
  ============================================================
{% endcomment %}

{%- comment -%}
  ── LIQUID: Pre-load gallery metafields for every camera product.
  We output a JS object so the runtime JS can reference them without
  additional fetch calls. Adjust handles if products are renamed.
{%- endcomment -%}
<script>
window.BFC_GALLERIES = {
  {%- assign cam_handles = 'canon-wp-1,olympus-stylus-mjui,olympus-xa-2-flash,minolta-freedom-zoom,pentax-k1000,canon-ae-1-program,nikon-f3,polaroid-600-rainbow-stripe,polaroid-go-gen-2-black' | split: ',' -%}
  {%- assign cam_ids     = 'cam-wp1,cam-mju,cam-xa2,cam-min,cam-k1000,cam-ae1,cam-f3,cam-p600,cam-go'                                                                                             | split: ',' -%}
  {%- for handle in cam_handles -%}
    {%- assign p = all_products[handle] -%}
    "{{ cam_ids[forloop.index0] }}": [
      "{%- if p.metafields.custom.gallery_1 != blank -%}{{ p.metafields.custom.gallery_1 | image_url: width: 900 }}{%- endif -%}",
      "{%- if p.metafields.custom.gallery_2 != blank -%}{{ p.metafields.custom.gallery_2 | image_url: width: 900 }}{%- endif -%}",
      "{%- if p.metafields.custom.gallery_3 != blank -%}{{ p.metafields.custom.gallery_3 | image_url: width: 900 }}{%- endif -%}"
    ]{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
};
</script>

<div class="bfc-kb" id="bfc-kb">

  {%- comment -%} ── HERO ── {%- endcomment -%}
  <div class="bfc-kb__hero">
    <div class="bfc-kb__hero-inner">
      <div class="bfc-kb__eyebrow">
        <span class="bfc-kb__eyebrow-line"></span>
        {{ section.settings.eyebrow | default: "Don't know what to get? Start here." }}
      </div>
      <h1 class="bfc-kb__hero-title">
        {{ section.settings.headline | default: "Find your first" }}<br>
        <em>{{ section.settings.headline_em | default: "film camera." }}</em>
      </h1>
      <p class="bfc-kb__hero-sub">
        {{ section.settings.subtext | default: "Answer three quick questions — we'll put together a kit built around how you actually want to shoot. Every camera is professionally restored and backed by our warranty." }}
      </p>
    </div>
    <div class="bfc-kb__trust">
      <div class="bfc-kb__trust-item">
        <span class="bfc-kb__trust-num">3–6</span>
        <span class="bfc-kb__trust-label">Month warranty on every camera</span>
      </div>
      <div class="bfc-kb__trust-divider"></div>
      <div class="bfc-kb__trust-item">
        <span class="bfc-kb__trust-num">Free</span>
        <span class="bfc-kb__trust-label">US shipping on orders over ${{ section.settings.free_shipping_threshold | default: 200 }}</span>
      </div>
      <div class="bfc-kb__trust-divider"></div>
      <div class="bfc-kb__trust-item">
        <span class="bfc-kb__trust-num">100%</span>
        <span class="bfc-kb__trust-label">Film tested before every sale</span>
      </div>
    </div>
  </div>

  {%- comment -%} ── STEP 1: CAMERA TYPE ── {%- endcomment -%}
  <div class="bfc-kb__section bfc-kb__section--visible" id="kb-sec-type">
    <div class="bfc-kb__sec-head">
      <div class="bfc-kb__sec-label"><span class="bfc-kb__sec-label-line"></span>Your shooting style</div>
      <h2 class="bfc-kb__sec-h">How do you want <em>to shoot?</em></h2>
    </div>
    <div class="bfc-kb__type-row">
      <button class="bfc-kb__type-card" data-type="ps" aria-pressed="false">
        <span class="bfc-kb__type-tag">Beginner Friendly</span>
        <span class="bfc-kb__type-name">Point &amp; Shoot</span>
        <span class="bfc-kb__type-desc">Auto everything — just raise and press. Great results without any learning curve.</span>
        <span class="bfc-kb__type-ideal">Best for travel, parties, everyday carry</span>
        <span class="bfc-kb__type-check" aria-hidden="true"></span>
      </button>
      <button class="bfc-kb__type-card" data-type="slr" aria-pressed="false">
        <span class="bfc-kb__type-tag">Full Control</span>
        <span class="bfc-kb__type-name">35mm SLR</span>
        <span class="bfc-kb__type-desc">Manual aperture, shutter, focus. The camera serious photographers learn on.</span>
        <span class="bfc-kb__type-ideal">Best for learning, portraits, artistic work</span>
        <span class="bfc-kb__type-check" aria-hidden="true"></span>
      </button>
      <button class="bfc-kb__type-card" data-type="pol" aria-pressed="false">
        <span class="bfc-kb__type-tag">Instant Prints</span>
        <span class="bfc-kb__type-name">Polaroid</span>
        <span class="bfc-kb__type-desc">Watch your photo develop in your hands. A physical memory the moment it's taken.</span>
        <span class="bfc-kb__type-ideal">Best for events, gifts, instant memories</span>
        <span class="bfc-kb__type-check" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  {%- comment -%} ── STEP 2: CAMERA PICKER ── {%- endcomment -%}
  <div class="bfc-kb__section" id="kb-sec-cam" aria-live="polite">
    <div class="bfc-kb__sec-head">
      <div class="bfc-kb__sec-label">
        <span class="bfc-kb__sec-label-line"></span>
        <span id="kb-cam-label">Choose your camera</span>
      </div>
      <h2 class="bfc-kb__sec-h">Pick your <em>camera</em></h2>
      <p class="bfc-kb__sec-sub">Tap a camera to select it. Hit the <strong>i</strong> button to see sample shots, full specs, and what comes in the box.</p>
    </div>
    <div class="bfc-kb__cam-grid" id="kb-cam-grid" role="radiogroup" aria-label="Choose a camera"></div>
  </div>

  {%- comment -%} ── STEP 3: FILM ── {%- endcomment -%}
  <div class="bfc-kb__section" id="kb-sec-film" aria-live="polite">
    <div class="bfc-kb__sec-head">
      <div class="bfc-kb__sec-label"><span class="bfc-kb__sec-label-line"></span>Film — optional</div>
      <h2 class="bfc-kb__sec-h">Load up <em>your first rolls</em></h2>
    </div>

    <div class="bfc-kb__film-rec">
      <div class="bfc-kb__film-rec-label">
        <span class="bfc-kb__film-rec-dot"></span>Our recommendation for beginners
      </div>
      <p class="bfc-kb__film-rec-text">
        Start with one roll of color and one of black &amp; white. Shooting both is the fastest way to find your style. We suggest <strong>Kodak Gold 200</strong> for color — warm, forgiving, and beautiful in natural light — and <strong>Ilford HP5</strong> for black &amp; white, a timeless classic that works in almost any situation.
      </p>
      <button class="bfc-kb__film-rec-btn" id="kb-film-rec-apply" type="button">
        Add both recommended rolls
      </button>
    </div>

    <div class="bfc-kb__addon-group">
      <div class="bfc-kb__addon-group-label">
        Color Film <span class="bfc-kb__addon-optional">Select one</span>
      </div>
      <div class="bfc-kb__addon-row" id="kb-film-color-row"></div>
    </div>

    <div class="bfc-kb__addon-group">
      <div class="bfc-kb__addon-group-label">
        Black &amp; White Film <span class="bfc-kb__addon-optional">Select one</span>
      </div>
      <div class="bfc-kb__addon-row" id="kb-film-bw-row"></div>
    </div>

    <div class="bfc-kb__film-nav">
      <button class="bfc-kb__btn bfc-kb__btn--primary" id="kb-film-continue" type="button">Continue to accessories</button>
      <button class="bfc-kb__skip-btn" id="kb-skip-film" type="button">Skip — no film for now</button>
    </div>
  </div>

  {%- comment -%} ── STEP 4: ACCESSORIES ── {%- endcomment -%}
  <div class="bfc-kb__section" id="kb-sec-add" aria-live="polite">
    <div class="bfc-kb__sec-head">
      <div class="bfc-kb__sec-label"><span class="bfc-kb__sec-label-line"></span>Accessories — optional</div>
      <h2 class="bfc-kb__sec-h">Round out <em>your kit</em></h2>
      <p class="bfc-kb__sec-sub">Tap to add, tap again to remove.</p>
    </div>
    <div id="kb-addon-strap" class="bfc-kb__addon-group"></div>
    <div id="kb-addon-case" class="bfc-kb__addon-group"></div>
    <div class="bfc-kb__skip-row">
      <button class="bfc-kb__btn bfc-kb__btn--primary" id="kb-acc-continue" type="button">Review my kit</button>
      <button class="bfc-kb__skip-btn" id="kb-skip-add" type="button">Skip accessories</button>
    </div>
  </div>

  {%- comment -%} ── STEP 5: REVIEW ── {%- endcomment -%}
  <div class="bfc-kb__section" id="kb-sec-review" aria-live="polite">
    <div class="bfc-kb__sec-head">
      <div class="bfc-kb__sec-label"><span class="bfc-kb__sec-label-line"></span>Your kit</div>
      <h2 class="bfc-kb__sec-h">Ready to <em>shoot.</em></h2>
    </div>
    <div class="bfc-kb__review-grid" id="kb-review-grid"></div>
    <div class="bfc-kb__review-total" id="kb-review-total"></div>
    <div style="height:56px"></div>
  </div>

</div>

{%- comment -%} ── CAMERA INFO MODAL ── {%- endcomment -%}
<div class="bfc-kb__modal-overlay" id="kb-modal-overlay" aria-hidden="true">
  <div class="bfc-kb__modal" role="dialog" aria-modal="true" aria-labelledby="kb-modal-title">
    <button class="bfc-kb__modal-close" id="kb-modal-close" type="button" aria-label="Close">&#215;</button>
    <div class="bfc-kb__modal-body" id="kb-modal-body"></div>
  </div>
</div>

{%- comment -%} ── STICKY BAR ── {%- endcomment -%}
<div class="bfc-kb__sticky" id="kb-sticky" hidden>
  <div class="bfc-kb__sticky-items" id="kb-sticky-items"></div>
  <div class="bfc-kb__sticky-right">
    <span class="bfc-kb__sticky-total">$<span id="kb-sticky-price">0</span></span>
    <button class="bfc-kb__btn bfc-kb__btn--primary" id="kb-sticky-cta" type="button">Continue</button>
  </div>
</div>

<style>
.bfc-kb *, .bfc-kb *::before, .bfc-kb *::after { box-sizing: border-box; }
.bfc-kb button { font-family: inherit; cursor: pointer; }
.bfc-kb { background: #F8F6EE; color: #202009; font-family: 'Poppins', sans-serif; }

/* ── HERO ── */
.bfc-kb__hero { background: #202009; padding: 64px 72px 60px; display: grid; grid-template-columns: 1fr auto; gap: 64px; align-items: center; }
.bfc-kb__eyebrow { display: flex; align-items: center; gap: 14px; font-size: 12px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; color: #E36E15; margin-bottom: 20px; }
.bfc-kb__eyebrow-line { display: inline-block; width: 28px; height: 1px; background: #E36E15; flex-shrink: 0; }
.bfc-kb__hero-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(48px, 6vw, 82px); font-weight: 300; line-height: .94; letter-spacing: -.02em; color: #F8F6EE; margin: 0; }
.bfc-kb__hero-title em { font-style: italic; color: #F4A027; }
.bfc-kb__hero-sub { margin-top: 22px; font-size: 15px; color: #6a6850; line-height: 1.7; max-width: 500px; }
.bfc-kb__trust { display: flex; flex-direction: column; border-left: 1px solid #2e2d1a; padding-left: 52px; min-width: 200px; }
.bfc-kb__trust-item { padding: 20px 0; border-bottom: 1px solid #2e2d1a; }
.bfc-kb__trust-item:last-child { border-bottom: none; }
.bfc-kb__trust-num { display: block; font-family: 'Cormorant Garamond', serif; font-size: 42px; font-weight: 300; color: #F4A027; line-height: 1; }
.bfc-kb__trust-label { display: block; font-size: 13px; color: #6a6850; margin-top: 4px; max-width: 200px; line-height: 1.4; }
.bfc-kb__trust-divider { display: none; }

/* ── SECTIONS ── */
.bfc-kb__section { padding: 56px 72px 0; opacity: 0; transform: translateY(14px); transition: opacity .38s ease, transform .38s ease; pointer-events: none; max-height: 0; overflow: hidden; }
.bfc-kb__section--visible { opacity: 1; transform: none; pointer-events: all; max-height: none; overflow: visible; }
.bfc-kb__sec-head { margin-bottom: 28px; }
.bfc-kb__sec-label { display: flex; align-items: center; gap: 12px; font-size: 12px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: #E36E15; margin-bottom: 10px; }
.bfc-kb__sec-label-line { display: inline-block; width: 18px; height: 1px; background: #E36E15; flex-shrink: 0; }
.bfc-kb__sec-h { font-family: 'Cormorant Garamond', serif; font-size: clamp(34px, 4vw, 52px); font-weight: 300; letter-spacing: -.01em; line-height: 1; color: #202009; margin: 0 0 10px; }
.bfc-kb__sec-h em { font-style: italic; color: #4E4741; }
.bfc-kb__sec-sub { font-size: 14px; color: #82906B; line-height: 1.65; max-width: 540px; margin: 0; }

/* ── TYPE CARDS ── */
.bfc-kb__type-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: #E3DDDA; outline: 2px solid #E3DDDA; }
.bfc-kb__type-card { background: #F8F6EE; border: none; border-bottom: 3px solid transparent; padding: 28px 26px 24px; text-align: left; display: flex; flex-direction: column; transition: background .15s, border-color .15s; cursor: pointer; }
.bfc-kb__type-card:hover { background: #f0ede4; }
.bfc-kb__type-card[aria-pressed="true"] { background: #202009; border-bottom-color: #E36E15; }
.bfc-kb__type-tag { display: block; font-size: 11px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: #E36E15; margin-bottom: 10px; }
.bfc-kb__type-name { display: block; font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 400; color: #202009; line-height: 1.1; margin-bottom: 12px; transition: color .15s; }
.bfc-kb__type-card[aria-pressed="true"] .bfc-kb__type-name { color: #F8F6EE; }
.bfc-kb__type-desc { display: block; font-size: 13px; color: #4E4741; line-height: 1.6; transition: color .15s; }
.bfc-kb__type-card[aria-pressed="true"] .bfc-kb__type-desc { color: #6a6850; }
.bfc-kb__type-ideal { display: block; font-size: 12px; color: #82906B; margin-top: 14px; padding-top: 14px; border-top: 1px solid #E3DDDA; transition: border-color .15s; }
.bfc-kb__type-card[aria-pressed="true"] .bfc-kb__type-ideal { border-top-color: #2e2d1a; }
.bfc-kb__type-check { display: inline-block; width: 18px; height: 18px; border: 1.5px solid #E3DDDA; margin-top: 14px; font-size: 10px; text-align: center; line-height: 16px; color: transparent; transition: all .15s; }
.bfc-kb__type-card[aria-pressed="true"] .bfc-kb__type-check { background: #E36E15; border-color: #E36E15; color: #F8F6EE; }
.bfc-kb__type-card[aria-pressed="true"] .bfc-kb__type-check::before { content: '✓'; }

/* ── CAMERA GRID ── */
.bfc-kb__cam-grid { display: grid; gap: 2px; background: #E3DDDA; outline: 2px solid #E3DDDA; }
.bfc-kb__cam-card { background: #F8F6EE; border: none; border-bottom: 3px solid transparent; cursor: pointer; text-align: left; display: flex; flex-direction: column; padding: 0; transition: background .15s, border-color .15s; position: relative; }
.bfc-kb__cam-card:hover { background: #f0ede4; }
.bfc-kb__cam-card[aria-checked="true"] { background: #202009; border-bottom-color: #E36E15; }
.bfc-kb__cam-img { aspect-ratio: 1; background: #eeebe3; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; transition: background .15s; }
.bfc-kb__cam-card[aria-checked="true"] .bfc-kb__cam-img { background: #19190a; }
.bfc-kb__cam-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .22s ease; }
.bfc-kb__cam-card:hover .bfc-kb__cam-img img { transform: scale(1.04); }
.bfc-kb__cam-body { padding: 16px 18px 20px; flex: 1; display: flex; flex-direction: column; border-top: 1px solid #E3DDDA; transition: border-color .15s; }
.bfc-kb__cam-card[aria-checked="true"] .bfc-kb__cam-body { border-top-color: #2e2d1a; }
.bfc-kb__cam-tag { font-size: 11px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #E36E15; margin-bottom: 6px; }
.bfc-kb__cam-name { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 400; color: #202009; line-height: 1.2; margin-bottom: 5px; transition: color .15s; }
.bfc-kb__cam-card[aria-checked="true"] .bfc-kb__cam-name { color: #F8F6EE; }
.bfc-kb__cam-detail { font-size: 12px; color: #4E4741; line-height: 1.5; flex: 1; transition: color .15s; }
.bfc-kb__cam-card[aria-checked="true"] .bfc-kb__cam-detail { color: #6a6850; }
.bfc-kb__cam-price { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 400; color: #202009; margin-top: 14px; transition: color .15s; }
.bfc-kb__cam-card[aria-checked="true"] .bfc-kb__cam-price { color: #F4A027; }

/* Info button */
.bfc-kb__cam-info-btn { position: absolute; top: 12px; right: 12px; width: 30px; height: 30px; background: rgba(248,246,238,0.92); border: 1px solid #E3DDDA; font-size: 13px; font-weight: 600; color: #4E4741; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all .15s; z-index: 2; font-family: 'Poppins', sans-serif; }
.bfc-kb__cam-info-btn:hover { background: #F8F6EE; border-color: #202009; color: #202009; }
.bfc-kb__cam-card[aria-checked="true"] .bfc-kb__cam-info-btn { background: rgba(32,32,9,0.75); border-color: #3a3920; color: #F8F6EE; }
.bfc-kb__cam-card[aria-checked="true"] .bfc-kb__cam-info-btn:hover { background: #E36E15; border-color: #E36E15; }

/* ── MODAL ── */
.bfc-kb__modal-overlay {
  position: fixed; inset: 0;
  background: rgba(32,32,9,0.7);
  z-index: 1000;
  display: flex; align-items: center; justify-content: center;
  padding: 24px;
  opacity: 0; pointer-events: none;
  transition: opacity .25s ease;
}
.bfc-kb__modal-overlay.open { opacity: 1; pointer-events: all; }
.bfc-kb__modal {
  background: #F8F6EE;
  width: 100%; max-width: 860px;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
}
.bfc-kb__modal-close {
  position: absolute; top: 16px; right: 20px;
  width: 36px; height: 36px;
  background: none; border: 1px solid #E3DDDA;
  font-size: 22px; color: #4E4741; line-height: 1;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 10;
  transition: border-color .15s, color .15s;
  font-family: inherit;
}
.bfc-kb__modal-close:hover { border-color: #202009; color: #202009; }
.bfc-kb__modal-body { display: grid; grid-template-columns: 1fr 1fr; }

/* Modal – left: images */
.bfc-kb__modal-images { background: #202009; padding: 36px 32px; display: flex; flex-direction: column; gap: 10px; }
.bfc-kb__modal-images-label { font-size: 11px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: #6a6850; margin-bottom: 6px; }
.bfc-kb__modal-img-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.bfc-kb__modal-img-main { aspect-ratio: 4/3; overflow: hidden; margin-bottom: 0; grid-column: 1 / -1; }
.bfc-kb__modal-img-thumb { aspect-ratio: 1; overflow: hidden; }
.bfc-kb__modal-img-main img,
.bfc-kb__modal-img-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.bfc-kb__modal-img-placeholder { width: 100%; height: 100%; background: #2a2918; display: flex; align-items: center; justify-content: center; font-size: 12px; color: #4a4928; letter-spacing: .04em; }

/* Modal – right: info */
.bfc-kb__modal-info { padding: 40px 36px; overflow-y: auto; }
.bfc-kb__modal-info-tag { font-size: 11px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: #E36E15; margin-bottom: 8px; }
.bfc-kb__modal-info-name { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 300; color: #202009; line-height: 1.05; margin-bottom: 4px; }
.bfc-kb__modal-info-price { font-family: 'Cormorant Garamond', serif; font-size: 26px; color: #E36E15; margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid #E3DDDA; }
.bfc-kb__modal-specs { display: grid; grid-template-columns: auto 1fr; gap: 0 20px; margin-bottom: 24px; }
.bfc-kb__modal-spec-key { font-size: 11px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: #82906B; padding: 6px 0; border-bottom: 1px solid #E3DDDA; white-space: nowrap; }
.bfc-kb__modal-spec-val { font-size: 13px; color: #202009; padding: 6px 0; border-bottom: 1px solid #E3DDDA; }
.bfc-kb__modal-loves-label { font-size: 11px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: #82906B; margin-bottom: 12px; }
.bfc-kb__modal-loves { display: flex; flex-direction: column; gap: 10px; margin-bottom: 22px; }
.bfc-kb__modal-love-item { display: flex; align-items: flex-start; gap: 12px; font-size: 13px; color: #4E4741; line-height: 1.55; }
.bfc-kb__modal-love-item::before { content: ''; display: inline-block; width: 5px; height: 5px; background: #E36E15; margin-top: 7px; flex-shrink: 0; }
