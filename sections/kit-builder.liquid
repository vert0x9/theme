      btn.innerHTML=
        '<button class="bfc-kb__cam-info-btn" type="button" data-info-id="'+cam.id+'" aria-label="More info about '+cam.name+'">i</button>'+
        '<div class="bfc-kb__cam-img"><img src="'+cam.img+'" alt="'+cam.name+'" loading="lazy" width="600" height="600"></div>'+
        '<div class="bfc-kb__cam-body">'+
          '<span class="bfc-kb__cam-tag">'+cam.tag+'</span>'+
          '<span class="bfc-kb__cam-name">'+cam.name+'</span>'+
          '<span class="bfc-kb__cam-detail">'+cam.detail+'</span>'+
          '<span class="bfc-kb__cam-price">$'+cam.price+'</span>'+
        '</div>';
      btn.addEventListener('click',function(e){
        if(e.target.closest('.bfc-kb__cam-info-btn'))return;
        pickCamera(cam);
      });
      btn.querySelector('.bfc-kb__cam-info-btn').addEventListener('click',function(e){
        e.stopPropagation();openModal(cam);
      });
      grid.appendChild(btn);
    });
  }

  function pickCamera(cam){
    state.camera=cam;
    document.querySelectorAll('.bfc-kb__cam-card').forEach(function(c){
      c.setAttribute('aria-checked',c.getAttribute('data-cam-id')===cam.id?'true':'false');
    });
    buildFilm();revealSection('kb-sec-film');updateSticky();
  }

  /* ── MODAL ── */
  function openModal(cam){
    var overlay=$('kb-modal-overlay');
    var body=$('kb-modal-body');

    /* Gallery: pull from Liquid-injected BFC_GALLERIES, fall back to empty */
    var galleries=window.BFC_GALLERIES||{};
    var imgs=galleries[cam.id]||['','',''];

    /* Build image panel: first image large, next two as thumbs */
    function imgEl(src,cls){
      return '<div class="'+cls+'">'+
        (src?'<img src="'+src+'" alt="Shot on '+cam.name+'" loading="lazy">'
            :'<div class="bfc-kb__modal-img-placeholder">Sample photo</div>')+
      '</div>';
    }
    var imgHtml=
      imgEl(imgs[0],'bfc-kb__modal-img-main')+
      imgEl(imgs[1],'bfc-kb__modal-img-thumb')+
      imgEl(imgs[2],'bfc-kb__modal-img-thumb');

    var specsHtml=cam.specs.map(function(r){
      return '<span class="bfc-kb__modal-spec-key">'+r[0]+'</span><span class="bfc-kb__modal-spec-val">'+r[1]+'</span>';
    }).join('');
    var lovesHtml=cam.loves.map(function(l){return '<div class="bfc-kb__modal-love-item">'+l+'</div>';}).join('');
    var isSel=state.camera&&state.camera.id===cam.id;
    var warranty=WARRANTY[state.type]||'3–6 month';

    body.innerHTML=
      '<div class="bfc-kb__modal-images">'+
        '<div class="bfc-kb__modal-images-label">Photos taken on this camera</div>'+
        '<div class="bfc-kb__modal-img-grid">'+imgHtml+'</div>'+
      '</div>'+
      '<div class="bfc-kb__modal-info">'+
        '<div class="bfc-kb__modal-info-tag">'+cam.tag+'</div>'+
        '<div class="bfc-kb__modal-info-name" id="kb-modal-title">'+cam.name+'</div>'+
        '<div class="bfc-kb__modal-info-price">$'+cam.price+'</div>'+
        '<div class="bfc-kb__modal-specs">'+specsHtml+'</div>'+
        '<div class="bfc-kb__modal-loves-label">Why people love it</div>'+
        '<div class="bfc-kb__modal-loves">'+lovesHtml+'</div>'+
        '<div class="bfc-kb__modal-included">'+cam.included+' <strong>'+warranty+' warranty included.</strong></div>'+
        '<button class="bfc-kb__modal-select-btn'+(isSel?' already-selected':'')+'" type="button" id="kb-modal-select-btn">'+
          (isSel?'Selected — this is your camera':'Select this camera')+
        '</button>'+
      '</div>';

    $('kb-modal-select-btn').addEventListener('click',function(){
      pickCamera(cam);
      this.textContent='Selected — this is your camera';
      this.classList.add('already-selected');
      document.querySelectorAll('.bfc-kb__cam-card').forEach(function(c){
        c.setAttribute('aria-checked',c.getAttribute('data-cam-id')===cam.id?'true':'false');
      });
      closeModal();
    });

    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden','false');
    document.body.style.overflow='hidden';
  }

  function closeModal(){
    var overlay=$('kb-modal-overlay');
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden','true');
    document.body.style.overflow='';
  }

  $('kb-modal-close').addEventListener('click',closeModal);
  $('kb-modal-overlay').addEventListener('click',function(e){
    if(e.target===this)closeModal();
  });
  document.addEventListener('keydown',function(e){
    if(e.key==='Escape')closeModal();
  });

  /* ── FILM ── */
  function buildFilm(){
    var colorFilms=DATA.film.color[state.type]||DATA.film.color.ps;
    var bwFilms=DATA.film.bw[state.type]||DATA.film.bw.ps;
    buildFilmRow('kb-film-color-row',colorFilms,'filmColor');
    buildFilmRow('kb-film-bw-row',bwFilms,'filmBW');
  }
  function buildFilmRow(rowId,items,key){
    var row=$(rowId);
    row.style.gridTemplateColumns='repeat('+Math.min(items.length,4)+',1fr)';
    row.innerHTML=items.map(function(f){return addonCardHtml(f,key);}).join('');
    row.querySelectorAll('.bfc-kb__addon-card').forEach(function(card){
      card.addEventListener('click',function(){
        var item=items.find(function(f){return f.id===card.getAttribute('data-addon-id');});
        toggleAddon(key,item,items);
      });
    });
  }
  $('kb-film-rec-apply').addEventListener('click',function(){
    var cf=DATA.film.color[state.type]||DATA.film.color.ps;
    var bf=DATA.film.bw[state.type]||DATA.film.bw.ps;
    var rc=cf.find(function(f){return f.recommended;});
    var rb=bf.find(function(f){return f.recommended;});
    if(rc)selectAddon('filmColor',rc);
    if(rb)selectAddon('filmBW',rb);
    updateSticky();
  });
  $('kb-film-continue').addEventListener('click',function(){buildAccessories();revealSection('kb-sec-add');});
  $('kb-skip-film').addEventListener('click',function(){buildAccessories();revealSection('kb-sec-add');});

  /* ── ACCESSORIES ── */
  function buildAccessories(){
    buildAddonGroup('kb-addon-strap','Camera Strap',DATA.straps,'strap');
    buildAddonGroup('kb-addon-case','Camera Case',DATA.cases,'caseItem');
  }
  function buildAddonGroup(containerId,label,items,key){
    var el=$(containerId),cols=Math.min(items.length,4);
    el.innerHTML=
      '<div class="bfc-kb__addon-group-label">'+label+
        '<span class="bfc-kb__addon-optional">Optional — tap to add</span>'+
      '</div>'+
      '<div class="bfc-kb__addon-row" style="grid-template-columns:repeat('+cols+',1fr)">'+
        items.map(function(i){return addonCardHtml(i,key);}).join('')+
      '</div>';
    el.querySelectorAll('.bfc-kb__addon-card').forEach(function(card){
      card.addEventListener('click',function(){
        var item=items.find(function(i){return i.id===card.getAttribute('data-addon-id');});
        toggleAddon(key,item,items);
      });
    });
  }
  function addonCardHtml(item,key){
    return '<button class="bfc-kb__addon-card" type="button" aria-pressed="false" data-addon-key="'+key+'" data-addon-id="'+item.id+'">'+
      (item.recommended?'<span class="bfc-kb__addon-rec-badge">Recommended</span>':'')+
      '<span class="bfc-kb__addon-name">'+item.name+'</span>'+
      '<span class="bfc-kb__addon-sub">'+item.sub+'</span>'+
      '<span class="bfc-kb__addon-price">$'+item.price+'</span>'+
    '</button>';
  }
  function toggleAddon(key,item){
    if(!item)return;
    if(state[key]&&state[key].id===item.id){
      state[key]=null;
      document.querySelectorAll('[data-addon-key="'+key+'"]').forEach(function(c){c.setAttribute('aria-pressed','false');});
    } else { selectAddon(key,item); }
    updateSticky();
  }
  function selectAddon(key,item){
    state[key]=item;
    document.querySelectorAll('[data-addon-key="'+key+'"]').forEach(function(c){
      c.setAttribute('aria-pressed',c.getAttribute('data-addon-id')===item.id?'true':'false');
    });
  }
  $('kb-acc-continue').addEventListener('click',goReview);
  $('kb-skip-add').addEventListener('click',goReview);

  /* ── REVIEW ── */
  function goReview(){ buildReview(); revealSection('kb-sec-review'); updateSticky(); }
  function buildReview(){
    var cam=state.camera;
    var warranty=(WARRANTY[state.type]||'3–6 month')+' Warranty Included';
    var addons=[
      state.filmColor&&Object.assign({},state.filmColor,{cat:'Color Film'}),
      state.filmBW   &&Object.assign({},state.filmBW,   {cat:'B&W Film'}),
      state.strap    &&Object.assign({},state.strap,    {cat:'Strap'}),
      state.caseItem &&Object.assign({},state.caseItem, {cat:'Case'})
    ].filter(Boolean);
    var addonsHtml=addons.length
      ?addons.map(function(a){
        return '<div class="bfc-kb__review-addon-row">'+
          '<div class="bfc-kb__review-addon-info">'+
            '<div class="bfc-kb__review-addon-cat">'+a.cat+'</div>'+
            '<div class="bfc-kb__review-addon-name">'+a.name+'</div>'+
            '<div class="bfc-kb__review-addon-sub">'+a.sub+'</div>'+
          '</div>'+
          '<div class="bfc-kb__review-addon-price">$'+a.price+'</div>'+
        '</div>';
      }).join('')
      :'<p class="bfc-kb__no-addons">No accessories added. <button class="bfc-kb__no-addons-link" type="button" id="kb-back-add">Add some?</button></p>';
    $('kb-review-grid').innerHTML=
      '<div class="bfc-kb__review-cell">'+
        '<span class="bfc-kb__review-cell-label">Camera</span>'+
        '<div class="bfc-kb__review-cam-row">'+
          '<div class="bfc-kb__review-cam-img"><img src="'+cam.img+'" alt="'+cam.name+'" width="88" height="88"></div>'+
          '<div>'+
            '<div class="bfc-kb__review-cam-name">'+cam.name+'</div>'+
            '<div class="bfc-kb__review-cam-detail">'+cam.detail+'</div>'+
            '<div class="bfc-kb__review-warranty">'+warranty+'</div>'+
            '<span class="bfc-kb__review-cam-price">$'+cam.price+'</span>'+
          '</div>'+
        '</div>'+
      '</div>'+
      '<div class="bfc-kb__review-cell">'+
        '<span class="bfc-kb__review-cell-label">Film &amp; Accessories</span>'+
        addonsHtml+
      '</div>';
    var backLink=$('kb-back-add');
    if(backLink)backLink.addEventListener('click',function(){$('kb-sec-add').scrollIntoView({behavior:'smooth',block:'start'});});
    var total=getTotal();
    var lines=[['Camera',cam.price]].concat(
      [state.filmColor&&['Color Film',state.filmColor.price],
       state.filmBW   &&['B&W Film',  state.filmBW.price],
       state.strap    &&['Strap',     state.strap.price],
       state.caseItem &&['Case',      state.caseItem.price]].filter(Boolean)
    );
    $('kb-review-total').innerHTML=
      '<div class="bfc-kb__review-breakdown">'+
        lines.map(function(l){return '<div class="bfc-kb__review-line"><span>'+l[0]+'</span><span>$'+l[1]+'</span></div>';}).join('')+
        '<div class="bfc-kb__review-line bfc-kb__review-line--total">Total <span>$'+total.toFixed(2)+'</span></div>'+
        (total>=FREE_SHIP?'<div class="bfc-kb__ship-badge">Free US shipping included</div>':'')+
      '</div>'+
      '<div class="bfc-kb__review-cta">'+
        '<button class="bfc-kb__btn bfc-kb__btn--dark" id="kb-atc-btn" type="button">Add Kit to Cart</button>'+
        '<span class="bfc-kb__review-cta-note">Ships within 1–3 business days</span>'+
      '</div>';
    $('kb-atc-btn').addEventListener('click',addKitToCart);
  }

  /* ── CART ── */
  function addKitToCart(){
    var btn=$('kb-atc-btn');
    btn.textContent='Adding to cart…';btn.disabled=true;
    var items=[state.camera,state.filmColor,state.filmBW,state.strap,state.caseItem]
      .filter(function(i){return i&&i.variantId;})
      .map(function(i){return{id:i.variantId,quantity:1,properties:{_kit_builder:'true'}};});
    if(!items.length){btn.textContent='Add Kit to Cart';btn.disabled=false;return;}
    fetch('/cart/add.js',{
      method:'POST',
      headers:{'Content-Type':'application/json','Accept':'application/json'},
      body:JSON.stringify({items:items})
    })
    .then(function(r){if(!r.ok)throw new Error();return r.json();})
    .then(function(){window.location.href='/cart';})
    .catch(function(){btn.textContent='Something went wrong — try again';btn.disabled=false;});
  }

  /* ── STICKY ── */
  function updateSticky(){
    var sticky=$('kb-sticky'),items=$('kb-sticky-items'),price=$('kb-sticky-price'),cta=$('kb-sticky-cta');
    if(!state.type){sticky.hidden=true;return;}
    sticky.hidden=false;
    price.textContent=getTotal().toFixed(2);
    var filmVal=[state.filmColor&&state.filmColor.name,state.filmBW&&state.filmBW.name].filter(Boolean).join(' + ')||null;
    var slots=[
      {label:'Style',val:{ps:'Point & Shoot',slr:'35mm SLR',pol:'Polaroid'}[state.type]},
      {label:'Camera',val:state.camera?state.camera.name:null},
      {label:'Film',val:filmVal}
    ];
    items.innerHTML=slots.map(function(s){
      var empty=!s.val;
      return '<div class="bfc-kb__sticky-item">'+
        '<span class="bfc-kb__sticky-item-label">'+s.label+'</span>'+
        '<span class="bfc-kb__sticky-item-val'+(empty?' bfc-kb__sticky-item-val--empty':'')+'">'+
          (s.val||(s.label==='Camera'?'Not selected yet':'Not added'))+
        '</span></div>';
    }).join('');
    var rev=$('kb-sec-review').classList.contains('bfc-kb__section--visible');
    if(!state.camera){cta.textContent='Choose camera';cta.onclick=function(){$('kb-sec-cam').scrollIntoView({behavior:'smooth',block:'start'});};}
    else if(!rev){cta.textContent='Review kit →';cta.onclick=goReview;}
    else{cta.textContent='Add to Cart →';cta.onclick=addKitToCart;}
  }
})();
</script>

{% schema %}
{
  "name": "Kit Builder",
  "tag": "section",
  "class": "bfc-kit-builder",
  "settings": [
    { "type": "text",     "id": "eyebrow",                 "label": "Eyebrow text",                "default": "Don't know what to get? Start here." },
    { "type": "text",     "id": "headline",                "label": "Hero headline",               "default": "Find your first" },
    { "type": "text",     "id": "headline_em",             "label": "Hero headline (italic line)", "default": "film camera." },
    { "type": "textarea", "id": "subtext",                 "label": "Hero subtext",                "default": "Answer three quick questions — we'll put together a kit built around how you actually want to shoot. Every camera is professionally restored and backed by our warranty." },
    { "type": "number",   "id": "free_shipping_threshold", "label": "Free shipping threshold ($)", "default": 200 }
  ],
  "presets": [{ "name": "Kit Builder" }]
}
{% endschema %}
