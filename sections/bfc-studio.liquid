{{ 'section-bfc-studio.css' | asset_url | stylesheet_tag }}

<div id="bfc-studio-{{ section.id }}" class="bfc-studio" data-section-id="{{ section.id }}">
  <section class="bfc-hero" id="bfc-hero">
    <div class="bfc-hero__lead">
      <div class="bfc-hero__tag">{{ section.settings.hero_tag | default: 'A photo studio · Brooklyn, NY' }}</div>
      <h1 class="bfc-hero__title">{{ section.settings.hero_title_1 | default: 'The Studio' }}</h1>
      <p class="bfc-hero__desc">{{ section.settings.hero_description | default: 'Bookable by the hour. Natural north light, restored film cameras, lighting and crew available. Run by Brooklyn Film Camera since 2015.' }}</p>
      <div class="bfc-hero__cta-row">
        <a class="bfc-btn bfc-btn--primary" href="{{ section.settings.gigster_url | default: 'https://www.peerspace.com/pages/listings/64261f0bf9d022000ebe8a02' }}" target="_blank" rel="noopener">Book the Studio &rarr;</a>
        <a class="bfc-btn bfc-btn--ghost" href="#bfc-pricing">See Pricing</a>
      </div>
    </div>

    {%- assign feature_count = 0 -%}
    {%- for block in section.blocks -%}{%- if block.type == 'feature' -%}{%- assign feature_count = feature_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
    {%- if feature_count > 0 -%}
      <aside class="bfc-hero__aside">
        <div class="bfc-eyebrow">— The Space</div>
        <ol class="bfc-hero__index">
          {%- assign idx = 0 -%}
          {%- for block in section.blocks -%}{%- if block.type == 'feature' -%}
            {%- assign idx = idx | plus: 1 -%}
            <li class="bfc-hero__index-row" {{ block.shopify_attributes }}>
              <span class="bfc-hero__index-num">{% if idx < 10 %}0{% endif %}{{ idx }}</span>
              <span class="bfc-hero__index-label">{{ block.settings.feature_title }}</span>
            </li>
          {%- endif -%}{%- endfor -%}
        </ol>
      </aside>
    {%- endif -%}
  </section>

  <section class="bfc-gallery" id="bfc-gallery">
    <div class="bfc-section-hdr">
      <span class="bfc-section-hdr__num">— 01</span>
      <h2 class="bfc-section-hdr__title">See the Space</h2>
      <span class="bfc-section-hdr__rule"></span>
    </div>
    {%- assign gallery_count = 0 -%}
    {%- for block in section.blocks -%}{%- if block.type == 'gallery_image' -%}{%- assign gallery_count = gallery_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
    {%- if gallery_count > 0 -%}
      <div class="bfc-gallery__grid">
        {%- assign g_idx = 0 -%}
        {%- for block in section.blocks -%}{%- if block.type == 'gallery_image' -%}
          {%- assign g_idx = g_idx | plus: 1 -%}
          <figure class="bfc-gallery__cell{% if block.settings.feature %} bfc-gallery__cell--wide{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.image -%}
              {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'bfc-gallery__img', alt: block.settings.caption | default: 'BFC Studio' }}
            {%- else -%}
              <div class="bfc-gallery__placeholder">{% if g_idx < 10 %}0{% endif %}{{ g_idx }}</div>
            {%- endif -%}
            {%- if block.settings.caption and block.settings.caption != blank -%}
              <figcaption class="bfc-gallery__caption">{{ block.settings.caption }}</figcaption>
            {%- endif -%}
          </figure>
        {%- endif -%}{%- endfor -%}
      </div>
    {%- else -%}
      <p class="bfc-gallery__empty">Add gallery images in the theme editor to populate this section.</p>
    {%- endif -%}
  </section>

  <section class="bfc-pricing" id="bfc-pricing">
    <div class="bfc-section-hdr">
      <span class="bfc-section-hdr__num">— 02</span>
      <h2 class="bfc-section-hdr__title">Pricing</h2>
      <span class="bfc-section-hdr__rule"></span>
    </div>
    <div class="bfc-pricing__grid">
      <div class="bfc-pricing__card bfc-pricing__card--single">
        <span class="bfc-pricing__accent"></span>
        <div class="bfc-pricing__card-head">
          <div class="bfc-eyebrow">Single Rental</div>
          <div class="bfc-pricing__price"><span class="bfc-pricing__price-num">${{ section.settings.base_price | default: 180 }}</span><span class="bfc-pricing__price-unit">/ {{ section.settings.min_hours | default: 4 }}-hour minimum</span></div>
        </div>
        <p class="bfc-pricing__note">Each additional hour adds <em>${{ section.settings.additional_hour_rate | default: 45 }}</em>. First-come, first-served on the open calendar — no membership required.</p>
      </div>
      <div class="bfc-pricing__card bfc-pricing__card--member">
        <span class="bfc-pricing__accent bfc-pricing__accent--alt"></span>
        <div class="bfc-pricing__card-head">
          <div class="bfc-eyebrow">Monthly Membership</div>
          <div class="bfc-pricing__price"><span class="bfc-pricing__price-num">${{ section.settings.member_monthly_price | default: 150 }}</span><span class="bfc-pricing__price-unit">/ month · {{ section.settings.member_monthly_hours | default: 4 }} hrs included</span></div>
        </div>
        <p class="bfc-pricing__note"><em>+${{ section.settings.member_addl_hour_rate | default: 35 }}/hr</em> added to your plan, <em>+${{ section.settings.member_overage_rate | default: 40 }}/hr</em> session overage. Members get advance access to availability.</p>
        {%- if section.settings.gigster_url and section.settings.gigster_url != blank -%}
          <a class="bfc-pricing__link" href="{{ section.settings.gigster_url }}" target="_blank" rel="noopener">Book on Peerspace &rarr;</a>
        {%- else -%}
          <a class="bfc-pricing__link" href="https://www.peerspace.com/pages/listings/64261f0bf9d022000ebe8a02" target="_blank" rel="noopener">Book on Peerspace &rarr;</a>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="bfc-book" id="bfc-book">
    <div class="bfc-section-hdr">
      <span class="bfc-section-hdr__num">— 03</span>
      <h2 class="bfc-section-hdr__title">Book Your Session</h2>
      <span class="bfc-section-hdr__rule"></span>
    </div>
    <div class="bfc-cta-band">
      <div class="bfc-cta-band__left">
        <div class="bfc-eyebrow" style="margin-bottom:16px;">Available now</div>
        <p class="bfc-cta-band__body">{{ section.settings.cta_body | default: 'Book the studio by the hour through our listing on Gigster. Live availability, instant confirmation, and deposit hold — all handled for you.' }}</p>
      </div>
      <div class="bfc-cta-band__right">
        <a class="bfc-btn bfc-btn--primary bfc-btn--lg" href="{{ section.settings.gigster_url | default: 'https://www.peerspace.com/pages/listings/64261f0bf9d022000ebe8a02' }}" target="_blank" rel="noopener">Book on Peerspace &rarr;</a>
        <div class="bfc-cta-band__note">You'll be taken to our Peerspace listing to check availability and complete your booking.</div>
      </div>
    </div>
  </section>


  <section class="bfc-suite" id="bfc-suite">
    <div class="bfc-suite__inner">
      <div class="bfc-suite__hdr">
        <span class="bfc-suite__num">— 04</span>
        <span class="bfc-suite__rule"></span>
      </div>
      <div class="bfc-suite__lead">
        <div class="bfc-suite__eyebrow">{{ section.settings.suite_eyebrow | default: 'Beyond the Space' }}</div>
        <h2 class="bfc-suite__title">{{ section.settings.suite_title | default: 'Full Creative Suite' }}</h2>
      </div>
      <div class="bfc-suite__body">
        <p>{{ section.settings.suite_body | default: "If you need more than just a space — concept, photographers, stylists, props, post — we can put the whole thing together. Tell us what you're trying to make and we'll build the team and the day around it." }}</p>
        <p class="bfc-suite__email-line">Get in touch with <em>{{ section.settings.suite_contact_name | default: 'Coco' }}</em> at</p>
        <a class="bfc-suite__email" href="mailto:{{ section.settings.suite_email | default: 'coco@brooklynfilmcamera.com' }}" id="bfc-suite-email-{{ section.id }}">{{ section.settings.suite_email | default: 'coco@brooklynfilmcamera.com' }}</a>
        <div class="bfc-suite__cta-row">
          <a class="bfc-btn bfc-btn--primary" href="mailto:{{ section.settings.suite_email | default: 'coco@brooklynfilmcamera.com' }}">Email {{ section.settings.suite_contact_name | default: 'Coco' }} &rarr;</a>
          <button type="button" class="bfc-btn bfc-btn--ghost-dark" id="bfc-suite-copy-{{ section.id }}" data-email="{{ section.settings.suite_email | default: 'coco@brooklynfilmcamera.com' }}">
            <span class="bfc-suite__copy-default">Copy Address</span>
            <span class="bfc-suite__copy-done">Copied ✓</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <section class="bfc-policies">
    <div class="bfc-section-hdr">
      <span class="bfc-section-hdr__num">— 05</span>
      <h2 class="bfc-section-hdr__title">Policies</h2>
      <span class="bfc-section-hdr__rule"></span>
    </div>
    <div class="bfc-policies__grid">
      <article>
        <div class="bfc-eyebrow">Cancellation</div>
        <p>Studio &amp; crew kill fee: <em>50%</em> within 24 hours, <em>100%</em> within 12. Equipment rentals and film are refunded in full.</p>
      </article>
      <article>
        <div class="bfc-eyebrow">Overtime</div>
        <p>Crew overtime is billed at <em>1.5&times; hourly</em> after {{ section.settings.full_day_hours | default: 10 }} hours on set.</p>
      </article>
      <article>
        <div class="bfc-eyebrow">Bookings</div>
        <p>First come, first served. <em>Members</em> get advance access to the availability calendar.</p>
      </article>
    </div>
  </section>

  <footer class="bfc-footer">
    <div class="bfc-footer__col">
      <div class="bfc-eyebrow">Visit</div>
      <strong>{{ section.settings.footer_address | default: 'Brooklyn, NY' }}</strong>
      <div class="bfc-footer__sub">{{ section.settings.footer_hours | default: 'Open every day 11am – 8pm' }}</div>
    </div>
    <div class="bfc-footer__col bfc-footer__col--right">
      <div class="bfc-eyebrow">Studio</div>
      <a href="mailto:{{ section.settings.footer_email | default: 'studio@brooklynfilmcamera.com' }}">{{ section.settings.footer_email | default: 'studio@brooklynfilmcamera.com' }}</a>
      <div class="bfc-footer__sub">Brooklyn Film Camera, est. 2015</div>
    </div>
  </footer>
</div>

<style>
  .bfc-studio {
    /* BFC palette */
    --bfc-cv: #F8F6EE;       /* Blank Canvas */
    --bfc-cv-deep: #EDE9DA;  /* deeper cream surface */
    --bfc-bk: #202009;       /* Blank Black */
    --bfc-ch: #4E4741;       /* Charcoal */
    --bfc-gr: #E3DDDA;       /* Mechanical Gray */
    --bfc-or: #E36E15;       /* Super Orange */
    --bfc-go: #F4A027;       /* Golden Hour */
    --bfc-ce: #ABCC99;       /* Celadon */

    /* Tokens */
    --bfc-bg: var(--bfc-cv);
    --bfc-text: var(--bfc-bk);
    --bfc-text-mute: var(--bfc-ch);
    --bfc-text-faint: rgba(32,32,9,0.45);
    --bfc-border: rgba(32,32,9,0.14);
    --bfc-border-soft: rgba(32,32,9,0.08);
    --bfc-surface: var(--bfc-cv-deep);

    --bfc-display: 'Cormorant Garamond', 'Times New Roman', Georgia, serif;
    --bfc-ui: 'Poppins', -apple-system, system-ui, sans-serif;

    background: var(--bfc-bg);
    color: var(--bfc-text);
    font-family: var(--bfc-ui);
    font-size: 15px;
    line-height: 1.55;
    letter-spacing: 0.005em;
  }
  .bfc-studio *, .bfc-studio *::before, .bfc-studio *::after { box-sizing: border-box; }
  .bfc-studio button { font-family: inherit; color: inherit; }
  .bfc-studio a { color: inherit; text-decoration: none; }
  .bfc-studio h1, .bfc-studio h2, .bfc-studio h3, .bfc-studio h4 { margin: 0; font-weight: 500; }
  .bfc-studio p { margin: 0; }
  .bfc-studio em { font-family: var(--bfc-display); font-style: italic; font-weight: 500; color: var(--bfc-text); }

  /* Eyebrow label */
  .bfc-eyebrow {
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    font-weight: 500; color: var(--bfc-ch);
  }

  /* Section header */
  .bfc-section-hdr {
    display: flex; align-items: baseline; gap: 20px;
    padding-bottom: 18px; margin-bottom: 40px;
    border-bottom: 1px solid var(--bfc-border);
  }
  .bfc-section-hdr__num {
    font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase;
    font-weight: 500; color: var(--bfc-or);
    flex-shrink: 0;
  }
  .bfc-section-hdr__title {
    font-family: var(--bfc-display); font-size: 44px; line-height: 1;
    font-weight: 500; letter-spacing: -0.005em;
  }
  .bfc-section-hdr__rule {
    flex: 1; height: 1px; background: var(--bfc-border-soft);
    align-self: center; margin-left: 6px;
  }

  /* Nav */
  .bfc-nav {
    position: sticky; top: 0; z-index: 10;
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 40px;
    background: rgba(248,246,238,0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--bfc-border-soft);
  }
  .bfc-nav__logo { display: inline-flex; align-items: baseline; gap: 10px; }
  .bfc-nav__logo-mark {
    font-family: var(--bfc-display); font-size: 22px; font-weight: 500;
    letter-spacing: 0.04em;
  }
  .bfc-nav__logo-mark span { color: var(--bfc-or); font-style: italic; }
  .bfc-nav__logo-sub {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--bfc-ch); font-weight: 500;
  }
  .bfc-nav__meta { display: flex; align-items: center; gap: 24px; }
  .bfc-nav__meta-item {
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--bfc-text-mute);
  }
  .bfc-nav__cta {
    font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 10px 18px;
    background: var(--bfc-bk); color: var(--bfc-cv);
    transition: background 0.15s;
  }
  .bfc-nav__cta:hover { background: #000; }

  /* Hero */
  .bfc-hero {
    display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: 64px;
    padding: 80px 40px 72px;
    max-width: 1200px; margin: 0 auto;
    align-items: end;
  }
  .bfc-hero__lead { min-width: 0; }
  .bfc-hero__tag {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 500; color: var(--bfc-or);
    margin-bottom: 28px;
  }
  .bfc-hero__title {
    font-family: var(--bfc-display); font-size: 96px; line-height: 0.95;
    font-weight: 500; letter-spacing: -0.015em;
    margin-bottom: 28px;
  }
  .bfc-hero__desc {
    font-size: 17px; line-height: 1.55;
    color: var(--bfc-text-mute);
    max-width: 480px;
    margin-bottom: 36px;
  }
  .bfc-hero__cta-row { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }

  .bfc-hero__aside {
    border-left: 1px solid var(--bfc-border);
    padding-left: 32px;
    align-self: end;
    padding-bottom: 8px;
  }
  .bfc-hero__index {
    list-style: none; padding: 0; margin: 16px 0 0;
  }
  .bfc-hero__index-row {
    display: flex; align-items: baseline; gap: 16px;
    padding: 14px 0;
    border-bottom: 1px dotted var(--bfc-border);
  }
  .bfc-hero__index-row:last-child { border-bottom: none; }
  .bfc-hero__index-num {
    font-family: var(--bfc-display); font-style: italic;
    font-size: 18px; color: var(--bfc-or); flex-shrink: 0;
    min-width: 28px;
  }
  .bfc-hero__index-label {
    font-size: 15px; color: var(--bfc-text);
    font-family: var(--bfc-display); font-weight: 500;
  }

  /* Buttons */
  .bfc-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 26px;
    font-size: 12px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    border: 1px solid transparent; cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .bfc-btn--primary {
    background: var(--bfc-or); color: var(--bfc-cv); border-color: var(--bfc-or);
  }
  .bfc-btn--primary:hover,
  .bfc-btn--primary:focus,
  .bfc-btn--primary:active {
    background: #B85A11; color: var(--bfc-cv); border-color: #B85A11;
  }
  .bfc-btn--ghost {
    background: transparent; color: var(--bfc-text); border-color: var(--bfc-border-soft);
  }
  .bfc-btn--ghost:hover { border-color: var(--bfc-bk); }
  .bfc-btn--full { width: 100%; justify-content: center; padding: 16px 26px; }
  .bfc-btn--disabled { opacity: 0.35; pointer-events: none; }
  .bfc-btn--loading { opacity: 0.7; pointer-events: none; }

  /* Pricing */
  .bfc-pricing {
    padding: 56px 40px;
    max-width: 1200px; margin: 0 auto;
  }
  .bfc-pricing__grid {
    display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 24px;
  }
  .bfc-pricing__card {
    position: relative;
    background: var(--bfc-cv);
    border: 1px solid var(--bfc-border);
    padding: 24px 26px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .bfc-pricing__card--member {
    background: var(--bfc-surface);
  }
  .bfc-pricing__accent { display: none; }
  .bfc-pricing__card-head { display: flex; flex-direction: column; gap: 10px; }
  .bfc-pricing__price {
    display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;
  }
  .bfc-pricing__price-num {
    font-family: var(--bfc-display); font-size: 36px; line-height: 1;
    font-weight: 500; letter-spacing: -0.005em;
  }
  .bfc-pricing__price-unit {
    font-size: 12px; color: var(--bfc-text-mute);
    letter-spacing: 0.02em;
  }
  .bfc-pricing__note {
    font-size: 13px; line-height: 1.55;
    color: var(--bfc-text-mute);
  }
  .bfc-pricing__link {
    align-self: flex-start;
    font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
    font-weight: 500; color: var(--bfc-text);
    border-bottom: 1px solid var(--bfc-bk);
    padding-bottom: 3px;
    margin-top: auto;
  }
  .bfc-pricing__link:hover { color: var(--bfc-or); border-color: var(--bfc-or); }

  /* Booking */
  .bfc-book {
    padding: 56px 40px;
    max-width: 1200px; margin: 0 auto;
  }
  .bfc-book__layout {
    display: grid; grid-template-columns: minmax(0, 1fr) 380px;
    gap: 56px;
  }
  .bfc-book__progress {
    display: flex; gap: 0;
    margin-bottom: 40px;
    border-bottom: 1px solid var(--bfc-border);
  }
  .bfc-progress__step {
    flex: 1;
    background: none; border: none;
    padding: 14px 0 16px;
    text-align: left; cursor: pointer;
    display: flex; align-items: baseline; gap: 10px;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    color: var(--bfc-text-faint);
    transition: color 0.2s, border-color 0.2s;
  }
  .bfc-progress__step:disabled { cursor: default; }
  .bfc-progress__num {
    font-family: var(--bfc-display); font-style: italic; font-weight: 500;
    font-size: 22px;
    color: var(--bfc-text-faint);
    transition: color 0.2s;
  }
  .bfc-progress__label {
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    font-weight: 500;
  }
  .bfc-progress__step.is-active {
    color: var(--bfc-text);
    border-bottom-color: var(--bfc-or);
  }
  .bfc-progress__step.is-active .bfc-progress__num { color: var(--bfc-or); }
  .bfc-progress__step.is-complete { color: var(--bfc-text-mute); }
  .bfc-progress__step.is-complete .bfc-progress__num { color: var(--bfc-text-mute); }

  .bfc-book__panel { display: none; }
  .bfc-book__panel.is-active {
    display: block;
    animation: bfcPanelIn 0.32s ease;
  }
  @keyframes bfcPanelIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .bfc-book__step-title {
    font-family: var(--bfc-display); font-size: 32px; font-weight: 500;
    line-height: 1.05; margin-bottom: 8px;
  }
  .bfc-book__step-optional {
    font-family: var(--bfc-display); font-style: italic; font-weight: 400;
    color: var(--bfc-text-mute); font-size: 22px;
  }
  .bfc-book__step-hint {
    font-size: 14px; line-height: 1.6;
    color: var(--bfc-text-mute);
    margin-bottom: 24px;
    max-width: 520px;
  }
  .bfc-book__nav {
    display: flex; justify-content: space-between; align-items: center;
    gap: 12px;
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--bfc-border-soft);
  }
  .bfc-book__nav--end { justify-content: flex-end; }

  /* Calendar */
  .bfc-cal {
    background: var(--bfc-cv);
    border: 1px solid var(--bfc-border);
    padding: 20px;
  }
  .bfc-cal__nav {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .bfc-cal__nav-btn {
    background: none; border: 1px solid var(--bfc-border-soft);
    padding: 4px 10px; cursor: pointer;
    font-size: 14px; color: var(--bfc-text);
    transition: border-color 0.15s, background 0.15s;
  }
  .bfc-cal__nav-btn:hover { border-color: var(--bfc-bk); background: var(--bfc-cv-deep); }
  .bfc-cal__month {
    font-family: var(--bfc-display); font-style: italic;
    font-size: 20px; font-weight: 500;
  }
  .bfc-cal__hdr {
    display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px;
    font-size: 10px; color: var(--bfc-text-faint); text-align: center;
    margin-bottom: 8px; letter-spacing: 0.12em; text-transform: uppercase;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--bfc-border-soft);
  }
  .bfc-cal__grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .bfc-cal__day {
    aspect-ratio: 1;
    background: none; border: 1px solid transparent;
    cursor: pointer; padding: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 3px;
    color: var(--bfc-text);
    font-family: var(--bfc-display); font-size: 17px; font-weight: 500;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
  }
  .bfc-cal__day:not(.bfc-cal__day--blocked):not(.bfc-cal__day--past):not(.bfc-cal__day--empty):hover {
    background: var(--bfc-cv-deep);
    border-color: var(--bfc-border);
  }
  .bfc-cal__day--past, .bfc-cal__day--empty { opacity: 0.25; cursor: default; pointer-events: none; }
  .bfc-cal__day--blocked { color: var(--bfc-text-faint); cursor: not-allowed; pointer-events: none; }
  .bfc-cal__day--selected { background: var(--bfc-or) !important; color: var(--bfc-cv); border-color: var(--bfc-or) !important; }
  .bfc-cal__day--selected .bfc-cal__day-dot { background: var(--bfc-cv) !important; }
  .bfc-cal__day-dot { width: 4px; height: 4px; border-radius: 50%; }
  .bfc-cal__dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; vertical-align: middle; margin-right: 5px; }
  .bfc-cal__dot--avail, .bfc-cal__day-dot--avail { background: var(--bfc-ce); }
  .bfc-cal__dot--partial, .bfc-cal__day-dot--partial { background: var(--bfc-go); }
  .bfc-cal__dot--blocked, .bfc-cal__day-dot--blocked { background: var(--bfc-text-faint); }
  .bfc-cal__legend {
    display: flex; gap: 18px; margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--bfc-border-soft);
    font-size: 11px; color: var(--bfc-text-mute);
    letter-spacing: 0.06em; text-transform: uppercase;
  }

  /* Time */
  .bfc-time { display: flex; gap: 20px; margin-top: 18px; }
  .bfc-time__field { flex: 1; }
  .bfc-time__field label {
    display: block; font-size: 11px;
    color: var(--bfc-text-mute); margin-bottom: 6px;
    letter-spacing: 0.16em; text-transform: uppercase;
    font-weight: 500;
  }
  .bfc-time__field input {
    width: 100%; border: none; border-bottom: 1px solid var(--bfc-border);
    background: transparent;
    padding: 6px 0 10px;
    font-family: var(--bfc-display); font-size: 22px; font-weight: 500;
    color: var(--bfc-text);
  }
  .bfc-time__field input:focus { border-bottom-color: var(--bfc-or); outline: none; }
  .bfc-time__summary {
    margin-top: 18px;
    padding: 14px 16px;
    background: var(--bfc-cv-deep);
    border-left: 3px solid var(--bfc-or);
    font-size: 14px; color: var(--bfc-text);
  }
  .bfc-time__summary--error { border-left-color: #c0392b; color: #8b1f12; }
  .bfc-time__summary strong { font-weight: 600; font-size: 16px; }

  /* Add-ons */
  .bfc-addons {
    border-top: 1px solid var(--bfc-border);
    background: transparent;
  }
  .bfc-addons:last-child { border-bottom: 1px solid var(--bfc-border); }
  .bfc-addons[open] { background: var(--bfc-cv-deep); }
  .bfc-addons__summary {
    list-style: none; cursor: pointer;
    display: flex; align-items: baseline; gap: 14px;
    padding: 18px 0;
    user-select: none;
  }
  .bfc-addons__summary::-webkit-details-marker { display: none; }
  .bfc-addons__summary::marker { display: none; }
  .bfc-addons[open] > .bfc-addons__summary { padding-left: 16px; padding-right: 16px; }
  .bfc-addons__caret {
    font-family: var(--bfc-display); font-size: 22px; line-height: 1;
    width: 16px; color: var(--bfc-or);
    transition: transform 0.18s;
  }
  .bfc-addons[open] .bfc-addons__caret { transform: rotate(45deg); }
  .bfc-addons__label {
    font-family: var(--bfc-display); font-size: 22px; font-weight: 500;
  }
  .bfc-addons__sub {
    font-size: 12px; color: var(--bfc-text-mute); flex: 1;
    letter-spacing: 0.04em;
  }
  .bfc-addons__count {
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    font-weight: 500; color: var(--bfc-or);
  }
  .bfc-addons__count:empty { display: none; }
  .bfc-addons__body { padding: 0 16px 24px; }
  .bfc-addons__note { font-size: 13px; color: var(--bfc-text-mute); margin-bottom: 16px; }
  .bfc-addons__grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 8px;
  }

  /* Pick */
  .bfc-pick {
    border: 1px solid var(--bfc-border); background: var(--bfc-cv);
    padding: 14px 16px;
    text-align: left; cursor: pointer;
    display: flex; flex-direction: column; gap: 4px;
    color: inherit;
    position: relative;
    transition: border-color 0.15s, background 0.15s;
  }
  .bfc-pick:hover { border-color: var(--bfc-or); }
  .bfc-pick.selected {
    border-color: var(--bfc-bk); background: var(--bfc-bk); color: var(--bfc-cv);
  }
  .bfc-pick.selected::after {
    content: '✓'; position: absolute; top: 8px; right: 10px;
    font-size: 12px; color: var(--bfc-or);
  }
  .bfc-pick.selected .bfc-pick__sub,
  .bfc-pick.selected .bfc-pick__rate,
  .bfc-pick.selected .bfc-pick__rate-unit { color: rgba(248,246,238,0.7); }
  .bfc-pick__name { font-size: 14px; font-weight: 500; padding-right: 20px; }
  .bfc-pick__sub { font-size: 12px; color: var(--bfc-text-mute); line-height: 1.4; }
  .bfc-pick__rate {
    font-family: var(--bfc-display); font-size: 18px; font-weight: 500;
    margin-top: 4px; color: var(--bfc-text);
  }
  .bfc-pick__rate-unit {
    font-family: var(--bfc-ui); font-size: 12px; font-weight: 400;
    color: var(--bfc-text-mute); margin-left: 2px;
  }

  /* Crew card */
  .bfc-crew-card {
    background: var(--bfc-cv);
    border: 1px solid var(--bfc-border);
    padding: 18px 20px; margin-bottom: 10px;
  }
  .bfc-crew-card:last-child { margin-bottom: 0; }
  .bfc-crew-card__head { margin-bottom: 14px; }
  .bfc-crew-card__name {
    font-family: var(--bfc-display); font-size: 20px; font-weight: 500;
    display: block;
  }
  .bfc-crew-card__desc {
    font-size: 13px; color: var(--bfc-text-mute); margin-top: 2px;
  }
  .bfc-crew-card__opts { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

  /* Aside (sticky summary + form) */
  .bfc-book__aside {
    align-self: start;
    position: sticky; top: 84px;
  }
  .bfc-summary {
    background: var(--bfc-bk); color: var(--bfc-cv);
    padding: 24px;
    margin-bottom: 16px;
  }
  .bfc-summary__title {
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--bfc-go); font-weight: 500;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(248,246,238,0.15);
  }
  .bfc-summary__lines { font-size: 14px; min-height: 24px; }
  .bfc-summary__line {
    display: flex; justify-content: space-between; gap: 12px;
    padding: 5px 0; line-height: 1.4;
  }
  .bfc-summary__line-name { color: rgba(248,246,238,0.75); flex: 1; min-width: 0; }
  .bfc-summary__line-price {
    font-family: var(--bfc-display); font-weight: 500; flex-shrink: 0;
    font-size: 16px;
  }
  .bfc-summary__empty {
    color: rgba(248,246,238,0.5); font-size: 13px;
    font-style: italic; font-family: var(--bfc-display);
  }
  .bfc-summary__total {
    margin-top: 18px; padding-top: 16px;
    border-top: 1px solid rgba(248,246,238,0.15);
    display: flex; justify-content: space-between; align-items: baseline;
  }
  .bfc-summary__total-label {
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    font-weight: 500;
  }
  .bfc-summary__total-amount {
    font-family: var(--bfc-display); font-size: 32px; font-weight: 500;
    color: var(--bfc-go);
  }

  /* Form */
  .bfc-form {
    display: flex; flex-direction: column; gap: 20px;
  }
  .bfc-form__row label {
    display: block; font-size: 11px;
    color: var(--bfc-text-mute); margin-bottom: 6px;
    letter-spacing: 0.16em; text-transform: uppercase;
    font-weight: 500;
  }
  .bfc-form__row-opt {
    color: var(--bfc-text-faint); font-weight: 400;
    margin-left: 4px; text-transform: none; letter-spacing: 0.02em;
  }
  .bfc-form__row input,
  .bfc-form__row textarea {
    width: 100%; border: none; border-bottom: 1px solid var(--bfc-border);
    background: transparent;
    padding: 4px 0 8px;
    font-family: var(--bfc-ui); font-size: 15px;
    color: var(--bfc-text); resize: vertical;
  }
  .bfc-form__row input:focus,
  .bfc-form__row textarea:focus {
    border-bottom-color: var(--bfc-or); outline: none;
  }
  .bfc-form__row input::placeholder,
  .bfc-form__row textarea::placeholder { color: var(--bfc-text-faint); }
  .bfc-form__row input.error,
  .bfc-form__row textarea.error { border-bottom-color: #c0392b; }
  .bfc-form__msg { font-size: 13px; min-height: 18px; color: var(--bfc-text-mute); }
  .bfc-form__msg--error { color: #c0392b; }
  .bfc-form__msg--success { color: #2d7a4f; }

  /* Policies */
  .bfc-policies {
    padding: 56px 40px;
    max-width: 1200px; margin: 0 auto;
  }
  .bfc-policies__grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 40px;
  }
  .bfc-policies article { display: flex; flex-direction: column; gap: 10px; }
  .bfc-policies p { font-size: 14px; line-height: 1.65; color: var(--bfc-text-mute); }

  /* Gallery */
  .bfc-gallery {
    padding: 56px 40px;
    max-width: 1200px; margin: 0 auto;
  }
  .bfc-gallery__grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .bfc-gallery__cell {
    position: relative; margin: 0;
    background: var(--bfc-cv-deep);
    overflow: hidden;
  }
  .bfc-gallery__cell--wide { grid-column: span 2; }
  .bfc-gallery__img {
    display: block; width: 100%; height: 100%;
    object-fit: cover; aspect-ratio: 4/5;
    transition: transform 0.4s ease;
  }
  .bfc-gallery__cell--wide .bfc-gallery__img { aspect-ratio: 8/5; }
  .bfc-gallery__cell:hover .bfc-gallery__img { transform: scale(1.02); }
  .bfc-gallery__placeholder {
    aspect-ratio: 4/5;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--bfc-display); font-style: italic;
    font-size: 32px; color: var(--bfc-text-faint);
    background: var(--bfc-cv-deep);
  }
  .bfc-gallery__cell--wide .bfc-gallery__placeholder { aspect-ratio: 8/5; }
  .bfc-gallery__caption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 14px 18px;
    font-family: var(--bfc-display); font-style: italic;
    font-size: 15px; color: var(--bfc-cv);
    background: linear-gradient(to top, rgba(32,32,9,0.7), rgba(32,32,9,0));
  }
  .bfc-gallery__empty {
    color: var(--bfc-text-mute); font-size: 14px;
    font-family: var(--bfc-display); font-style: italic;
    padding: 32px 0;
  }

  /* Full Creative Suite (dark band) */
  .bfc-suite {
    background: #171410; color: var(--bfc-cv) !important;
    padding: 80px 40px;
    margin-top: 24px;
  }
  .bfc-suite__inner {
    max-width: 720px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center;
    text-align: center;
    gap: 28px;
  }
  .bfc-suite__hdr {
    display: flex; align-items: center; gap: 20px; width: 100%;
  }
  .bfc-suite__num {
    font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase;
    font-weight: 500; color: var(--bfc-or) !important;
  }
  .bfc-suite__rule { flex: 1; height: 1px; background: rgba(248,246,238,0.18); }
  .bfc-suite__lead { display: flex; flex-direction: column; gap: 12px; align-items: center; }
  .bfc-suite__eyebrow {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 500; color: var(--bfc-or) !important;
  }
  .bfc-suite__title {
    font-family: var(--bfc-display); font-size: 64px; line-height: 0.98;
    font-weight: 500; letter-spacing: -0.012em;
    color: var(--bfc-cv) !important;
  }
  .bfc-suite__body {
    display: flex; flex-direction: column; gap: 18px;
    align-items: center;
    max-width: 580px;
  }
  .bfc-suite__body p {
    font-size: 17px; line-height: 1.6;
    color: rgba(248,246,238,0.82) !important;
  }
  .bfc-suite__body em { color: var(--bfc-or) !important; }
  .bfc-suite__email-line { font-size: 14px !important; color: rgba(248,246,238,0.6) !important; margin-top: 8px; }
  .bfc-suite__email {
    font-family: var(--bfc-display); font-style: italic;
    font-size: 36px; font-weight: 500;
    color: var(--bfc-cv) !important;
    border-bottom: 1px solid rgba(248,246,238,0.3);
    padding-bottom: 4px;
    word-break: break-all;
    line-height: 1.1;
  }
  .bfc-suite__email:hover { color: var(--bfc-or) !important; border-color: var(--bfc-or); }
  .bfc-suite__cta-row {
    display: flex; flex-wrap: wrap; gap: 14px; align-items: center;
    justify-content: center;
    margin-top: 12px;
  }
  .bfc-suite__copy-done { display: none; }
  .bfc-btn--ghost-dark {
    background: transparent; color: var(--bfc-cv) !important;
    border-color: rgba(248,246,238,0.3);
  }
  .bfc-btn--ghost-dark:hover {
    border-color: var(--bfc-or); color: var(--bfc-or) !important;
  }
  .bfc-btn--ghost-dark.bfc-btn--copied {
    border-color: var(--bfc-or); color: var(--bfc-or) !important;
  }
  .bfc-btn--ghost-dark.bfc-btn--copied .bfc-suite__copy-default { display: none; }
  .bfc-btn--ghost-dark.bfc-btn--copied .bfc-suite__copy-done { display: inline; }

  /* CTA Band */
  .bfc-book { padding: 56px 40px; max-width: 1200px; margin: 0 auto; }
  .bfc-cta-band {
    display: grid; grid-template-columns: 1fr auto;
    gap: 48px; align-items: center;
    padding: 48px 56px;
    background: var(--bfc-bk); color: var(--bfc-cv);
    margin-top: 40px;
  }
  .bfc-cta-band__body {
    font-size: 17px; line-height: 1.65;
    color: rgba(248,246,238,0.75);
    max-width: 480px;
  }
  .bfc-cta-band__right {
    display: flex; flex-direction: column; gap: 14px; align-items: flex-end;
    flex-shrink: 0;
  }
  .bfc-cta-band__note {
    font-size: 12px; color: rgba(248,246,238,0.35);
    max-width: 220px; text-align: right; line-height: 1.5;
  }
  .bfc-btn--lg { padding: 18px 36px; font-size: 13px; white-space: nowrap; }
  @media (max-width: 900px) {
    .bfc-book { padding: 40px 24px; }
    .bfc-cta-band { grid-template-columns: 1fr; padding: 36px 28px; gap: 28px; }
    .bfc-cta-band__right { align-items: flex-start; }
    .bfc-cta-band__note { text-align: left; max-width: 100%; }
  }

  /* Footer */
  .bfc-footer {
    border-top: 1px solid var(--bfc-border);
    padding: 40px 40px;
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 32px;
    font-size: 14px;
  }
  .bfc-footer__col { display: flex; flex-direction: column; gap: 6px; }
  .bfc-footer__col--right { text-align: right; align-items: flex-end; }
  .bfc-footer strong {
    font-family: var(--bfc-display); font-size: 22px; font-weight: 500;
    color: var(--bfc-text);
  }
  .bfc-footer__sub { color: var(--bfc-text-mute); font-size: 13px; }
  .bfc-footer a {
    font-family: var(--bfc-display); font-size: 22px; font-weight: 500;
    color: var(--bfc-text);
    border-bottom: 1px solid var(--bfc-border);
    padding-bottom: 2px;
  }
  .bfc-footer a:hover { color: var(--bfc-or); border-color: var(--bfc-or); }

  /* Mobile */
  @media (max-width: 900px) {
    .bfc-nav { padding: 14px 24px; flex-wrap: wrap; gap: 12px; }
    .bfc-nav__meta-item { display: none; }
    .bfc-hero {
      grid-template-columns: 1fr;
      padding: 56px 24px 48px;
      gap: 40px;
    }
    .bfc-hero__title { font-size: 64px; }
    .bfc-hero__aside {
      border-left: none;
      border-top: 1px solid var(--bfc-border);
      padding-left: 0; padding-top: 24px;
    }
    .bfc-pricing, .bfc-book, .bfc-policies, .bfc-footer, .bfc-gallery { padding-left: 24px; padding-right: 24px; }
    .bfc-suite { padding: 56px 24px; }
    .bfc-suite__title { font-size: 44px; }
    .bfc-suite__email { font-size: 26px; }
    .bfc-gallery__grid { grid-template-columns: 1fr 1fr; gap: 8px; }
    .bfc-gallery__cell--wide { grid-column: span 2; }
    .bfc-pricing__grid { grid-template-columns: 1fr; }
    .bfc-book__layout { grid-template-columns: 1fr; gap: 36px; }
    .bfc-book__aside { position: static; }
    .bfc-book__step-title { font-size: 26px; }
    .bfc-book__step-optional { font-size: 18px; }
    .bfc-progress__step { padding: 12px 0; }
    .bfc-progress__num { font-size: 18px; }
    .bfc-progress__label { font-size: 10px; letter-spacing: 0.12em; }
    .bfc-book__nav { flex-wrap: wrap; }
    .bfc-section-hdr__title { font-size: 32px; }
    .bfc-section-hdr__rule { display: none; }
    .bfc-time { flex-direction: column; gap: 14px; }
    .bfc-footer { grid-template-columns: 1fr; }
    .bfc-footer__col--right { text-align: left; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .bfc-hero__title { font-size: 52px; }
    .bfc-pricing__price-num { font-size: 30px; }
  }
</style>

<script>
(function(){
  var SID = '{{ section.id }}';
  var root = document.getElementById('bfc-studio-' + SID);
  if (!root) return;
  var copyBtn = document.getElementById('bfc-suite-copy-' + SID);
  if (copyBtn){
    copyBtn.addEventListener('click', function(){
      var email = copyBtn.getAttribute('data-email') || '';
      var done = function(){
        copyBtn.classList.add('bfc-btn--copied');
        setTimeout(function(){ copyBtn.classList.remove('bfc-btn--copied'); }, 2000);
      };
      if (navigator.clipboard && navigator.clipboard.writeText){
        navigator.clipboard.writeText(email).then(done).catch(function(){ fallback(email, done); });
      } else { fallback(email, done); }
    });
  }
  function fallback(t, cb){
    try { var ta = document.createElement('textarea'); ta.value = t; ta.style.position = 'fixed'; ta.style.opacity = '0'; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); cb(); } catch(e){}
  }
})();
</script>


