{%- comment -%}
  ============================================================
  BFC EXTENDED WARRANTY — PAGE SECTION
  ============================================================
  Drop this section into a page template (e.g. page.extended-warranty.json)
  and apply that template to /pages/extended-warranty.

  Flow:
    1. Pick camera category (SLR, Point & Shoot, Medium Format,
       Polaroid/SX-70, Super 8)
    2. Enter the camera's purchase price (or paste a BFC product URL
       to auto-fill the price)
    3. Pick coverage length — SLR/POL/MF/SX/S8 get one button (+6mo,
       since base warranty is already 6mo). Point & Shoot gets four
       (+3/+6/+9/+12, since base is 3mo).
    4. Add the correct variant to cart

  Customer-account note: Shopify's new Customer Accounts (CAO) makes
  the `customer` object nil in storefront Liquid, so we can't auto-list
  someone's past orders. Two fallbacks:
    a) Deep-link to /account so they can find their order themselves.
    b) Manual order-number + email lookup that POSTs to a Base44
       endpoint (since Base44 holds the Shopify Admin refresh token
       and can resolve the camera's price from the order). The Base44
       endpoint URL is configured in section settings; if blank, the
       lookup UI is hidden.

  ⚠️ VARIANT IDS — edit `WARRANTY_VARIANTS` in the script block below
  to match the actual variant IDs from your bfc-warranty-tiers-js.liquid
  snippet. Tier max thresholds (in cents) are the canonical 11-tier set:
  [20000, 30000, 40000, 50000, 70000, 100000, 150000, 200000, 300000,
   400000, 9999999]. Categories slr/mf/pol/sx/s8 only need v6+p6.
  Category `pas` needs v3+p3, v6+p6, v9+p9, v12+p12 (PAS p6/p9 fall
  back to tier-6 IDs for tiers 7-10 per BFC's pricing rules).
============================================================
{%- endcomment -%}

{% style %}
.bfc-ew {
  --or: #E36E15;
  --go: #F4A027;
  --ce: #ABCC99;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sr: 'Cormorant Garamond', Georgia, serif;
  --sn: 'Poppins', sans-serif;
  --t:  0.2s ease;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
  padding: 64px 48px 96px;
}
.bfc-ew * { box-sizing: border-box; }
.bfc-ew-inner { max-width: 880px; margin: 0 auto; display: flex; flex-direction: column; }
/* Flow order: header/warning, then verify-your-order, then coverage length, then result, then disclaimer.
   Using flex order keeps the markup intact while presenting the entry point before the locked steps. */
.bfc-ew-header { order: 0; }
.bfc-ew-warning { order: 1; }
.bfc-ew-lookup { order: 2; }
#bfc-ew-step3 { order: 3; }
.bfc-ew-result { order: 4; }
.bfc-ew-disclaimer { order: 5; }

/* ── HEADER ────────────────────────────────── */
.bfc-ew-header {
  text-align: center;
  margin-bottom: 56px;
}
.bfc-ew-eyebrow {
  display: inline-block;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or);
  margin-bottom: 16px;
}
.bfc-ew-title {
  font-family: var(--sr);
  font-size: clamp(36px, 4.8vw, 60px);
  font-weight: 300; line-height: 1.02;
  color: var(--bk);
  margin: 0 0 18px;
  letter-spacing: -0.01em;
}
.bfc-ew-title em { font-style: italic; color: var(--or); }
.bfc-ew-lead {
  font-size: 14px; line-height: 1.7;
  color: var(--ch);
  max-width: 56ch;
  margin: 0 auto;
}

/* ── ELIGIBILITY WARNING ──
   High-contrast dark banner with three numbered rules. Sits between
   the header and the calculator so it's unmissable. */
.bfc-ew-warning {
  background: var(--bk);
  color: #fff;
  border-left: 4px solid var(--or);
  padding: 28px 32px 30px;
  margin-bottom: 40px;
}
.bfc-ew-warning-head {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 18px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(255,255,255,0.12);
}
.bfc-ew-warning-icon {
  flex-shrink: 0;
  color: var(--or);
}
.bfc-ew-warning-title {
  font-family: var(--sn);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or);
}
.bfc-ew-warning-rules {
  list-style: none;
  margin: 0; padding: 0;
  display: grid;
  gap: 16px;
}
.bfc-ew-warning-rules li {
  display: grid;
  grid-template-columns: 36px 1fr;
  gap: 14px;
  align-items: start;
}
.bfc-ew-warning-rule-num {
  font-family: var(--sm, ui-monospace, 'SF Mono', monospace);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--or);
  padding-top: 3px;
}
.bfc-ew-warning-rule-body {
  font-family: var(--sn);
  font-size: 13.5px;
  line-height: 1.6;
  color: rgba(255,255,255,0.82);
}
.bfc-ew-warning-rule-body strong {
  color: #fff;
  font-weight: 600;
}
@media (max-width: 700px) {
  .bfc-ew-warning { padding: 22px 22px 24px; }
  .bfc-ew-warning-rules li { grid-template-columns: 28px 1fr; gap: 10px; }
  .bfc-ew-warning-rule-body { font-size: 13px; }
}

/* ── STEPS ─────────────────────────────────── */
.bfc-ew-step {
  background: #fff;
  border: 1px solid rgba(32,32,9,0.1);
  margin-bottom: 16px;
}
.bfc-ew-step-head {
  display: flex; align-items: center; gap: 14px;
  padding: 22px 28px 18px;
  border-bottom: 1px solid rgba(32,32,9,0.08);
}
.bfc-ew-step-num {
  flex-shrink: 0;
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(227,110,21,0.1);
  color: var(--or);
  font-family: var(--sn);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.06em;
}
.bfc-ew-step-title {
  font-family: var(--sr);
  font-size: 20px; font-weight: 400;
  color: var(--bk);
  line-height: 1.2;
  letter-spacing: -0.005em;
}
.bfc-ew-step-body { padding: 24px 28px 26px; }
.bfc-ew-step.is-disabled { opacity: 0.5; pointer-events: none; }

/* ── STEP 1: CATEGORY OPTIONS ─────────────── */
.bfc-ew-cats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 8px;
}
.bfc-ew-cat {
  padding: 14px 16px;
  background: #fff;
  border: 1px solid rgba(32,32,9,0.18);
  cursor: pointer;
  text-align: left;
  font-family: var(--sn);
  font-size: 12px;
  color: var(--bk);
  transition: background var(--t), border-color var(--t);
  line-height: 1.3;
}
.bfc-ew-cat:hover { background: var(--cv); }
.bfc-ew-cat.is-active {
  background: var(--bk); color: #fff;
  border-color: var(--bk);
}
.bfc-ew-cat-name { font-weight: 600; letter-spacing: 0.02em; }
.bfc-ew-cat-sub {
  display: block;
  font-size: 10px;
  color: rgba(32,32,9,0.5);
  margin-top: 3px;
  letter-spacing: 0.04em;
}
.bfc-ew-cat.is-active .bfc-ew-cat-sub { color: rgba(255,255,255,0.6); }

/* ── STEP 2: PRICE INPUT ───────────────────── */
.bfc-ew-price-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}
.bfc-ew-price-field {
  position: relative;
  display: flex;
  align-items: center;
}
.bfc-ew-price-field::before {
  content: '$';
  position: absolute;
  left: 14px;
  font-family: var(--sr);
  font-size: 22px;
  color: rgba(32,32,9,0.4);
  pointer-events: none;
}
.bfc-ew-price-input {
  width: 100%;
  padding: 14px 14px 14px 34px;
  background: var(--cv);
  border: 1px solid rgba(32,32,9,0.18);
  font-family: var(--sr);
  font-size: 22px;
  font-weight: 400;
  color: var(--bk);
  outline: none;
  transition: border-color var(--t);
  -moz-appearance: textfield;
}
.bfc-ew-price-input::-webkit-outer-spin-button,
.bfc-ew-price-input::-webkit-inner-spin-button {
  -webkit-appearance: none; margin: 0;
}
.bfc-ew-price-input:focus { border-color: var(--or); }

.bfc-ew-url-toggle {
  background: none; border: none;
  font-family: var(--sn);
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--or);
  cursor: pointer;
  padding: 4px 0;
  text-align: left;
  align-self: flex-start;
}
.bfc-ew-url-toggle:hover { color: #c9600f; }
.bfc-ew-url-row {
  display: none;
  gap: 8px;
}
.bfc-ew-url-row.is-open { display: flex; }
.bfc-ew-url-input {
  flex: 1; min-width: 0;
  padding: 12px 14px;
  background: var(--cv);
  border: 1px solid rgba(32,32,9,0.18);
  font-family: var(--sn);
  font-size: 13px;
  color: var(--bk);
  outline: none;
}
.bfc-ew-url-input:focus { border-color: var(--or); }
.bfc-ew-url-btn {
  padding: 12px 20px;
  background: var(--bk); color: #fff;
  border: none;
  font-family: var(--sn);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  cursor: pointer;
  white-space: nowrap;
}
.bfc-ew-url-btn:hover { background: #000; }
.bfc-ew-url-btn:disabled { opacity: 0.5; cursor: not-allowed; }

.bfc-ew-url-status {
  font-family: var(--sn);
  font-size: 11px;
  color: var(--ch);
  margin-top: 2px;
  min-height: 14px;
}
.bfc-ew-url-status.is-error { color: #b03a2e; }
.bfc-ew-url-status.is-success { color: #2a4820; }

/* ── STEP 3: COVERAGE LENGTH ───────────────── */
.bfc-ew-lengths {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 8px;
}
.bfc-ew-length {
  padding: 14px 12px;
  background: #fff;
  border: 1px solid rgba(32,32,9,0.18);
  cursor: pointer;
  text-align: center;
  font-family: var(--sn);
  color: var(--bk);
  transition: background var(--t), border-color var(--t);
  line-height: 1.2;
}
.bfc-ew-length:hover { background: var(--cv); }
.bfc-ew-length.is-active {
  background: var(--bk); color: #fff;
  border-color: var(--bk);
}
.bfc-ew-length-months {
  display: block;
  font-family: var(--sr);
  font-size: 24px;
  font-weight: 400;
  margin-bottom: 2px;
}
.bfc-ew-length-label {
  display: block;
  font-size: 10px;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(32,32,9,0.55);
}
.bfc-ew-length.is-active .bfc-ew-length-label { color: rgba(255,255,255,0.65); }
.bfc-ew-length-info {
  display: block;
  font-size: 11px;
  margin-top: 6px;
  color: rgba(32,32,9,0.55);
}
.bfc-ew-length.is-active .bfc-ew-length-info { color: rgba(255,255,255,0.7); }

/* ── RESULT CARD ───────────────────────────── */
.bfc-ew-result {
  background: var(--bk); color: #fff;
  padding: 32px 36px;
  margin-top: 24px;
  display: none;
}
.bfc-ew-result.is-visible { display: block; }
.bfc-ew-result-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24px;
  margin-bottom: 22px;
  padding-bottom: 22px;
  border-bottom: 1px solid rgba(255,255,255,0.12);
}
.bfc-ew-result-summary { min-width: 0; flex: 1; }
.bfc-ew-result-ey {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or);
  margin-bottom: 10px;
  display: block;
}
.bfc-ew-result-tier {
  font-family: var(--sr);
  font-size: 26px; font-weight: 300;
  color: #fff;
  line-height: 1.15;
  margin-bottom: 6px;
}
.bfc-ew-result-tier em { font-style: italic; color: var(--go); }
.bfc-ew-result-coverage {
  font-family: var(--sn);
  font-size: 12px;
  color: rgba(255,255,255,0.65);
  letter-spacing: 0.02em;
}
.bfc-ew-result-price {
  flex-shrink: 0;
  text-align: right;
}
.bfc-ew-result-price-amt {
  font-family: var(--sr);
  font-size: clamp(34px, 4vw, 48px);
  font-weight: 300;
  line-height: 1;
  color: #fff;
  letter-spacing: -0.01em;
}
.bfc-ew-result-price-label {
  display: block;
  font-size: 10px;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-top: 6px;
}

/* ── ORDER ID FIELD ──
   Required input for the camera's original order number. Attached to the
   warranty cart line as a line item property so the order shows up in the
   Shopify Admin order page alongside the camera order it extends. */
.bfc-ew-order-field {
  margin-bottom: 18px;
}
.bfc-ew-order-label {
  display: flex; align-items: baseline; gap: 10px;
  font-family: var(--sn);
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8px;
}
.bfc-ew-order-required {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.16em;
  color: var(--or);
}
.bfc-ew-order-input {
  width: 100%;
  padding: 13px 16px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.18);
  font-family: var(--sn);
  font-size: 14px; font-weight: 500;
  color: #fff;
  outline: none;
  transition: border-color var(--t), background var(--t);
  letter-spacing: 0.02em;
}
.bfc-ew-order-input::placeholder { color: rgba(255,255,255,0.35); }
.bfc-ew-order-input:focus {
  border-color: var(--or);
  background: rgba(255,255,255,0.08);
}
.bfc-ew-order-input.is-invalid {
  border-color: #d96050;
  background: rgba(217,96,80,0.08);
}
.bfc-ew-order-help {
  font-size: 11px;
  color: rgba(255,255,255,0.45);
  line-height: 1.55;
  margin-top: 8px;
}

.bfc-ew-result-actions {
  display: flex; gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}
.bfc-ew-atc {
  padding: 16px 28px;
  background: var(--or); color: #fff;
  border: none;
  font-family: var(--sn);
  font-size: 12px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  cursor: pointer;
  transition: background var(--t);
  flex-grow: 1;
  min-width: 180px;
}
.bfc-ew-atc:hover { background: #c9600f; }
.bfc-ew-atc:disabled { opacity: 0.5; cursor: not-allowed; }
.bfc-ew-atc.is-success { background: #2a4820; }

/* ── CONFIRM MODAL ─────────────────────────── */
.bfc-ew-confirm-overlay {
  display: none; position: fixed; inset: 0; z-index: 1000;
  background: rgba(32,32,9,0.6); align-items: center; justify-content: center;
  padding: 20px;
}
.bfc-ew-confirm-overlay.is-open { display: flex; }
.bfc-ew-confirm {
  background: #F8F6EE; max-width: 460px; width: 100%;
  padding: 32px 30px 26px; border: 1px solid rgba(32,32,9,0.12);
}
.bfc-ew-confirm-title {
  font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 600;
  font-size: 26px; line-height: 1.1; margin: 0 0 6px; color: #202009;
}
.bfc-ew-confirm-lead { font-size: 13px; color: #4E4741; line-height: 1.5; margin: 0 0 18px; }
.bfc-ew-confirm-rows { border-top: 1px solid rgba(32,32,9,0.1); margin-bottom: 16px; }
.bfc-ew-confirm-row {
  display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
  padding: 12px 0; border-bottom: 1px solid rgba(32,32,9,0.08);
}
.bfc-ew-confirm-key {
  font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
  color: #4E4741; flex-shrink: 0;
}
.bfc-ew-confirm-val { font-size: 14px; font-weight: 600; color: #202009; text-align: right; }
.bfc-ew-confirm-warn {
  font-size: 11.5px; line-height: 1.55; color: #8a3a14;
  background: rgba(227,110,21,0.07); padding: 12px 14px; margin-bottom: 18px;
}
.bfc-ew-confirm-actions { display: flex; gap: 10px; }
.bfc-ew-confirm-btn {
  flex: 1; padding: 13px; border: none; cursor: pointer;
  font-family: 'Poppins', sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase; transition: background 0.2s ease, color 0.2s ease;
}
.bfc-ew-confirm-cancel { background: transparent; border: 1px solid rgba(32,32,9,0.2); color: #202009; }
.bfc-ew-confirm-cancel:hover { border-color: #202009; }
.bfc-ew-confirm-go { background: #E36E15; color: #fff; }
.bfc-ew-confirm-go:hover { background: #c9600f; }
.bfc-ew-result-note {
  font-size: 11px;
  color: rgba(255,255,255,0.5);
  margin-top: 14px;
  line-height: 1.5;
}

/* ── ORDER LOOKUP ──────────────────────────── */
.bfc-ew-lookup {
  margin-top: 56px;
  padding-top: 48px;
  border-top: 1px solid rgba(32,32,9,0.1);
}
.bfc-ew-lookup-head { text-align: center; margin-bottom: 24px; }
.bfc-ew-lookup-ey {
  display: inline-block;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: rgba(32,32,9,0.5);
  margin-bottom: 12px;
}
.bfc-ew-lookup-title {
  font-family: var(--sr);
  font-size: clamp(24px, 3vw, 32px);
  font-weight: 300; line-height: 1.1;
  color: var(--bk);
  margin: 0;
}
.bfc-ew-lookup-options {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px;
  margin-top: 24px;
}
.bfc-ew-lookup-card {
  background: #fff;
  border: 1px solid rgba(32,32,9,0.1);
  padding: 28px 28px 24px;
}
.bfc-ew-lookup-card-ey {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--or);
  margin-bottom: 12px;
  display: block;
}
.bfc-ew-lookup-card-title {
  font-family: var(--sr);
  font-size: 20px; font-weight: 400;
  line-height: 1.2;
  margin-bottom: 10px;
}
.bfc-ew-lookup-card-body {
  font-size: 12.5px; line-height: 1.6;
  color: var(--ch);
  margin-bottom: 16px;
}
.bfc-ew-lookup-link {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--or);
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
}
.bfc-ew-lookup-link:hover { color: #c9600f; }
.bfc-ew-lookup-form { display: flex; flex-direction: column; gap: 10px; }
.bfc-ew-lookup-input {
  width: 100%;
  padding: 11px 14px;
  background: var(--cv);
  border: 1px solid rgba(32,32,9,0.18);
  font-family: var(--sn);
  font-size: 13px;
  color: var(--bk);
  outline: none;
}
.bfc-ew-lookup-input:focus { border-color: var(--or); }
.bfc-ew-lookup-btn {
  padding: 11px 20px;
  background: var(--bk); color: #fff;
  border: none;
  font-family: var(--sn);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  cursor: pointer;
  align-self: flex-start;
}
.bfc-ew-lookup-btn:hover { background: #000; }
.bfc-ew-lookup-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.bfc-ew-lookup-status {
  font-size: 11px;
  color: var(--ch);
  line-height: 1.5;
  margin-top: 6px;
  min-height: 16px;
}
.bfc-ew-lookup-status.is-error { color: #b03a2e; }
.bfc-ew-lookup-status.is-success { color: #2a4820; }
.bfc-ew-lookup-result {
  margin-top: 12px;
  padding: 14px 16px;
  background: rgba(171,204,153,0.18);
  border-left: 2px solid var(--ce);
  font-size: 12px;
  line-height: 1.55;
  display: none;
}
.bfc-ew-lookup-result.is-visible { display: block; }
.bfc-ew-lookup-result-title { font-weight: 600; margin-bottom: 4px; color: var(--bk); }
.bfc-ew-lookup-result-meta { color: var(--ch); font-size: 11px; }
.bfc-ew-lookup-result-action {
  margin-top: 10px;
  padding: 8px 16px;
  background: var(--or); color: #fff;
  border: none;
  font-family: var(--sn);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  cursor: pointer;
}

@media (max-width: 700px) {
  .bfc-ew { padding: 40px 20px 64px; }
  .bfc-ew-step-head { padding: 18px 20px 16px; }
  .bfc-ew-step-body { padding: 20px 20px 22px; }
  .bfc-ew-result { padding: 24px 22px; }
  .bfc-ew-result-top { flex-direction: column; gap: 12px; }
  .bfc-ew-result-price { text-align: left; }
  .bfc-ew-lookup-card { padding: 22px 20px 20px; }
}

/* ── DISCLAIMER ─────────────────────────────── */
.bfc-ew-disclaimer {
  margin-top: 64px;
  padding-top: 40px;
  border-top: 1px solid rgba(32,32,9,0.1);
}
.bfc-ew-disclaimer-ey {
  display: block;
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: rgba(32,32,9,0.4);
  margin-bottom: 16px;
}
.bfc-ew-disclaimer-body {
  font-size: 11.5px;
  line-height: 1.75;
  color: rgba(32,32,9,0.5);
}
.bfc-ew-disclaimer-body p { margin: 0 0 10px; }
.bfc-ew-disclaimer-body p:last-child { margin-bottom: 0; }
.bfc-ew-disclaimer-body strong { color: rgba(32,32,9,0.7); font-weight: 600; }
{% endstyle %}

<div class="bfc-ew">
  <div class="bfc-ew-inner">

    {%- comment -%} ── HEADER ── {%- endcomment -%}
    <div class="bfc-ew-header">
