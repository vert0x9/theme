{{ 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Poppins:wght@300;400;500;600&display=swap' | stylesheet_tag }}

{%- style -%}
  .repair-hero {
    --or: #E36E15;
    --go: #F4A027;
    --ce: #ABCC99;
    --cv: #F8F6EE;
    --bk: #202009;
    --ch: #4E4741;
    --gr: #E3DDDA;

    position: relative;
    width: 100%;
    min-height: {{ section.settings.section_height }}px;
    background: var(--bk);
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .repair-hero__content {
    position: relative;
    z-index: 2;
    padding: 80px 60px;
    max-width: 55%;
  }

  .repair-hero__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(3rem, 5.5vw, 5rem);
    line-height: 1.05;
    color: var(--cv);
    letter-spacing: -0.02em;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1), transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.1s;
  }

  .repair-hero__heading .accent {
    color: var(--or);
  }

  .repair-hero__tagline {
    margin-top: 20px;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: var(--gr);
    letter-spacing: 0.02em;
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.25s;
  }

  .repair-hero__cta {
    margin-top: 40px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.4s;
  }

  .repair-hero__cta a {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--bk);
    background: var(--cv);
    padding: 12px 28px;
    text-decoration: none;
    border: none;
    transition: background 0.3s ease, color 0.3s ease, transform 0.15s ease;
  }

  .repair-hero__cta a:hover {
    background: var(--or);
    color: var(--cv);
    transform: translateY(-2px);
  }

  .repair-hero__cta a:active {
    transform: translateY(0);
  }

  .repair-hero__image {
    position: absolute;
    right: {{ section.settings.image_offset }}%;
    top: 50%;
    transform: translateY(-48%) scale(0.97);
    width: 55%;
    max-width: 700px;
    z-index: 1;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1), transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.15s;
  }

  .repair-hero.is-visible .repair-hero__image {
    opacity: 1;
    transform: translateY(-50%) scale(1);
  }

  .repair-hero.is-visible .repair-hero__heading,
  .repair-hero.is-visible .repair-hero__tagline,
  .repair-hero.is-visible .repair-hero__cta {
    opacity: 1;
    transform: translateY(0);
  }

  .repair-hero__image img {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 20px 60px rgba(0,0,0,0.4));
  }

  .repair-hero__accent-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--or), var(--go), var(--or));
  }

  @media (max-width: 768px) {
    .repair-hero {
      min-height: auto;
      flex-direction: column-reverse;
      padding: 40px 24px;
    }

    .repair-hero__content {
      max-width: 100%;
      padding: 0;
      margin-top: 30px;
    }

    .repair-hero__heading {
      font-size: clamp(2.2rem, 8vw, 3rem);
    }

    .repair-hero__image {
      position: relative;
      right: auto;
      top: auto;
      transform: scale(0.97);
      width: 80%;
      max-width: 400px;
      margin: 0 auto;
    }

    .repair-hero.is-visible .repair-hero__image {
      transform: scale(1);
    }
  }
{%- endstyle -%}

<section class="repair-hero">
  <div class="repair-hero__content">
    <h1 class="repair-hero__heading">
      {{ section.settings.heading_line_1 }}<br>
      <span class="accent">{{ section.settings.heading_accent }}</span> {{ section.settings.heading_line_2 }}
    </h1>

    {%- if section.settings.tagline != blank -%}
      <p class="repair-hero__tagline">{{ section.settings.tagline }}</p>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <div class="repair-hero__cta">
        <a href="{{ section.settings.button_link }}">{{ section.settings.button_text }}</a>
      </div>
    {%- endif -%}
  </div>

  {%- if section.settings.image != blank -%}
    <div class="repair-hero__image">
      <img
        src="{{ section.settings.image | image_url: width: 1400 }}"
        alt="{{ section.settings.image.alt | default: section.settings.heading_accent }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
      >
    </div>
  {%- endif -%}

  {%- if section.settings.show_accent_line -%}
    <div class="repair-hero__accent-line"></div>
  {%- endif -%}
</section>

<script>
  (function() {
    var hero = document.querySelector('.repair-hero');
    if (!hero) return;
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      observer.observe(hero);
    } else {
      hero.classList.add('is-visible');
    }
  })();
</script>

{% schema %}
{
  "name": "Repair Hero",
  "tag": "section",
  "class": "repair-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Get Your Camera"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Accent word (orange)",
      "default": "Repaired"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Text after accent",
      "default": "Now"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Expert service from our in-house technicians"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "START YOUR REPAIR"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Camera image"
    },
    {
      "type": "range",
      "id": "image_offset",
      "label": "Image horizontal offset (%)",
      "min": -10,
      "max": 10,
      "step": 1,
      "default": -2
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height (px)",
      "min": 400,
      "max": 700,
      "step": 20,
      "default": 520
    },
    {
      "type": "checkbox",
      "id": "show_accent_line",
      "label": "Show accent line",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Repair Hero"
    }
  ]
}
{% endschema %}
