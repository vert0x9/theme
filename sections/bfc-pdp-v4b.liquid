window.bfc4UpdateATC = function() {
  const atcText = document.getElementById('bfc4-atc-text');
  const totalEl = document.getElementById('bfc4-total');
  if (!atcText) return;

  const activeCond = document.querySelector('.bfc4-cond-btn.is-active');
  const camPriceCents = activeCond ? parseInt(activeCond.dataset.variantPrice, 10) : 0;
  const formatMoney = (cents) => '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');

  let total = camPriceCents;
  if (window.bfc4Mode === 'kit') {
    // sum starter kit items
    if (window.bfc4StarterTotal) total += window.bfc4StarterTotal;
    if (atcText) atcText.textContent = 'Add Kit to Cart — ' + formatMoney(total);
  } else {
    if (atcText) atcText.textContent = 'Add to Cart — ' + formatMoney(total);
  }
  if (totalEl) totalEl.textContent = formatMoney(total);
};

// Override bfc4SelectVariant to update soft pills + ATC + hidden form input
window.bfc4SelectVariant = function(btn) {
  if (btn.disabled) return;
  // Clear active state on BOTH the top cond-btns and bottom var-btns
  document.querySelectorAll('.bfc4-cond-btn, .bfc4-var-btn').forEach(function(b) { b.classList.remove('is-active'); });
  btn.classList.add('is-active');
  // Mirror selection across both selectors so they stay in sync visually
  if (btn.dataset.variantId) {
    document.querySelectorAll('.bfc4-cond-btn[data-variant-id="' + btn.dataset.variantId + '"], .bfc4-var-btn[data-variant-id="' + btn.dataset.variantId + '"]').forEach(function(b) {
      b.classList.add('is-active');
    });
  }
  // Keep hidden product form in sync — submitBtn.click() reads from this input
  var inp = document.getElementById('bfc4-variant-input');
  if (inp && btn.dataset.variantId) inp.value = btn.dataset.variantId;
  // Update inline price next to title
  var titlePriceEl = document.getElementById('bfc4-title-price');
  if (titlePriceEl && btn.dataset.variantPriceFmt) titlePriceEl.textContent = btn.dataset.variantPriceFmt;
  // Push variant change into STATE so bfc4Render updates both top + bottom totals,
  // and warranty tier recalculates for the new price
  if (typeof window.bfc4SetVariant === 'function') {
    window.bfc4SetVariant(btn.dataset.variantId, btn.dataset.variantPrice);
  }
  bfc4UpdateATC();
};

// Local XHR helper — independent of IIFE scope so this script tag can stand alone
function bfc4XhrLocal(url, opts) {
  opts = opts || {};
  return new Promise(function(resolve, reject) {
    var xhr = new XMLHttpRequest();
    xhr.open(opts.method || 'GET', url, true);
    xhr.withCredentials = true;
    if (opts.headers) Object.keys(opts.headers).forEach(function(k){ xhr.setRequestHeader(k, opts.headers[k]); });
    xhr.setRequestHeader('X-Requested-With','XMLHttpRequest');
    xhr.onload  = function(){ resolve({ ok: xhr.status>=200 && xhr.status<300, status: xhr.status, body: xhr.responseText }); };
    xhr.onerror = function(){ reject(new Error('Network error')); };
    xhr.send(opts.body || null);
  });
}

// Override bfc4AddToCart to handle kit/body modes
// MIRRORS v4 pattern: kit/warranty via XHR, camera ALWAYS via submitBtn.click (Release theme drawer)
window.bfc4AddToCart = function() {
  var atcButtons   = document.querySelectorAll('.bfc4-atc');  // both top and bottom
  var atcText      = document.getElementById('bfc4-atc-text');
  var stickyBtn    = document.getElementById('bfc4-sticky-btn');
  var stickyText   = document.getElementById('bfc4-sticky-btn-text');
  // Desktop sticky TOC's Add to Cart button — wired through the same flow so it
  // mirrors Adding…/Added! state instead of just sitting there inert.
  var tocAtc       = document.getElementById('bfc4-toc-atc');
  var tocAtcText   = document.getElementById('bfc4-toc-atc-text');
  var origAtcText  = atcText ? atcText.textContent : '';
  var origStickyText = stickyText ? stickyText.textContent : '';
  var origTocText  = tocAtcText ? tocAtcText.textContent : '';
  // Snapshot all bottom-button text spans so we can restore them
  var atcSpans = [];
  atcButtons.forEach(function(b) {
    var s = b.querySelector('span');
    if (s) atcSpans.push({ el: s, orig: s.textContent });
  });

  function setStatus(s) {
    atcSpans.forEach(function(sp) { sp.el.textContent = s; });
    if (atcText) atcText.textContent = s;
    if (stickyText) stickyText.textContent = s;
    if (tocAtcText) tocAtcText.textContent = s;
  }
  function lock() {
    atcButtons.forEach(function(b) { b.disabled = true; });
    if (stickyBtn) stickyBtn.disabled = true;
    if (tocAtc) tocAtc.disabled = true;
    setStatus('Adding\u2026');
  }
  function success() {
    atcButtons.forEach(function(b) { b.classList.add('is-success'); });
    if (stickyBtn) stickyBtn.classList.add('is-success');
    if (tocAtc) tocAtc.classList.add('is-success');
    setStatus('Added!');
    setTimeout(function() {
      atcButtons.forEach(function(b) { b.classList.remove('is-success'); b.disabled = false; });
      if (stickyBtn) { stickyBtn.classList.remove('is-success'); stickyBtn.disabled = false; }
      if (tocAtc) { tocAtc.classList.remove('is-success'); tocAtc.disabled = false; }
      atcSpans.forEach(function(sp) { sp.el.textContent = sp.orig; });
      if (atcText) atcText.textContent = origAtcText;
      if (stickyText) stickyText.textContent = origStickyText;
      if (tocAtcText) tocAtcText.textContent = origTocText;
    }, 2400);
  }

  function addCamera() {
    var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
    if (submitBtn) submitBtn.click();
    success();
  }

  try {
    var activeCond = document.querySelector('.bfc4-cond-btn.is-active');
    var camVid = activeCond ? activeCond.dataset.variantId : null;
    if (!camVid) {
      var camInp = document.getElementById('bfc4-variant-input');
      camVid = camInp ? camInp.value : null;
    }
    if (!camVid) { addCamera(); return; }

    // Sync hidden form input — v4b's cond-btn click doesn't propagate variantId to the form
    var inp = document.getElementById('bfc4-variant-input');
    if (inp) inp.value = camVid;

    // Build kit + warranty items (camera handled separately via native form submit)
    var items = [];
    var filmCount = 0;
    if (window.bfc4Mode === 'kit' && Array.isArray(window.bfc4StarterItems)) {
      window.bfc4StarterItems.forEach(function(it) {
        if (!it || !it.id) return;
        // Count films — Shopify Flow uses cart attribute _free_developing_credit
        // to apply the credit. We need 2+ films in the kit for it to qualify.
        // Item is a film when its column is 'Film' AND it's not the developing-credit line itself.
        var itIsFilm = (it.col || '').toLowerCase().indexOf('film') >= 0 && it.isDev !== true;
        if (itIsFilm) filmCount++;
        var props = { _kit_bundle: 'true' };
        if (it.isDev) {
          props._free_developing      = 'true';
          props._bundle_discount_type = 'free_developing';
        }
        items.push({ id: parseInt(it.id, 10), quantity: 1, properties: props });
      });
    }
    // Set cart attribute BEFORE adding line items so Shopify Flow sees it during the order.
    // Fire-and-forget — even if this fails, the line items still get added (camera always
    // ships). bfc4SyncDevCredit also re-evaluates this on cart changes as a backup.
    var xhrFnEarly = (typeof window.bfc4Xhr === 'function') ? window.bfc4Xhr : bfc4XhrLocal;
    var cartAttrs = {
      attributes: {
        '_kit_bundle': 'true',
        '_kit_camera': '{{ product.title | escape }}',
        '_free_developing_credit': filmCount >= 2 ? 'true' : 'false'
      }
    };
    xhrFnEarly('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(cartAttrs)
    });
    if (window.bfc4WarrantySelected) {
      var warrantyProps = { _warranty_type: 'extended' };
      if (window.bfc4WarrantyMonths) warrantyProps._warranty_months = String(window.bfc4WarrantyMonths);
      items.push({
        id: parseInt(window.bfc4WarrantySelected, 10),
        quantity: 1,
        properties: warrantyProps
      });
    }

    lock();

    // No kit/warranty → just add camera via native form (opens cart drawer)
    if (items.length === 0) { addCamera(); return; }

    // Add kit/warranty items ONE AT A TIME — Shopify's /cart/add.js rejects the whole batch
    // if any single variant is unavailable. Per-item adds let each succeed independently.
    // submitBtn.click() ALWAYS runs at the end so camera lands no matter what.
    var xhrFn = (typeof window.bfc4Xhr === 'function') ? window.bfc4Xhr : bfc4XhrLocal;
    function addOne(idx) {
      if (idx >= items.length) { addCamera(); return; }
      xhrFn('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [items[idx]] })
      }).then(function(res) {
        if (!res.ok) console.warn('[BFC4-V4b] item', idx, 'add returned', res.status, items[idx]);
        addOne(idx + 1);
      }).catch(function(err) {
        console.error('[BFC4-V4b] item', idx, 'XHR error:', err);
        addOne(idx + 1);
      });
    }
    addOne(0);
  } catch(e) {
    // Anything unexpected — still get camera into cart so user isn't stuck
    console.error('[BFC4-V4b] ATC outer error:', e);
    addCamera();
  }
};

// ─── Warranty modal ───
window.bfc4OpenWarranty = function() {
  const modal = document.getElementById('bfc4-w-modal');
  if (modal) modal.classList.add('is-open');
  document.body.style.overflow = 'hidden';
};
window.bfc4CloseWarranty = function() {
  const modal = document.getElementById('bfc4-w-modal');
  if (modal) modal.classList.remove('is-open');
  document.body.style.overflow = '';
};
// ── Warranty modal — selection stages to global state; main ATC adds it alongside camera+kit ──
window.bfc4SelectWarrantyOpt = function(btn) {
  document.querySelectorAll('.bfc4-w-opt').forEach(function(b) { b.classList.remove('is-active'); });
  btn.classList.add('is-active');
  var confirm = document.getElementById('bfc4-w-confirm');
  if (confirm) {
    confirm.classList.add('is-ready');
    confirm.disabled = false;
    confirm.textContent = 'Add coverage to cart';
  }
  // Stage in BOTH the global flags (read by outside ATC handler) AND STATE
  // (read by inside-IIFE bfc4Render so the buy-box total reflects warranty cost).
  window.bfc4WarrantySelected = btn.dataset.variantId || null;
  window.bfc4WarrantyMonths   = parseInt(btn.dataset.total, 10) || null;
  if (typeof window.bfc4SetExtWarranty === 'function') {
    window.bfc4SetExtWarranty({
      months:   parseInt(btn.dataset.months, 10),
      total:    parseInt(btn.dataset.total, 10),
      price:    parseInt(btn.dataset.price, 10),
      variantId: btn.dataset.variantId || null
    });
  }
};

window.bfc4ConfirmWarranty = function() {
  // Just stage the selection + show feedback. Actual cart add happens when user clicks main ATC,
  // so camera + kit + warranty all land in the cart drawer in a single popup (better UX than two).
  var confirmBtn = document.getElementById('bfc4-w-confirm');
  if (confirmBtn) {
    confirmBtn.textContent = '\u2713 Added to your kit';
    confirmBtn.style.background = '#2a4820';
    confirmBtn.style.color = '#fff';
  }
  setTimeout(function() {
    bfc4CloseWarranty();
    if (confirmBtn) {
      confirmBtn.textContent = 'Add coverage to cart';
      confirmBtn.style.background = '';
      confirmBtn.style.color = '';
    }
  }, 800);
};

// Esc to close modal
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') bfc4CloseWarranty();
});

// ─── STICKY TOC — section tracking + smooth scroll ───
(function() {
  var toc = document.getElementById('bfc4-toc');
  if (!toc) return;
  var anchors = ['top', 'chapter', 'custom', 'reviews'];
  var sections = anchors
    .map(function(id) { return { id: id, el: document.getElementById('bfc4-' + id) }; })
    .filter(function(s) { return s.el; });

  function setActive(id) {
    toc.querySelectorAll('a[data-toc]').forEach(function(a) {
      a.classList.toggle('is-active', a.dataset.toc === id);
    });
  }

  // Detect theme header height so we can sit below it (not over it)
  function getThemeHeaderHeight() {
    // Try common Shopify header selectors
    var selectors = [
      'sticky-header',
      '.shopify-section-header-sticky',
      'header.shopify-section',
      'header.site-header',
      '.header-wrapper',
      'header[role="banner"]',
      '.section-header'
    ];
    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (el) {
        var pos = getComputedStyle(el).position;
        if (pos === 'fixed' || pos === 'sticky') {
          var h = el.offsetHeight;
          if (h > 0 && h < 200) return h;
        }
      }
    }
    return 0;
  }

  var themeHeaderHeight = 0;
  function refreshHeaderOffset() {
    themeHeaderHeight = getThemeHeaderHeight();
    // Subtract 1px so the TOC overlaps the theme header by a hair — closes the
    // sub-pixel gap that appears when offsetHeight rounds to an integer but the
    // header's actual rendered bottom edge is fractional.
    toc.style.top = (themeHeaderHeight > 0 ? themeHeaderHeight - 1 : 0) + 'px';
  }

  // Smooth scroll with TOC + theme-header offset (so target isn't hidden behind both)
  toc.querySelectorAll('a[data-toc]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.getElementById('bfc4-' + a.dataset.toc);
      if (!target) return;
      e.preventDefault();
      var offset = (toc.offsetHeight || 48) + themeHeaderHeight + 12;
      var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: top, behavior: 'smooth' });
    });
  });

  // Show TOC after user has scrolled past the buy box.
  var topEl = document.getElementById('bfc4-top');

  // Detect whether a cart drawer / modal is currently open. We hide our TOC entirely
  // in that case so it doesn't poke through or compete with the drawer for attention.
  function isOverlayOpen() {
    // Common Shopify body class signals
    var bodyClasses = document.body.className || '';
    if (/\b(cart-drawer-open|drawer-open|is-cart-open|drawer--open|overlay-open|modal-open|js-drawer-open|cart-open)\b/.test(bodyClasses)) return true;
    // Common drawer element states
    var drawer = document.querySelector(
      'cart-drawer[open], cart-notification[open], .cart-drawer.is-open, .cart-drawer.active, ' +
      '.cart-drawer.drawer--active, .drawer.is-active, .drawer.is-open, [data-cart-drawer].is-open, ' +
      'cart-drawer.active'
    );
    if (drawer) return true;
    // Body scroll-locked is a strong signal a modal is up
    if (document.body.style.overflow === 'hidden' && document.body.dataset.bfc4LockedByUs !== '1') {
      // Theme may have set overflow:hidden for its own drawer/modal
      return true;
    }
    return false;
  }

  function updateTocVisibility() {
    if (isOverlayOpen()) {
      toc.classList.remove('is-visible');
      return;
    }
    if (!topEl) {
      toc.classList.toggle('is-visible', window.pageYOffset > 200);
      return;
    }
    var rect = topEl.getBoundingClientRect();
    // Show when buy box has scrolled mostly out of view (with a grace zone for the theme header)
    toc.classList.toggle('is-visible', rect.bottom < themeHeaderHeight + 80);
  }

  // Active section tracking — section whose top is closest to TOC bottom
  function updateActiveSection() {
    if (!sections.length) return;
    var threshold = themeHeaderHeight + (toc.offsetHeight || 48) + 20;
    var current = sections[0].id;
    sections.forEach(function(s) {
      var rect = s.el.getBoundingClientRect();
      if (rect.top <= threshold) current = s.id;
    });
    setActive(current);
  }

  function onScroll() {
    updateTocVisibility();
    updateActiveSection();
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', function() { refreshHeaderOffset(); onScroll(); });
  // React to drawer/modal open/close via body class mutations (no scroll needed)
  if ('MutationObserver' in window) {
    new MutationObserver(onScroll).observe(document.body, { attributes: true, attributeFilter: ['class', 'style'] });
  }
  refreshHeaderOffset();
  onScroll();
  // Re-check header after a short delay (some themes lazy-init their sticky headers)
  setTimeout(function() { refreshHeaderOffset(); onScroll(); }, 600);
})();

window.bfc4TocAddToCart = function() {
  if (typeof window.bfc4AddToCart === 'function') {
    window.bfc4AddToCart();
  }
};

</script>

