{%- comment -%}
  Auto-scroll past the announcement bar on fresh page loads.
  - Runs only on direct navigation (not back/forward/refresh) so we don't
    fight with the browser's own scroll-restoration behavior.
  - Detects common Shopify announcement bar selectors; bails if nothing matches.
  - Uses an instant scroll (no animation) so it's invisible to the user —
    the page just appears to start below the bar.
{%- endcomment -%}
<script>
(function() {
  try {
    var nav = (performance.getEntriesByType && performance.getEntriesByType('navigation')[0]) || null;
    var navType = nav ? nav.type : (performance.navigation ? ['navigate','reload','back_forward','reserved'][performance.navigation.type] : 'navigate');
    if (navType !== 'navigate') return; // Skip on reload, back/forward, etc

    function scrollPastAnnouncement() {
      var bar = document.querySelector(
        '.announcement-bar, .announcement, ' +
        '.shopify-section-announcement-bar, .shopify-section-group-header-group .announcement-bar, ' +
        '[data-section-type="announcement-bar"], .header__announcement, .site-announcement'
      );
      if (!bar) return;
      var h = bar.offsetHeight;
      // Sanity: bar should be present (>0) and short (<100px). Also skip if it's already scrolled past.
      if (h <= 0 || h > 100) return;
      if (window.pageYOffset >= h - 1) return;
      window.scrollTo(0, h);
    }

    // Wait for DOM to be ready so the bar element exists, but don't wait for full load.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scrollPastAnnouncement, { once: true });
    } else {
      scrollPastAnnouncement();
    }
  } catch (e) { /* fail silent — never block the page */ }
})();
</script>

