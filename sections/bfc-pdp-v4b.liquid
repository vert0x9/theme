    // ── Re-evaluate developing credit whenever cart changes ──────────────
  // Handles case where user adds 2 film rolls, then removes one from cart drawer
  function bfc4SyncDevCredit() {
    bfc4Xhr('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var filmCount = 0;
        (cart.items || []).forEach(function(item) {
          var props = item.properties || {};
          if (props._kit_bundle === 'true' && props._bundle_discount_type !== 'free_developing') {
            // Check if this item is a film item by looking for _kit_bundle without free_developing flag
            // We use the line item's product type or title as fallback
            var title = (item.product_title || '').toLowerCase();
            var type = (item.product_type || '').toLowerCase();
            if (title.indexOf('film') >= 0 || type.indexOf('film') >= 0) filmCount++;
          }
        });
        var shouldHaveCredit = filmCount >= 2 ? 'true' : 'false';
        // Only update if it needs to change
        var currentCredit = (cart.attributes || {})['_free_developing_credit'];
        if (currentCredit !== shouldHaveCredit) {
          bfc4Xhr('/cart/update.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ attributes: { '_free_developing_credit': shouldHaveCredit } })
          });
        }
      })
      .catch(function() {}); // silent fail
  }

  // Listen for cart updates from theme (drawer, quantity changes, removals)
  document.addEventListener('cart:updated', bfc4SyncDevCredit);
  document.addEventListener('cart:refresh', bfc4SyncDevCredit);
  // Also poll on visibility change (user returns to tab after cart changes)
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden) bfc4SyncDevCredit();
  });

  // ── Sticky Mobile ATC Bar — scroll-based (more reliable than IO across themes) ──
  var stickyBar = document.getElementById('bfc4-sticky-bar-outside');
  var mainAtc   = document.getElementById('bfc4-atc');
  if (stickyBar && mainAtc) {
    // Locate the theme footer once (it's outside the .bfc4 wrapper). Cache for performance —
    // checked on every scroll. Falls back to null if no footer found, in which case the
    // footer-visible check just won't trigger.
    var pageFooter = (function() {
      var candidates = document.querySelectorAll('footer, .footer, [role="contentinfo"], .site-footer, .footer-wrapper');
      for (var i = 0; i < candidates.length; i++) {
        if (!candidates[i].closest('.bfc4')) return candidates[i];
      }
      return null;
    })();

    function bfc4UpdateStickyBar() {
      if (window.innerWidth > 900) {
        stickyBar.classList.remove('is-visible');
        return;
      }
      // Hide while a cart drawer or modal is open
      var bodyClasses = document.body.className || '';
      if (/\b(cart-drawer-open|drawer-open|is-cart-open|drawer--open|overlay-open|modal-open|js-drawer-open|cart-open)\b/.test(bodyClasses)) {
        stickyBar.classList.remove('is-visible');
        return;
      }
      var openDrawer = document.querySelector('cart-drawer[open], cart-notification[open], .cart-drawer.is-open, .cart-drawer.active, .drawer.is-active, .drawer.is-open');
      if (openDrawer) {
        stickyBar.classList.remove('is-visible');
        return;
      }
      var vh = window.innerHeight;
      // Hide if ANY ATC button (top buy box OR bottom buy block) is currently in viewport.
      // No point pinning a sticky CTA when the user is already looking at the real ATC.
      var atcButtons = document.querySelectorAll('.bfc4-atc');
      for (var i = 0; i < atcButtons.length; i++) {
        var rect = atcButtons[i].getBoundingClientRect();
        if (rect.bottom > 0 && rect.top < vh) {
          stickyBar.classList.remove('is-visible');
          return;
        }
      }
      // Hide once the user has scrolled into the theme footer area — the BFC content
      // has ended and pinning a CTA over the footer's links/copyright feels intrusive.
      if (pageFooter) {
        var fRect = pageFooter.getBoundingClientRect();
        if (fRect.top < vh) {
          stickyBar.classList.remove('is-visible');
          return;
        }
      }
      // Default on mobile: show. The user is somewhere in the middle of the page where
      // no ATC is visible and they haven't reached the footer yet.
      stickyBar.classList.add('is-visible');
    }
    window.addEventListener('scroll', bfc4UpdateStickyBar, { passive: true });
    window.addEventListener('resize', bfc4UpdateStickyBar);
    // Listen for body class mutations (cart drawer open/close)
    if ('MutationObserver' in window) {
      new MutationObserver(bfc4UpdateStickyBar).observe(document.body, { attributes: true, attributeFilter: ['class', 'style'] });
    }
    bfc4UpdateStickyBar();
  }

  // ── Photo gallery lightbox ────────────────────────────
  // srcs/cur held on window so external callers (hero slides) can repopulate before opening.
  (function() {
    window.__bfc4Lb = window.__bfc4Lb || { srcs: [], cur: 0 };
    var grid = document.getElementById('ba-shot-grid');
    if (grid) {
      var anchors = grid.querySelectorAll('a[data-lightbox="gallery"]');
      anchors.forEach(function(a) { window.__bfc4Lb.srcs.push(a.getAttribute('href')); });
    }

    window.bfc4Lightbox = function(event, idx) {
      if (event) { event.preventDefault(); event.stopPropagation(); }
      var lb = window.__bfc4Lb;
      if (!lb.srcs.length) return;
      lb.cur = idx;
      var box = document.getElementById('ba-lightbox');
      var img = document.getElementById('ba-lightbox-img');
      var wrap = document.getElementById('ba-lightbox-imgwrap');
      var counter = document.getElementById('ba-lightbox-counter');
      // Reset zoom + pan on open / nav
      if (img) {
        img.classList.remove('is-zoomed');
        img.src = lb.srcs[lb.cur];
      }
      if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
      if (counter) counter.textContent = (lb.cur + 1) + ' / ' + lb.srcs.length;
      if (box) box.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      // Preload all srcs so subsequent arrow nav is instant (browser caches them)
      lb.srcs.forEach(function(src) { var pre = new Image(); pre.src = src; });
    };

    window.bfc4LightboxClose = function(event, force) {
      // Force=true (close X button or Escape key) always closes.
      // Otherwise: close only when click is on background space (not on a button or the image).
      if (force !== true) {
        if (!event || !event.target) return;
        var t = event.target;
        if (t.tagName === 'IMG') return;          // image click → toggles zoom
        if (t.closest('button')) return;          // arrow/close button click → handled by their handlers
      }
      var box = document.getElementById('ba-lightbox');
      var img = document.getElementById('ba-lightbox-img');
      var wrap = document.getElementById('ba-lightbox-imgwrap');
      if (img) img.classList.remove('is-zoomed');
      if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
      if (box) box.classList.remove('is-open');
      document.body.style.overflow = '';
    };

    window.bfc4LightboxNav = function(event, dir) {
      if (event) event.stopPropagation();
      var lb = window.__bfc4Lb;
      if (!lb.srcs.length) return;
      lb.cur = (lb.cur + dir + lb.srcs.length) % lb.srcs.length;
      var img = document.getElementById('ba-lightbox-img');
      var wrap = document.getElementById('ba-lightbox-imgwrap');
      var counter = document.getElementById('ba-lightbox-counter');
      // Reset zoom when navigating
      if (img) {
        img.classList.remove('is-zoomed');
        img.src = lb.srcs[lb.cur];
      }
      if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
      if (counter) counter.textContent = (lb.cur + 1) + ' / ' + lb.srcs.length;
    };

    // Click image to toggle zoom. When zoomed in, the image expands beyond the
    // wrapper's bounds and the wrapper's overflow:auto lets the user pan by scrolling
    // (or swiping on mobile). Zoom-in centers the scroll on the click point.
    window.bfc4LightboxToggleZoom = function(event) {
      event.stopPropagation();
      var img = document.getElementById('ba-lightbox-img');
      var wrap = document.getElementById('ba-lightbox-imgwrap');
      if (!img || !wrap) return;
      if (img.classList.contains('is-zoomed')) {
        img.classList.remove('is-zoomed');
        wrap.scrollLeft = 0;
        wrap.scrollTop = 0;
      } else {
        var rect = img.getBoundingClientRect();
        var fracX = (event.clientX - rect.left) / rect.width;
        var fracY = (event.clientY - rect.top) / rect.height;
        img.classList.add('is-zoomed');
        // After class change reflows the image, scroll wrapper to center the click point
        requestAnimationFrame(function() {
          var newW = img.offsetWidth;
          var newH = img.offsetHeight;
          var ww = wrap.clientWidth;
          var wh = wrap.clientHeight;
          wrap.scrollLeft = Math.max(0, fracX * newW - ww / 2);
          wrap.scrollTop  = Math.max(0, fracY * newH - wh / 2);
        });
      }
    };

    // Wire click on lightbox image to toggle zoom (replaces old inline onclick)
    (function() {
      var img = document.getElementById('ba-lightbox-img');
      if (img) img.addEventListener('click', window.bfc4LightboxToggleZoom);
    })();

    // Hero slide click → repopulate lightbox srcs from current slides, then open
    window.bfc4OpenHeroLightbox = function(idx) {
      var slideImgs = document.querySelectorAll('.bfc4-slide img');
      if (!slideImgs.length) return;
      window.__bfc4Lb.srcs = Array.prototype.map.call(slideImgs, function(img) {
        return img.dataset.zoom || img.currentSrc || img.src;
      });
      bfc4Lightbox(null, idx || 0);
    };

    // Shot-on grid click → repopulate lightbox srcs from the grid's anchor hrefs,
    // then open. Necessary because __bfc4Lb.srcs is shared with the hero lightbox,
    // and a prior hero open would have replaced srcs with hero images. Without this
    // re-populate, clicking a Shot On thumb after a hero open would show hero photos.
    window.bfc4OpenShotLightbox = function(event, idx) {
      if (event) { event.preventDefault(); event.stopPropagation(); }
      var grid = document.getElementById('ba-shot-grid');
      if (!grid) return;
      var anchors = grid.querySelectorAll('a[data-lightbox="gallery"]');
      if (!anchors.length) return;
      window.__bfc4Lb.srcs = Array.prototype.map.call(anchors, function(a) {
        return a.getAttribute('href');
      });
      bfc4Lightbox(null, idx || 0);
    };

    document.addEventListener('keydown', function(e) {
      var box = document.getElementById('ba-lightbox');
      if (!box || !box.classList.contains('is-open')) return;
      if (e.key === 'Escape') bfc4LightboxClose(null, true);
      else if (e.key === 'ArrowLeft') bfc4LightboxNav(null, -1);
      else if (e.key === 'ArrowRight') bfc4LightboxNav(null, 1);
    });

    // Wire hero slide images to open the lightbox
    document.querySelectorAll('.bfc4-slide img').forEach(function(img, i) {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', function(e) {
