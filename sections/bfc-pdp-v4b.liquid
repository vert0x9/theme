<script>
(function() {
  'use strict';

  // ── XHR helper (bypasses Judge.me monkey-patching of window.fetch) ─────
  function bfc4Xhr(url, opts) {
    opts = opts || {};
    return new Promise(function(resolve, reject) {
      var xhr = new XMLHttpRequest();
      xhr.open(opts.method || 'GET', url, true);
      xhr.withCredentials = true;
      if (opts.headers) Object.keys(opts.headers).forEach(function(k){xhr.setRequestHeader(k, opts.headers[k]);});
      xhr.setRequestHeader('X-Requested-With','XMLHttpRequest');
      xhr.onload = function() {
        resolve({
          ok: xhr.status>=200 && xhr.status<300,
          status: xhr.status,
          json: function(){ try{return Promise.resolve(JSON.parse(xhr.responseText));}catch(e){return Promise.resolve({});} },
          text: function(){ return Promise.resolve(xhr.responseText); }
        });
      };
      xhr.onerror = function(){ reject(new Error('Network error')); };
      xhr.send(opts.body || null);
    });
  }
  // Expose for outside-IIFE handlers (kit/body mode ATC, warranty modal)
  window.bfc4Xhr = bfc4Xhr;

  var STATE = {
    variantId:    {{ current_variant.id }},
    variantPrice: {{ current_variant.price }},
    kit: {},
    extWarranty: null
  };

  // Expose minimal STATE setters so outside-IIFE handlers can update variant + trigger render
  window.bfc4SetVariant = function(id, price) {
    if (id != null)    STATE.variantId    = parseInt(id, 10);
    if (price != null) STATE.variantPrice = parseInt(price, 10);
    if (typeof bfc4UpdateWarrantyTier === 'function') bfc4UpdateWarrantyTier(STATE.variantPrice);
    if (typeof bfc4Render === 'function') bfc4Render();
  };

  // Setter for extended warranty — called by the warranty modal (outside this IIFE).
  // Pass null to clear. Updates STATE so bfc4Render reflects warranty cost in totals.
  window.bfc4SetExtWarranty = function(opts) {
    if (opts == null) {
      STATE.extWarranty = null;
    } else {
      STATE.extWarranty = {
        months:    opts.months,
        total:     opts.total,
        price:     opts.price,
        variantId: opts.variantId
      };
