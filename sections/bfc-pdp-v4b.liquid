  // ── Popup ────────────────────────────────────────
  window.baOpenPopup = function(catId) {
    var data = document.getElementById('ba-popup-data-' + catId);
    if (!data) return;
    document.getElementById('ba-popup-title').textContent = data.dataset.title;
    var desc = data.dataset.desc || '';
    document.getElementById('ba-popup-desc').innerHTML = baFormatDesc(desc);
    var imgs = data.dataset.imgs ? data.dataset.imgs.split('||') : [];
    baRenderPopupImgs(imgs);
    document.getElementById('ba-popup-overlay').classList.add('is-open');
    document.body.style.overflow = 'hidden';
    // Update arrow disabled states AFTER overlay is visible — when this fn runs,
    // the popup is still display:none so offsetWidth/scrollWidth are 0, which
    // makes baUpdatePopupArrows incorrectly disable both arrows. Defer to next frame
    // so we read real layout dimensions.
    requestAnimationFrame(function() {
      requestAnimationFrame(baUpdatePopupArrows);
    });
  };

  // Render images into the popup. Grid layout adapts to count:
  // 1 photo = full width, 2 = halves, 3 = thirds, 4+ = horizontal carousel with arrows.
  function baRenderPopupImgs(imgs) {
    var container = document.getElementById('ba-popup-imgs');
    if (!container) return;
    var wrap = container.parentElement;
    if (!imgs.length) {
      container.innerHTML = '';
      container.removeAttribute('data-count');
      container.classList.remove('is-carousel');
      if (wrap) wrap.classList.remove('has-more');
      return;
    }
    container.innerHTML = imgs.map(function(src) {
      return '<img src="' + src + '" loading="lazy"/>';
    }).join('');
    // Drive grid layout via data-count (clamped 1..3) + is-carousel for >3
    container.dataset.count = String(Math.min(imgs.length, 3));
    container.classList.toggle('is-carousel', imgs.length > 3);
    if (wrap) wrap.classList.toggle('has-more', imgs.length > 3);
    container.scrollLeft = 0;
    // NOTE: baUpdatePopupArrows() intentionally not called here — it's deferred
    // to after the popup is visible (see baOpenPopup). Calling here while the
    // popup is still hidden would read 0-width and incorrectly disable both arrows.
  }

  window.baPopupSlide = function(dir) {
    var container = document.getElementById('ba-popup-imgs');
    if (!container) return;
    var pageWidth = container.offsetWidth;
    // Bail early if the container hasn't laid out yet — would make scrollBy a no-op
    if (pageWidth <= 0) return;
    var before = container.scrollLeft;
    // Try modern API with options first; fall back to legacy direct scrollLeft.
    // Some older Safari + edge cases reject the options-object form silently.
    try {
      container.scrollBy({ left: dir * pageWidth, behavior: 'smooth' });
    } catch (e) {
      container.scrollLeft = before + dir * pageWidth;
    }
    // After a brief moment, verify the scroll actually moved. If not, force it.
    setTimeout(function() {
      if (Math.abs(container.scrollLeft - before) < 1) {
        // Smooth-scroll may have been suppressed (e.g. user prefers-reduced-motion,
        // or browser doesn't support smooth on flex/grid containers). Force jump.
        container.scrollLeft = before + dir * pageWidth;
      }
      baUpdatePopupArrows();
    }, 350);
  };

  function baUpdatePopupArrows() {
    var container = document.getElementById('ba-popup-imgs');
    if (!container) return;
    var wrap = container.parentElement;
    if (!wrap) return;
    var prev = wrap.querySelector('.ba-popup-imgs-arr.is-prev');
    var next = wrap.querySelector('.ba-popup-imgs-arr.is-next');
    if (prev) prev.disabled = container.scrollLeft <= 1;
    if (next) next.disabled = container.scrollLeft + container.offsetWidth >= container.scrollWidth - 1;
  }
  // Update arrow states as user scrolls the carousel manually
  document.addEventListener('DOMContentLoaded', function() {
    var c = document.getElementById('ba-popup-imgs');
    if (c) c.addEventListener('scroll', baUpdatePopupArrows, { passive: true });
  });

  // Parse a stripped product description into prose paragraphs + a specs <dl>.
  // Handles three layouts: (a) "Key: Value" inline, (b) "Key" block followed by
  // a separate value block (Portra-style: <p>Size</p><p>35mm / 120</p>),
  // (c) flat concatenated text from strip_html with no separators.
  function baFormatDesc(raw) {
    if (!raw) return '';
    var text = String(raw)
      .replace(/\|\|PARA\|\|/g, '\n\n')
      .replace(/\|\|LINE\|\|/g, '\n')
      .replace(/\u00A0/g, ' ');
    var blocks = [];
    text.split(/\n+/).forEach(function(line) {
      line = line.trim();
      if (!line) return;
      var pieces = line.split(/(?=[A-Z][a-z][A-Za-z]{0,15}(?:\s[A-Z]?[A-Za-z]+){0,3}:\s)/);
      pieces.forEach(function(p) { p = p.trim(); if (p) blocks.push(p); });
    });
    function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function isShortLabel(s) {
      // Short capitalized phrase, 1-3 words, no terminal punctuation — treat as a spec label
      if (s.length < 2 || s.length > 18) return false;
      if (!/^[A-Z]/.test(s)) return false;
      if (/[.!?:]$/.test(s)) return false;
      if (/[\d]/.test(s)) return false; // labels rarely contain digits
      var wordCount = s.trim().split(/\s+/).length;
      return wordCount <= 3;
    }
    var proseHtml = '';
    var specsHtml = '';
    var specRe = /^([A-Z][A-Za-z\s\/\-]{0,28}):\s*(.+)$/;
    var i = 0;
    while (i < blocks.length) {
      var block = blocks[i];
      var m = block.match(specRe);
      if (m && m[1].length >= 2 && m[1].length <= 25 && m[1].indexOf('.') === -1) {
        // (a) "Key: Value" all in one block
        specsHtml += '<dt>' + escHtml(m[1].trim()) + '</dt><dd>' + escHtml(m[2].trim()) + '</dd>';
        i++;
      } else if (isShortLabel(block) && i + 1 < blocks.length) {
        // (b) Bare label block followed by value block (e.g. <p>Type</p><p>Color Negative Film</p>)
        specsHtml += '<dt>' + escHtml(block) + '</dt><dd>' + escHtml(blocks[i+1]) + '</dd>';
        i += 2;
      } else {
        proseHtml += '<p>' + escHtml(block) + '</p>';
        i++;
      }
    }
    var html = proseHtml;
    if (specsHtml) html += '<dl class="ba-popup-specs">' + specsHtml + '</dl>';
    return html;
  }
