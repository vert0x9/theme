/* ── MOBILE ───────────────────────────────── */
@media (max-width: 900px) {
  .bfc4-split { grid-template-columns: 1fr; min-height: 0; }
  /* Cap mobile hero at a reasonable fixed height instead of 100vw — large phones
     (414px+) were rendering the hero ~400px tall, pushing everything below the fold.
     The photo-wrap loses its 1/1 aspect ratio in favor of a fixed 320px height;
     the slide img already uses object-fit:cover on mobile so it fills cleanly. */
  .bfc4-left { position: relative; width: 100%; height: auto; max-height: none; }
  .bfc4-photo-wrap { aspect-ratio: auto; height: 320px; }
  .bfc4-arrow { display: none; }
  .bfc4-right { padding: 20px 20px 48px; gap: 14px; overflow-y: visible; }
  .bfc4-title { font-size: 28px; }
  .bfc4 .bfc4-title-price { font-size: 28px; }
  .bfc4 .bfc4-header { gap: 8px; }
  /* Kit items: more readable on mobile — 2 columns instead of 4, bigger imagery + text.
     The cramped 9px-text 4-col grid was hard to read; 2 cols gives each tile real estate. */
  .bfc4-tiles { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .bfc4-tile-img-wrap { aspect-ratio: 4/3; }
  .bfc4-tile-body { padding: 10px 12px; gap: 4px; }
  .bfc4-tile-name { font-size: 12px; line-height: 1.3; }
  .bfc4-tile-price { font-size: 12px; }
  .bfc4-tile-orig { font-size: 10px; }
  .bfc4-tile-change { display: none; }
  .bfc4-custom { padding: 36px 20px 0; }
  .bfc4 .ba-columns { display: flex; flex-direction: column; gap: 0; width: 100%; }
  .bfc4 .ba-col { background: #fff; border: 1px solid rgba(32,32,9,0.1); margin-bottom: 8px; width: 100%; }
  .bfc4 .ba-col-head { cursor: pointer; border-bottom: none; }
  .bfc4 .ba-col-head:hover { background: rgba(32,32,9,0.02) !important; }
  .bfc4 .ba-col-chevron { display: block !important; }
  .bfc4 .ba-col-body { display: none !important; grid-template-columns: 1fr !important; padding: 0; border-top: 1px solid rgba(32,32,9,0.08); }
  .bfc4 .ba-col.is-open .ba-col-body { display: block !important; }
  .bfc4 .ba-mini-card { display: grid !important; grid-template-columns: 52px 1fr; flex-direction: unset; border: none; border-bottom: 1px solid rgba(32,32,9,0.07) !important; }
  .bfc4 .ba-col-body .ba-mini-img-wrap { width: 52px !important; aspect-ratio: unset !important; height: 52px !important; min-height: 52px !important; border-right: 1px solid rgba(32,32,9,0.06) !important; border-bottom: none !important; flex-shrink: 0 !important; }
  .bfc4 .ba-col-body .ba-mini-img { width: 52px !important; height: 52px !important; min-height: 52px !important; }
  .bfc4 .ba-col-body .ba-mini-card { display: grid !important; flex-direction: unset !important; grid-template-columns: 52px 1fr !important; }
  .bfc4 .ba-col-body .ba-mini-body { flex-direction: row !important; align-items: center !important; padding: 10px 12px !important; }
  .bfc4 .ba-col-body .ba-mini-right { text-align: right !important; }
  .bfc4 .ba-col-body .ba-mini-name { white-space: normal !important; text-align: left !important; height: auto !important; -webkit-line-clamp: 2 !important; }
  .bfc4 .ba-mini-body { flex-direction: row; align-items: center; padding: 10px 12px; }
  .bfc4 .ba-mini-right { text-align: right; }
  .bfc4-promos { padding: 0 20px; }
  .bfc4-below-checkout { padding: 24px 20px 40px; overflow: hidden; }
  .bfc4-selected-row { flex-direction: column; gap: 16px; }
  .bfc4-selected-items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    overflow-x: visible;
    flex-wrap: unset;
  }
  .bfc4-sel-item { width: 100%; }
  .bfc4-sel-item-img { width: 100%; height: auto; aspect-ratio: 4/3; }
  .bfc4-below-atc { width: 100%; max-width: 100%; }
  .bfc4-below-atc .bfc4-price { font-size: 32px; }
  .bfc4 .ba-shot-head { padding: 36px 20px 16px; flex-direction: column; gap: 4px; }
  .bfc4 .ba-shot-title { font-size: 28px; }
  .bfc4 .ba-shot-grid { grid-template-columns: repeat(3, 1fr); }
  .bfc4 .ba-restore-top { grid-template-columns: 1fr; gap: 24px; padding: 32px 20px 24px; }
  .bfc4 .ba-restore-stats { grid-template-columns: repeat(3, 1fr); }
  .bfc4 .ba-restore-steps { grid-template-columns: 1fr 1fr; }
  .bfc4 .ba-r-step { padding: 20px 16px; }
  .bfc4 .ba-specs { padding: 56px 20px; }
  .bfc4 .ba-specs-head { margin-bottom: 32px; }
  .bfc4 .ba-specs-title { font-size: 32px; }
  .bfc4 .ba-specs-table { grid-template-columns: 1fr; }
  .bfc4 .ba-spec { grid-template-columns: 110px 1fr; padding: 14px 18px; }
  .bfc4 .ba-spec-val { font-size: 14px; }
  .bfc4-mini-specs { grid-template-columns: 1fr; }
  .bfc4-mini-spec:nth-child(odd) { padding-right: 0; }
  .bfc4-mini-spec:nth-child(even) { padding-left: 0; border-left: none; }
  #bfc4-warranty-info > div { grid-template-columns: 1fr !important; padding: 32px 20px !important; }
  #bfc4-warranty-info > div > div:first-child { padding-right: 0 !important; border-right: none !important; padding-bottom: 24px; border-bottom: 1px solid rgba(32,32,9,0.1); }
  #bfc4-warranty-info > div > div:last-child { padding-left: 0 !important; padding-top: 24px; }
  .bfc4 .ba-film-promo-icon { display: none; }
  .bfc4-nav-links { flex-direction: column; gap: 0; }
  .bfc4-customize { border-bottom: 1px solid rgba(32,32,9,0.07); padding: 10px 0; width: 100%; justify-content: space-between; }
  .bfc4 .ba-film-promo-text { flex: 4; }
  .bfc4 .ba-film-promo-status { flex: 1; text-align: right; font-size: 9px; }
}

/* ── ABOVE-FOLD VH-BASED SCALING (desktop only) ──────────
   Fix: on 15"+ laptops the right column was cramped at the top with
   awkward empty space below the ATC, while the camera image (50vw,
   1:1) filled the taller column. Clamps below anchor the MIN value to
   current spacing so 12-13" laptops (~720-820vh) keep the exact same
   look — clamp falls to min. On taller viewports the column gets
   progressively more breathing room (padding, gaps, button heights all
   scale with vh). Gated by min-width: 901px so mobile keeps its
   existing pixel overrides untouched. */
@media (min-width: 901px) {
  .bfc4-right {
    padding-top: clamp(22px, 2.8vh, 44px);
    gap: clamp(20px, 2.4vh, 30px);
  }
  .bfc4 .bfc4-header { gap: clamp(4px, 0.6vh, 10px); }
  .bfc4-trust-strip {
    margin-top: clamp(8px, 1.1vh, 14px);
    padding-top: clamp(10px, 1.4vh, 16px);
  }
  .bfc4 .bfc4-buy { gap: clamp(16px, 2vh, 24px); }
  .bfc4 .bfc4-eyebrow-std { margin-bottom: clamp(10px, 1.3vh, 16px); }
  .bfc4 .bfc4-cond-btn { padding-block: clamp(9px, 1.2vh, 14px); }
  .bfc4 .bfc4-po-btn { padding-block: clamp(12px, 1.6vh, 18px); }
  .bfc4 .bfc4-ks-head { padding-block: clamp(8px, 1.1vh, 14px); }
  .bfc4 .bfc4-ks-item { padding-block: clamp(8px, 1.1vh, 14px); }
  .bfc4 .bfc4-ks-perk { padding-block: clamp(7px, 1vh, 12px); }
  .bfc4 .bfc4-atc { padding: clamp(18px, 2.4vh, 26px); }
}

/* ── Sticky Mobile ATC Bar ────────────────── */
.bfc4-sticky-bar {
  /* Re-declare brand vars since this lives OUTSIDE the .bfc4 wrapper */
  --or: #E36E15;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sn: 'Poppins', sans-serif;
  display: none; position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--cv); border-top: 1px solid rgba(32,32,9,0.15);
  padding: 10px 16px;
  /* Low z-index so cart drawer layers above */
  z-index: 30;
  align-items: center; gap: 12px; box-shadow: 0 -2px 12px rgba(0,0,0,0.08);
  font-family: var(--sn);
  box-sizing: border-box;
}
.bfc4-sticky-bar * { box-sizing: border-box; }
.bfc4-sticky-info { flex: 1; min-width: 0; }
.bfc4-sticky-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--bk); margin: 0; }
.bfc4-sticky-meta { display: flex; align-items: center; gap: 6px; margin-top: 1px; }
.bfc4-sticky-grade { font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ch); }
.bfc4-sticky-price { font-size: 13px; font-weight: 700; color: var(--or); }
.bfc4-sticky-btn { background: var(--or); color: #fff; border: none; padding: 12px 24px; font-size: 10px; font-weight: 700; font-family: var(--sn); text-transform: uppercase; letter-spacing: 0.14em; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
.bfc4-sticky-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.bfc4-sticky-bar.is-visible { display: flex; }
@media (max-width: 600px) {
  /* Tighten everything on small screens so the bar fits without horizontal scroll.
     Name truncates with ellipsis; meta line stays single-row with shrunken text. */
  .bfc4-sticky-bar { padding: 8px 12px; gap: 10px; }
  .bfc4-sticky-info { min-width: 0; overflow: hidden; }
  .bfc4-sticky-name { font-size: 11px; }
  .bfc4-sticky-meta { gap: 5px; min-width: 0; flex-wrap: nowrap; overflow: hidden; }
  .bfc4-sticky-grade { font-size: 8.5px; white-space: nowrap; }
  .bfc4-sticky-price { font-size: 12px; white-space: nowrap; }
  .bfc4-sticky-btn { padding: 10px 14px; font-size: 9.5px; letter-spacing: 0.1em; }
}

/* ── PHOTO LIGHTBOX (outside .bfc4 wrapper) ────────── */
.ba-lightbox {
  --or: #E36E15;
  --sn: 'Poppins', sans-serif;
  position: fixed; inset: 0;
  background: rgba(32,32,9,0.94);
  z-index: 99998;
  display: none;
  align-items: center; justify-content: center;
  padding: 60px 40px;
  cursor: zoom-out;
  font-family: var(--sn);
  box-sizing: border-box;
}
.ba-lightbox * { box-sizing: border-box; }
.ba-lightbox.is-open { display: flex; }
.ba-lightbox-inner {
  position: relative;
  width: 100%; height: 100%;
  max-width: 100vw; max-height: 100vh;
  cursor: default;
  display: flex; align-items: center; justify-content: center;
}
/* Wrapper around image — handles overflow when zoomed so user can pan via scrolling */
.ba-lightbox-imgwrap {
  position: relative;
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  overflow: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.3) transparent;
}
.ba-lightbox-imgwrap::-webkit-scrollbar { width: 8px; height: 8px; }
.ba-lightbox-imgwrap::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.3); }
.ba-lightbox-img {
  max-width: 100%; max-height: 100%;
  object-fit: contain;
  display: block;
  background: #000;
  cursor: zoom-in;
  transition: max-width 0.2s ease, max-height 0.2s ease;
  user-select: none;
  -webkit-user-drag: none;
}
.ba-lightbox-img.is-zoomed {
  cursor: grab;
  max-width: 250%;
  max-height: 250%;
}
.ba-lightbox-img.is-zoomed:active { cursor: grabbing; }
.ba-lightbox-close {
  position: fixed; top: 20px; right: 20px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: #fff;
  width: 40px; height: 40px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s ease;
  z-index: 100000;
}
.ba-lightbox-close:hover { background: rgba(255,255,255,0.2); }
.ba-lightbox-arrow {
  position: fixed; top: 50%;
  transform: translateY(-50%);
  width: 56px; height: 56px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s ease;
  z-index: 100000;
}
.ba-lightbox-arrow:hover { background: rgba(255,255,255,0.2); }
.ba-lightbox-arrow.is-prev { left: 24px; }
.ba-lightbox-arrow.is-next { right: 24px; }
.ba-lightbox-counter {
  position: fixed; bottom: 20px; left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.7);
  font-size: 11px; letter-spacing: 0.12em;
  font-family: var(--sn);
  z-index: 100000;
}
@media (max-width: 900px) {
  .ba-lightbox { padding: 60px 8px; }
  .ba-lightbox-arrow.is-prev { left: 8px; }
  .ba-lightbox-arrow.is-next { right: 8px; }
  .ba-lightbox-arrow { width: 44px; height: 44px; background: rgba(255,255,255,0.15); }
  .ba-lightbox-close { top: 12px; right: 12px; }
}


/* ── BADGES (replaces mini-specs) ──────────── */
.bfc4-badges {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px 18px;
  padding: 4px 0;
}
.bfc4-badge {
  display: flex; align-items: center; gap: 10px;
  font-family: var(--sn);
  font-size: 11.5px;
  color: var(--ch);
  line-height: 1.4;
}
.bfc4-badge-icon {
  width: 16px; height: 16px;
  flex-shrink: 0;
  fill: var(--or);
}

/* ── COMPACT REFURBISHMENT STRIP (right col, above-fold) ── */
.bfc4-trust-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 4px 14px;
  list-style: none;
  margin: 8px 0 0;
  padding: 10px 0 0;
  border-top: 1px solid rgba(32,32,9,0.08);
}
.bfc4-trust-strip li {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--sn);
  font-size: 10.5px;
  line-height: 1.3;
  color: var(--ch);
  letter-spacing: 0.01em;
  white-space: nowrap;
}
.bfc4-trust-strip li svg { color: var(--or); flex-shrink: 0; }
/* The "Restored inside & out" item is a button that opens a restoration-info popup —
   serves as a backup affordance for single-variant products where the Condition (i)
   isn't rendered. Visually matches a regular trust-strip item but with a tiny (i)
   trailing the text and an underline on hover. */
.bfc4-trust-strip li .bfc4-trust-link {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--sn);
  font-size: inherit;
  line-height: inherit;
  color: inherit;
  letter-spacing: inherit;
  white-space: nowrap;
  transition: color 0.15s;
}
.bfc4-trust-strip li .bfc4-trust-link .bfc4-trust-check { color: var(--or); }
.bfc4-trust-strip li .bfc4-trust-link .bfc4-trust-info {
  color: rgba(32,32,9,0.4);
  transition: color 0.15s;
}
.bfc4-trust-strip li .bfc4-trust-link:hover {
  color: var(--bk);
}
.bfc4-trust-strip li .bfc4-trust-link:hover span {
  text-decoration: underline;
  text-underline-offset: 3px;
}
.bfc4-trust-strip li .bfc4-trust-link:hover .bfc4-trust-info {
  color: var(--bk);
}
@media (max-width: 700px) {
  /* On narrow screens, allow wrap to 2 rows so items don't truncate */
  .bfc4-trust-strip { gap: 4px 12px; }
  .bfc4-trust-strip li { font-size: 10px; }
}

/* ── STICKY TOC — Baymard-validated PDP nav pattern ── */
/* Scroll-based show/hide is more reliable than IntersectionObserver for cross-theme. */
.bfc4-toc {
  /* Re-declare brand vars since this element lives OUTSIDE the .bfc4 wrapper */
  --or: #E36E15;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --sn: 'Poppins', sans-serif;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  /* Low z-index so cart drawer / theme menu / popups all layer above it */
  z-index: 30;
  background: var(--cv);
  border-bottom: 1px solid rgba(32,32,9,0.12);
  font-family: var(--sn);
  transform: translateY(-100%);
  transition: transform 0.25s ease;
  pointer-events: none;
  visibility: hidden;
  box-sizing: border-box;
}
.bfc4-toc * { box-sizing: border-box; }
.bfc4-toc.is-visible {
  transform: translateY(0);
  pointer-events: auto;
  visibility: visible;
}
.bfc4-toc-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 11px 28px;
  max-width: 1400px;
  margin: 0 auto;
}
.bfc4-toc-links {
  display: flex;
  gap: 28px;
  list-style: none;
  margin: 0;
  padding: 0;
  flex-wrap: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
}
.bfc4-toc-links::-webkit-scrollbar { display: none; }
.bfc4-toc-links a {
  display: inline-block;
  padding: 4px 0;
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ch);
  text-decoration: none;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: color 0.15s, border-color 0.15s;
}
.bfc4-toc-links a:hover { color: var(--bk); }
.bfc4-toc-links a.is-active {
  color: var(--bk);
  border-bottom-color: var(--or);
}
.bfc4-toc-atc {
  flex-shrink: 0;
  padding: 9px 18px;
  background: var(--or);
  color: #fff;
  border: none;
  font-family: var(--sn);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.15s;
}
.bfc4-toc-atc:hover { background: #c9600f; }
.bfc4-toc-atc:disabled { opacity: 0.7; cursor: not-allowed; }
.bfc4-toc-atc.is-success { background: #2a4820 !important; color: #fff !important; }
.bfc4-toc-atc.is-success * { color: #fff !important; }
@media (max-width: 900px) {
  /* Bottom sticky ATC bar covers the same affordance on mobile, so the top TOC is redundant
     and just steals vertical space. Hidden entirely on viewports ≤900px. */
  .bfc4-toc { display: none !important; }
}
@media (max-width: 700px) {
  .bfc4-toc-inner { padding: 9px 14px; gap: 12px; }
  .bfc4-toc-links { gap: 18px; }
  .bfc4-toc-links a { font-size: 10.5px; letter-spacing: 0.06em; }
  .bfc4-toc-atc { padding: 7px 12px; font-size: 10px; letter-spacing: 0.06em; }
}

/* ── EXPANDABLE SECTIONS (below fold) ────── */
.bfc4 details.ba-acc {
  border-top: 1px solid rgba(32,32,9,0.1);
  background: var(--cv);
}
.bfc4 details.ba-acc:last-of-type {
  border-bottom: 1px solid rgba(32,32,9,0.1);
}
.bfc4 details.ba-acc summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28px 48px;
  cursor: pointer;
  list-style: none;
  background: var(--cv);
  transition: background 0.2s ease;
}
.bfc4 details.ba-acc summary:hover { background: rgba(32,32,9,0.02); }
.bfc4 details.ba-acc summary::-webkit-details-marker { display: none; }
.bfc4 .ba-acc-summary-l {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.bfc4 .ba-acc-eyebrow {
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--or);
}
.bfc4 .ba-acc-title {
  font-family: var(--sr);
  font-size: 28px; font-weight: 300;
  color: var(--bk); line-height: 1;
  letter-spacing: -0.005em;
}
.bfc4 .ba-acc-chevron {
  width: 18px; height: 18px;
  color: var(--ch);
  transition: transform 0.3s ease;
  flex-shrink: 0;
}
.bfc4 details.ba-acc[open] .ba-acc-chevron {
  transform: rotate(180deg);
}
.bfc4 .ba-acc-body {
  padding: 0 48px 56px;
}

/* Adjust existing nested sections — kill their own borders/padding when in accordion */
.bfc4 .ba-acc-body .ba-restore,
.bfc4 .ba-acc-body .ba-specs {
  border-top: none;
  padding-top: 0;
  padding-left: 0;
  padding-right: 0;
}
.bfc4 .ba-acc-body .ba-restore-inner,
.bfc4 .ba-acc-body .ba-specs-inner {
  max-width: none;
}
.bfc4 .ba-acc-body .ba-specs { padding-bottom: 0; }
.bfc4 .ba-acc-body .ba-specs-head { margin-bottom: 36px; }
.bfc4 .ba-acc-body .ba-specs-title { font-size: 36px; }
.bfc4 .ba-acc-body .ba-specs-eyebrow { font-size: 9px; }

/* ── RESTORATION PHOTO + EXTENDED CONTENT ── */
.bfc4 .ba-restore-photo {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: var(--gr);
  overflow: hidden;
  margin-bottom: 40px;
}
.bfc4 .ba-restore-photo img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.bfc4 .ba-restore-prose {
  max-width: 720px;
  margin: 0 auto 40px;
  font-family: var(--sn);
  font-size: 14.5px;
  color: var(--ch);
  line-height: 1.7;
  text-align: center;
}
.bfc4 .ba-restore-prose p { margin-bottom: 14px; }
.bfc4 .ba-restore-prose p:last-child { margin-bottom: 0; }

/* Mobile */
@media (max-width: 900px) {
  .bfc4 details.ba-acc summary { padding: 20px; }
  .bfc4 .ba-acc-title { font-size: 22px; }
  .bfc4 .ba-acc-body { padding: 0 20px 36px; }
  .bfc4 .ba-acc-body .ba-specs-title { font-size: 28px; }
  .bfc4 .ba-restore-photo { aspect-ratio: 4 / 3; margin-bottom: 28px; }
  .bfc4 .ba-restore-prose { font-size: 13.5px; margin-bottom: 28px; }
  .bfc4-badges { grid-template-columns: 1fr; }
}


/* ── CHAPTER WRAPPER (SX-70 style, dark) — 3-col layout ──── */
.bfc4 .bfc4-chapter {
  background: var(--bk);
  color: #fff;
  position: relative;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
/* Header column (left) — replaces standalone centered header */
.bfc4 .bfc4-chapter-header {
  padding: 64px 48px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}
.bfc4 .bfc4-chapter-eyebrow {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin-bottom: 18px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(255,255,255,0.15);
  align-self: flex-start;
}
.bfc4 .bfc4-chapter-title {
  font-family: var(--sr);
  font-size: 30px;
  font-weight: 300;
  color: #fff;
  margin: 0 0 18px;
  line-height: 1.15;
  letter-spacing: -0.005em;
}
.bfc4 .bfc4-chapter-title em {
  font-style: normal;
  color: rgba(255,255,255,0.6);
  font-weight: 300;
}
.bfc4 .bfc4-chapter-sub {
  font-size: 13.5px;
  color: rgba(255,255,255,0.7);
  line-height: 1.6;
  margin: 0 0 28px;
}
.bfc4 .bfc4-chapter-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 22px;
  background: transparent;
  border: 1px solid rgba(227,110,21,0.6);
  color: var(--or);
  font-family: var(--sn);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
  align-self: flex-start;
}
.bfc4 .bfc4-chapter-toggle:hover {
  background: rgba(227,110,21,0.1);
  border-color: var(--or);
}
.bfc4 .bfc4-chapter-toggle-icon {
  transition: transform 0.3s ease;
}
.bfc4 .bfc4-chapter-toggle[aria-expanded="true"] .bfc4-chapter-toggle-icon {
  transform: rotate(180deg);
}

/* ── Per-column toggle (mobile only) ──
   On mobile, the global "View full process & all specs" button is hidden and each
   column gets its own scoped toggle. This way users expand only the section they're
   currently scrolled to, instead of expanding all three at once way up at the top. */
.bfc4 .bfc4-chapter-col-toggle {
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  width: 100%;
  margin-top: 22px;
  padding: 11px 16px;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.22);
  color: rgba(255,255,255,0.85);
  font-family: var(--sn);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
}
.bfc4 .bfc4-chapter-col-toggle:hover {
  background: rgba(255,255,255,0.05);
  border-color: rgba(255,255,255,0.4);
  color: #fff;
}
.bfc4 .bfc4-chapter-col-toggle-icon {
  transition: transform 0.3s ease;
  flex-shrink: 0;
}
.bfc4 .bfc4-chapter-col-toggle[aria-expanded="true"] .bfc4-chapter-col-toggle-icon {
  transform: rotate(180deg);
}

/* Per-extra .is-open expansion — works alongside the global body.is-open rule.
   This lets per-col toggles on mobile open just one extra at a time. */
.bfc4 .bfc4-chapter-extra.is-open {
  max-height: 6000px;
  opacity: 1;
  margin-top: 28px;
}
.bfc4 .bfc4-chapter-body {
  /* No top border — grid columns provide their own dividers */
}

/* THREE-column grid: header | process | specs */
.bfc4 .bfc4-chapter-grid {
  display: grid;
  grid-template-columns: 1.1fr 1fr 1fr;
  max-width: 1380px;
  margin: 0 auto;
  padding: 0;
}
.bfc4 .bfc4-chapter-col {
  padding: 64px 48px;
  min-width: 0;
  border-left: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-col:first-child {
  border-left: none;
}
.bfc4 .bfc4-chapter-col-head {
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-col-ey {
  display: block;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin-bottom: 12px;
}
.bfc4 .bfc4-chapter-col-title {
  font-family: var(--sr);
  font-size: 26px;
  font-weight: 300;
  color: #fff;
  line-height: 1.15;
  letter-spacing: -0.005em;
  margin: 0;
}
.bfc4 .bfc4-chapter-col-title em {
  font-style: normal;
  color: rgba(255,255,255,0.55);
  font-weight: 300;
}
.bfc4 .bfc4-chapter-col-sub {
  font-family: var(--sn);
  font-size: 12.5px;
  color: rgba(255,255,255,0.55);
  line-height: 1.55;
  margin: 12px 0 0;
}


/* Process: short list always visible */
.bfc4 .bfc4-chapter-process-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.bfc4 .bfc4-chapter-process-list li {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 16px;
  align-items: baseline;
  font-family: var(--sn);
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
}
.bfc4 .bfc4-chapter-process-list .num {
  font-family: var(--sr);
  font-size: 20px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  line-height: 1;
}

/* Specs: 4 quick specs in 2x2 grid, always visible */
.bfc4 .bfc4-chapter-specs-quick {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border-top: 1px solid rgba(255,255,255,0.1);
  border-left: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-quick > div {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 18px 20px;
  border-right: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-quick .key {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}
.bfc4 .bfc4-chapter-specs-quick .val {
  font-family: var(--sr);
  font-size: 16px;
  font-weight: 400;
  color: #fff;
  line-height: 1.3;
}

/* Extras hidden by default — both expand together when chapter body has .is-open */
.bfc4 .bfc4-chapter-extra {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.6s ease, opacity 0.4s ease, margin-top 0.4s ease;
  margin-top: 0;
}
.bfc4 .bfc4-chapter-body.is-open .bfc4-chapter-extra {
  max-height: 6000px;
  opacity: 1;
  margin-top: 36px;
}

/* Restoration extra content (left col) */
.bfc4 .bfc4-chapter-process-extra .ba-restore-photo {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: rgba(255,255,255,0.04);
  overflow: hidden;
  margin-bottom: 28px;
}
.bfc4 .bfc4-chapter-process-extra .ba-restore-photo img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.bfc4 .bfc4-chapter-process-extra .ba-restore-prose {
  font-family: var(--sn);
  font-size: 13.5px;
  color: rgba(255,255,255,0.78);
  line-height: 1.7;
  margin-bottom: 28px;
}
.bfc4 .bfc4-chapter-process-extra .ba-restore-prose p { margin-bottom: 12px; }
.bfc4 .bfc4-chapter-process-extra .ba-restore-prose p:last-child { margin-bottom: 0; }
.bfc4 .bfc4-chapter-process-detail {
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding-top: 24px;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-process-detail-step {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 16px;
  align-items: baseline;
}
.bfc4 .bfc4-chapter-process-detail-step .num {
  font-family: var(--sr);
  font-size: 20px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  line-height: 1;
}
.bfc4 .bfc4-chapter-process-detail-step .body strong {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4px;
  font-family: var(--sn);
}
.bfc4 .bfc4-chapter-process-detail-step .body p {
  font-size: 12px;
  color: rgba(255,255,255,0.6);
  line-height: 1.55;
  margin: 0;
}

/* Specs extra rows (right col, full table) */
.bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full {
  display: grid;
  grid-template-columns: 1fr;
  border-top: 1px solid rgba(255,255,255,0.1);
  border-left: 1px solid rgba(255,255,255,0.1);
  border-right: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full > div {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  align-items: baseline;
}
.bfc4 .bfc4-chapter-specs-extra .key {
  font-size: 8.5px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}
.bfc4 .bfc4-chapter-specs-extra .val {
  font-family: var(--sr);
  font-size: 14px;
  color: #fff;
  line-height: 1.3;
}

/* Mobile: stack columns */

/* Header column extras (photo + prose appear here when expanded) */
.bfc4 .bfc4-chapter-header-extra .ba-restore-photo {
  width: 100%;
  aspect-ratio: 4 / 3;
  background: rgba(255,255,255,0.04);
  overflow: hidden;
  margin-bottom: 24px;
}
.bfc4 .bfc4-chapter-header-extra .ba-restore-photo img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose {
  font-family: var(--sn);
  font-size: 13px;
  color: rgba(255,255,255,0.7);
  line-height: 1.7;
  text-align: left;
  max-width: none;
  margin: 0;
}
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose p { margin-bottom: 12px; }
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose p:last-child { margin-bottom: 0; }

@media (max-width: 900px) {
  .bfc4 .bfc4-chapter-grid { grid-template-columns: 1fr; }
  .bfc4 .bfc4-chapter-col { padding: 40px 24px; }
  .bfc4 .bfc4-chapter-col:nth-child(2) {
    border-left: none;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .bfc4 .bfc4-chapter-col-title { font-size: 26px; }
  .bfc4 .bfc4-chapter-specs-quick { grid-template-columns: 1fr; }
  .bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full { grid-template-columns: 1fr; }
}

/* ── Dark overrides for nested ba-restore + ba-specs ── */

/* Restoration in dark chapter */
.bfc4 .bfc4-chapter .ba-restore {
  background: transparent;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 0 48px;
}
.bfc4 .bfc4-chapter .ba-restore-inner { max-width: 1100px; margin: 0 auto; }
.bfc4 .bfc4-chapter .ba-restore-photo {
  margin: 56px 0 40px;
  background: rgba(255,255,255,0.04);
}
.bfc4 .bfc4-chapter .ba-restore-top {
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter .ba-restore-headline {
  padding: 56px 48px 56px 0;
}
.bfc4 .bfc4-chapter .ba-restore-ey {
  color: var(--or);
}
.bfc4 .bfc4-chapter .ba-restore-title {
  color: #fff;
}
.bfc4 .bfc4-chapter .ba-restore-title em {
  color: rgba(255,255,255,0.4);
}
.bfc4 .bfc4-chapter .ba-restore-stats {
  padding: 56px 0 56px 48px;
}
.bfc4 .bfc4-chapter .ba-r-stat {
  border-left-color: rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter .ba-r-stat-num {
  color: #fff;
}
.bfc4 .bfc4-chapter .ba-r-stat-num span {
  color: var(--or);
}
.bfc4 .bfc4-chapter .ba-r-stat-label {
  color: rgba(255,255,255,0.5);
}
.bfc4 .bfc4-chapter .ba-restore-prose {
  color: rgba(255,255,255,0.78);
}
.bfc4 .bfc4-chapter .ba-restore-steps {
}
.bfc4 .bfc4-chapter .ba-r-step {
  border-right-color: rgba(255,255,255,0.06);
}
.bfc4 .bfc4-chapter .ba-r-num {
  color: rgba(227,110,21,0.5);
}
.bfc4 .bfc4-chapter .ba-r-title {
  color: #fff;
}
.bfc4 .bfc4-chapter .ba-r-desc {
  color: rgba(255,255,255,0.55);
}

/* Specs in dark chapter */
.bfc4 .bfc4-chapter .ba-specs {
  background: transparent;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 72px 48px 80px;
}
.bfc4 .bfc4-chapter .ba-specs-inner { max-width: 1100px; margin: 0 auto; }
.bfc4 .bfc4-chapter .ba-specs-eyebrow {
  color: var(--or);
}
.bfc4 .bfc4-chapter .ba-specs-title {
  color: #fff;
}
.bfc4 .bfc4-chapter .ba-specs-note {
  color: rgba(255,255,255,0.5);
}
.bfc4 .bfc4-chapter .ba-specs-table {
  border-top-color: rgba(255,255,255,0.1);
  border-left-color: rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter .ba-spec {
  border-right-color: rgba(255,255,255,0.1);
  border-bottom-color: rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter .ba-spec:hover {
  background: rgba(227,110,21,0.06);
}
.bfc4 .bfc4-chapter .ba-spec-key {
  color: var(--or);
}
.bfc4 .bfc4-chapter .ba-spec-val {
  color: #fff;
}

/* Mobile */
@media (max-width: 900px) {
  .bfc4 .bfc4-chapter-grid { grid-template-columns: 1fr; }
  .bfc4 .bfc4-chapter-col { padding: 36px 24px; border-left: none; }
  .bfc4 .bfc4-chapter-col + .bfc4-chapter-col { border-top: 1px solid rgba(255,255,255,0.08); }
  .bfc4 .bfc4-chapter-header { padding: 44px 24px 32px; }
  .bfc4 .bfc4-chapter-title { font-size: 28px; }
  .bfc4 .bfc4-chapter-sub { font-size: 13.5px; }
  .bfc4 .bfc4-chapter-col-title { font-size: 24px; }
  .bfc4 .bfc4-chapter .ba-restore-photo { aspect-ratio: 4/3; }
  /* Swap global → per-column toggles on mobile */
  .bfc4 .bfc4-chapter-toggle { display: none; }
  .bfc4 .bfc4-chapter-col-toggle { display: inline-flex; }
}


/* ── BANNERS BELOW PHOTO (left column) — side by side ── */
.bfc4-left-banners {
  display: grid;
