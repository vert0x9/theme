  // Starter kit STATE seeded from tile data-attributes on load (see bottom of script)

  // ── Tile toggle (top tiles = add-ons) ──────────
  function syncAccordionLocks() {
    var starterVariantIds = [];
    var starterProductIds = [];
    // Read from STATE.kit (live state) so deselects from any UI propagate immediately
    Object.values(STATE.kit).forEach(function(sel) {
      if (!sel) return;
      if (sel.variantId) starterVariantIds.push(String(sel.variantId));
      if (sel.productId) starterProductIds.push(String(sel.productId));
    });
    document.querySelectorAll('.ba-mini-card').forEach(function(card) {
      // Match by productId first (more robust — variantId can drift between Liquid first variant
      // and JS-side first-available variant), fall back to variantId for older non-JSX layouts.
      var inKit =
        (card.dataset.productId && starterProductIds.indexOf(String(card.dataset.productId)) >= 0) ||
        (card.dataset.variantId && starterVariantIds.indexOf(String(card.dataset.variantId)) >= 0);
      card.classList.toggle('is-sel', inKit);
      card.style.pointerEvents = inKit ? 'none' : '';
      card.style.opacity = inKit ? '0.7' : '';
      var badge = card.querySelector('.bfc4-in-kit-badge');
      if (inKit && !badge) {
        badge = document.createElement('div');
        badge.className = 'bfc4-in-kit-badge';
        badge.style.cssText = 'position:absolute;top:4px;left:4px;background:var(--or);color:#fff;font-size:7px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:2px 5px;z-index:2;';
        badge.textContent = 'In Kit';
        card.style.position = 'relative';
        card.appendChild(badge);
      } else if (!inKit && badge) {
        badge.remove();
      }
    });
  }
  window.syncAccordionLocks = syncAccordionLocks;

  window.bfc4TileToggle = function(tile) {
    var wasSel = tile.classList.contains('is-sel');
    tile.classList.toggle('is-sel', !wasSel);
    var check = tile.querySelector('.bfc4-tile-sel-check');
    if (!wasSel) {
      // add to STATE
      var tileId = tile.dataset.tileId || ('tile-' + Math.random());
      var isFilm = (tile.dataset.col || '').toLowerCase().indexOf('film') >= 0 && tile.dataset.isDev !== 'true';
      if (!check) {
        check = document.createElement('div');
        check.className = 'bfc4-tile-sel-check';
        check.textContent = '✓';
        tile.querySelector('.bfc4-tile-img-wrap').appendChild(check);
      }
      STATE.kit[tileId] = {
        variantId: tile.dataset.variantId,
        name:      tile.dataset.productTitle,
        orig:      parseInt(tile.dataset.orig || '0', 10),
        sale:      parseInt(tile.dataset.sale || '0', 10),
        isDev:     tile.dataset.isDev === 'true',
        disc:      parseInt(tile.dataset.disc || '0', 10),
        isFilm:    isFilm,
        colId:     tile.dataset.tileId,
        img:       tile.dataset.img || null
      };
      tile.dataset.stateKey = tileId;
    } else {
      // remove from STATE
      var key = tile.dataset.stateKey;
      if (key) delete STATE.kit[key];
      if (check) check.remove();
    }
    bfc4Render();
    syncAccordionLocks();
  };

