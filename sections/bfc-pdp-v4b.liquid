</style>

<div class="bfc4">

{%- comment -%} ── Collect starter kit blocks ── {%- endcomment -%}
{%- assign sk_blocks = section.blocks | where: 'type', 'kit_item' -%}
{%- assign has_starter = false -%}
{%- for block in sk_blocks -%}
  {%- if block.settings.is_starter_kit and block.settings.product != blank -%}
    {%- assign has_starter = true -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Compute kit total for starter {%- endcomment -%}
{%- liquid
  assign sk_total = current_variant.price
  for block in sk_blocks
    if block.settings.is_starter_kit and block.settings.product != blank
      assign sk_bp  = block.settings.product
      assign sk_dv = sk_bp.variants.first
      unless sk_dv.available
        for v in sk_bp.variants
          if v.available
            assign sk_dv = v
            break
          endif
        endfor
      endunless
      assign sk_d   = block.settings.discount_percent
      assign sk_dev = block.settings.is_developing
      if sk_dev
        assign sk_sale = 0
      elsif sk_d > 0
        assign sk_df   = sk_d | times: 1.0 | divided_by: 100
        assign sk_sv   = sk_dv.price | times: sk_df | floor
        assign sk_sale = sk_dv.price | minus: sk_sv
      else
        assign sk_sale = sk_dv.price
      endif
      assign sk_total = sk_total | plus: sk_dv.price
    endif
  endfor
-%}

{%- comment -%} ── SPLIT: left image + right content ── {%- endcomment -%}
<div class="bfc4-split">

{%- comment -%} Expose starter-kit data to JS for cart logic {%- endcomment -%}
<script>
  window.bfc4HasStarter = {{ has_starter | json }};
  window.bfc4StarterItems = [
    {%- for block in sk_blocks -%}
      {%- if block.settings.is_starter_kit and block.settings.product != blank -%}
        {%- assign sk_bp = block.settings.product -%}
        {%- assign sk_col = block.settings.column | default: block.settings.label -%}
        {%- assign sk_dv = sk_bp.variants.first -%}
        {%- assign sk_avail = false -%}
        {%- for v in sk_bp.variants -%}
          {%- if v.available -%}{%- assign sk_dv = v -%}{%- assign sk_avail = true -%}{%- break -%}{%- endif -%}
        {%- endfor -%}
        { id: {{ sk_dv.id }}, price: {{ sk_dv.price }}, isDev: {{ block.settings.is_developing | json }}, col: {{ sk_col | json }}, available: {{ sk_avail | json }}, productId: {{ sk_bp.id }}, name: {{ sk_bp.title | json }}, img: {{ sk_bp.featured_image | image_url: width: 200 | json }} },
      {%- endif -%}
    {%- endfor -%}
  ];

  // Pool of available alternatives keyed by column — used to substitute OOS starter items
  window.bfc4ColumnPool = {};
  {%- for block in sk_blocks -%}
    {%- if block.type == 'kit_item' and block.settings.product != blank -%}
      {%- assign cp_bp  = block.settings.product -%}
      {%- assign cp_col = block.settings.column | default: block.settings.label -%}
      {%- for v in cp_bp.variants -%}
        {%- if v.available -%}
  (window.bfc4ColumnPool[{{ cp_col | json }}] = window.bfc4ColumnPool[{{ cp_col | json }}] || []).push({ id: {{ v.id }}, price: {{ v.price }}, isDev: {{ block.settings.is_developing | json }}, productId: {{ cp_bp.id }}, name: {{ cp_bp.title | json }}, img: {{ cp_bp.featured_image | image_url: width: 200 | json }} });
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  {%- endfor -%}

  // Substitute any OOS starter item with a sibling product in the same column
  (function(){
    if (!Array.isArray(window.bfc4StarterItems)) return;
    window.bfc4StarterItems = window.bfc4StarterItems.map(function(it) {
      if (it && it.available) return it;
      var candidates = (window.bfc4ColumnPool[it.col] || []).filter(function(p){ return p.productId !== it.productId; });
      if (candidates.length === 0) return null;
      var sub = candidates[0];
      return { id: sub.id, price: sub.price, isDev: it.isDev, col: it.col, available: true, productId: sub.productId, name: sub.name, img: sub.img, subbed: true, originalProductId: it.productId };
    }).filter(Boolean);
  })();

  // Visually update kit summary cards for any substituted slots, and remove dropped slots
  function bfc4ApplyKitSubs() {
    if (!Array.isArray(window.bfc4StarterItems)) return;
    var subbed = {};
    window.bfc4StarterItems.forEach(function(it) {
      if (it.subbed && it.originalProductId) subbed[it.originalProductId] = it;
    });
    document.querySelectorAll('.bfc4-ks-item[data-orig-product-id]').forEach(function(card) {
      var origId = card.dataset.origProductId;
      var sub = subbed[origId];
      if (sub) {
        var img = card.querySelector('.bfc4-ks-thumb');
        if (img && img.tagName === 'IMG' && sub.img) { img.src = sub.img; img.alt = sub.name; }
        var nm  = card.querySelector('.bfc4-ks-name');
        if (nm) nm.textContent = sub.name;
        card.dataset.subbed = 'true';
      } else {
        // Card's original product is in starter list and available — leave alone.
        // If neither subbed nor in starter list, the slot was dropped → hide card.
        var stillIn = window.bfc4StarterItems.some(function(it){ return String(it.productId) === String(origId); });
        if (!stillIn) card.style.display = 'none';
      }
    });
    // Re-trigger expand-your-kit highlighting so In-Kit badges track substitutes
    if (typeof window.syncAccordionLocks === 'function') window.syncAccordionLocks();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bfc4ApplyKitSubs);
  } else {
    bfc4ApplyKitSubs();
  }

  // Debug helper: run window.bfc4Debug() in browser console to see state
  window.bfc4Debug = function() {
    console.log('=== BFC4 DEBUG ===');
    console.log('STARTER ITEMS (after substitution):', window.bfc4StarterItems);
    console.log('COLUMN POOL:', window.bfc4ColumnPool);
    console.log('Mode:', window.bfc4Mode);
    console.log('--- Highlighted in expand-your-kit (.is-sel mini cards) ---');
    document.querySelectorAll('.ba-mini-card.is-sel').forEach(function(c) {
      console.log('  HIGHLIGHTED:', c.dataset.productTitle, '| productId:', c.dataset.productId, '| variantId:', c.dataset.variantId, '| col:', c.dataset.colName);
    });
    console.log('--- Kit summary cards at top ---');
    document.querySelectorAll('.bfc4-ks-item').forEach(function(c) {
      var name = c.querySelector('.bfc4-ks-name');
      console.log('  TOP:', name ? name.textContent : '?', '| origProductId:', c.dataset.origProductId, '| subbed:', c.dataset.subbed || 'no');
    });
  };

  window.bfc4StarterTotal = window.bfc4StarterItems.reduce((sum, it) => sum + (it.isDev ? 0 : it.price), 0);
</script>


  {%- comment -%} LEFT: sticky slider — uses section image pickers if set, falls back to product.media {%- endcomment -%}
  <div class="bfc4-left" id="bfc4-top">
    <div class="bfc4-photo-wrap">
    {%- comment -%} Check if any section images are set {%- endcomment -%}
    {%- assign has_section_imgs = false -%}
    {%- for i in (1..5) -%}
      {%- assign img_key = 'slide_' | append: i -%}
      {%- if section.settings[img_key] != blank -%}{%- assign has_section_imgs = true -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_section_imgs -%}
      {%- comment -%} Count section slides {%- endcomment -%}
      {%- assign slide_images = '' -%}
      {%- for i in (1..5) -%}
        {%- assign img_key = 'slide_' | append: i -%}
        {%- if section.settings[img_key] != blank -%}{%- assign slide_images = slide_images | append: '1' -%}{%- endif -%}
      {%- endfor -%}
      {%- assign total_slides = slide_images | size -%}

      <div class="bfc4-slides" id="bfc4-slides">
        {%- for i in (1..5) -%}
          {%- assign img_key = 'slide_' | append: i -%}
          {%- assign img_mob_key = 'slide_' | append: i | append: '_mobile' -%}
          {%- assign img_val = section.settings[img_key] -%}
          {%- assign img_mob = section.settings[img_mob_key] -%}
          {%- if img_val != blank -%}
            <div class="bfc4-slide">
              <picture>
                {%- if img_mob != blank -%}
                  <source media="(max-width: 767px)" srcset="{{ img_mob | image_url: width: 900 }}"/>
                {%- endif -%}
                <img
                  src="{{ img_val | image_url: width: 900 }}"
                  srcset="{{ img_val | image_url: width: 600 }} 600w, {{ img_val | image_url: width: 900 }} 900w, {{ img_val | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 900px) 100vw, 50vw"
                  data-zoom="{{ img_val | image_url: width: 1600 }}"
                  alt="{{ product.title | escape }}"
                  width="900" height="900"
                  {%- if i == 1 -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
                />
              </picture>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- comment -%} Fallback: use product.media images {%- endcomment -%}
      {%- assign media_images = product.media | where: 'media_type', 'image' -%}
      {%- assign total_slides = media_images | size -%}

      <div class="bfc4-slides" id="bfc4-slides">
        {%- for media in media_images limit: 8 -%}
          <div class="bfc4-slide">
            <img
              src="{{ media | image_url: width: 900 }}"
              srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 900px) 100vw, 50vw"
              data-zoom="{{ media | image_url: width: 1600 }}"
              alt="{{ product.title | escape }}"
              width="900" height="900"
              {%- if forloop.first -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
            />
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if total_slides > 1 -%}
      <button class="bfc4-arrow is-prev" onclick="bfc4Slide(-1)" aria-label="Previous">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8L10 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
      <button class="bfc4-arrow is-next" onclick="bfc4Slide(1)" aria-label="Next">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 3L11 8L6 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
      <div class="bfc4-dots" id="bfc4-dots">
        {%- for i in (1..total_slides) -%}
          <button class="bfc4-dot{% if forloop.first %} is-active{% endif %}" onclick="bfc4GoTo({{ forloop.index0 }})"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
    </div>{%- comment -%} /bfc4-photo-wrap {%- endcomment -%}

    {%- comment -%} ── BADGES (moved from right col) ── {%- endcomment -%}
    <div class="bfc4-badges bfc4-left-badges">
      <div class="bfc4-badge">
        <svg class="bfc4-badge-icon" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1Zm3.1 5.37-3.5 3.5a.5.5 0 0 1-.7 0l-1.5-1.5a.5.5 0 1 1 .7-.7L7.25 8.8l3.15-3.13a.5.5 0 1 1 .7.7Z"/></svg>
        Full restoration
      </div>
      <div class="bfc4-badge">
        <svg class="bfc4-badge-icon" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1Zm3.1 5.37-3.5 3.5a.5.5 0 0 1-.7 0l-1.5-1.5a.5.5 0 1 1 .7-.7L7.25 8.8l3.15-3.13a.5.5 0 1 1 .7.7Z"/></svg>
        Tested on professional bench equipment
      </div>
      <div class="bfc4-badge">
        <svg class="bfc4-badge-icon" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1Zm3.1 5.37-3.5 3.5a.5.5 0 0 1-.7 0l-1.5-1.5a.5.5 0 1 1 .7-.7L7.25 8.8l3.15-3.13a.5.5 0 1 1 .7.7Z"/></svg>
        New battery installed &amp; ready to shoot
      </div>
      <div class="bfc4-badge">
        <svg class="bfc4-badge-icon" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1Zm3.1 5.37-3.5 3.5a.5.5 0 0 1-.7 0l-1.5-1.5a.5.5 0 1 1 .7-.7L7.25 8.8l3.15-3.13a.5.5 0 1 1 .7.7Z"/></svg>
        6-month warranty
      </div>
    </div>
  </div>

  {%- comment -%} RIGHT: product content {%- endcomment -%}
  <div class="bfc4-right">

    {%- comment -%}
      1. Header — title + reviews + description + trust strip, all in one block.
      Earlier these were pulled out as flex siblings to allow CSS order:99 reordering on
      mobile (description below ATC), but that was reverted, so they're back inside the
      header to remove the extra .bfc4-right flex gaps that were padding desktop.
    {%- endcomment -%}
    <div class="bfc4-header">
      <div class="bfc4-title-row">
        <h1 class="bfc4-title">{{ product.title }}</h1>
      {%- render 'bfc-rating-stars', pdp_handle: product.handle -%}
        <span class="bfc4-title-price" id="bfc4-title-price">{{ current_variant.price | money }}</span>
      </div>
      <span id="bfc4-star-placeholder"></span>

      {%- assign desc_text = '' -%}
      {%- if product.description contains 'bfc-desc-specs__desc' -%}
        {%- assign desc_inner = product.description | split: 'bfc-desc-specs__desc">' | last | split: '</div>' | first -%}
        {%- assign desc_text = desc_inner | strip_html | strip -%}
      {%- endif -%}
      {%- if desc_text == blank -%}
        {%- assign desc_text = product.description | split: 'bfc-desc-specs__grid' | first | strip_html | strip -%}
      {%- endif -%}
      {%- if desc_text == blank -%}
        {%- assign desc_text = product.description | strip_html | strip -%}
      {%- endif -%}
      <p class="bfc4-desc">{{ desc_text }}</p>

      {%- comment -%} Refurbishment trust strip — BFC's differentiator vs "tested" sellers {%- endcomment -%}
      <ul class="bfc4-trust-strip">
        <li>
          <button type="button" class="bfc4-trust-link" onclick="baOpenPopup('bfc4-restoration-popup')" aria-label="Learn how we restore each camera">
            <svg viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path fill="currentColor" d="M6.5 11.5 3 8l1-1 2.5 2.5L12 4l1 1z"/></svg>
            Restored inside &amp; out
          </button>
        </li>
        <li><svg viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path fill="currentColor" d="M6.5 11.5 3 8l1-1 2.5 2.5L12 4l1 1z"/></svg>Bench-tested by techs</li>
        <li><svg viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path fill="currentColor" d="M6.5 11.5 3 8l1-1 2.5 2.5L12 4l1 1z"/></svg>New seals &amp; battery</li>
        <li><svg viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path fill="currentColor" d="M6.5 11.5 3 8l1-1 2.5 2.5L12 4l1 1z"/></svg>6-month warranty</li>
      </ul>
    </div>

    {%- comment -%} 2. Buy block (price + condition + purchase option + kit summary + ATC + warranty link) {%- endcomment -%}
    <div class="bfc4-buy">

      {%- comment -%}
        Standalone price row removed — price now lives on the ATC button only.
        bfc4Render and bfc4UpdateATC both still target #bfc4-total but use defensive `if (el)`
        checks, so missing element won't error. Saves ~60px above-fold.
      {%- endcomment -%}

      {%- comment -%} Condition (soft pills, replaces grade row) {%- endcomment -%}
      {%- if product.variants.size > 1 -%}
        <div class="bfc4-condition">
          <span class="bfc4-eyebrow-std" style="display: inline-flex; align-items: center; gap: 6px;">
            Condition
            <button type="button" class="bfc4-w-info-btn" onclick="baOpenPopup('bfc4-cond-popup')" aria-label="What do these grades mean?" title="What do these grades mean?">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg>
            </button>
          </span>
          <div class="bfc4-condition-row">
            {%- for variant in product.variants -%}
              <button
                class="bfc4-cond-btn{% if variant.id == current_variant.id %} is-active{% endif %}"
                data-variant-id="{{ variant.id }}"
                data-variant-price="{{ variant.price }}"
                data-variant-price-fmt="{{ variant.price | money }}"
                data-variant-available="{{ variant.available }}"
                onclick="bfc4SelectVariant(this)"
                {%- unless variant.available -%}disabled{%- endunless -%}
              >
                <span class="bfc4-cond-label">{{ variant.title }}</span>
                <span class="bfc4-cond-price">{{ variant.price | money }}</span>
                {%- unless variant.available -%}<span class="bfc4-cond-oos">OOS</span>{%- endunless -%}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Purchase Option toggle (only if starter kit configured) {%- endcomment -%}
      {%- if has_starter -%}
        <div class="bfc4-po">
          <span class="bfc4-eyebrow-std">Purchase Option</span>
          <div class="bfc4-po-toggle">
            <button class="bfc4-po-btn is-active" data-mode="kit" onclick="bfc4SetMode('kit')">
              <span class="bfc4-po-label">Starter Kit</span>
              <span class="bfc4-po-perk">+ free dev credit</span>
            </button>
            <button class="bfc4-po-btn" data-mode="body" onclick="bfc4SetMode('body')">
              <span class="bfc4-po-label">Camera only</span>
            </button>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Kit summary card — moved ABOVE ATC so kit contents are in view with the buy CTA {%- endcomment -%}
      {%- if has_starter -%}
        <div class="bfc4-kit-summary" id="bfc4-kit-summary">
          <div class="bfc4-ks-head">
            <span class="bfc4-ks-title">
              <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7L5.5 10.5L12 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- assign sk_count = 0 -%}
              {%- for block in sk_blocks -%}
                {%- if block.settings.is_starter_kit and block.settings.product != blank -%}
                  {%- unless block.settings.is_developing -%}
                    {%- assign sk_count = sk_count | plus: 1 -%}
                  {%- endunless -%}
                {%- endif -%}
              {%- endfor -%}
              Kit includes {{ sk_count }} item{% if sk_count != 1 %}s{% endif %}
            </span>
            <a href="#bfc4-custom" class="bfc4-ks-customize" onclick="document.getElementById('bfc4-custom').scrollIntoView({behavior:'smooth'}); return false;">Customize kit →</a>
          </div>

          <div class="bfc4-ks-items">
            {%- for block in sk_blocks -%}
              {%- if block.type != 'kit_item' or block.settings.product == blank -%}{% continue %}{%- endif -%}
              {%- unless block.settings.is_starter_kit -%}{% continue %}{%- endunless -%}
              {%- if block.settings.is_developing -%}{% continue %}{%- endif -%}
              {%- assign sk_bp = block.settings.product -%}
              {%- assign sk_col = block.settings.column | default: block.settings.label -%}
              {%- assign sk_name = block.settings.custom_label | default: sk_bp.title -%}
              {%- assign ks_id = 'bfc4-ks-' | append: forloop.index -%}
              {%- assign ks_imgs = '' -%}
              {%- for media in sk_bp.media limit: 6 -%}
                {%- if media.media_type == 'image' -%}
                  {%- assign ks_img_url = media | image_url: width: 600 -%}
                  {%- if ks_imgs == '' -%}{%- assign ks_imgs = ks_img_url -%}
                  {%- else -%}{%- assign ks_imgs = ks_imgs | append: '||' | append: ks_img_url -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
              <div class="bfc4-ks-item" data-orig-product-id="{{ sk_bp.id }}" data-col="{{ sk_col | escape }}">
                {%- if sk_bp.featured_image -%}
                  <img class="bfc4-ks-thumb" src="{{ sk_bp.featured_image | image_url: width: 200 }}" alt="{{ sk_bp.title | escape }}" loading="lazy"/>
                {%- else -%}
                  <span class="bfc4-ks-thumb"></span>
                {%- endif -%}
                <div class="bfc4-ks-info">
                  <span class="bfc4-ks-name">{{ sk_name }}</span>
                  <span class="bfc4-ks-sub">{{ sk_col }}</span>
                </div>
                <button type="button" class="bfc4-ks-info-btn" onclick="baOpenPopup('{{ ks_id }}')" aria-label="More info about {{ sk_name | escape }}">
                  <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg>
                </button>
              </div>
              <div id="ba-popup-data-{{ ks_id }}" style="display:none"
                data-title="{{ sk_bp.title | escape }}"
                data-desc="{{ sk_bp.description | replace: '</p>', '||PARA||' | replace: '</div>', '||PARA||' | replace: '<br>', '||LINE||' | replace: '<br/>', '||LINE||' | replace: '<br />', '||LINE||' | replace: '</li>', '||LINE||' | replace: '</h2>', '||PARA||' | replace: '</h3>', '||PARA||' | replace: '</h4>', '||PARA||' | strip_html | strip | escape }}"
                data-imgs="{{ ks_imgs | escape }}"
              ></div>
            {%- endfor -%}
          </div>

          {%- comment -%} Dev credit perk row — always shown with kit {%- endcomment -%}
          <div class="bfc4-ks-perk">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7L5.5 10.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="bfc4-ks-perk-title">Free developing credit</span>
            <span class="bfc4-ks-perk-sub">— included with the kit</span>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ATC button {%- endcomment -%}
      <button class="bfc4-atc" id="bfc4-atc" onclick="bfc4AddToCart()">
        <span id="bfc4-atc-text">{% if has_starter %}Add Kit to Cart &mdash; {{ sk_total | money }}{% else %}Add to Cart &mdash; {{ current_variant.price | money }}{% endif %}</span>
      </button>

      {%- comment -%} Inline warranty link {%- endcomment -%}
      <div class="bfc4-warranty-link">
        Need more coverage? <button type="button" onclick="bfc4OpenWarranty()" class="bfc4-warranty-btn">Extend warranty &rarr;</button>
      </div>
    </div>


    {%- comment -%} Warranty modal — opens via Extend warranty link.
        Tier pricing/variant IDs come from snippets/bfc-warranty-tiers.liquid
        (single source of truth across all PDPs). The snippet outputs w_w9_vid,
        w_w9_price, w_w12_vid, w_w12_price — re-aliased here to the unprefixed
        names that the modal HTML below already references. {%- endcomment -%}
    {%- assign cam_price = current_variant.price -%}
    {% include 'bfc-warranty-tiers', category: 'slr', cam_price: cam_price %}
    {%- liquid
      assign w9_vid = w_w9_vid
      assign w9_price = w_w9_price
      assign w12_vid = w_w12_vid
      assign w12_price = w_w12_price
    -%}

    {%- comment -%}
      Compact jump-nav — restored after warranty link as a single horizontal row.
      Quieter than the original 3 chunky buttons but keeps the "where do I go next?"
      affordance. Dot separators between items make it feel like a breadcrumb-style
      page index rather than 3 individual CTAs competing with the ATC.
    {%- endcomment -%}
    <div class="bfc4-jumpnav">
      <span class="bfc4-jumpnav-label">Jump to:</span>
      <button type="button" class="bfc4-jumpnav-link" onclick="document.getElementById('bfc4-custom').scrollIntoView({behavior:'smooth'})">Expand your kit</button>
      <span class="bfc4-jumpnav-sep" aria-hidden="true">·</span>
      <button type="button" class="bfc4-jumpnav-link" onclick="document.getElementById('bfc4-policy-section').scrollIntoView({behavior:'smooth'})">Warranty</button>
      <span class="bfc4-jumpnav-sep" aria-hidden="true">·</span>
      <button type="button" class="bfc4-jumpnav-link" onclick="document.getElementById('ba-restore').scrollIntoView({behavior:'smooth'})">Specs &amp; Photos</button>
    </div>

  </div>{%- comment -%} /bfc4-right {%- endcomment -%}
</div>{%- comment -%} /bfc4-split {%- endcomment -%}

{%- comment -%} ── BELOW FOLD ── {%- endcomment -%}
<div class="bfc4-below">
  {%- comment -%} Shot on {%- endcomment -%}
  {%- if g1 or g2 or g3 -%}
  <div class="ba-shot">
    <div class="ba-shot-head">
      <h2 class="ba-shot-title">Shot on {{ product.title }}</h2>
      <span class="ba-shot-sub">From real customers</span>
    </div>
    <div class="ba-shot-grid" id="ba-shot-grid">
      {%- if g1 -%}<a href="{{ g1 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="0" onclick="bfc4OpenShotLightbox(event, 0)"><img src="{{ g1 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g2 -%}<a href="{{ g2 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="1" onclick="bfc4OpenShotLightbox(event, 1)"><img src="{{ g2 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g3 -%}<a href="{{ g3 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="2" onclick="bfc4OpenShotLightbox(event, 2)"><img src="{{ g3 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g4 -%}<a href="{{ g4 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="3" onclick="bfc4OpenShotLightbox(event, 3)"><img src="{{ g4 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g5 -%}<a href="{{ g5 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="4" onclick="bfc4OpenShotLightbox(event, 4)"><img src="{{ g5 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g6 -%}<a href="{{ g6 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="5" onclick="bfc4OpenShotLightbox(event, 5)"><img src="{{ g6 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ════════════════════════════════════════════════
       (Sticky TOC moved outside .bfc4 wrapper — see end of file)
       ════════════════════════════════════════════════ {%- endcomment -%}

  {%- comment -%} ════════════════════════════════════════════════
       CHAPTER — Restoration process + Camera specs (combined)
       Centered dark header with toggle button (SX-70 style)
       ════════════════════════════════════════════════ {%- endcomment -%}
  <div class="bfc4-chapter" id="bfc4-chapter">
    <div class="bfc4-chapter-body" id="bfc4-chapter-body">
      <div class="bfc4-chapter-grid">

        {%- comment -%} ── LEFT: HEADER ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-header">
          <h2 class="bfc4-chapter-title">{{ product.title | escape }}</h2>
          {%- comment -%}
            Replaces the duplicate product description (already shown above-fold).
            This prose communicates BFC's actual restoration depth — the differentiator vs
            "tested and certified" sellers like KEH who don't open the camera.
          {%- endcomment -%}
          <p class="bfc4-chapter-sub">We started Brooklyn Film Camera to take the guesswork out of buying a film camera. Most shops give you a wipe-down and, at best, replace the light seals &mdash; that isn't enough. Forty-year-old mechanical cameras need real work to shoot like they did the day they left the factory.</p>
          <button type="button" class="bfc4-chapter-toggle" id="bfc4-chapter-toggle" aria-expanded="false" aria-controls="bfc4-chapter-body" onclick="bfc4ToggleChapter()">
            <span class="bfc4-chapter-toggle-text">View full process &amp; all specs</span>
            <svg class="bfc4-chapter-toggle-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {%- comment -%} Per-column toggle (mobile only — global toggle hides on small screens) {%- endcomment -%}
          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide story" data-closed-label="View full story" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View full story</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {%- comment -%} Hidden until toggle expands — photo + prose live here {%- endcomment -%}
          <div class="bfc4-chapter-extra bfc4-chapter-header-extra">
            {%- if section.settings.restoration_photo != blank -%}
              <div class="ba-restore-photo">
                <img src="{{ section.settings.restoration_photo | image_url: width: 1200 }}" alt="Restoration in progress at Brooklyn Film Camera" loading="lazy"/>
              </div>
            {%- endif -%}

            {%- if section.settings.restoration_prose != blank -%}
              <div class="ba-restore-prose">{{ section.settings.restoration_prose }}</div>
            {%- else -%}
              <div class="ba-restore-prose">
                <p>Every camera we sell passes through our in-house technicians. We adjust shutter speeds back to factory spec, modify circuitry when the original components have aged out, replace parts when needed, and bench-test every function before anything ships. Years of research and development go into the process, and we keep refining it.</p>
                <p>You're not gambling on whether the camera works. You're getting a tool brought back to pristine condition by people who've spent careers learning how.</p>
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ── LEFT: PROCESS ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-process" id="ba-restore">
          <div class="bfc4-chapter-col-head">
            <span class="bfc4-chapter-col-ey">Our Process</span>
            <h3 class="bfc4-chapter-col-title">Hand-restored in Brooklyn</h3>
            <p class="bfc4-chapter-col-sub">Each camera goes through four checkpoints before it ships.</p>
          </div>

          <ul class="bfc4-chapter-process-list">
            <li><span class="num">01</span><span>Mechanical inspection &amp; calibration</span></li>
            <li><span class="num">02</span><span>Full restoration</span></li>
            <li><span class="num">03</span><span>Lens cleaned, lubricated, adjusted</span></li>
            <li><span class="num">04</span><span>Tested on professional bench equipment</span></li>
          </ul>

          {%- comment -%} Per-column toggle (mobile only) {%- endcomment -%}
          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide steps" data-closed-label="View all steps" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View all steps</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {%- comment -%} Hidden until toggle expands — only detail steps stay here {%- endcomment -%}
          <div class="bfc4-chapter-extra bfc4-chapter-process-extra">
            <div class="bfc4-chapter-process-detail">
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">01</span>
                <div class="body"><strong>Mechanical Inspection</strong><p>Shutter, film advance, rewind &mdash; every function tested on professional bench equipment.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">02</span>
                <div class="body"><strong>Full Restoration</strong><p>Light seals replaced, foam renewed, mechanism cleaned. Fresh seals on every camera, no exceptions.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">03</span>
                <div class="body"><strong>Lens CLA</strong><p>Clean, lubricate, and adjust for sharp, accurate shots.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">04</span>
                <div class="body"><strong>Final QC</strong><p>Tested with professional equipment before it ships from Brooklyn.</p></div>
              </div>
            </div>
          </div>
        </div>

        {%- comment -%} ── RIGHT: SPECS ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-specs">
          <div class="bfc4-chapter-col-head">
            <h3 class="bfc4-chapter-col-title">Specifications</h3>
            <p class="bfc4-chapter-col-sub">The exact technical details of this camera.</p>
          </div>

          <div class="bfc4-chapter-specs-quick">
            {%- comment -%} Quick view: Mount / Shutter / Battery / Flash (4 priority specs) {%- endcomment -%}
            {%- assign qs_count = 0 -%}
            {%- if spec_mount != blank and qs_count < 4 -%}
              <div><span class="key">Mount</span><span class="val">{{ spec_mount }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_shutter != blank and qs_count < 4 -%}
              <div><span class="key">Shutter</span><span class="val">{{ spec_shutter }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_battery != blank and qs_count < 4 -%}
              <div><span class="key">Battery</span><span class="val">{{ spec_battery }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_flash != blank and qs_count < 4 -%}
              <div><span class="key">Flash</span><span class="val">{{ spec_flash }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_lens != blank and qs_count < 4 -%}
              <div><span class="key">Lens</span><span class="val">{{ spec_lens }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_focus != blank and qs_count < 4 -%}
              <div><span class="key">Focus</span><span class="val">{{ spec_focus }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_meter != blank and qs_count < 4 -%}
              <div><span class="key">Metering</span><span class="val">{{ spec_meter }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
          </div>

          {%- comment -%} Per-column toggle (mobile only) {%- endcomment -%}
          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide specs" data-closed-label="View all specs" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View all specs</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {%- comment -%} Hidden until toggle expands {%- endcomment -%}
          <div class="bfc4-chapter-extra bfc4-chapter-specs-extra">
            <div class="bfc4-chapter-specs-full">
              {%- comment -%} Show every available spec in expanded view (incl. ones already in quick) {%- endcomment -%}
              {%- if spec_lens    != blank -%}<div><span class="key">Lens</span><span class="val">{{ spec_lens }}</span></div>{%- endif -%}
              {%- if spec_meter   != blank -%}<div><span class="key">Metering</span><span class="val">{{ spec_meter }}</span></div>{%- endif -%}
              {%- if spec_focus   != blank -%}<div><span class="key">Focus</span><span class="val">{{ spec_focus }}</span></div>{%- endif -%}
              {%- if spec_timer   != blank -%}<div><span class="key">Self Timer</span><span class="val">{{ spec_timer }}</span></div>{%- endif -%}
              {%- if spec_tripod  != blank -%}<div><span class="key">Tripod</span><span class="val">{{ spec_tripod }}</span></div>{%- endif -%}
              {%- if spec_expcomp != blank -%}<div><span class="key">Exp. Comp.</span><span class="val">{{ spec_expcomp }}</span></div>{%- endif -%}
              {%- if spec_dx      != blank -%}<div><span class="key">DX Reader</span><span class="val">{{ spec_dx }}</span></div>{%- endif -%}
              {%- if product.variants.size > 1 -%}
                <div><span class="key">Condition</span><span class="val">A &amp; B Grade</span></div>
              {%- else -%}
                <div><span class="key">Condition</span><span class="val">Quality benchmark verified</span></div>
              {%- endif -%}
            </div>
          </div>
        </div>

      </div>
    </div>{%- comment -%} /bfc4-chapter-body {%- endcomment -%}
  </div>{%- comment -%} /bfc4-chapter {%- endcomment -%}

  {%- comment -%} Custom kit section {%- endcomment -%}
  <div class="bfc4-custom" id="bfc4-custom">
    <div class="bfc4-custom-head">
      <h2 class="bfc4-custom-title">Mix &amp; match.</h2>

    </div>

    {%- comment -%} Collect columns {%- endcomment -%}
    {%- assign col_names = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'kit_item' and block.settings.product != blank -%}
        {%- assign col = block.settings.column | default: block.settings.label -%}
        {%- unless col_names contains col -%}
          {%- if col_names == '' -%}{%- assign col_names = col -%}
          {%- else -%}{%- assign col_names = col_names | append: '||' | append: col -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign col_name_arr = col_names | split: '||' -%}

    <div class="ba-columns">
      {%- for col_name in col_name_arr -%}
        <div class="ba-col" id="bfc4-col-{{ forloop.index }}" data-col-name="{{ col_name | escape }}">
          <div class="ba-col-head" onclick="baToggleCol(this.closest('.ba-col'))">
            <div class="ba-col-title">
              {% if col_name == 'More' %}Accessories{% else %}{{ col_name }}{% endif %}
              <span class="ba-col-count" id="ba-col-count-{{ forloop.index }}">0</span>
            </div>
            <svg class="ba-col-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
          </div>
          <div class="ba-col-body">
          {%- assign col_item_index = 0 -%}
          {%- assign col_item_total = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'kit_item' and block.settings.product != blank -%}
              {%- assign block_col = block.settings.column | default: block.settings.label -%}
              {%- if block_col == col_name -%}{%- assign col_item_total = col_item_total | plus: 1 -%}{%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- for block in section.blocks -%}
            {%- if block.type != 'kit_item' -%}{% continue %}{%- endif -%}
            {%- assign bp = block.settings.product -%}
            {%- if bp == blank -%}{% continue %}{%- endif -%}
            {%- assign block_col = block.settings.column | default: block.settings.label -%}
            {%- unless block_col == col_name -%}{% continue %}{%- endunless -%}
            {%- assign col_item_index = col_item_index | plus: 1 -%}

            {%- liquid
              assign is_dev       = block.settings.is_developing
              assign disc         = block.settings.discount_percent
              assign specific_vid = block.settings.variant_id | strip
              assign cat_id       = 'ba-cat-' | append: forloop.index
              assign show_variants = false
              if bp.variants.size > 1 and specific_vid == blank
                assign show_variants = true
              endif
              assign display_variant = bp.variants.first
            -%}
            {%- unless specific_vid == blank -%}
              {%- for v in bp.variants -%}
                {%- assign vid_str = v.id | append: '' -%}
                {%- if vid_str == specific_vid -%}{%- assign display_variant = v -%}{%- endif -%}
              {%- endfor -%}
            {%- endunless -%}
            {%- liquid
              assign orig_cents = display_variant.price
              if is_dev
                assign sale_cents = 0
              elsif disc > 0
                assign disc_float = disc | times: 1.0 | divided_by: 100
                assign save_cents = orig_cents | times: disc_float | floor
                assign sale_cents = orig_cents | minus: save_cents
              else
                assign sale_cents = orig_cents
              endif
            -%}
            {%- assign popup_imgs = '' -%}
            {%- for media in bp.media limit: 6 -%}
              {%- if media.media_type == 'image' -%}
                {%- assign img_url = media | image_url: width: 600 -%}
                {%- if popup_imgs == '' -%}{%- assign popup_imgs = img_url -%}
                {%- else -%}{%- assign popup_imgs = popup_imgs | append: '||' | append: img_url -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            <div
              class="ba-mini-card{% if col_item_index > 2 %} is-hidden{% endif %}{% unless display_variant.available %} is-oos{% endunless %}"
              id="{{ cat_id }}"
              data-variant-id="{{ display_variant.id }}"
              data-product-id="{{ bp.id }}"
              data-product-title="{{ bp.title | escape }}"
              data-orig="{{ orig_cents }}"
              data-sale="{{ orig_cents }}"
              data-is-dev="{{ is_dev }}"
              data-disc="{{ disc }}"
              data-cat="{{ cat_id }}"
              data-col-id="bfc4-col-{{ forloop.parentloop.index }}"
              data-col-name="{{ col_name | escape }}"
              data-starter="{{ block.settings.is_starter_kit }}"
              {% if display_variant.available %}onclick="baMiniSelect(this, event)"{% endif %}
              {{ block.shopify_attributes }}
            >
              <div class="ba-mini-img-wrap">
                {%- if bp.featured_image -%}
                  <img class="ba-mini-img" src="{{ bp.featured_image | image_url: width: 400 }}" alt="{{ bp.title | escape }}" loading="lazy"/>
                {%- else -%}
                  <div class="ba-mini-img-ph"></div>
                {%- endif -%}
                {%- unless display_variant.available -%}<span class="ba-mini-oos">Out of Stock</span>{%- endunless -%}
                <button
                  class="ba-mini-info-icon"
                  onclick="event.stopPropagation(); baOpenPopup('{{ cat_id }}')"
                  aria-label="View details"
                ><svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg></button>
              </div>
              <div class="ba-mini-body">
                <div class="ba-mini-info">
                  <div class="ba-mini-name">{{ block.settings.custom_label | default: bp.title }}</div>
                </div>
                <div class="ba-mini-right">
                  {%- unless is_dev -%}<span class="ba-mini-price">{{ orig_cents | money }}</span>{%- endunless -%}
                </div>
              </div>
              {%- if show_variants -%}
                <div class="ba-mini-vars" onclick="event.stopPropagation()">
                  {%- for variant in bp.variants -%}
                    {%- if variant.available -%}
                      {%- liquid
                        assign v_orig = variant.price
                        if is_dev
                          assign v_sale = 0
                        elsif disc > 0
                          assign v_df = disc | times: 1.0 | divided_by: 100
                          assign v_sv = v_orig | times: v_df | floor
                          assign v_sale = v_orig | minus: v_sv
                        else
                          assign v_sale = v_orig
                        endif
                      -%}
                      <button
                        class="ba-mini-var-btn{% if forloop.first %} is-sel{% endif %}"
                        data-variant-id="{{ variant.id }}"
                        data-product-title="{{ bp.title | escape }}"
                        data-orig="{{ variant.price }}"
                        data-sale="{{ variant.price }}"
                        data-is-dev="{{ is_dev }}"
                        data-disc="{{ disc }}"
                        data-cat="{{ cat_id }}"
                        onclick="baMiniSelectVar(this)"
                      >{{ variant.title }} – {%- if is_dev -%}Free{%- else -%}{{ v_sale | money }}{%- endif -%}</button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
            <div id="ba-popup-data-{{ cat_id }}" style="display:none"
              data-title="{{ bp.title | escape }}"
              data-desc="{{ bp.description | replace: '</p>', '||PARA||' | replace: '</div>', '||PARA||' | replace: '<br>', '||LINE||' | replace: '<br/>', '||LINE||' | replace: '<br />', '||LINE||' | replace: '</li>', '||LINE||' | replace: '</h2>', '||PARA||' | replace: '</h3>', '||PARA||' | replace: '</h4>', '||PARA||' | strip_html | strip | escape }}"
              data-imgs="{{ popup_imgs | escape }}"
            ></div>
          {%- endfor -%}

          {%- comment -%} ── AUTO-INJECT compatible products via system_compatibility metafield (More column only) ── {%- endcomment -%}
          {%- if col_name == 'More' -%}
            {%- assign current_compat = product.metafields.custom.system_compatibility.value -%}
            {%- if current_compat != blank -%}
              {%- assign auto_collection = collections['lenses-and-accessories'] | default: collections.all -%}

              {%- assign shown_handles = '' -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'kit_item' and block.settings.product != blank -%}
                  {%- assign shown_handles = shown_handles | append: block.settings.product.handle | append: '||' -%}
                {%- endif -%}
              {%- endfor -%}

              {%- comment -%} Count compatible (for More button accuracy) {%- endcomment -%}
              {%- assign auto_total = 0 -%}
              {%- for cp in auto_collection.products -%}
                {%- if cp.id == product.id -%}{%- continue -%}{%- endif -%}
              {%- comment -%} Exclude same product type (don't show cameras as accessories for cameras) {%- endcomment -%}
              {%- if cp.type == product.type -%}{%- continue -%}{%- endif -%}
                {%- if shown_handles contains cp.handle -%}{%- continue -%}{%- endif -%}
                {%- assign cp_compat = cp.metafields.custom.system_compatibility.value -%}
                {%- if cp_compat == blank -%}{%- continue -%}{%- endif -%}
                {%- assign matched = false -%}
                {%- for tag in current_compat -%}
                  {%- if cp_compat contains tag -%}{%- assign matched = true -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                {%- if matched -%}{%- assign auto_total = auto_total | plus: 1 -%}{%- endif -%}
              {%- endfor -%}
              {%- assign col_item_total = col_item_total | plus: auto_total -%}

              {%- comment -%} Render compatible product tiles {%- endcomment -%}
              {%- for cp in auto_collection.products -%}
                {%- if cp.id == product.id -%}{%- continue -%}{%- endif -%}
              {%- comment -%} Exclude same product type (don't show cameras as accessories for cameras) {%- endcomment -%}
              {%- if cp.type == product.type -%}{%- continue -%}{%- endif -%}
                {%- if shown_handles contains cp.handle -%}{%- continue -%}{%- endif -%}
                {%- assign cp_compat = cp.metafields.custom.system_compatibility.value -%}
                {%- if cp_compat == blank -%}{%- continue -%}{%- endif -%}
                {%- assign matched = false -%}
                {%- for tag in current_compat -%}
                  {%- if cp_compat contains tag -%}{%- assign matched = true -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                {%- unless matched -%}{%- continue -%}{%- endunless -%}

                {%- assign col_item_index = col_item_index | plus: 1 -%}
                {%- assign auto_cat_id = 'ba-auto-' | append: cp.id -%}
                {%- assign cp_variant = cp.selected_or_first_available_variant -%}

                {%- assign auto_popup_imgs = '' -%}
                {%- for media in cp.media limit: 6 -%}
                  {%- if media.media_type == 'image' -%}
                    {%- assign aimg = media | image_url: width: 600 -%}
                    {%- if auto_popup_imgs == '' -%}{%- assign auto_popup_imgs = aimg -%}
                    {%- else -%}{%- assign auto_popup_imgs = auto_popup_imgs | append: '||' | append: aimg -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}

                <div
                  class="ba-mini-card{% if col_item_index > 2 %} is-hidden{% endif %}{% unless cp_variant.available %} is-oos{% endunless %}"
                  id="{{ auto_cat_id }}"
                  data-variant-id="{{ cp_variant.id }}"
                  data-product-id="{{ cp.id }}"
                  data-product-title="{{ cp.title | escape }}"
                  data-orig="{{ cp_variant.price }}"
                  data-sale="{{ cp_variant.price }}"
                  data-is-dev="false"
                  data-disc="0"
                  data-cat="{{ auto_cat_id }}"
                  data-col-id="bfc4-col-{{ forloop.parentloop.index }}"
                  data-col-name="{{ col_name | escape }}"
                  data-starter="false"
                  data-auto-compat="true"
                  {% if cp_variant.available %}onclick="baMiniSelect(this, event)"{% endif %}>
                  <div class="ba-mini-img-wrap">
                    {%- if cp.featured_image -%}
                      <img class="ba-mini-img" src="{{ cp.featured_image | image_url: width: 200 }}" alt="{{ cp.title | escape }}" loading="lazy">
                    {%- else -%}
                      <div class="ba-mini-img-ph"></div>
                    {%- endif -%}
                    {%- unless cp_variant.available -%}<span class="ba-mini-oos">Out of Stock</span>{%- endunless -%}
                    <button
                      class="ba-mini-info-icon"
                      onclick="event.stopPropagation(); baOpenPopup('{{ auto_cat_id }}')"
                      aria-label="View details"
                    ><svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg></button>
                  </div>
                  <div class="ba-mini-body">
                    <div class="ba-mini-info">
                      <div class="ba-mini-name">{{ cp.title }}</div>
                    </div>
                    <div class="ba-mini-price">{{ cp_variant.price | money }}</div>
                  </div>
                </div>
                <div id="ba-popup-data-{{ auto_cat_id }}" style="display:none"
                  data-title="{{ cp.title | escape }}"
                  data-desc="{{ cp.description | replace: '</p>', '||PARA||' | replace: '</div>', '||PARA||' | replace: '<br>', '||LINE||' | replace: '<br/>', '||LINE||' | replace: '<br />', '||LINE||' | replace: '</li>', '||LINE||' | replace: '</h2>', '||PARA||' | replace: '</h3>', '||PARA||' | replace: '</h4>', '||PARA||' | strip_html | strip | escape }}"
                  data-imgs="{{ auto_popup_imgs | escape }}"
                ></div>
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}

          {%- if col_item_total > 2 -%}
            <button class="ba-col-more" onclick="event.stopPropagation(); baExpandCol(this.closest('.ba-col'))">
              <span class="ba-col-more-text">{{ col_item_total | minus: 2 }} more &rsaquo;</span>
            </button>
          {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Promo banners {%- endcomment -%}


    {%- comment -%} Selected add-ons row + checkout {%- endcomment -%}
    <div class="bfc4-below-checkout">
      <div class="bfc4-selected-row" id="bfc4-selected-row">
        <div class="bfc4-selected-items" id="bfc4-selected-items">
          {%- comment -%} Populated by JS {%- endcomment -%}
        </div>
        <div class="bfc4-below-atc">
          {%- if product.variants.size > 1 -%}
            <div class="bfc4-grade-compact">
              <span class="bfc4-grade-label">Grade</span>
              <div class="bfc4-grade-row">
