{%- comment -%} Sticky Mobile ATC Bar {%- endcomment -%}
{% render 'bfc-pdp-lightbox' %}
<div class="bfc4-sticky-bar" id="bfc4-sticky-bar">
  <div class="bfc4-sticky-info">
    <div class="bfc4-sticky-name">{{ product.title }}</div>
    <div class="bfc4-sticky-meta">
      {%- if product.variants.size > 1 and current_variant.title != "Default Title" -%}<span class="bfc4-sticky-grade" id="bfc4-sticky-grade">{{ current_variant.title }}</span>{%- endif -%}
      <span class="bfc4-sticky-price" id="bfc4-sticky-price">{{ current_variant.price | money }}</span>
    </div>
  </div>
  <button class="bfc4-sticky-btn" onclick="var _s=this;_s.textContent='Adding\u2026';_s.style.opacity='0.7';bfc4BundleATC()"{%- unless current_variant.available %} disabled{%- endunless %}>Add to Cart</button>
</div>

<script>
(function() {
  var stickyBar = document.getElementById('bfc4-sticky-bar');
  var mainAtc   = document.getElementById('bfc4-atc');
  if (stickyBar && mainAtc) {
    var _stickySuppress = false;
    new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (_stickySuppress) return;
        stickyBar.classList.toggle('is-visible', !e.isIntersecting);
      });
    }, { threshold: 0 }).observe(mainAtc);
    window._bfcStickySuppress = function() { _stickySuppress = true; };
    window._bfcStickyUnsuppress = function() { _stickySuppress = false; };
  }
  /* Hide sticky bar when cart drawer opens (minimal, safe) */
  if (stickyBar) {
    var _hideSticky = function() { stickyBar.classList.remove('is-visible'); };
    /* Click any cart icon/link → hide immediately */
    document.addEventListener('click', function(e) {
      var t = e.target.closest('a[href="/cart"], a[href^="/cart?"], [data-cart-icon], [data-cart-toggle], summary[aria-controls*="cart" i], button[aria-controls*="cart" i], .header__icon--cart');
      if (t) _hideSticky();
    }, true);
    /* Body class changes (js-drawer-open etc) */
    new MutationObserver(function() {
      if (document.body.classList.contains('js-drawer-open')
       || document.body.classList.contains('drawer-open')
       || document.body.classList.contains('cart-open')) _hideSticky();
    }).observe(document.body, { attributes: true, attributeFilter: ['class'] });
    /* Theme events (cart:open, cart:refresh — NOT cart:updated which is noisy) */
    ['cart:open', 'cart-drawer:open', 'drawer:open'].forEach(function(ev) {
      document.addEventListener(ev, _hideSticky);
    });
  }

  // Sticky bar ATC feedback — watch main button for success class
  if (mainAtc && stickyBar) {
    new MutationObserver(function() {
      if (mainAtc.classList.contains('is-success')) {
        var sBtn = stickyBar.querySelector('.bfc4-sticky-btn');
        if (window._bfcStickySuppress) window._bfcStickySuppress();
        if (sBtn) { sBtn.textContent = 'Added!'; sBtn.style.background = '#2a4820'; }
        setTimeout(function() {
          stickyBar.classList.remove('is-visible');
          if (sBtn) { sBtn.textContent = 'Add to Cart'; sBtn.style.background = ''; }
          if (window._bfcStickyUnsuppress) setTimeout(window._bfcStickyUnsuppress, 3000);
        }, 2000);
      }
    }).observe(mainAtc, { attributes: true, attributeFilter: ['class'] });
  }
})();
</script>

