<style>
/* ─────────────────────────────────────────
   RELEASE THEME HEADER FIX
   The dark hero triggers overlay/expanded
   header mode — this forces normal padding.
───────────────────────────────────────── */
.js-header {
  --header-padding-top: 0px !important;
  --header-padding-bottom: 0px !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
}
/* ─────────────────────────────────────────
   BFC MEMBERSHIP SECTION
   All styles scoped to .bfc-mem to avoid
   conflicts with existing theme CSS.
───────────────────────────────────────── */

.bfc-mem {
  --bfc-canvas:      #F8F6EE;
  --bfc-black:       #202009;
  --bfc-charcoal:    #4E4741;
  --bfc-gray:        #E3DDDA;
  --bfc-manila:      #FFEACC;
  --bfc-brown:       #5A3E2D;
  --bfc-olive-lt:    #82906B;
  --bfc-olive:       #525741;
  --bfc-celadon:     #ABCC99;
  --bfc-border:      rgba(78,71,65,0.13);
  --bfc-border-md:   rgba(78,71,65,0.24);
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  line-height: 1.6;
  color: var(--bfc-black);
}

.bfc-mem *, .bfc-mem *::before, .bfc-mem *::after {
  box-sizing: border-box;
}

/* ── LAYOUT ── */
.bfc-wrap {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 48px;
}

/* ── EYEBROW ── */
.bfc-eyebrow {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--bfc-charcoal);
  display: block;
  margin-bottom: 14px;
}

/* ── SECTION HEADING ── */
.bfc-s-hed {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(30px, 3.6vw, 48px);
  font-weight: 500;
  line-height: 1.08;
  letter-spacing: -0.01em;
}
.bfc-s-hed em { font-style: italic; }

/* ── DIVIDER ── */
hr.bfc-rule {
  border: none;
  border-top: 1px solid var(--bfc-border);
  margin: 0;
}

/* ─────────────────────────────────────────
   HERO
───────────────────────────────────────── */
.bfc-hero {
  background: var(--bfc-black);
  color: var(--bfc-canvas);
  padding: 100px 0 88px;
  position: relative;
  overflow: hidden;
}
.bfc-hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.028;
  pointer-events: none;
}
.bfc-hero-grid {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 80px;
  align-items: center;
  position: relative;
  z-index: 1;
}
.bfc-hero .bfc-eyebrow { color: rgba(227,221,218,0.42); margin-bottom: 20px; }

.bfc-hero-hed {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(52px, 6.8vw, 88px);
  font-weight: 500;
  line-height: 1.12;
  letter-spacing: -0.02em;
  color: var(--bfc-canvas);
  margin-bottom: 28px;
}
.bfc-hero-hed em { font-style: italic; color: var(--bfc-manila); }

.bfc-hero-body {
  font-size: 14px;
  font-weight: 300;
  line-height: 1.8;
  color: rgba(227,221,218,0.62);
  max-width: 480px;
}
.bfc-mem .bfc-hero-body p {
  margin: 0 0 80px;
}
.bfc-hero-body strong { color: var(--bfc-canvas); font-weight: 500; }

.bfc-hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; }

.bfc-btn-hero-primary {
  background: var(--bfc-canvas);
  color: var(--bfc-black);
  font-family: 'Poppins', sans-serif;
  font-size: 10.5px; font-weight: 600;
  letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none; padding: 14px 32px;
  display: inline-block; border: none; cursor: pointer;
  transition: background 0.18s;
}
.bfc-btn-hero-primary:hover { background: var(--bfc-gray); color: var(--bfc-black); text-decoration: none; }

.bfc-btn-hero-ghost {
  background: transparent;
  color: rgba(227,221,218,0.62);
  font-family: 'Poppins', sans-serif;
  font-size: 10.5px; font-weight: 600;
  letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none; padding: 13px 30px;
  border: 1px solid rgba(255,255,255,0.16);
  display: inline-block; cursor: pointer;
  transition: border-color 0.18s, color 0.18s;
}
.bfc-btn-hero-ghost:hover { border-color: rgba(255,255,255,0.45); color: var(--bfc-canvas); text-decoration: none; }

/* Stats panel */
.bfc-hero-panel {
  border: 1px solid rgba(255,255,255,0.09);
  overflow: hidden;
}
.bfc-panel-head {
  font-size: 9px; font-weight: 600; letter-spacing: 0.22em;
  text-transform: uppercase; color: rgba(227,221,218,0.32);
  padding: 16px 22px 15px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.bfc-sr {
  display: flex; justify-content: space-between;
  align-items: center; padding: 12px 22px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  transition: background 0.15s;
}
.bfc-sr:last-child { border-bottom: none; }
.bfc-sr:hover { background: rgba(255,255,255,0.03); }
.bfc-sr-lbl { font-size: 11.5px; font-weight: 300; color: rgba(227,221,218,0.75); }
.bfc-sr-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 23px; font-weight: 500;
  color: var(--bfc-canvas); letter-spacing: -0.01em;
}

/* Entrance animation */
@keyframes bfcFadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.bfc-hero-left > * { opacity: 0; animation: bfcFadeUp 0.6s ease forwards; }
.bfc-hero-left > *:nth-child(1) { animation-delay: 0.08s; }
.bfc-hero-left > *:nth-child(2) { animation-delay: 0.19s; }
.bfc-hero-left > *:nth-child(3) { animation-delay: 0.30s; }
.bfc-hero-left > *:nth-child(4) { animation-delay: 0.41s; }

/* ─────────────────────────────────────────
   TICKER
───────────────────────────────────────── */
.bfc-ticker { background: var(--bfc-charcoal); padding: 12px 0; overflow: hidden; }
.bfc-t-track {
  display: flex; gap: 52px; white-space: nowrap;
  animation: bfcTick 28s linear infinite; width: max-content;
}
.bfc-t-item {
  font-size: 9.5px; font-weight: 600; letter-spacing: 0.2em;
  text-transform: uppercase; color: rgba(255,255,255,0.85);
  display: flex; align-items: center; gap: 9px;
}
.bfc-t-item::before {
  content: ''; width: 3px; height: 3px; border-radius: 50%;
  background: rgba(255,255,255,0.4); display: block; flex-shrink: 0;
}
@keyframes bfcTick {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ─────────────────────────────────────────
   PERKS
───────────────────────────────────────── */
.bfc-perks { padding: 88px 0; background: var(--bfc-canvas); }

.bfc-s-header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: end;
  margin-bottom: 52px;
}
.bfc-s-intro {
  font-size: 13.5px; font-weight: 300; line-height: 1.78;
  color: var(--bfc-charcoal); align-self: end;
}

/* "Included with every plan" pill */
.bfc-all-plans-pill {
  display: inline-flex; align-items: center; gap: 9px;
  background: var(--bfc-black); color: var(--bfc-canvas);
  font-size: 10px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 8px 14px; margin-bottom: 16px;
}
.bfc-all-plans-pill::before {
  content: ''; width: 5px; height: 5px;
  background: var(--bfc-celadon); display: block; flex-shrink: 0;
}

.bfc-perks-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 1px solid var(--bfc-border);
  border-left: 1px solid var(--bfc-border);
}
.bfc-perk {
  border-right: 1px solid var(--bfc-border);
  border-bottom: 1px solid var(--bfc-border);
  padding: 24px 26px;
  transition: background 0.18s;
}
.bfc-perk:hover { background: var(--bfc-gray); }
.bfc-perk-idx {
  font-size: 9px; font-weight: 600; letter-spacing: 0.16em;
  color: var(--bfc-olive-lt); display: block; margin-bottom: 10px;
}
.bfc-perk-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 19px; font-weight: 600; line-height: 1.2;
  margin-bottom: 6px; color: var(--bfc-black);
}
.bfc-perk-body {
  font-size: 12px; font-weight: 300; line-height: 1.65; color: var(--bfc-charcoal);
}

/* ─────────────────────────────────────────
   COMPARISON TABLE
───────────────────────────────────────── */
.bfc-compare { padding: 88px 0; background: var(--bfc-gray); }
.bfc-compare .bfc-s-hed { margin-bottom: 32px; }

.bfc-ctable-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.bfc-ctable {
  width: 100%; border-collapse: collapse; background: var(--bfc-canvas);
}
.bfc-ctable th, .bfc-ctable td {
  padding: 15px 20px; text-align: left;
  border-bottom: 1px solid var(--bfc-border);
  vertical-align: middle;
}
.bfc-ctable th {
  font-size: 9.5px; font-weight: 600; letter-spacing: 0.17em;
  text-transform: uppercase; color: var(--bfc-charcoal); background: var(--bfc-canvas);
}
.bfc-ctable th.bfc-cm {
  color: var(--bfc-olive); background: rgba(82,87,65,0.05);
  border-bottom: 2px solid var(--bfc-olive);
}
.bfc-ctable tbody tr:last-child td { border-bottom: none; }
.bfc-ctable td { font-size: 13px; font-weight: 400; }
.bfc-ctable td.bfc-cf { color: var(--bfc-charcoal); }
.bfc-ctable td.bfc-cm {
  background: rgba(82,87,65,0.04); color: var(--bfc-olive); font-weight: 500;
}
.bfc-ck { color: var(--bfc-olive); font-weight: 600; }
.bfc-dim { color: var(--bfc-olive-lt); }
.bfc-ctable tbody tr:hover td { background: rgba(78,71,65,0.025); }
.bfc-ctable tbody tr:hover td.bfc-cm { background: rgba(82,87,65,0.07); }

/* ─────────────────────────────────────────
   PRICING
───────────────────────────────────────── */
.bfc-pricing {
  background: var(--bfc-brown);
  color: var(--bfc-canvas);
  padding: 88px 0;
}
.bfc-pricing-hd { text-align: center; margin-bottom: 14px; }
.bfc-pricing-hd .bfc-eyebrow { color: rgba(227,221,218,0.45); }
.bfc-pricing-hed {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 500; line-height: 1.05;
  letter-spacing: -0.01em; color: var(--bfc-canvas);
}
.bfc-pricing-hed em { font-style: italic; }
.bfc-pricing-sub {
  font-size: 13px; font-weight: 300;
  color: rgba(227,221,218,0.55); margin-top: 10px;
}

/* Billing toggle */
.bfc-tog-row {
  display: flex; align-items: center; justify-content: center;
  gap: 13px; margin: 34px 0 48px;
}
.bfc-tog-lbl {
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(227,221,218,0.4);
  cursor: pointer; transition: color 0.15s;
}
.bfc-tog-lbl.on { color: var(--bfc-canvas); }
.bfc-tog-pill {
  width: 42px; height: 22px; border-radius: 11px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.18);
  position: relative; cursor: pointer; transition: background 0.2s;
}
.bfc-tog-pill.on { background: var(--bfc-celadon); border-color: var(--bfc-celadon); }
.bfc-tog-knob {
  position: absolute; top: 2px; left: 2px;
  width: 16px; height: 16px; border-radius: 50%; background: #fff;
  transition: transform 0.22s cubic-bezier(0.4,0,0.2,1);
}
.bfc-tog-pill.on .bfc-tog-knob { transform: translateX(20px); }
.bfc-save-pill {
  font-size: 9.5px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; background: var(--bfc-celadon);
  color: var(--bfc-olive); padding: 3px 9px;
}

/* Plan cards */
.bfc-plans {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
}
.bfc-p-card {
  border: 1px solid rgba(255,255,255,0.1);
  padding: 36px 28px; position: relative;
  transition: border-color 0.2s, transform 0.18s;
}
.bfc-p-card:hover { border-color: rgba(255,255,255,0.22); transform: translateY(-3px); }
.bfc-p-card.hi    { border-color: var(--bfc-celadon); background: rgba(171,204,153,0.05); }

.bfc-p-badge {
  position: absolute; top: 0; right: 28px;
  background: var(--bfc-celadon); color: var(--bfc-olive);
  font-size: 9px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; padding: 4px 11px;
  transform: translateY(-50%);
}
.bfc-p-name {
  font-size: 9.5px; font-weight: 600; letter-spacing: 0.2em;
  text-transform: uppercase; color: rgba(227,221,218,0.5); margin-bottom: 18px;
}
.bfc-p-price {
  display: flex; align-items: baseline; gap: 3px; margin-bottom: 5px;
}
.bfc-p-sym  { font-size: 17px; font-weight: 300; color: rgba(248,246,238,0.4); margin-top: 7px; }
.bfc-p-num  {
  font-family: 'Cormorant Garamond', serif;
  font-size: 54px; font-weight: 500; line-height: 1; color: var(--bfc-canvas);
}
.bfc-p-freq { font-size: 11px; font-weight: 300; color: rgba(227,221,218,0.45); }

.bfc-p-mo {}
.bfc-p-yr  { display: none; }
.bfc-show-yr .bfc-p-mo { display: none; }
.bfc-show-yr .bfc-p-yr { display: flex; }

.bfc-p-val {
  font-size: 11.5px; font-weight: 400; color: var(--bfc-celadon); margin-bottom: 24px;
}
.bfc-p-div { border: none; border-top: 1px solid rgba(255,255,255,0.08); margin: 24px 0; }
.bfc-p-tag {
  font-size: 13px; font-weight: 300; line-height: 1.68;
  color: rgba(227,221,218,0.6); margin-bottom: 26px;
}
.bfc-p-feats {
  list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 34px;
  padding: 0;
}
.bfc-p-feats li {
  font-size: 12.5px; font-weight: 400;
  color: rgba(248,246,238,0.78);
  display: flex; align-items: baseline; gap: 9px; line-height: 1.5;
}
.bfc-p-feats li::before { content: '+'; color: var(--bfc-celadon); font-weight: 600; font-size: 13px; flex-shrink: 0; }
.bfc-fs { color: var(--bfc-canvas); font-weight: 500; }

.bfc-btn-plan {
  display: block; width: 100%; text-align: center;
  font-family: 'Poppins', sans-serif;
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.15em;
  text-transform: uppercase; padding: 14px 20px;
  text-decoration: none; cursor: pointer; border: none; transition: all 0.18s;
}
.bfc-btn-plan:hover { text-decoration: none; }
.bfc-btn-ghost { background: transparent; color: var(--bfc-canvas); border: 1px solid rgba(255,255,255,0.2); }
.bfc-btn-ghost:hover { border-color: var(--bfc-canvas); color: var(--bfc-canvas); }
.bfc-btn-cel   { background: var(--bfc-celadon); color: var(--bfc-olive); }
.bfc-btn-cel:hover { background: #bdd9aa; color: var(--bfc-olive); }

.bfc-p-note {
  text-align: center; margin-top: 28px;
  font-size: 11px; font-weight: 300;
  color: rgba(227,221,218,0.35); letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────
   FORMATS
───────────────────────────────────────── */
.bfc-formats { padding: 88px 0; background: var(--bfc-canvas); }
.bfc-fmt-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;
}
.bfc-fmt-left .bfc-s-hed { margin-bottom: 18px; }
.bfc-fmt-body {
  font-size: 13.5px; font-weight: 300; line-height: 1.76;
  color: var(--bfc-charcoal); margin-bottom: 28px;
}
.bfc-live-pill {
  display: inline-flex; align-items: center; gap: 9px;
  background: var(--bfc-gray); padding: 9px 16px;
  font-size: 11px; font-weight: 500; letter-spacing: 0.04em; color: var(--bfc-black);
}
.bfc-live-dot {
  width: 6px; height: 6px; border-radius: 50%; background: #5fa64a;
  flex-shrink: 0;
  animation: bfcBlink 2.3s infinite;
}
@keyframes bfcBlink { 0%,100%{opacity:1} 50%{opacity:0.35} }

.bfc-ftags { display: flex; flex-wrap: wrap; gap: 6px; }
.bfc-ftag {
  font-size: 10.5px; font-weight: 500; letter-spacing: 0.07em;
  padding: 7px 13px; border: 1px solid var(--bfc-border-md);
  color: var(--bfc-charcoal); background: transparent; transition: all 0.15s; cursor: default;
}
.bfc-ftag:hover { background: var(--bfc-black); color: var(--bfc-canvas); border-color: var(--bfc-black); }

/* ─────────────────────────────────────────
   MAIL-IN
───────────────────────────────────────── */
.bfc-mailin {
  padding: 80px 0; background: var(--bfc-canvas);
  border-top: 1px solid var(--bfc-border);
}
.bfc-mailin-top {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: 32px; margin-bottom: 52px; flex-wrap: wrap;
}
.bfc-mailin-hed {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(26px, 3vw, 40px);
  font-weight: 500; line-height: 1.08; margin: 10px 0 0;
}
.bfc-mailin-hed em { font-style: italic; }
.bfc-mailin-steps {
  display: grid; grid-template-columns: repeat(3, 1fr);
  border-top: 1px solid var(--bfc-border);
  border-left: 1px solid var(--bfc-border);
}
.bfc-mstep {
  border-right: 1px solid var(--bfc-border);
  border-bottom: 1px solid var(--bfc-border);
  padding: 32px 28px 28px;
}
.bfc-mstep-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 64px; font-weight: 500; line-height: 1;
  color: var(--bfc-border-md); display: block;
  margin-bottom: 18px; letter-spacing: -0.02em;
}
.bfc-mstep-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 600; line-height: 1.2;
  color: var(--bfc-black); margin-bottom: 8px;
}
.bfc-mstep-body {
  font-size: 12.5px; font-weight: 300; line-height: 1.68; color: var(--bfc-charcoal);
}
@media screen and (max-width: 880px) {
  .bfc-mailin-top { margin-bottom: 36px; }
  .bfc-mailin-steps { grid-template-columns: 1fr; }
  .bfc-mailin { padding: 60px 0; }
}
@media screen and (max-width: 540px) {
  .bfc-mailin { padding: 48px 0; }
  .bfc-mstep  { padding: 24px 18px; }
  .bfc-mstep-num { font-size: 52px; margin-bottom: 12px; }
}

.bfc-btn-solid {
  display: inline-block;
  background: var(--bfc-black); color: var(--bfc-canvas);
  font-family: 'Poppins', sans-serif;
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.15em;
  text-transform: uppercase; text-decoration: none;
  padding: 13px 30px; border: none; cursor: pointer;
  transition: background 0.18s;
}
.bfc-btn-solid:hover { background: var(--bfc-charcoal); color: var(--bfc-canvas); text-decoration: none; }

/* ─────────────────────────────────────────
   CTA FOOTER
───────────────────────────────────────── */
.bfc-footer-cta {
  background: var(--bfc-black); color: var(--bfc-canvas);
  padding: 88px 0; text-align: center;
}
.bfc-footer-cta .bfc-eyebrow { color: rgba(227,221,218,0.38); }
.bfc-footer-hed {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(34px, 4.4vw, 58px);
  font-weight: 500; line-height: 1.05;
  letter-spacing: -0.01em; color: var(--bfc-canvas); margin-bottom: 14px;
}
.bfc-footer-hed em { font-style: italic; }
.bfc-footer-sub {
  font-size: 13px; font-weight: 300;
  color: rgba(227,221,218,0.55); max-width: 480px;
  margin: 0 auto 36px; line-height: 1.78;
}
.bfc-footer-btns { display: flex; gap: 11px; justify-content: center; }

.bfc-btn-canvas {
  display: inline-block;
  background: var(--bfc-canvas); color: var(--bfc-black);
  font-family: 'Poppins', sans-serif;
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.15em;
  text-transform: uppercase; text-decoration: none;
  padding: 13px 30px; border: none; cursor: pointer;
  transition: background 0.18s;
}
.bfc-btn-canvas:hover { background: var(--bfc-gray); color: var(--bfc-black); text-decoration: none; }

.bfc-btn-ghost-light {
  display: inline-block;
  background: transparent; color: var(--bfc-canvas);
