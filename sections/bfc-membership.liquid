/* ─────────────────────────────────────────
   RESPONSIVE
───────────────────────────────────────── */
@media screen and (max-width: 880px) {
  .bfc-wrap { padding: 0 24px; }
  .bfc-hero-grid, .bfc-s-header, .bfc-fmt-grid {
    grid-template-columns: 1fr; gap: 28px;
  }
  .bfc-plans { grid-template-columns: 1fr 1fr; gap: 14px; }
  .bfc-hero-panel { display: none; }
  .bfc-mem .bfc-hero-body p { margin-bottom: 40px; }
  .bfc-hero       { padding: 64px 0 56px; }
  .bfc-mailin-inner { grid-template-columns: 1fr; gap: 36px; }  .bfc-perks      { padding: 60px 0; }
  .bfc-compare    { padding: 60px 0; }
  .bfc-pricing    { padding: 60px 0; }
  .bfc-formats    { padding: 60px 0; }
  .bfc-mailin     { padding: 48px 0; }
  .bfc-footer-cta { padding: 64px 0; }
  .bfc-perks-grid { grid-template-columns: 1fr 1fr; }
  .bfc-footer-btns { flex-direction: column; align-items: center; }
  .bfc-ctable { min-width: 480px; }
}

@media screen and (max-width: 540px) {
  .bfc-wrap       { padding: 0 18px; }
  .bfc-perks-grid { grid-template-columns: 1fr; }
  .bfc-hero-hed   { font-size: 44px; letter-spacing: -0.015em; }
  .bfc-mem .bfc-hero-body  { font-size: 13.5px; }
  .bfc-mem .bfc-hero-body p { margin-bottom: 32px; }
  .bfc-btn-hero-primary,
  .bfc-btn-hero-ghost { display: block; text-align: center; }
  .bfc-s-header   { gap: 16px; margin-bottom: 36px; }
  .bfc-s-hed      { font-size: 30px; }
  .bfc-perk       { padding: 20px 18px; }

  /* ── TABLE: mobile — allow wrapping, contain within viewport ── */
  .bfc-ctable-wrap {
    border: 1px solid var(--bfc-border);
    margin-top: 24px;
    overflow-x: hidden;
    width: 100%;
  }
  .bfc-ctable {
    min-width: 0; width: 100%; table-layout: fixed;
    border-collapse: collapse;
  }
  .bfc-ctable th,
  .bfc-ctable td {
    padding: 11px 8px;
    font-size: 10.5px;
    line-height: 1.4;
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
    vertical-align: middle;
  }
  .bfc-ctable th:first-child,
  .bfc-ctable td:first-child {
    width: 44%;
    text-align: left;
    padding-left: 12px;
    font-size: 10.5px;
  }
  .bfc-ctable th:not(:first-child),
  .bfc-ctable td:not(:first-child) {
    width: 28%;
    text-align: center;
    font-size: 10px;
    letter-spacing: 0;
    white-space: normal;
  }
  .bfc-ctable th:not(:first-child) {
    letter-spacing: 0.1em;
    font-size: 9px;
  }
  .bfc-compare .bfc-s-hed { margin-bottom: 20px; }

  /* ── PLANS: horizontal swipe slider ── */
  .bfc-plans-slider-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 18px;
    margin: 0 -18px;
    padding: 0 18px 16px;
    /* hide scrollbar */
    scrollbar-width: none;
  }
  .bfc-plans-slider-wrap::-webkit-scrollbar { display: none; }
  .bfc-plans {
    display: flex !important;
    flex-direction: row !important;
    gap: 12px;
    width: max-content;
  }
  .bfc-p-card {
    scroll-snap-align: start;
    width: 78vw;
    max-width: 320px;
    flex-shrink: 0;
    padding: 28px 22px;
  }

  .bfc-p-num      { font-size: 44px; }
  .bfc-ftag       { font-size: 10px; padding: 6px 11px; }
  .bfc-t-track    { gap: 36px; }
  .bfc-t-item     { font-size: 9px; }
  .bfc-footer-hed { font-size: 34px; }
  .bfc-footer-btns { gap: 8px; }
  .bfc-btn-canvas,
  .bfc-btn-ghost-light { display: block; text-align: center; }
  .bfc-mailin     { padding: 48px 0; }
  .bfc-tog-row    { gap: 10px; flex-wrap: wrap; justify-content: center; }

  /* "Included with every plan" pill shrink */
  .bfc-all-plans-pill { font-size: 9px; padding: 7px 12px; letter-spacing: 0.12em; }
}

@media screen and (max-width: 375px) {
  .bfc-wrap     { padding: 0 14px; }
  .bfc-hero-hed { font-size: 38px; }
  .bfc-ctable   { min-width: 0; }
  .bfc-ctable th, .bfc-ctable td { padding: 10px 6px; font-size: 10px; }
  .bfc-ctable th:not(:first-child) { font-size: 8.5px; }
  .bfc-ctable th:not(:first-child),
  .bfc-ctable td:not(:first-child) { font-size: 9.5px; }
  .bfc-plans-slider-wrap { margin: 0 -14px; padding: 0 14px 16px; }
  .bfc-p-card   { width: 84vw; }
}
/* ─────────────────────────────────────────
   CALCULATOR
───────────────────────────────────────── */
.bfc-calc { background: var(--bfc-canvas); padding: 72px 0; border-top: 1px solid var(--bfc-border); }
.bfc-calc-inner {
  border: 1px solid var(--bfc-border-md);
  background: #fff;
}
.bfc-calc-head {
  padding: 22px 28px;
  border-bottom: 1px solid var(--bfc-border);
  background: var(--bfc-gray);
}
.bfc-calc-title {
  font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--bfc-black); margin-bottom: 3px;
}
.bfc-calc-sub { font-size: 11.5px; font-weight: 300; color: var(--bfc-charcoal); }
.bfc-calc-body { padding: 28px; }
.bfc-calc-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 20px;
}
.bfc-calc-field label {
  display: block; font-size: 9px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--bfc-charcoal); margin-bottom: 7px;
}
.bfc-calc-field input,
.bfc-calc-field select {
  width: 100%; padding: 10px 13px;
  border: 1px solid var(--bfc-border-md);
  font-family: 'Poppins', sans-serif; font-size: 13px; color: var(--bfc-black);
  background: var(--bfc-canvas); appearance: none; -webkit-appearance: none;
  transition: border-color 0.15s;
}
.bfc-calc-field input:focus,
.bfc-calc-field select:focus { outline: none; border-color: var(--bfc-black); }
.bfc-calc-addons-label {
  font-size: 9px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--bfc-charcoal); margin-bottom: 9px;
}
.bfc-calc-addons { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
.bfc-calc-addon {
  padding: 7px 14px; border: 1px solid var(--bfc-border-md);
  font-family: 'Poppins', sans-serif; font-size: 9.5px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;
  color: var(--bfc-charcoal); transition: all 0.12s;
}
.bfc-calc-addon.on { background: var(--bfc-black); border-color: var(--bfc-black); color: #fff; }
.bfc-calc-results {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
  border-top: 1px solid var(--bfc-border); padding-top: 24px;
}
.bfc-calc-result {
  padding: 16px 14px; border: 1px solid var(--bfc-border);
}
.bfc-calc-result.bfc-cr-hi  { border-color: var(--bfc-celadon); background: rgba(171,204,153,0.08); }
.bfc-calc-result.bfc-cr-best { background: var(--bfc-black); border-color: var(--bfc-black); color: var(--bfc-canvas); }
.bfc-cr-name { font-size: 9px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px; opacity: 0.55; }
.bfc-cr-total { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 500; line-height: 1; margin-bottom: 3px; }
.bfc-cr-period { font-size: 9.5px; font-weight: 300; opacity: 0.45; margin-bottom: 9px; }
.bfc-cr-save { font-size: 11px; font-weight: 500; color: var(--bfc-charcoal); opacity: 0.6; margin-top: 4px; }
.bfc-cr-save-lbl {
  font-size: 9px; font-weight: 600; letter-spacing: 0.16em;
  text-transform: uppercase; opacity: 0.5; margin-bottom: 2px;
}
.bfc-cr-save-amt {
  display: block;
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 600; line-height: 1;
  color: var(--bfc-olive); margin-bottom: 2px;
}
.bfc-calc-result.bfc-cr-hi .bfc-cr-save-amt { color: var(--bfc-olive); }
.bfc-calc-result.bfc-cr-best .bfc-cr-save { color: rgba(248,246,238,0.6); }
.bfc-calc-result.bfc-cr-best .bfc-cr-save-amt { color: var(--bfc-celadon); }
.bfc-cr-total-sm {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px !important; font-weight: 500; line-height: 1;
  margin-top: 6px; margin-bottom: 1px; opacity: 0.5;
}
.bfc-cr-tag {
  display: inline-block; background: var(--bfc-celadon); color: var(--bfc-olive);
  font-size: 7.5px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 2px 8px; margin-bottom: 7px;
}
@media screen and (max-width: 880px) {
  .bfc-calc-results { grid-template-columns: 1fr 1fr; }
}
@media screen and (max-width: 540px) {
  .bfc-calc-row    { grid-template-columns: 1fr; }
  .bfc-calc-body   { padding: 20px 18px; }
  .bfc-calc-head   { padding: 16px 18px; }
  .bfc-calc-results { grid-template-columns: 1fr 1fr; gap: 8px; }
  .bfc-cr-total    { font-size: 26px; }
}

/* "Not sure?" button — canvas section */
.bfc-calc-nudge {
  text-align: center; margin-top: 20px;
}
.bfc-btn-nudge {
  display: inline-block;
  font-family: 'Poppins', sans-serif;
  font-size: 10px; font-weight: 500; letter-spacing: 0.08em;
  color: rgba(227,221,218,0.55); text-decoration: underline;
  text-underline-offset: 3px; cursor: pointer; background: none; border: none;
  transition: color 0.15s;
}
.bfc-btn-nudge:hover { color: var(--bfc-canvas); text-decoration: underline; }

/* "Buy Membership" CTA after table */
.bfc-compare-cta {
  text-align: center; padding: 40px 0 16px;
}

