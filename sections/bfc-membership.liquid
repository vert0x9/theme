<script>
(function() {
  var yr = false;
  var tog   = document.getElementById('bfc-tog');
  var grid  = document.getElementById('bfc-plans-grid');
  var lblMo = document.getElementById('bfc-lm');
  var lblYr = document.getElementById('bfc-ly');

  function apply() {
    // Toggle billing display
    if (yr) {
      tog.classList.add('on');
      grid.classList.add('bfc-show-yr');
      lblMo.classList.remove('on');
      lblYr.classList.add('on');
    } else {
      tog.classList.remove('on');
      grid.classList.remove('bfc-show-yr');
      lblMo.classList.add('on');
      lblYr.classList.remove('on');
    }
    // Update checkout URLs on plan CTA buttons
    document.querySelectorAll('.bfc-plan-cta').forEach(function(a) {
      a.href = yr ? a.dataset.yr : a.dataset.mo;
    });
    // Update credit value notes (monthly vs yearly = 12×)
    var credits = {
      casual:  { mo: 'Includes 1 Dev + Scan credit — an $18 value',    yr: 'Includes 12 Dev + Scan credits — a $216 value' },
      enth:    { mo: 'Includes 3 Dev + Scan credits — a $54 value',    yr: 'Includes 36 Dev + Scan credits — a $648 value' },
      serious: { mo: 'Includes 7 Dev + Scan credits — a $126 value',   yr: 'Includes 84 Dev + Scan credits — a $1,512 value' }
    };
    ['casual','enth','serious'].forEach(function(k) {
      var el = document.getElementById('bfc-val-' + k);
      if (el) el.textContent = yr ? credits[k].yr : credits[k].mo;
    });
    calcSavings();
  }

  if (tog)   tog.addEventListener('click',   function() { yr = !yr;  apply(); });
  if (lblMo) lblMo.addEventListener('click', function() { yr = false; apply(); });
  if (lblYr) lblYr.addEventListener('click', function() { yr = true;  apply(); });

  // Smooth scroll for #bfc-plans and #bfc-calculator anchors
  document.querySelectorAll('a[href^="#bfc-"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var id = a.getAttribute('href').replace('#', '');
      var target = document.getElementById(id);
      if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
    });
  });

  /* ── CALCULATOR ── */
  var calcAddons = { tiff: false, sleeves: true }; // sleeves on by default

  // Apply default visual state for sleeves
  var sleevesEl = document.getElementById('bfc-addon-sleeves');
  if (sleevesEl) sleevesEl.classList.add('on');

  document.querySelectorAll('.bfc-calc-addon').forEach(function(el) {
    el.addEventListener('click', function() {
      var key = el.id.replace('bfc-addon-', '');
      calcAddons[key] = !calcAddons[key];
      el.classList.toggle('on', calcAddons[key]);
      calcSavings();
    });
  });

  var rollsInput = document.getElementById('bfc-calc-rolls');
  var scanSel    = document.getElementById('bfc-calc-scan');
  if (rollsInput) rollsInput.addEventListener('input', calcSavings);
  if (scanSel)    scanSel.addEventListener('change', calcSavings);

  function fmt(n) { return '$' + n.toFixed(2); }

  function calcSavings() {
    var res = document.getElementById('bfc-calc-results');
    if (!res) return;

    var rolls      = Math.max(1, parseInt((rollsInput && rollsInput.value) || 4));
    var scanGuest  = parseFloat((scanSel && scanSel.value) || 0);
    var scanMember = parseFloat((scanSel && scanSel.options[scanSel.selectedIndex].dataset.member) || 0);
    var tiffGuest  = calcAddons.tiff    ? 1 : 0;
    var slvGuest   = calcAddons.sleeves ? 2 : 0;

    // Guest: pays full price every roll (tiff + sleeves add-ons if selected)
    var guestPerRoll = 18 + scanGuest + tiffGuest + slvGuest;
    var guestTotal   = guestPerRoll * rolls;

    // Member model:
    //   - Each credit covers 1 full roll at guest price ($18 value)
    //   - Credited rolls cost: $0
    //   - Extra rolls cost: $16/roll (member developing rate)
    //   - Tiff + sleeves always free for members
    //   - scan addon at member rate applies to all rolls
    function memberTotal(fee, credits, scanAddon) {
      var credited = Math.min(credits, rolls);
      var extra    = rolls - credited;
      return fee + extra * 16 + rolls * scanAddon;
    }

    var casualFee  = yr ? 17.10 : 18;
    var enthFee    = yr ? 42.75 : 45;   // $45/mo: 3 credits @ $15 each — cheaper than $16 extra rate
    var seriousFee = yr ? 94.05 : 99;

    // Serious Shooter gets $4 for 4K (others pay $6, scanMember is 6 for 4K option)
    var seriousScanAddon = (scanMember === 6) ? 4 : scanMember;

    var casualCost  = memberTotal(casualFee,  1, scanMember);
    var enthCost    = memberTotal(enthFee,    3, scanMember);
    var seriousCost = memberTotal(seriousFee, 7, seriousScanAddon);

    var scores = [
      { k: 'guest',   save: 0 },
      { k: 'casual',  save: guestTotal - casualCost },
      { k: 'enth',    save: guestTotal - enthCost },
      { k: 'serious', save: guestTotal - seriousCost }
    ];
    scores.sort(function(a, b) { return b.save - a.save; });
    var best = scores[0].save > 0 ? scores[0].k : 'guest';

    function card(key, name, total, save) {
      var isBest = best === key;
      var cls    = isBest ? 'bfc-cr-best' : (save > 0 ? 'bfc-cr-hi' : '');

      var body = '';
      if (key === 'guest') {
        // Guest: just show the price as before
        body = '<div class="bfc-cr-total">' + fmt(total) + '</div>' +
               '<div class="bfc-cr-period">per month</div>' +
               '<div class="bfc-cr-save">No membership</div>';
      } else if (save > 0) {
        // Member cards: Save amount big on top, total price smaller below
        body = '<div class="bfc-cr-save-lbl">Save</div>' +
               '<span class="bfc-cr-save-amt">' + fmt(save) + '</span>' +
               '<div class="bfc-cr-total bfc-cr-total-sm">' + fmt(total) + '</div>' +
               '<div class="bfc-cr-period">/ month total</div>';
      } else {
        body = '<div class="bfc-cr-total">' + fmt(total) + '</div>' +
               '<div class="bfc-cr-period">per month</div>';
      }

      return '<div class="bfc-calc-result ' + cls + '">' +
        (isBest && key !== 'guest' ? '<div class="bfc-cr-tag">Best for you</div>' : '') +
        '<div class="bfc-cr-name">' + name + '</div>' +
        body +
        '</div>';
    }

    res.innerHTML =
      card('guest',   'Guest',           guestTotal,  0) +
      card('casual',  'Casual Shooter',  casualCost,  guestTotal - casualCost) +
      card('enth',    'Enthusiast',      enthCost,    guestTotal - enthCost) +
      card('serious', 'Serious Shooter', seriousCost, guestTotal - seriousCost);
  }

  calcSavings();
})();
</script>


