
{% liquid
  assign base_text = section.settings.text_color | default: '#111111'
  assign base_bg = section.settings.background_color | default: '#F7F4F0'
  assign page_width_px = settings.page_width | default: 1200
  assign horizontal_pad = section.settings.horizontal_padding | default: 24
  assign heading_size_preset = section.settings.heading_size_preset | default: 'default'
  case heading_size_preset
    when 'sm'
      assign header_size_mobile = '1.4'
      assign header_size_desktop = '2.0'
    when 'md'
      assign header_size_mobile = '1.6'
      assign header_size_desktop = '2.4'
    when 'lg'
      assign header_size_mobile = '2.0'
      assign header_size_desktop = '3.2'
    when 'xl'
      assign header_size_mobile = '2.4'
      assign header_size_desktop = '3.8'
    when 'xxl'
      assign header_size_mobile = '2.8'
      assign header_size_desktop = '4.4'
    else
      assign header_size_mobile = '1.75'
      assign header_size_desktop = '2.75'
  endcase
  assign header_weight = section.settings.header_font_weight | default: 600
  assign body_weight = section.settings.body_font_weight | default: 400
  assign body_size = section.settings.body_font_size | default: 16
  assign body_size_small = section.settings.body_font_size_small | default: 12
  assign header_line_height = section.settings.header_line_height | default: '1.05'
  assign header_letter_spacing = section.settings.header_letter_spacing | default: 0
  assign heading_color = section.settings.heading_color | default: base_text
  assign body_line_height = section.settings.body_line_height | default: '1.5'
  assign body_letter_spacing = section.settings.body_letter_spacing | default: 0
  assign section_pad_top = section.settings.section_padding_top | default: 40
  assign section_pad_bottom = section.settings.section_padding_bottom | default: 40
  assign accent_color = section.settings.accent_color | default: '#E36E15'
  assign secondary_text_color = section.settings.secondary_text_color | default: '#82906B'
  assign item_title_font = section.settings.item_title_font
%}
<section id="bfc-holiday-guides-{{ section.id }}" class="bfc-combined" aria-label="{{ section.settings.section_label | default: 'BFC Holiday Guides' }}">
  <style>
    {{ item_title_font | font_face: font_display: 'swap' }}

    /* Fix shopify-section wrapper background & spacing */
    #shopify-section-{{ section.id }} {
      background-color: {{ base_bg }};
      margin: 0;
      padding: {{ section_pad_top }}px 0 {{ section_pad_bottom }}px;
      width: 100%;
    }
    #bfc-holiday-guides-{{ section.id }}{
      --bfc-header-family: var(--font-heading-family, inherit);
      --bfc-body-family: var(--font-body-family, inherit);
      --bfc-header-weight: {{ header_weight }};
      --bfc-body-weight: {{ body_weight }};
      --bfc-header-size-mobile: {{ header_size_mobile }}rem;
      --bfc-header-size-desktop: {{ header_size_desktop }}rem;
      --bfc-horizontal-pad: {{ horizontal_pad }}px;
      --bfc-page-width: {{ page_width_px }}px;
      --bfc-align-pad: clamp(
        var(--bfc-horizontal-pad),
        calc((100vw - min(100vw, var(--bfc-page-width))) / 2 + var(--bfc-horizontal-pad)),
        120px
      );
      --bfc-body-size: {{ body_size }}px;
      --bfc-body-size-small: {{ body_size_small }}px;
      --bfc-text: {{ base_text }};
      --bfc-bg: {{ base_bg }};
      --bfc-heading-color: {{ heading_color }};
      --bfc-header-letter-spacing: {{ header_letter_spacing }}px;
      --bfc-header-line-height: {{ header_line_height }};
      --bfc-body-letter-spacing: {{ body_letter_spacing }}px;
      --bfc-body-line-height: {{ body_line_height }};
      --bfc-accent: {{ accent_color }};
      --bfc-secondary-text: {{ secondary_text_color }};
      --bfc-item-title-family: {{ item_title_font.family | default: 'Poppins' }}, {{ item_title_font.fallback_families | default: 'sans-serif' }};
      --bfc-item-title-weight: {{ item_title_font.weight | default: 500 }};
      color: var(--bfc-text);
      background: var(--bfc-bg);
      font-family: var(--bfc-body-family);
      font-weight: var(--bfc-body-weight);
      font-size: var(--bfc-body-size);
    }
    #bfc-holiday-guides-{{ section.id }} .bfc-heading{
      font-family: var(--bfc-header-family, inherit);
      font-size: clamp(var(--bfc-header-size-mobile, 1.75rem), 3.5vw, var(--bfc-header-size-desktop, 2.75rem));
      font-weight: var(--bfc-header-weight, 300);
      line-height: var(--bfc-header-line-height, 1.05);
      letter-spacing: var(--bfc-header-letter-spacing, -0.02em);
      margin: 0;
      color: var(--bfc-heading-color, #111111);
    }
        #bfc-holiday-guides-{{ section.id }} .bfc-block{
      margin: 0 auto;
    }
    #bfc-holiday-guides-{{ section.id }} .bfc-block + .bfc-block{
      margin-top: 24px;
    }
    #bfc-holiday-guides-{{ section.id }} .visually-hidden{
      position: absolute;width: 1px;height: 1px;padding: 0;margin: -1px;overflow: hidden;clip: rect(0,0,0,0);white-space: nowrap;border: 0;
    }
    #bfc-holiday-guides-{{ section.id }} a:focus-visible,
    #bfc-holiday-guides-{{ section.id }} button:focus-visible,
    #bfc-holiday-guides-{{ section.id }} input:focus-visible{
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }
    @media (prefers-reduced-motion: reduce){
      #bfc-holiday-guides-{{ section.id }} *{
        animation-duration: .01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: .01ms !important;
      }
    }
  
    #bfc-holiday-guides-{{ section.id }} .bfc-eyebrow{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bfc-secondary-text);
      margin: 0 0 10px;
    }
    #bfc-holiday-guides-{{ section.id }} .bfc-item-title{
      font-family: var(--bfc-item-title-family);
      font-weight: var(--bfc-item-title-weight);
      font-size: var(--bfc-body-size);
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--bfc-text);
    }

    #bfc-holiday-guides-{{ section.id }} .bfc-detail-text{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: var(--bfc-body-weight);
      letter-spacing: var(--bfc-body-letter-spacing);
      line-height: var(--bfc-body-line-height);
      color: var(--bfc-secondary-text);
      margin: 0;
    }

  </style>
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'holiday_guides' %}
        {% liquid
          assign holiday_id = 'holiday-gear-guides-' | append: section.id | append: '-' | append: block.id
          assign holiday_group = block.settings.group_id | default: block.id
          assign holiday_use_auto_group = false
          if holiday_group == 'auto'
            assign holiday_use_auto_group = true
          endif
          assign holiday_index = forloop.index0
          assign holiday_use_inline_links = block.settings.use_inline_links
          assign has_holiday_image = false
          assign holiday_media_layout = block.settings.media_layout | default: 'single'
          if block.settings.image != blank
            assign has_holiday_image = true
          endif
          assign holiday_has_grid_images = false
          if holiday_media_layout == 'grid'
            if block.settings.image_grid_1 != blank or block.settings.image_grid_2 != blank or block.settings.image_grid_3 != blank or block.settings.image_grid_4 != blank or block.settings.image_grid_5 != blank or block.settings.image_grid_6 != blank
              assign holiday_has_grid_images = true
            endif
          endif
          assign holiday_slide_count = 0
          if holiday_media_layout == 'slideshow'
            if block.settings.slide_1 != blank
              assign holiday_slide_count = holiday_slide_count | plus: 1
            endif
            if block.settings.slide_2 != blank
              assign holiday_slide_count = holiday_slide_count | plus: 1
            endif
            if block.settings.slide_3 != blank
              assign holiday_slide_count = holiday_slide_count | plus: 1
            endif
            if block.settings.slide_4 != blank
              assign holiday_slide_count = holiday_slide_count | plus: 1
            endif
            if block.settings.slide_5 != blank
              assign holiday_slide_count = holiday_slide_count | plus: 1
            endif
            if holiday_slide_count > 0
              assign holiday_has_grid_images = true
            endif
          endif
          assign holiday_radius = block.settings.media_radius
          assign holiday_keep_side_by_side = block.settings.keep_side_by_side_mobile
          assign holiday_full_width_content = block.settings.full_width_content
          assign holiday_lock_media_fit = block.settings.lock_media_fit
          assign holiday_mobile_media_ratio = block.settings.mobile_media_ratio | default: 'third'
          assign holiday_mobile_grid_rows = block.settings.mobile_grid_rows | default: 3
          if block.settings.square_corners
            assign holiday_radius = 0
          endif
        %}
        <section
          id="{{ holiday_id }}"
          class="bfc-block hgg"
          style="
            --hgg-pt: {{ block.settings.padding_top }}px;
            --hgg-pb: {{ block.settings.padding_bottom }}px;
            --hgg-max: {{ page_width_px }}px;
            --hgg-gap: {{ block.settings.gap }}px;
            --hgg-media-ratio: {{ block.settings.media_ratio }};
            --hgg-radius: {{ holiday_radius }}px;
            --hgg-bg: {{ block.settings.bg_color }};
            --hgg-text: {{ block.settings.text_color }};
            --hgg-border: {{ block.settings.border_color }};
          "
          {{ block.shopify_attributes }}
        >
          <div class="hgg__wrap">
            <div class="hgg__grid">
              <div class="hgg__content">
                {% if block.settings.eyebrow != blank %}
                  <p class="hgg__eyebrow">{{ block.settings.eyebrow | escape }}</p>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h2 class="hgg__heading bfc-heading">{{ block.settings.heading | escape }}</h2>
                {% endif %}
                {% if block.settings.body != blank %}
                  <div class="hgg__body rte">
                    {{ block.settings.body }}
                  </div>
                {% endif %}
                {% if block.settings.show_product_grid %}
                  {% assign guide_limit = block.settings.products_to_show | default: 8 %}
                  {% assign guide_collection = block.settings.product_collection %}
                  {% assign use_collection = false %}
                  {% if guide_collection != blank and guide_collection.products.size > 0 %}
                    {% assign use_collection = true %}
                  {% endif %}

                  {% if use_collection %}
                    {%- comment -%} Render in-stock products from the collection up to the limit {%- endcomment -%}
                    <div class="hgg__products">
                      {% assign guide_rendered = 0 %}
                      {% for product in guide_collection.products %}
                        {% if product.available and guide_rendered < guide_limit %}
                          {% assign grid_image = product.featured_image %}
                          <a class="hgg__product" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                            <div class="hgg__product-media">
                              {% if grid_image %}
                                <img
                                  src="{{ grid_image | image_url: width: 800 }}"
                                  srcset="
                                    {{ grid_image | image_url: width: 400 }} 400w,
                                    {{ grid_image | image_url: width: 600 }} 600w,
                                    {{ grid_image | image_url: width: 800 }} 800w,
                                    {{ grid_image | image_url: width: 1200 }} 1200w
                                  "
                                  sizes="(min-width: 990px) 220px, (min-width: 750px) 180px, 45vw"
                                  alt="{{ grid_image.alt | default: product.title | escape }}"
                                  loading="lazy"
                                  width="{{ grid_image.width }}"
                                  height="{{ grid_image.height }}"
                                >
                              {% else %}
                                <div class="hgg__product-placeholder" aria-hidden="true"></div>
                              {% endif %}
                            </div>
                            <div class="hgg__product-meta" aria-hidden="true">
                              <span class="hgg__product-title">{{ product.title | escape }}</span>
                              <span class="hgg__product-price">{{ product.price | money }}</span>
                            </div>
                          </a>
                          {% assign guide_rendered = guide_rendered | plus: 1 %}
                        {% endif %}
                      {% endfor %}
                    </div>
                  {% else %}
                  {% assign guide_products = block.settings.products | compact %}
                  {% if guide_products and guide_products.size > 0 %}
                    <div class="hgg__products">
                      {% for product in guide_products %}
                        {% assign grid_image = product.featured_image %}
                        <a class="hgg__product" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                          <div class="hgg__product-media">
                            {% if grid_image %}
                              <img
                                src="{{ grid_image | image_url: width: 800 }}"
                                srcset="
                                  {{ grid_image | image_url: width: 400 }} 400w,
                                  {{ grid_image | image_url: width: 600 }} 600w,
                                  {{ grid_image | image_url: width: 800 }} 800w,
                                  {{ grid_image | image_url: width: 1200 }} 1200w
                                "
                                sizes="(min-width: 990px) 220px, (min-width: 750px) 180px, 45vw"
                                alt="{{ grid_image.alt | default: product.title | escape }}"
                                loading="lazy"
                                width="{{ grid_image.width }}"
                                height="{{ grid_image.height }}"
                              >
                            {% else %}
                              <div class="hgg__product-placeholder" aria-hidden="true"></div>
                            {% endif %}
                          </div>
                          <div class="hgg__product-meta" aria-hidden="true">
                            <span class="hgg__product-title">{{ product.title | escape }}</span>
                            <span class="hgg__product-price">{{ product.price | money }}</span>
                          </div>
                        </a>
                      {% endfor %}
                    </div>
                  {% endif %}
                  {% endif %}
                {% endif %}
                {% assign guide_count = 0 %}
                {% if holiday_use_inline_links %}
                  {% if block.settings.link_label_1 != blank %}{% assign guide_count = guide_count | plus: 1 %}{% endif %}
                  {% if block.settings.link_label_2 != blank %}{% assign guide_count = guide_count | plus: 1 %}{% endif %}
                  {% if block.settings.link_label_3 != blank %}{% assign guide_count = guide_count | plus: 1 %}{% endif %}
                {% elsif holiday_use_auto_group %}
                  {% for guide in section.blocks %}
                    {% if forloop.index0 > holiday_index %}
                      {% if guide.type == 'holiday_guides' %}
                        {% break %}
                      {% endif %}
                      {% if guide.type == 'holiday_guide_link' %}
                        {% assign guide_count = guide_count | plus: 1 %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                {% else %}
                  {% for guide in section.blocks %}
                    {% if guide.type == 'holiday_guide_link' and guide.settings.group_id == holiday_group %}
                      {% assign guide_count = guide_count | plus: 1 %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
                {% if guide_count > 0 %}
                  <ul class="hgg__links" role="list">
                    {% if holiday_use_inline_links %}
                      {% if block.settings.link_label_1 != blank %}
                        <li class="hgg__link-item">
                          {% assign link_url = block.settings.link_url_1 %}
                          {% assign link_label = block.settings.link_label_1 %}
                          {% if link_label != blank and link_url != blank %}
                            <a class="hgg__link" href="{{ link_url }}">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </a>
                          {% elsif link_label != blank %}
                            <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </span>
                          {% endif %}
                        </li>
                      {% endif %}
                      {% if block.settings.link_label_2 != blank %}
                        <li class="hgg__link-item">
                          {% assign link_url = block.settings.link_url_2 %}
                          {% assign link_label = block.settings.link_label_2 %}
                          {% if link_label != blank and link_url != blank %}
                            <a class="hgg__link" href="{{ link_url }}">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </a>
                          {% elsif link_label != blank %}
                            <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </span>
                          {% endif %}
                        </li>
                      {% endif %}
                      {% if block.settings.link_label_3 != blank %}
                        <li class="hgg__link-item">
                          {% assign link_url = block.settings.link_url_3 %}
                          {% assign link_label = block.settings.link_label_3 %}
                          {% if link_label != blank and link_url != blank %}
                            <a class="hgg__link" href="{{ link_url }}">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </a>
                          {% elsif link_label != blank %}
                            <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                              <span class="hgg__link-text">{{ link_label | escape }}</span>
                              <span class="hgg__arrow" aria-hidden="true">→</span>
                            </span>
                          {% endif %}
                        </li>
                      {% endif %}
                    {% elsif holiday_use_auto_group %}
                      {% for guide in section.blocks %}
                        {% if forloop.index0 > holiday_index %}
                          {% if guide.type == 'holiday_guides' %}
                            {% break %}
                          {% endif %}
                          {% if guide.type == 'holiday_guide_link' %}
                            <li class="hgg__link-item" {{ guide.shopify_attributes }}>
                              {% assign link_url = guide.settings.link %}
                              {% assign link_label = guide.settings.label %}
                              {% if link_label != blank and link_url != blank %}
                                <a class="hgg__link" href="{{ link_url }}">
                                  <span class="hgg__link-text">{{ link_label | escape }}</span>
                                  <span class="hgg__arrow" aria-hidden="true">→</span>
                                </a>
                              {% elsif link_label != blank %}
                                <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                                  <span class="hgg__link-text">{{ link_label | escape }}</span>
                                  <span class="hgg__arrow" aria-hidden="true">→</span>
                                </span>
                              {% endif %}
                            </li>
                          {% endif %}
                        {% endif %}
                      {% endfor %}
                    {% else %}
                      {% for guide in section.blocks %}
                        {% if guide.type == 'holiday_guide_link' and guide.settings.group_id == holiday_group %}
                          <li class="hgg__link-item" {{ guide.shopify_attributes }}>
                            {% assign link_url = guide.settings.link %}
                            {% assign link_label = guide.settings.label %}
                            {% if link_label != blank and link_url != blank %}
                              <a class="hgg__link" href="{{ link_url }}">
                                <span class="hgg__link-text">{{ link_label | escape }}</span>
                                <span class="hgg__arrow" aria-hidden="true">→</span>
                              </a>
                            {% elsif link_label != blank %}
                              <span class="hgg__link hgg__link--disabled" aria-disabled="true">
                                <span class="hgg__link-text">{{ link_label | escape }}</span>
                                <span class="hgg__arrow" aria-hidden="true">→</span>
                              </span>
                            {% endif %}
                          </li>
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  </ul>
                {% endif %}
              </div>
              <div class="hgg__media{% unless has_holiday_image or holiday_has_grid_images %} is-empty{% endunless %}{% if holiday_lock_media_fit %} hgg__media--contain{% endif %}">
                {% if holiday_media_layout == 'grid' %}
                  <div class="hgg__media-grid">
                    {% for i in (1..6) %}
                      {% liquid
                        assign grid_image = nil
                        case i
                          when 1
                            assign grid_image = block.settings.image_grid_1
                          when 2
                            assign grid_image = block.settings.image_grid_2
                          when 3
                            assign grid_image = block.settings.image_grid_3
                          when 4
                            assign grid_image = block.settings.image_grid_4
                          when 5
                            assign grid_image = block.settings.image_grid_5
                          when 6
                            assign grid_image = block.settings.image_grid_6
                        endcase
                      %}
                      <div class="hgg__media-grid-item">
                        {% if grid_image != blank %}
                          {{
                            grid_image
                            | image_url: width: 1200
                            | image_tag:
                              widths: '400, 600, 800, 1000, 1200',
                              sizes: '(min-width: 990px) 20vw, 33vw',
                              loading: 'lazy',
                              class: 'hgg__img',
                              alt: grid_image.alt | default: block.settings.heading | default: block.settings.eyebrow
                         }}
                        {% else %}
                          <div class="hgg__placeholder" aria-hidden="true"></div>
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                {% elsif holiday_media_layout == 'slideshow' %}
                  <div class="hgg__media-inner"
                    data-hgg-slideshow
                    data-hgg-interval="{{ block.settings.slide_interval | default: 5 | times: 1000 }}"
                    data-hgg-autoplay="{% if block.settings.slide_autoplay %}1{% else %}0{% endif %}"
                  >
                    {% for i in (1..5) %}
                      {% liquid
                        assign slide_image = nil
                        assign slide_image_mobile = nil
                        case i
                          when 1
                            assign slide_image = block.settings.slide_1
                            assign slide_image_mobile = block.settings.slide_1_mobile
                          when 2
                            assign slide_image = block.settings.slide_2
                            assign slide_image_mobile = block.settings.slide_2_mobile
                          when 3
                            assign slide_image = block.settings.slide_3
                            assign slide_image_mobile = block.settings.slide_3_mobile
                          when 4
                            assign slide_image = block.settings.slide_4
                            assign slide_image_mobile = block.settings.slide_4_mobile
                          when 5
                            assign slide_image = block.settings.slide_5
                            assign slide_image_mobile = block.settings.slide_5_mobile
                        endcase
                      %}
                      {% if slide_image != blank %}
                        <div class="hgg__slide{% if forloop.first %} is-active{% endif %}" data-hgg-slide="{{ forloop.index0 }}">
                          {% if slide_image_mobile != blank %}
                            <picture>
                              <source
                                media="(max-width: 989px)"
                                srcset="
                                  {{ slide_image_mobile | image_url: width: 600 }} 600w,
                                  {{ slide_image_mobile | image_url: width: 800 }} 800w,
                                  {{ slide_image_mobile | image_url: width: 1000 }} 1000w,
                                  {{ slide_image_mobile | image_url: width: 1200 }} 1200w
                                "
                                sizes="100vw"
                              >
                              <img
                                src="{{ slide_image | image_url: width: 2400 }}"
                                srcset="
                                  {{ slide_image | image_url: width: 600 }} 600w,
                                  {{ slide_image | image_url: width: 800 }} 800w,
                                  {{ slide_image | image_url: width: 1000 }} 1000w,
                                  {{ slide_image | image_url: width: 1200 }} 1200w,
                                  {{ slide_image | image_url: width: 1600 }} 1600w,
                                  {{ slide_image | image_url: width: 2000 }} 2000w,
                                  {{ slide_image | image_url: width: 2400 }} 2400w
                                "
                                sizes="(min-width: 990px) 52vw, 100vw"
                                loading="lazy"
                                class="hgg__img"
                                alt="{{ slide_image.alt | default: block.settings.heading | default: block.settings.eyebrow | escape }}"
                                width="{{ slide_image.width }}"
                                height="{{ slide_image.height }}"
                              >
                            </picture>
                          {% else %}
                            {{
                              slide_image
                              | image_url: width: 2400
                              | image_tag:
                                widths: '600, 800, 1000, 1200, 1600, 2000, 2400',
                                sizes: '(min-width: 990px) 52vw, 100vw',
                                loading: 'lazy',
                                class: 'hgg__img',
                                alt: slide_image.alt | default: block.settings.heading | default: block.settings.eyebrow
                            }}
                          {% endif %}
                        </div>
                      {% endif %}
                    {% endfor %}
                    {% if block.settings.slide_show_dots and holiday_slide_count > 1 %}
                      <div class="hgg__slide-dots" role="tablist">
                        {% for i in (0..4) %}
                          {% if i < holiday_slide_count %}
                            <button
                              type="button"
                              class="hgg__slide-dot{% if forloop.first %} is-active{% endif %}"
                              data-hgg-dot="{{ i }}"
                              role="tab"
                              aria-label="Go to slide {{ i | plus: 1 }}"
                            ></button>
                          {% endif %}
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                {% else %}
                  <div class="hgg__media-inner">
                    {% if has_holiday_image %}
                      {{
                        block.settings.image
                        | image_url: width: 2400
                        | image_tag:
                          widths: '600, 800, 1000, 1200, 1600, 2000, 2400',
                          sizes: '(min-width: 990px) 52vw, 100vw',
                          loading: 'lazy',
                          class: 'hgg__img',
                          alt: block.settings.image.alt | default: block.settings.heading | default: block.settings.eyebrow
                     }}
                    {% else %}
                      <div class="hgg__placeholder" aria-hidden="true"></div>
                    {% endif %}
                  </div>
                {% endif %}
                {% if block.settings.cta_label != blank and block.settings.cta_link != blank %}
                  <div class="hgg__cta hgg__cta--media">
                    <a class="hgg__btn" href="{{ block.settings.cta_link }}">
                      {{ block.settings.cta_label | escape }}
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
          {%- style -%}
            #{{ holiday_id }}{
              background: var(--hgg-bg);
              color: var(--hgg-text);
              padding-top: var(--hgg-pt);
              padding-bottom: var(--hgg-pb);
              --bfc-block-pad: calc(var(--bfc-align-pad) + {{ block.settings.side_padding_vw }}vw);
            }
            #{{ holiday_id }} .hgg__wrap{
              max-width: var(--hgg-max);
              margin: 0 auto;
              padding-left: var(--bfc-block-pad);
              padding-right: var(--bfc-block-pad);
            }
            #{{ holiday_id }} .hgg__grid{
              display: grid;
              grid-template-columns: minmax(280px, 1fr) minmax(320px, 1.15fr);
              gap: var(--hgg-gap);
              align-items: stretch;
            }
            #{{ holiday_id }} .hgg__content{
              max-width: 40rem;
            }
            {% if holiday_full_width_content %}
              #{{ holiday_id }} .hgg__content{
                max-width: none;
              }
            {% endif %}
            #{{ holiday_id }} .hgg__media{
              display: flex;
              flex-direction: column;
              height: 100%;
              min-height: 0;
            }
            #{{ holiday_id }} .hgg__eyebrow{
              margin: 0 0 10px;
              font-size: var(--bfc-body-size-small);
              letter-spacing: .12em;
              text-transform: uppercase;
              opacity: .85;
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__heading{
              margin: 0 0 14px;
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__body{
              margin: 0 0 18px;
              font-size: var(--bfc-body-size);
              line-height: 1.5;
              opacity: .95;
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__products{
              display: grid;
              gap: 12px;
              grid-template-columns: repeat(2, minmax(0, 1fr));
              margin-bottom: 18px;
            }
            #{{ holiday_id }} .hgg__product{
              text-decoration: none;
              color: inherit;
              display: grid;
              gap: 8px;
            }
            #{{ holiday_id }} .hgg__product-media{
              position: relative;
              background: rgba(0,0,0,0.04);
              aspect-ratio: 1 / 1;
              overflow: hidden;
            }
            #{{ holiday_id }} .hgg__product-media img{
              width: 100%;
              height: 100%;
              object-fit: cover;
              display: block;
            }
            #{{ holiday_id }} .hgg__product-placeholder{
              width: 100%;
              height: 100%;
              background: rgba(0,0,0,0.05);
            }
            #{{ holiday_id }} .hgg__product-meta{
              display: grid;
              gap: 4px;
              font-size: var(--bfc-body-size-small);
            }
            #{{ holiday_id }} .hgg__product-title{
              font-weight: var(--bfc-header-weight);
              font-size: var(--bfc-body-size-small);
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__product-price{
              opacity: 0.8;
              color: var(--hgg-text);
            }
            #{{ holiday_id }} .hgg__links{
              margin: 0;
              padding: 0;
              list-style: none;
              border-top: 1px solid var(--hgg-border);
            }
            #{{ holiday_id }} .hgg__link-item{
              margin: 0;
              padding: 0;
              border-bottom: 1px solid var(--hgg-border);
            }
            #{{ holiday_id }} .hgg__link{
              display: flex;
              align-items: center;
              justify-content: space-between;
              gap: 14px;
              padding: 14px 0;
              text-decoration: none;
              color: inherit;
              font-size: var(--bfc-body-size);
              line-height: 1.2;
              transition: opacity .15s ease, transform .15s ease;
            }
            #{{ holiday_id }} .hgg__link:hover{
              opacity: .85;
            }
            #{{ holiday_id }} .hgg__link:focus-visible{
              outline: 2px solid currentColor;
              outline-offset: 4px;
            }
            #{{ holiday_id }} .hgg__arrow{
              flex: 0 0 auto;
              font-size: 1.1em;
              transform: translateY(-1px);
            }
            #{{ holiday_id }} .hgg__cta{
              margin-top: 18px;
            }
            #{{ holiday_id }} .hgg__cta--media{
              margin-top: auto;
            }
            #{{ holiday_id }} .hgg__btn{
              display: inline-flex;
              align-items: center;
              gap: 6px;
              text-decoration: underline;
              text-underline-offset: 0.15em;
              color: inherit;
              font-size: var(--bfc-body-size);
            }
            #{{ holiday_id }} .hgg__media-inner{
              position: relative;
              overflow: hidden;
              border-radius: var(--hgg-radius);
              flex: 1 1 0;
              min-height: 0;
              background: rgba(0,0,0,.06);
            }
            #{{ holiday_id }} .hgg__img{
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
              object-fit: cover;
              display: block;
            }
            #{{ holiday_id }} .hgg__placeholder{
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
            }
            #{{ holiday_id }} .hgg__media--contain .hgg__media-inner,
            #{{ holiday_id }} .hgg__media--contain .hgg__media-grid-item{
              background: var(--hgg-bg);
              padding: 10px;
            }
            #{{ holiday_id }} .hgg__media--contain .hgg__img{
              object-fit: contain;
              inset: 10px;
              width: calc(100% - 20px);
              height: calc(100% - 20px);
            }
            #{{ holiday_id }} .hgg__media--contain .hgg__placeholder{
              inset: 10px;
              width: calc(100% - 20px);
              height: calc(100% - 20px);
            }
            #{{ holiday_id }} .hgg__media-grid{
              display: grid;
              grid-template-columns: repeat(3, minmax(0, 1fr));
              grid-auto-rows: 1fr;
              gap: 12px;
              flex: 1 1 0;
              min-height: 0;
            }
            #{{ holiday_id }} .hgg__media-grid-item{
              position: relative;
              overflow: hidden;
              border-radius: var(--hgg-radius);
              background: rgba(0,0,0,.06);
              min-height: 0;
            }
            #{{ holiday_id }} .hgg__media-grid-item .hgg__img,
            #{{ holiday_id }} .hgg__media-grid-item .hgg__placeholder{
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
            }

            /* Slideshow — sits inside .hgg__media-inner, same sizing as single image */
            #{{ holiday_id }} .hgg__slide{
              position: absolute;
              inset: 0;
              opacity: 0;
              transition: opacity 700ms ease;
              pointer-events: none;
              z-index: 1;
            }
            #{{ holiday_id }} .hgg__slide.is-active{
              opacity: 1;
              pointer-events: auto;
            }
            #{{ holiday_id }} .hgg__slide-dots{
              position: absolute;
              bottom: 16px;
              left: 50%;
              transform: translateX(-50%);
              display: flex;
              gap: 8px;
              padding: 8px 12px;
              background: rgba(0,0,0,.35);
              border-radius: 999px;
              z-index: 3;
            }
            #{{ holiday_id }} .hgg__slide-dot{
              width: 8px;
              height: 8px;
              border-radius: 50%;
              border: none;
              background: rgba(255,255,255,.5);
              cursor: pointer;
              padding: 0;
              transition: background 200ms ease, transform 200ms ease;
            }
            #{{ holiday_id }} .hgg__slide-dot:hover{
              background: rgba(255,255,255,.85);
            }
            #{{ holiday_id }} .hgg__slide-dot.is-active{
              background: #fff;
              transform: scale(1.25);
            }

            @media (min-width: 990px){
              #{{ holiday_id }}{
                --hgg-bleed: clamp(0px, calc((100vw - var(--hgg-max)) / 2), 120px);
              }
              #{{ holiday_id }} .hgg__media{
                margin-right: calc(-1 * var(--hgg-bleed));
              }
              #{{ holiday_id }} .hgg__media-inner,
              #{{ holiday_id }} .hgg__media-grid{
                width: calc(100% + var(--hgg-bleed));
              }
            }
            @media (min-width: 1440px){
              #{{ holiday_id }} .hgg__media{
                margin-right: 0;
              }
              #{{ holiday_id }} .hgg__media-inner,
              #{{ holiday_id }} .hgg__media-grid{
                width: 100%;
              }
            }
            /* Large screens: max-width + auto margins handle centering,
               so drop padding back to base to avoid double-centering */
            @media (min-width: {{ page_width_px | plus: 100 }}px){
              #{{ holiday_id }} .hgg__wrap{
                padding-left: calc({{ horizontal_pad }}px + {{ block.settings.side_padding_vw | default: 0 }}vw);
                padding-right: calc({{ horizontal_pad }}px + {{ block.settings.side_padding_vw | default: 0 }}vw);
              }
            }
            @media (max-width: 989px){
              {% if block.settings.ignore_padding_mobile %}
                #{{ holiday_id }}{
                  --bfc-block-pad: var(--bfc-horizontal-pad);
                }
              {% endif %}
              #{{ holiday_id }} .hgg__wrap{
                padding-right: var(--bfc-block-pad);
              }
              {% unless holiday_keep_side_by_side %}
                #{{ holiday_id }} .hgg__grid{
                  grid-template-columns: 1fr;
                }
                #{{ holiday_id }} .hgg__media{
                  order: -1;
                  height: auto;
                }
                #{{ holiday_id }} .hgg__media-inner{
                  flex: none;
                  aspect-ratio: var(--hgg-media-ratio, 1.25);
                }
                #{{ holiday_id }} .hgg__content{
                  max-width: none;
                }
              {% else %}
                #{{ holiday_id }} .hgg__grid{
                  {% if holiday_mobile_media_ratio == 'half' %}
                    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
                  {% else %}
                    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
                  {% endif %}
                  gap: calc(var(--hgg-gap) * 0.6);
                }
                #{{ holiday_id }} .hgg__heading{
                  font-size: var(--bfc-header-size-mobile);
                }
                #{{ holiday_id }} .hgg__body,
                #{{ holiday_id }} .hgg__link,
                #{{ holiday_id }} .hgg__btn{
                  font-size: var(--bfc-body-size-small);
                }
                #{{ holiday_id }} .hgg__media-grid{
                  grid-template-columns: 1fr;
                  gap: 8px;
                }
                #{{ holiday_id }} .hgg__media-grid-item:nth-child(n+{{ holiday_mobile_grid_rows | plus: 1 }}){
                  display: none;
                }
              {% endunless %}
            }
          {%- endstyle -%}
          {% if holiday_media_layout == 'slideshow' and holiday_slide_count > 1 %}
            <script>
              (function(){
                var root = document.querySelector('#{{ holiday_id }} .hgg__media-inner[data-hgg-slideshow]');
                if (!root) return;
                var slides = root.querySelectorAll('.hgg__slide');
                var dots = root.querySelectorAll('[data-hgg-dot]');
                var interval = parseInt(root.dataset.hggInterval, 10) || 5000;
                var autoplay = root.dataset.hggAutoplay === '1';
                var idx = 0;
                var timer = null;

                function go(n){
                  idx = (n + slides.length) % slides.length;
                  slides.forEach(function(s, i){ s.classList.toggle('is-active', i === idx); });
                  dots.forEach(function(d, i){ d.classList.toggle('is-active', i === idx); });
                }
                function next(){ go(idx + 1); }
                function start(){
                  if (!autoplay || slides.length < 2) return;
                  stop();
                  timer = setInterval(next, interval);
                }
                function stop(){ if (timer){ clearInterval(timer); timer = null; } }

                dots.forEach(function(d){
                  d.addEventListener('click', function(){
                    var n = parseInt(d.dataset.hggDot, 10);
                    go(n);
                    start();
                  });
                });
                root.addEventListener('mouseenter', stop);
                root.addEventListener('mouseleave', start);
                start();
              })();
            </script>
          {% endif %}
        </section>
    {% endcase %}
  {% endfor %}
</section>
