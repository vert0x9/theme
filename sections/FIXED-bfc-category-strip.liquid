      "options": [
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "xl",
          "label": "X-Large"
        },
        {
          "value": "xxl",
          "label": "XX-Large"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "header_line_height",
      "label": "Heading line height",
      "options": [
        {
          "value": "1.0",
          "label": "1.0 (Tightest)"
        },
        {
          "value": "1.05",
          "label": "1.05 (Default)"
        },
        {
          "value": "1.1",
          "label": "1.1"
        },
        {
          "value": "1.2",
          "label": "1.2"
        },
        {
          "value": "1.3",
          "label": "1.3"
        },
        {
          "value": "1.4",
          "label": "1.4 (Loose)"
        }
      ],
      "default": "1.05"
    },
    {
      "type": "range",
      "id": "header_letter_spacing",
      "label": "Heading letter spacing",
      "min": -2,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": -2
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "info": "Falls back to base text color if unset",
      "default": "#111111"
    },
    {
      "type": "select",
      "id": "body_line_height",
      "label": "Body line height",
      "options": [
        {
          "value": "1.3",
          "label": "1.3 (Tight)"
        },
        {
          "value": "1.4",
          "label": "1.4"
        },
        {
          "value": "1.5",
          "label": "1.5 (Default)"
        },
        {
          "value": "1.6",
          "label": "1.6"
        },
        {
          "value": "1.8",
          "label": "1.8 (Loose)"
        }
      ],
      "default": "1.5"
    },
    {
      "type": "range",
      "id": "body_letter_spacing",
      "label": "Body letter spacing",
      "min": -1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "font_picker",
      "id": "item_title_font",
      "label": "Item title font",
      "info": "Font used for product/item titles (e.g. the old best-seller title font)",
      "default": "poppins_n5"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Base text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Base background color",
      "default": "#F7F4F0"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Used for links and highlights",
      "default": "#E36E15"
    },
    {
      "type": "color",
      "id": "secondary_text_color",
