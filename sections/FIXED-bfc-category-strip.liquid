  "presets": [
    {
      "name": "BFC Category Strip",
      "blocks": [
        {
          "type": "cover_item",
          "settings": {
            "title": "Category 1"
          }
        },
        {
          "type": "cover_item",
          "settings": {
            "title": "Category 2"
          }
        },
        {
          "type": "cover_item",
          "settings": {
            "title": "Category 3"
          }
        },
        {
          "type": "cover_item",
          "settings": {
            "title": "Category 4"
          }
        }
      ]
