
{% liquid
  assign base_text = section.settings.text_color | default: '#111111'
  assign base_bg = section.settings.background_color | default: '#F7F4F0'
  assign page_width_px = settings.page_width | default: 1200
  assign horizontal_pad = section.settings.horizontal_padding | default: 24
  assign heading_size_preset = section.settings.heading_size_preset | default: 'default'
  case heading_size_preset
    when 'sm'
      assign header_size_mobile = '1.4'
      assign header_size_desktop = '2.0'
    when 'md'
      assign header_size_mobile = '1.6'
      assign header_size_desktop = '2.4'
    when 'lg'
      assign header_size_mobile = '2.0'
      assign header_size_desktop = '3.2'
    when 'xl'
      assign header_size_mobile = '2.4'
      assign header_size_desktop = '3.8'
    when 'xxl'
      assign header_size_mobile = '2.8'
      assign header_size_desktop = '4.4'
    else
      assign header_size_mobile = '1.75'
      assign header_size_desktop = '2.75'
  endcase
  assign header_weight = section.settings.header_font_weight | default: 600
  assign body_weight = section.settings.body_font_weight | default: 400
  assign body_size = section.settings.body_font_size | default: 16
  assign body_size_small = section.settings.body_font_size_small | default: 12
  assign header_line_height = section.settings.header_line_height | default: '1.05'
  assign header_letter_spacing = section.settings.header_letter_spacing | default: 0
  assign heading_color = section.settings.heading_color | default: base_text
  assign body_line_height = section.settings.body_line_height | default: '1.5'
  assign body_letter_spacing = section.settings.body_letter_spacing | default: 0
  assign section_pad_top = section.settings.section_padding_top | default: 40
  assign section_pad_bottom = section.settings.section_padding_bottom | default: 40
  assign accent_color = section.settings.accent_color | default: '#E36E15'
  assign secondary_text_color = section.settings.secondary_text_color | default: '#82906B'
  assign item_title_font = section.settings.item_title_font
%}
<section id="bfc-category-strip-{{ section.id }}" class="bfc-combined" aria-label="{{ section.settings.section_label | default: 'BFC Category Strip' }}">
  <style>
    {{ item_title_font | font_face: font_display: 'swap' }}

    /* Fix shopify-section wrapper background & spacing */
    #shopify-section-{{ section.id }} {
      background-color: {{ base_bg }};
      margin: 0;
      padding: {{ section_pad_top }}px 0 {{ section_pad_bottom }}px;
      width: 100%;
    }
    #bfc-category-strip-{{ section.id }}{
      --bfc-header-family: var(--font-heading-family, inherit);
      --bfc-body-family: var(--font-body-family, inherit);
      --bfc-header-weight: {{ header_weight }};
      --bfc-body-weight: {{ body_weight }};
      --bfc-header-size-mobile: {{ header_size_mobile }}rem;
      --bfc-header-size-desktop: {{ header_size_desktop }}rem;
      --bfc-horizontal-pad: {{ horizontal_pad }}px;
      --bfc-page-width: {{ page_width_px }}px;
      --bfc-align-pad: clamp(
        var(--bfc-horizontal-pad),
        calc((100vw - min(100vw, var(--bfc-page-width))) / 2 + var(--bfc-horizontal-pad)),
        120px
      );
      --bfc-body-size: {{ body_size }}px;
      --bfc-body-size-small: {{ body_size_small }}px;
      --bfc-text: {{ base_text }};
      --bfc-bg: {{ base_bg }};
      --bfc-heading-color: {{ heading_color }};
      --bfc-header-letter-spacing: {{ header_letter_spacing }}px;
      --bfc-header-line-height: {{ header_line_height }};
      --bfc-body-letter-spacing: {{ body_letter_spacing }}px;
      --bfc-body-line-height: {{ body_line_height }};
      --bfc-accent: {{ accent_color }};
      --bfc-secondary-text: {{ secondary_text_color }};
      --bfc-item-title-family: {{ item_title_font.family | default: 'Poppins' }}, {{ item_title_font.fallback_families | default: 'sans-serif' }};
      --bfc-item-title-weight: {{ item_title_font.weight | default: 500 }};
      color: var(--bfc-text);
      background: var(--bfc-bg);
      font-family: var(--bfc-body-family);
      font-weight: var(--bfc-body-weight);
      font-size: var(--bfc-body-size);
    }
    #bfc-category-strip-{{ section.id }} .bfc-heading{
      font-family: var(--bfc-header-family, inherit);
      font-size: clamp(var(--bfc-header-size-mobile, 1.75rem), 3.5vw, var(--bfc-header-size-desktop, 2.75rem));
      font-weight: var(--bfc-header-weight, 300);
      line-height: var(--bfc-header-line-height, 1.05);
      letter-spacing: var(--bfc-header-letter-spacing, -0.02em);
      margin: 0;
      color: var(--bfc-heading-color, #111111);
    }
        #bfc-category-strip-{{ section.id }} .bfc-block{
      margin: 0 auto;
    }
    #bfc-category-strip-{{ section.id }} .bfc-block + .bfc-block{
      margin-top: 24px;
    }
    #bfc-category-strip-{{ section.id }} .visually-hidden{
      position: absolute;width: 1px;height: 1px;padding: 0;margin: -1px;overflow: hidden;clip: rect(0,0,0,0);white-space: nowrap;border: 0;
    }
    #bfc-category-strip-{{ section.id }} a:focus-visible,
    #bfc-category-strip-{{ section.id }} button:focus-visible,
    #bfc-category-strip-{{ section.id }} input:focus-visible{
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }
    @media (prefers-reduced-motion: reduce){
      #bfc-category-strip-{{ section.id }} *{
        animation-duration: .01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: .01ms !important;
      }
    }
  
    #bfc-category-strip-{{ section.id }} .bfc-eyebrow{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bfc-secondary-text);
      margin: 0 0 10px;
    }
    #bfc-category-strip-{{ section.id }} .bfc-item-title{
      font-family: var(--bfc-item-title-family);
      font-weight: var(--bfc-item-title-weight);
      font-size: var(--bfc-body-size);
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--bfc-text);
    }

    #bfc-category-strip-{{ section.id }} .bfc-detail-text{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: var(--bfc-body-weight);
      letter-spacing: var(--bfc-body-letter-spacing);
      line-height: var(--bfc-body-line-height);
      color: var(--bfc-secondary-text);
      margin: 0;
    }

  </style>

  {% if section.settings.heading != blank or section.settings.subheading != blank %}
    <div class="bfc-cstrip__head">
      {% if section.settings.eyebrow != blank %}
        <p class="bfc-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="bfc-heading bfc-cstrip__title">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="bfc-detail-text bfc-cstrip__sub">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="bfc-cstrip__grid">
      {% for block in section.blocks %}
        {% if block.type == 'cover_item' %}
          {%- liquid
            assign cover_link = block.settings.url | default: '#'
            assign cover_title = block.settings.title
            assign cover_subtitle = block.settings.subtitle
            assign cover_badge = block.settings.badge
            assign cover_image = block.settings.image
          -%}
          <a class="bfc-cstrip__item" href="{{ cover_link }}" {{ block.shopify_attributes }}>
            <div class="bfc-cstrip__media">
              {% if cover_image != blank %}
                <img
                  src="{{ cover_image | image_url: width: 600 }}"
                  srcset="
                    {{ cover_image | image_url: width: 300 }} 300w,
                    {{ cover_image | image_url: width: 600 }} 600w,
                    {{ cover_image | image_url: width: 900 }} 900w
                  "
                  sizes="(min-width: 990px) 200px, (min-width: 750px) 24vw, 45vw"
                  alt="{{ cover_image.alt | default: cover_title | escape }}"
                  loading="lazy"
                  width="{{ cover_image.width }}"
                  height="{{ cover_image.height }}"
                >
              {% else %}
                <div class="bfc-cstrip__placeholder" aria-hidden="true">
                  {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
              {% if cover_badge != blank %}
                <span class="bfc-cstrip__badge">{{ cover_badge | escape }}</span>
              {% endif %}
            </div>
            {% if cover_title != blank or cover_subtitle != blank %}
              <div class="bfc-cstrip__meta">
                {% if cover_title != blank %}
                  <span class="bfc-cstrip__name bfc-item-title">{{ cover_title | escape }}</span>
                {% endif %}
                {% if cover_subtitle != blank %}
                  <span class="bfc-cstrip__subtitle bfc-detail-text">{{ cover_subtitle | escape }}</span>
                {% endif %}
              </div>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div class="bfc-cstrip__empty">Add cover items in the theme editor.</div>
  {% endif %}
</section>

<style>
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__head{
    padding: 0 var(--bfc-align-pad);
    margin-bottom: 24px;
    text-align: {{ section.settings.header_align }};
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__sub{
    margin-top: 10px;
    max-width: 680px;
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__grid{
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
    padding: 0 var(--bfc-align-pad);
  }
  @media (min-width: 750px){
    #bfc-category-strip-{{ section.id }} .bfc-cstrip__grid{
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__item{
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__media{
    position: relative;
    aspect-ratio: {{ section.settings.media_aspect }};
    background: {{ section.settings.media_placeholder_color | default: '#E3DDDA' }};
    overflow: hidden;
    border-radius: {% if section.settings.square_corners %}0{% else %}{{ section.settings.media_radius }}px{% endif %};
    margin-bottom: 10px;
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__media img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .3s ease;
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__item:hover .bfc-cstrip__media img{
    transform: scale(1.04);
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__placeholder{
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.35;
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__badge{
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--bfc-accent, #E36E15);
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 2px;
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__meta{
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: {{ section.settings.text_align }};
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__name{
    display: block;
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__subtitle{
    display: block;
  }
  #bfc-category-strip-{{ section.id }} .bfc-cstrip__empty{
    padding: 2rem;
    text-align: center;
    color: var(--bfc-secondary-text);
  }
</style>

{% schema %}
{
  "name": "BFC Category Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to hide the section heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between items (px)",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "header",
      "content": "Item style"
    },
    {
      "type": "select",
      "id": "media_aspect",
      "label": "Image shape",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "4 / 5",
          "label": "Portrait (4:5)"
        },
        {
          "value": "3 / 4",
          "label": "Tall (3:4)"
        },
        {
          "value": "16 / 9",
          "label": "Landscape (16:9)"
        }
      ],
      "default": "1 / 1"
    },
    {
      "type": "range",
      "id": "media_radius",
      "label": "Image corner radius (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "square_corners",
      "label": "Square corners (override radius)",
      "default": false
    },
    {
      "type": "color",
      "id": "media_placeholder_color",
      "label": "Image placeholder color",
      "default": "#E3DDDA"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Item text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "header_font_weight",
      "label": "Header font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "SemiBold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "body_font_weight",
      "label": "Body font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "body_font_size_small",
      "label": "Small text size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "heading_size_preset",
      "label": "Heading size",
