  <script>
    (function () {
      const root = document.getElementById('bfcpdp-{{ section.id }}');
      if (!root) return;

      const sticky = root.querySelector('[data-bfcpdp-sticky]');
      if (sticky) {
        let lastScroll = window.scrollY;
        window.addEventListener('scroll', () => {
          const current = window.scrollY;
          if (current > 120 && current < lastScroll) {
            sticky.classList.add('is-visible');
          } else if (current > lastScroll) {
            sticky.classList.remove('is-visible');
          } else if (current <= 120) {
            sticky.classList.remove('is-visible');
          }
          lastScroll = current;
        });
      }

      const gallery = root.querySelector('[data-bfcpdp-gallery]');
      if (gallery) {
        const stage = gallery.querySelector('[data-gallery-stage]');
        const mediaWrap = stage && stage.querySelector('[data-gallery-media]');
        const captionEl = stage && stage.querySelector('[data-gallery-caption]');
        const thumbs = gallery.querySelectorAll('[data-gallery-thumb]');
        thumbs.forEach((thumb) => {
          thumb.addEventListener('click', () => {
            thumbs.forEach((btn) => btn.setAttribute('aria-current', 'false'));
            thumb.setAttribute('aria-current', 'true');
            if (!mediaWrap) return;
            const type = thumb.dataset.type;
            const caption = thumb.dataset.caption || '';
            if (captionEl) {
              captionEl.textContent = caption;
            }
            if (type === 'video' && thumb.dataset.video) {
              const poster = thumb.dataset.poster ? ` poster="${thumb.dataset.poster}"` : '';
              mediaWrap.innerHTML = `\n                <figure>\n                  <video controls playsinline${poster}>\n                    <source src="${thumb.dataset.video}" type="video/mp4">\n                  </video>\n                </figure>\n              `;
            } else if (thumb.dataset.image) {
              const alt = thumb.dataset.alt || '';
              const srcset = thumb.dataset.srcset || '';
              mediaWrap.innerHTML = `\n                <figure>\n                  <img src="${thumb.dataset.image}" srcset="${srcset}" sizes="(min-width: 768px) 60vw, 100vw" alt="${alt}" loading="lazy">\n                </figure>\n              `;
            }
          });
        });
      }
    })();
  </script>

