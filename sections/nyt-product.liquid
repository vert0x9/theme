                {% endif %}
                {% if block.settings.subtitle != blank %}
                  <p class="dek">{{ block.settings.subtitle }}</p>
                {% endif %}
                {% if block.settings.price != blank %}
                  <div class="meta">{{ block.settings.price }}</div>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% assign footer_block = section.blocks | where: 'type', 'footer_cta' | first %}
    {% if footer_block %}
      <section class="bfcpdp__footer-cta" {{ footer_block.shopify_attributes }}>
        {% if footer_block.settings.eyebrow != blank %}
          <div class="eyebrow">{{ footer_block.settings.eyebrow }}</div>
        {% endif %}
        {% if footer_block.settings.heading != blank %}
