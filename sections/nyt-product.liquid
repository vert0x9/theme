    alt="{{ block.settings.alt | default: img.alt | escape }}"
    width="{{ img.width }}"
    height="{{ img.height }}"
    loading="lazy"
    decoding="async"
  >
{% endif %}
                </a>
              {% endif %}
              <div>
                {% if block.settings.title != blank %}
