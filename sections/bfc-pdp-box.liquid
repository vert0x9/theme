{{- 'section-product.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'product-variants.js' | asset_url }}" defer="defer"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet"/></noscript>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign warranty_base = product.metafields.bfc.warranty_months | default: 6

  assign g1 = product.metafields.custom.gallery_1.value
  assign g2 = product.metafields.custom.gallery_2.value
  assign g3 = product.metafields.custom.gallery_3.value
  assign g4 = product.metafields.custom.gallery_4.value
  assign g5 = product.metafields.custom.gallery_5.value
  assign g6 = product.metafields.custom.gallery_6.value

  assign spec_lens    = product.metafields.custom.spec_lens.value
  assign spec_shutter = product.metafields.custom.spec_shutterspeeds.value
  assign spec_mount   = product.metafields.custom.spec_lensmount.value
  assign spec_battery = product.metafields.custom.spec_battery.value
  assign spec_flash   = product.metafields.custom.spec_flash.value
  assign spec_tripod  = product.metafields.custom.spec_tripodmount.value
  assign spec_timer   = product.metafields.custom.spec_selftimer.value
  assign spec_dx      = product.metafields.custom.spec_dxcodereader.value
  assign spec_expcomp = product.metafields.custom.spec_exposurecompensation.value
  assign spec_meter   = product.metafields.custom.spec_meter.value
  assign spec_focus   = product.metafields.custom.spec_focus.value
-%}

<style>.bfc4 *,.bfc4 *::before,.bfc4 *::after{box-sizing:border-box;margin:0;padding:0}.bfc4{--or:#E36E15;--go:#F4A027;--ce:#ABCC99;--cv:#F8F6EE;--bk:#202009;--ch:#4E4741;--gr:#E3DDDA;--sr:'Cormorant Garamond',Georgia,serif;--sn:'Poppins',sans-serif;--t:0.2s ease;font-family:var(--sn);color:var(--bk);background:var(--cv);-webkit-font-smoothing:antialiased;overflow-x:hidden}.bfc4-split{display:grid;grid-template-columns:1fr 1fr;align-items:start}.bfc4-left{position:sticky;top:0;width:50vw;height:50vw;max-height:100vh;overflow:hidden;background:var(--gr)}.bfc4-slides{display:flex;width:100%;height:100%;transition:transform 0.5s cubic-bezier(0.4,0,0.2,1);will-change:transform}.bfc4-slide{min-width:100%;height:100%;flex-shrink:0;position:relative}.bfc4-slide img{width:100%;height:100%;object-fit:contain;object-position:center;display:block}.bfc4-arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:10;background:rgba(32,32,9,0.3);border:none;width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background var(--t);backdrop-filter:blur(4px)}.bfc4-arrow:hover{background:rgba(32,32,9,0.6)}.bfc4-arrow.is-prev{left:16px;visibility:hidden}.bfc4-arrow.is-next{right:16px}.bfc4-arrow svg{display:block}.bfc4-dots{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);display:flex;gap:6px;z-index:10}.bfc4-dot{width:6px;height:6px;background:rgba(255,255,255,0.4);border:none;cursor:pointer;padding:0;transition:background var(--t),transform var(--t)}.bfc4-dot.is-active{background:#fff;transform:scale(1.3)}.bfc4-right{background:var(--cv);padding:36px 40px 56px;display:flex;flex-direction:column;gap:20px}.bfc4-free-dev-mini{display:flex;align-items:center;gap:6px;font-size:10px;color:#ABCC99;font-weight:600;letter-spacing:0.04em;margin-top:8px}.bfc4-grade-compact{display:flex;align-items:center;gap:10px;margin-bottom:4px}.bfc4-grade-label{font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--ch);white-space:nowrap}.bfc4-grade-compact .bfc4-grade-row{flex:1}.bfc4-grade-compact .bfc4-var-btn{padding:7px 8px;font-size:10px}.bfc4-tile{cursor:pointer;transition:border-color var(--t),box-shadow var(--t)}.bfc4-tile.is-sel{border:2px solid var(--or);box-shadow:0 0 0 1px rgba(227,110,21,0.15)}.bfc4-tile-sel-check{position:absolute;top:6px;right:6px;width:18px;height:18px;background:var(--or);color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center}.bfc4-below-checkout{padding:24px 48px 48px;background:var(--cv)}.bfc4-selected-row{display:flex;flex-direction:row;gap:32px;align-items:flex-start;padding-top:24px}.bfc4-selected-items{flex:1;min-width:0;display:flex;flex-wrap:nowrap;gap:12px;align-items:flex-start;overflow-x:auto;padding-bottom:4px;justify-content:flex-start}.bfc4-sel-item{display:flex;flex-direction:column;align-items:center;gap:5px;width:120px;flex-shrink:0;cursor:pointer}.bfc4-sel-item-img{width:120px;height:90px;object-fit:cover;border:2px solid transparent;background:var(--gr);transition:border-color var(--t)}.bfc4-sel-item:not(.is-cam):hover .bfc4-sel-item-img{border-color:rgba(227,110,21,0.4)}.bfc4-sel-item.is-sel .bfc4-sel-item-img{border-color:var(--or)}.bfc4-sel-item.is-cam .bfc4-sel-item-img{border-color:var(--or);cursor:default}.bfc4-sel-item-img.is-placeholder{display:flex;align-items:center;justify-content:center;font-size:24px;background:var(--gr)}.bfc4-sel-item-name{font-size:9px;color:var(--ch);text-align:center;line-height:1.3;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}.bfc4-below-atc{width:220px;flex-shrink:0;display:flex;flex-direction:column;gap:8px}.bfc4-header{}.bfc4-eyebrow{font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--ch);margin-bottom:6px;display:block}.bfc4-title{font-family:var(--sn);font-size:28px;font-weight:600;line-height:1.1;letter-spacing:-0.3px;margin-bottom:6px}.bfc4-title em{font-style:normal;color:var(--ch);font-weight:400}.bfc4-warranty{font-size:10px;color:var(--ch);letter-spacing:0.08em;display:flex;align-items:center;gap:6px}.bfc4-warranty::before{content:'';width:16px;height:1px;background:var(--ch);display:block}.bfc4-kit-head{border-top:1px solid rgba(32,32,9,0.1);padding-top:16px}.bfc4-kit-eyebrow{font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--or);margin-bottom:6px;display:block}.bfc4-kit-desc{font-size:12px;color:var(--ch);line-height:1.6;margin-top:4px}.bfc4-tiles{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}.bfc4-tile{display:flex;flex-direction:column;background:#fff;border:1px solid rgba(32,32,9,0.08);overflow:hidden;cursor:default;position:relative}.bfc4-tile.is-cam{border:2px solid var(--or);cursor:default}.bfc4-tile-img-wrap{aspect-ratio:3/2;overflow:hidden;background:var(--gr);position:relative}.bfc4-tile-img-wrap img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.4s ease}.bfc4-tile:hover .bfc4-tile-img-wrap img{transform:scale(1.04)}.bfc4-tile-body{padding:10px 10px 8px;flex:1;display:flex;flex-direction:column;gap:2px}.bfc4-tile-label{font-size:8px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--ch)}.bfc4-tile-name{font-size:11px;font-weight:600;line-height:1.3;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}.bfc4-tile-price{font-size:11px;font-weight:700;color:var(--or);margin-top:2px}.bfc4-tile-price.is-free{color:#2a4820}.bfc4-tile-orig{font-size:9px;color:rgba(32,32,9,0.5);text-decoration:line-through}.bfc4-tile-change{margin-top:6px;font-size:8.5px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(32,32,9,0.55);background:none;border:none;cursor:pointer;font-family:var(--sn);padding:0;text-align:left;transition:color var(--t);display:flex;align-items:center;gap:3px}.bfc4-tile-change:hover{color:var(--or)}.bfc4-tile-cam-badge{position:absolute;