<script>
(function() {
'use strict';
// ── XHR helper (bypasses Judge.me monkey-patching of window.fetch) ─────
function bfc4Xhr(url, opts) {
  opts = opts || {};
  return new Promise(function(resolve, reject) {
    var xhr = new XMLHttpRequest();
    xhr.open(opts.method || 'GET', url, true);
    xhr.withCredentials = true;
    if (opts.headers) Object.keys(opts.headers).forEach(function(k){xhr.setRequestHeader(k, opts.headers[k]);});
    xhr.setRequestHeader('X-Requested-With','XMLHttpRequest');
    xhr.onload = function() {
      resolve({
        ok: xhr.status>=200 && xhr.status<300,
        status: xhr.status,
        json: function(){ try{return Promise.resolve(JSON.parse(xhr.responseText));}catch(e){return Promise.resolve({});} },
        text: function(){ return Promise.resolve(xhr.responseText); }
      });
    };
    xhr.onerror = function(){ reject(new Error('Network error')); };
    xhr.send(opts.body || null);
  });
}
var STATE = {
variantId:    {{ current_variant.id }},
variantPrice: {{ current_variant.price }},
kit: {},
extWarranty: null
};
function syncAccordionLocks() {
var starterVariantIds = [];
document.querySelectorAll('.bfc4-tile.is-sel:not(.is-cam)').forEach(function(tile) {
if (tile.dataset.variantId) starterVariantIds.push(tile.dataset.variantId);
});
document.querySelectorAll('.ba-mini-card').forEach(function(card) {
var inKit = starterVariantIds.indexOf(card.dataset.variantId) >= 0;
card.classList.toggle('is-sel', inKit);
card.style.pointerEvents = inKit ? 'none' : '';
card.style.opacity = inKit ? '0.7' : '';
var badge = card.querySelector('.bfc4-in-kit-badge');
if (inKit && !badge) {
badge = document.createElement('div');
badge.className = 'bfc4-in-kit-badge';
badge.style.cssText = 'position:absolute;top:4px;left:4px;background:var(--or);color:#fff;font-size:7px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:2px 5px;z-index:2;';
badge.textContent = 'In Kit';
card.style.position = 'relative';
card.appendChild(badge);
} else if (!inKit && badge) {
badge.remove();
}
});
}
window.bfc4TileToggle = function(tile) {
var wasSel = tile.classList.contains('is-sel');
tile.classList.toggle('is-sel', !wasSel);
var check = tile.querySelector('.bfc4-tile-sel-check');
if (!wasSel) {
var tileId = tile.dataset.tileId || ('tile-' + Math.random());
var isFilm = (tile.dataset.col || '').toLowerCase().indexOf('film') >= 0 && tile.dataset.isDev !== 'true';
if (!check) {
check = document.createElement('div');
check.className = 'bfc4-tile-sel-check';
check.textContent = '✓';
tile.querySelector('.bfc4-tile-img-wrap').appendChild(check);
}
STATE.kit[tileId] = {
variantId: tile.dataset.variantId,
name:      tile.dataset.productTitle,
orig:      parseInt(tile.dataset.orig || '0', 10),
sale:      parseInt(tile.dataset.sale || '0', 10),
isDev:     tile.dataset.isDev === 'true',
disc:      parseInt(tile.dataset.disc || '0', 10),
isFilm:    isFilm,
colId:     tile.dataset.tileId,
img:       tile.dataset.img || null
};
tile.dataset.stateKey = tileId;
} else {
var key = tile.dataset.stateKey;
if (key) delete STATE.kit[key];
if (check) check.remove();
}
bfc4Render();
syncAccordionLocks();
};
window.bfc4ClearTiles = function() {
document.querySelectorAll('.bfc4-tile.is-sel:not(.is-cam)').forEach(function(tile) {
tile.classList.remove('is-sel');
var check = tile.querySelector('.bfc4-tile-sel-check');
if (check) check.remove();
var key = tile.dataset.stateKey;
if (key) delete STATE.kit[key];
});
bfc4Render();
syncAccordionLocks();
};
window.bfc4SelectVariant = function(btn) {
if (btn.dataset.variantAvailable === 'false') return;
document.querySelectorAll('.bfc4-var-btn').forEach(function(b) { b.classList.remove('is-active'); });
btn.classList.add('is-active');
STATE.variantId    = parseInt(btn.dataset.variantId, 10);
STATE.variantPrice = parseInt(btn.dataset.variantPrice, 10);
var inp = document.getElementById('bfc4-variant-input');
if (inp) inp.value = STATE.variantId;
var camPriceEl = document.getElementById('bfc4-cam-price');
var ksCamEl    = document.getElementById('bfc4-ks-cam-price');
if (camPriceEl) camPriceEl.textContent = btn.dataset.variantPriceFmt;
if (ksCamEl)    ksCamEl.textContent    = btn.dataset.variantPriceFmt;
var stickyGrade = document.getElementById('bfc4-sticky-grade');
if (stickyGrade) stickyGrade.textContent = btn.textContent.trim();
bfc4UpdateWarrantyTier(STATE.variantPrice);
bfc4Render();
};
window.baSelectVariant = window.bfc4SelectVariant;
window.bfc4ChangeItem = function(colName) {
var customSec = document.getElementById('bfc4-custom');
if (customSec) customSec.scrollIntoView({ behavior: 'smooth' });
setTimeout(function() {
var cols = document.querySelectorAll('.ba-col[data-col-name]');
cols.forEach(function(col) {
if (col.dataset.colName === colName) {
col.classList.add('is-open');
col.classList.add('flash-highlight');
setTimeout(function() { col.classList.remove('flash-highlight'); }, 1600);
}
});
}, 600);
};

  // ── Also in collection slider ─────────────────────────────────────────
  (function() {
    var track = document.getElementById('bfc4-also-track');
    if (!track) return;
    var prevBtn = document.querySelector('.bfc4-also-arr.is-prev');
    var nextBtn = document.querySelector('.bfc4-also-arr.is-next');
    function updateArrows() {
      if (prevBtn) prevBtn.disabled = track.scrollLeft <= 4;
      if (nextBtn) nextBtn.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 4;
    }
    window.bfc4AlsoSlide = function(dir) {
      track.scrollLeft += dir * 440;
      setTimeout(updateArrows, 350);
    };
    track.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
  })();

  var BFC_WARRANTY_TIERS = [
{ max: 50000,   v6: '46108352151724', p6: 1500,  v9: '46108352184492', p9: 3000,  v12: '46108352217260', p12: 4500  },
{ max: 100000,  v6: '46108381872300', p6: 2000,  v9: '46108381970604', p9: 4000,  v12: '46108382068908', p12: 8000  },
{ max: 9999999, v6: '46108381905068', p6: 4000,  v9: '46108382003372', p9: 6000,  v12: '46108382101676', p12: 12000 }
];
function bfc4GetWarrantyTier(price) {
for (var i = 0; i < BFC_WARRANTY_TIERS.length; i++) {
if (price <= BFC_WARRANTY_TIERS[i].max) return BFC_WARRANTY_TIERS[i];
}
return BFC_WARRANTY_TIERS[BFC_WARRANTY_TIERS.length - 1];
}
function bfc4UpdateWarrantyTier(variantPrice) {
var tier = bfc4GetWarrantyTier(variantPrice);
var td = [{ vid: tier.v6, price: tier.p6 }, { vid: tier.v9, price: tier.p9 }, { vid: tier.v12, price: tier.p12 }];
document.querySelectorAll('.bfc4-ext-w-btn').forEach(function(btn, i) {
if (!td[i]) return;
btn.dataset.variantId = td[i].vid;
btn.dataset.price = td[i].price;
var el = btn.querySelector('.bfc4-ext-w-price');
if (el) el.textContent = '+$' + (td[i].price / 100).toFixed(0);
if (btn.classList.contains('is-sel') && STATE.extWarranty) {
STATE.extWarranty.variantId = td[i].vid;
STATE.extWarranty.price = td[i].price;
}
});
bfc4Render();
}
window.bfc4SelectWarranty = function(btn) {
var wasSelected = btn.classList.contains('is-sel');
document.querySelectorAll('.bfc4-ext-w-btn').forEach(function(b) { b.classList.remove('is-sel'); });
var clearBtn = document.getElementById('bfc4-ext-w-clear');
if (wasSelected) {
STATE.extWarranty = null;
if (clearBtn) clearBtn.classList.remove('is-vis');
} else {
btn.classList.add('is-sel');
STATE.extWarranty = {
months: parseInt(btn.dataset.months, 10),
total:  parseInt(btn.dataset.total, 10),
price:  parseInt(btn.dataset.price, 10),
variantId: btn.dataset.variantId || null
};
if (clearBtn) clearBtn.classList.add('is-vis');
}
bfc4Render();
};
window.bfc4ClearWarranty = function() {
document.querySelectorAll('.bfc4-ext-w-btn').forEach(function(b) { b.classList.remove('is-sel'); });
STATE.extWarranty = null;
var clearBtn = document.getElementById('bfc4-ext-w-clear');
if (clearBtn) clearBtn.classList.remove('is-vis');
bfc4Render();
};
function bfc4Render() {
var total = STATE.variantPrice;
var filmCount = 0;
Object.values(STATE.kit).forEach(function(sel) {
total += sel.sale;
if (sel.isFilm) filmCount++;
});
if (STATE.extWarranty) total += STATE.extWarranty.price;
var devValue = filmCount >= 2 ? 1800 : 0;
var totalEl   = document.getElementById('bfc4-total');
var totalEl2  = document.getElementById('bfc4-total-2');
if (totalEl)   totalEl.textContent   = fmt(total);
if (totalEl2)  totalEl2.textContent  = fmt(total);
var stickyPrice = document.getElementById('bfc4-sticky-price');
if (stickyPrice) stickyPrice.textContent = fmt(total);
var promoEl = document.getElementById('ba-film-promo');
if (promoEl) promoEl.style.display = filmCount >= 2 ? 'flex' : 'none';
var selEl = document.getElementById('bfc4-selected-items');
if (selEl) {
var html = '';
var camImg = document.querySelector('#bfc4-tiles .bfc4-tile.is-cam img');
html += '<div class="bfc4-sel-item is-cam is-sel">'
+ (camImg ? '<img class="bfc4-sel-item-img" src="' + camImg.src + '" alt=""/>' : '<div class="bfc4-sel-item-img is-placeholder">📷</div>')
+ '<span class="bfc4-sel-item-name">{{ product.title | escape }}</span>'
+ '</div>';
Object.entries(STATE.kit).forEach(function(entry) {
var key = entry[0], sel = entry[1];
html += '<div class="bfc4-sel-item is-sel" onclick="bfc4RemoveSel(\'' + key + '\')" title="Click to remove">'
+ (sel.img ? '<img class="bfc4-sel-item-img" src="' + sel.img + '" alt=""/>' : '<div class="bfc4-sel-item-img is-placeholder">+</div>')
+ '<span class="bfc4-sel-item-name">' + esc(sel.name) + '</span>'
+ '</div>';
});
selEl.innerHTML = html;
}
}
window.bfc4RemoveSel = function(key) {
delete STATE.kit[key];
document.querySelectorAll('.bfc4-tile[data-state-key="' + key + '"]').forEach(function(tile) {
tile.classList.remove('is-sel');
var check = tile.querySelector('.bfc4-tile-sel-check');
if (check) check.remove();
});
bfc4Render();
syncAccordionLocks();
};
window.bfc4AddToCart = async function() {
var btn    = document.getElementById('bfc4-atc');
var textEl = document.getElementById('bfc4-atc-text');
var stickyBtn  = document.getElementById('bfc4-sticky-btn');
var stickyText = document.getElementById('bfc4-sticky-btn-text');
if (btn) { btn.disabled = true; }
if (stickyBtn) { stickyBtn.disabled = true; }
if (textEl) { textEl.textContent = 'Adding\u2026'; }
if (stickyText) { stickyText.textContent = 'Adding\u2026'; }
var items = [];
var filmCount = 0;
Object.values(STATE.kit).forEach(function(sel) {
if (!sel.variantId) return;
var vid = parseInt(sel.variantId, 10);
if (isNaN(vid) || vid === 0) return;
if (sel.isFilm) filmCount++;
var props = { _kit_bundle: 'true' };
if (sel.isDev) {
props._free_developing      = 'true';
props._bundle_discount_type = 'free_developing';
}
items.push({ id: vid, quantity: 1, properties: props });
});
try {
var cartAttrs = { attributes: { '_kit_bundle': 'true', '_kit_camera': '{{ product.title | escape }}', '_free_developing_credit': filmCount >= 2 ? 'true' : 'false' } };
await bfc4Xhr('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(cartAttrs) });
if (items.length > 0) {
var res = await bfc4Xhr('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ items: items }) });
if (!res.ok) {
var errBody = await res.json().catch(function() { return {}; });
console.error('[BFC4] cart/add.js error:', res.status, errBody);
throw new Error(res.status);
}
}
if (STATE.extWarranty && STATE.extWarranty.variantId) {
await bfc4Xhr('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ items: [{ id: STATE.extWarranty.variantId, quantity: 1, properties: { _warranty_months: STATE.extWarranty.total, _warranty_type: 'extended' } }] }) });
}
var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
if (submitBtn) submitBtn.click();
if (btn) { btn.classList.add('is-success'); }
if (textEl) { textEl.textContent = 'Added!'; }
if (stickyText) { stickyText.textContent = 'Added!'; }
setTimeout(function() {
if (btn) { btn.classList.remove('is-success'); btn.disabled = false; }
if (stickyBtn) { stickyBtn.disabled = false; }
if (textEl) { textEl.textContent = 'Add Starter Kit'; }
if (stickyText) { stickyText.textContent = 'Add to Cart'; }
}, 2400);
} catch(e) {
console.error('[BFC4] ATC error:', e);
if (btn) { btn.disabled = false; }
if (stickyBtn) { stickyBtn.disabled = false; }
if (textEl) { textEl.textContent = 'Add Starter Kit'; }
if (stickyText) { stickyText.textContent = 'Add to Cart'; }
}
};
window.bfc4CameraOnly = async function() {
var btns = document.querySelectorAll('.bfc4-cam-only');
btns.forEach(function(b) { b.disabled = true; b.textContent = 'Adding…'; });
try {
await bfc4Xhr('/cart/update.js', {
method: 'POST',
headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
body: JSON.stringify({ attributes: { '_kit_bundle': 'false', '_free_developing_credit': 'false', '_kit_camera': '' } })
});
if (STATE.extWarranty && STATE.extWarranty.variantId) {
await bfc4Xhr('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ items: [{ id: STATE.extWarranty.variantId, quantity: 1 }] }) });
}
var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
if (submitBtn) submitBtn.click();
} catch(e) {
console.error('[BFC4] Camera only error:', e);
} finally {
btns.forEach(function(b) {
b.disabled = false;
b.textContent = 'Camera Only \u2014 {{ current_variant.price | money }}';
});
}
};
window.baToggleCol = function(col) {
var isMobile = window.innerWidth <= 900;
if (!isMobile) return;
col.classList.toggle('is-open');
};
window.baExpandCol = function(col) {
col.classList.toggle('is-expanded');
var btn = col.querySelector('.ba-col-more-text');
if (!btn) return;
var hidden = col.querySelectorAll('.ba-mini-card.is-hidden').length;
btn.textContent = col.classList.contains('is-expanded') ? 'Show less \u2039' : hidden + ' more \u203a';
};
window.baMiniSelect = function(card, e) {
var catId = card.dataset.cat;
var wasSelected = card.classList.contains('is-sel');
document.querySelectorAll('[data-cat="' + catId + '"].ba-mini-card').forEach(function(c) { c.classList.remove('is-sel'); });
if (wasSelected) {
delete STATE.kit[catId];
} else {
card.classList.add('is-sel');
var isFilm = (card.dataset.colName || '').toLowerCase().indexOf('film') >= 0 && card.dataset.isDev !== 'true';
var imgEl = card.querySelector('.ba-mini-img');
STATE.kit[catId] = {
variantId: card.dataset.variantId,
name:      card.dataset.productTitle,
orig:      parseInt(card.dataset.orig, 10),
sale:      parseInt(card.dataset.sale, 10),
isDev:     card.dataset.isDev === 'true',
disc:      parseInt(card.dataset.disc, 10),
isFilm:    isFilm,
colId:     card.dataset.colId,
img:       imgEl ? imgEl.src : null
};
}
baUpdateColCounts();
bfc4Render();
};
window.baMiniSelectVar = function(btn) {
var catId = btn.dataset.cat;
var card  = document.getElementById(catId);
card.querySelectorAll('.ba-mini-var-btn').forEach(function(b) { b.classList.remove('is-sel'); });
btn.classList.add('is-sel');
card.dataset.variantId    = btn.dataset.variantId;
card.dataset.productTitle = btn.dataset.productTitle;
card.dataset.orig         = btn.dataset.orig;
card.dataset.sale         = btn.dataset.sale;
if (card.classList.contains('is-sel')) {
STATE.kit[catId].variantId = btn.dataset.variantId;
STATE.kit[catId].name      = btn.dataset.productTitle;
STATE.kit[catId].orig      = parseInt(btn.dataset.orig, 10);
STATE.kit[catId].sale      = parseInt(btn.dataset.sale, 10);
bfc4Render();
}
};
function baUpdateColCounts() {
var counts = {};
Object.values(STATE.kit).forEach(function(sel) {
if (sel.colId) counts[sel.colId] = (counts[sel.colId] || 0) + 1;
});
document.querySelectorAll('.ba-col-count').forEach(function(el) {
var colEl = el.closest('.ba-col');
if (!colEl) return;
var n = counts[colEl.id] || 0;
el.textContent = n;
el.classList.toggle('is-visible', n > 0);
});
}
window.baRemoveItem = function(catId) {
var card = document.getElementById(catId);
if (card) card.classList.remove('is-sel');
delete STATE.kit[catId];
baUpdateColCounts();
bfc4Render();
};
window.baClearAll = function() {
document.querySelectorAll('.ba-mini-card.is-sel').forEach(function(card) {
baMiniSelect(card, { stopPropagation: function(){} });
});
};
window.baOpenPopup = function(catId) {
var data = document.getElementById('ba-popup-data-' + catId);
if (!data) return;
document.getElementById('ba-popup-title').textContent = data.dataset.title;
var desc = data.dataset.desc;
document.getElementById('ba-popup-desc').innerHTML = desc ? '<p>' + desc.replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br/>') + '</p>' : '';
var imgs = data.dataset.imgs ? data.dataset.imgs.split('||') : [];
document.getElementById('ba-popup-imgs').innerHTML = imgs.map(function(src) { return '<img src="' + src + '" alt="" role="presentation" loading="lazy"/>'; }).join('');
document.getElementById('ba-popup-overlay').classList.add('is-open');
document.body.style.overflow = 'hidden';
};
window.baClosePopup = function() {
document.getElementById('ba-popup-overlay').classList.remove('is-open');
document.body.style.overflow = '';
};
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') baClosePopup(); });
var bfc4Slide_current = 0;
var bfc4Slide_total   = document.querySelectorAll('.bfc4-slide').length;
window.bfc4Slide = function(dir) {
bfc4GoTo((bfc4Slide_current + dir + bfc4Slide_total) % bfc4Slide_total);
};
window.bfc4GoTo = function(idx) {
bfc4Slide_current = idx;
var slides = document.getElementById('bfc4-slides');
if (slides) slides.style.transform = 'translateX(-' + (idx * 100) + '%)';
document.querySelectorAll('.bfc4-dot').forEach(function(d, i) { d.classList.toggle('is-active', i === idx); });
var prev = document.querySelector('.bfc4-arrow.is-prev');
if (prev) prev.style.visibility = idx === 0 ? 'hidden' : 'visible';
};
(function() {
var left = document.querySelector('.bfc4-left');
if (!left || bfc4Slide_total <= 1) return;
var startX = 0;
left.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
left.addEventListener('touchend', function(e) {
var dx = e.changedTouches[0].clientX - startX;
if (Math.abs(dx) > 40) bfc4Slide(dx < 0 ? 1 : -1);
});
})();
function fmt(cents) { return '$' + (cents / 100).toFixed(2).replace(/\.00$/, ''); }
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
if (window.innerWidth <= 900) {
document.querySelectorAll('.ba-col').forEach(function(c) { c.classList.remove('is-open'); });
}
document.querySelectorAll('.bfc4-tile.is-sel:not(.is-cam)').forEach(function(tile) {
var tileId = tile.dataset.tileId || ('sk-' + Math.random().toString(36).slice(2));
tile.dataset.stateKey = tileId;
var isFilm = (tile.dataset.col || '').toLowerCase().indexOf('film') >= 0 && tile.dataset.isDev !== 'true';
STATE.kit[tileId] = {
variantId: tile.dataset.variantId,
name:      tile.dataset.productTitle || '',
orig:      parseInt(tile.dataset.orig || '0', 10),
sale:      parseInt(tile.dataset.sale || '0', 10),
isDev:     tile.dataset.isDev === 'true',
disc:      parseInt(tile.dataset.disc || '0', 10),
isFilm:    isFilm,
colId:     tileId,
img:       tile.dataset.img || null
};
});
syncAccordionLocks();
bfc4UpdateWarrantyTier(STATE.variantPrice);
bfc4Render();

// ── Sticky Mobile ATC Bar ──────────────────────
var stickyBar = document.getElementById('bfc4-sticky-bar');
var mainAtc   = document.getElementById('bfc4-atc');
if (stickyBar && mainAtc && window.innerWidth <= 900) {
  var stickyScrollHidden = false;
  var stickyDrawerHidden = false;
  function syncSticky() {
    stickyBar.classList.toggle('is-visible', stickyScrollHidden && !stickyDrawerHidden);
  }
  new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      stickyScrollHidden = !e.isIntersecting;
    });
    syncSticky();
  }, { threshold: 0 }).observe(mainAtc);

  // Hide sticky when cart drawer is open (so checkout button isn't blocked)
  function checkDrawer() {
    var d = document.querySelector('cart-drawer');
    if (!d) { stickyDrawerHidden = false; syncSticky(); return; }
    var open = d.classList.contains('active') || d.classList.contains('is-open') || d.hasAttribute('open');
    if (!open) {
      // fallback: check if visible panel has actual size
      var inner = d.querySelector('.drawer__inner, [class*="drawer"]');
      if (inner) {
        var r = inner.getBoundingClientRect();
        if (r.width > 0 && r.height > 0 && r.right > 0 && r.left < window.innerWidth) open = true;
      }
    }
    stickyDrawerHidden = open;
    syncSticky();
  }
  var drawerEl = document.querySelector('cart-drawer');
  if (drawerEl) new MutationObserver(checkDrawer).observe(drawerEl, { attributes: true, subtree: true, attributeFilter: ['class','open','aria-hidden','style'] });
  new MutationObserver(function() {
    var d = document.querySelector('cart-drawer');
    if (d && !d.dataset.bfcWatched) {
      d.dataset.bfcWatched = '1';
      new MutationObserver(checkDrawer).observe(d, { attributes: true, subtree: true, attributeFilter: ['class','open','aria-hidden','style'] });
    }
    checkDrawer();
  }).observe(document.body, { childList: true });
  setInterval(checkDrawer, 1500); // safety net
}
})();
</script>

