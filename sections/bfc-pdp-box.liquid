,32,9,0.08)}.bfc4-policy-col:last-child{border-right:none}.bfc4-policy-ey{font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--or);margin-bottom:12px;display:block}.bfc4-policy-title{font-family:var(--sr);font-size:28px;font-weight:300;line-height:1.1;margin-bottom:16px}.bfc4-policy-body{font-size:12px;color:var(--ch);line-height:1.75}.bfc4-policy-body strong{color:var(--bk);font-weight:600}.bfc4-policy-pill{display:inline-flex;align-items:center;gap:5px;background:rgba(42,72,32,0.08);color:#2a4820;font-size:10px;font-weight:700;letter-spacing:0.06em;padding:4px 10px;margin-bottom:14px}@media (max-width:900px){.bfc4-policy{grid-template-columns:1fr}.bfc4-policy-col{padding:32px 20px 36px;border-right:none;border-bottom:1px solid rgba(32,32,9,0.08)}.bfc4-policy-col:last-child{border-bottom:none}.bfc4-ext-w-options{grid-template-columns:repeat(3,1fr)}}
.bfc4-nav-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  padding-top: 4px;
  border-top: 1px solid rgba(32,32,9,0.08);
}
.bfc4-nav-btns .bfc4-customize {
  padding-bottom: 2px;
}
@media (max-width: 900px) {
  .bfc4-nav-btns {
    gap: 0;
    flex-direction: column;
    border-top: none;
  }
  .bfc4-nav-btns .bfc4-customize {
    padding: 12px 0;
    border-top: 1px solid rgba(32,32,9,0.08);
    border-bottom: none;
    width: 100%;
    justify-content: space-between;
  }
  .bfc4-nav-btns .bfc4-customize svg {
    transform: rotate(-90deg);
  }
  .bfc4-nav-btns .bfc4-customize:hover svg {
    transform: rotate(-90deg) translateX(3px);
  }
}

/* ── Sticky Mobile ATC Bar ────────────────── */
.bfc4-sticky-bar { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--cv); border-top: 1px solid rgba(32,32,9,0.15); padding: 10px 16px; z-index: 100; align-items: center; gap: 12px; box-shadow: 0 -2px 12px rgba(0,0,0,0.08); }
.bfc4-sticky-info { flex: 1; min-width: 0; }
.bfc4-sticky-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--bk); }
.bfc4-sticky-meta { display: flex; align-items: center; gap: 6px; margin-top: 1px; }
.bfc4-sticky-grade { font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ch); }
.bfc4-sticky-price { font-size: 13px; font-weight: 700; color: var(--or); }
.bfc4-sticky-btn { background: var(--or); color: #fff; border: none; padding: 12px 24px; font-size: 10px; font-weight: 700; font-family: var(--sn); text-transform: uppercase; letter-spacing: 0.14em; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
.bfc4-sticky-btn:disabled { opacity: 0.5; cursor: not-allowed; }
@media (max-width: 900px) {
  .bfc4-sticky-bar.is-visible { display: flex; }
}
</style>

<main id="bfc4-main" aria-label="{{ product.title | escape }} product page">
<div class="bfc4">

{%- comment -%} ── Collect starter kit blocks ── {%- endcomment -%}
{%- assign sk_blocks = section.blocks | where: 'type', 'kit_item' -%}
{%- assign has_starter = false -%}
{%- for block in sk_blocks -%}
  {%- if block.settings.is_starter_kit and block.settings.product != blank -%}
    {%- assign has_starter = true -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Compute kit total for starter {%- endcomment -%}
{%- liquid
  assign sk_total = current_variant.price
  for block in sk_blocks
    if block.settings.is_starter_kit and block.settings.product != blank
      assign sk_bp  = block.settings.product
      assign sk_dv  = sk_bp.variants.first
      assign sk_d   = block.settings.discount_percent
      assign sk_dev = block.settings.is_developing
      if sk_dev
        assign sk_sale = 0
      elsif sk_d > 0
        assign sk_df   = sk_d | times: 1.0 | divided_by: 100
        assign sk_sv   = sk_dv.price | times: sk_df | floor
        assign sk_sale = sk_dv.price | minus: sk_sv
      else
        assign sk_sale = sk_dv.price
      endif
      assign sk_total = sk_total | plus: sk_dv.price
    endif
  endfor
-%}

{%- comment -%} ── SPLIT: left image + right content ── {%- endcomment -%}
<div class="bfc4-split">

  {%- comment -%} LEFT: sticky slider — uses section image pickers if set, falls back to product.media {%- endcomment -%}
  <div class="bfc4-left" id="bfc4-top" role="region" aria-label="Product images">
    {%- comment -%} Check if any section images are set {%- endcomment -%}
    {%- assign has_section_imgs = false -%}
    {%- for i in (1..5) -%}
      {%- assign img_key = 'slide_' | append: i -%}
      {%- if section.settings[img_key] != blank -%}{%- assign has_section_imgs = true -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_section_imgs -%}
      {%- comment -%} Count section slides {%- endcomment -%}
      {%- assign slide_images = '' -%}
      {%- for i in (1..5) -%}
        {%- assign img_key = 'slide_' | append: i -%}
        {%- if section.settings[img_key] != blank -%}{%- assign slide_images = slide_images | append: '1' -%}{%- endif -%}
      {%- endfor -%}
      {%- assign total_slides = slide_images | size -%}

      <div class="bfc4-slides" id="bfc4-slides">
        {%- for i in (1..5) -%}
          {%- assign img_key = 'slide_' | append: i -%}
          {%- assign img_mob_key = 'slide_' | append: i | append: '_mobile' -%}
          {%- assign img_val = section.settings[img_key] -%}
          {%- assign img_mob = section.settings[img_mob_key] -%}
          {%- if img_val != blank -%}
            <div class="bfc4-slide">
              <picture>
                {%- if img_mob != blank -%}
                  <source media="(max-width: 767px)" srcset="{{ img_mob | image_url: width: 900 }}"/>
                {%- endif -%}
                <img
                  src="{{ img_val | image_url: width: 900 }}"
                  srcset="{{ img_val | image_url: width: 600 }} 600w, {{ img_val | image_url: width: 900 }} 900w, {{ img_val | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 900px) 100vw, 50vw"
                  alt="{{ product.title | escape }}"
                  width="900" height="900"
                  {%- if i == 1 -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
                />
              </picture>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- comment -%} Fallback: use product.media images {%- endcomment -%}
      {%- assign media_images = product.media | where: 'media_type', 'image' -%}
      {%- assign total_slides = media_images | size -%}

      <div class="bfc4-slides" id="bfc4-slides">
        {%- for media in media_images limit: 8 -%}
          <div class="bfc4-slide">
            <img
              src="{{ media | image_url: width: 900 }}"
              srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 900px) 100vw, 50vw"
              alt="{{ product.title | escape }}"
              width="900" height="900"
              {%- if forloop.first -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
            />
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if total_slides > 1 -%}
      <button class="bfc4-arrow is-prev" onclick="bfc4Slide(-1)" aria-label="Previous">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false"><path d="M10 3L5 8L10 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
      <button class="bfc4-arrow is-next" onclick="bfc4Slide(1)" aria-label="Next">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false"><path d="M6 3L11 8L6 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
      <div class="bfc4-dots" id="bfc4-dots" role="tablist" aria-label="Product image slides">
        {%- for i in (1..total_slides) -%}
          <button class="bfc4-dot{% if forloop.first %} is-active{% endif %}" role="tab" aria-label="Slide {{ forloop.index }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" onclick="bfc4GoTo({{ forloop.index0 }})"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} RIGHT: product content {%- endcomment -%}
  <div class="bfc4-right">

    {%- comment -%} 1. Product header + description {%- endcomment -%}
    <div class="bfc4-header">
      <span class="bfc4-eyebrow">{{ product.type | default: 'Polaroid Instant Camera' }} — Professionally Restored &middot; <a href="https://brooklynfilmcamera.com/pages/warranty" style="color:inherit;text-decoration:underline;text-underline-offset:2px;">{{ warranty_base }}-Month Warranty</a></span>
      <h1 class="bfc4-title">{{ product.title }}</h1>
      {%- comment -%} Extract prose only from __desc, skipping spec grid {%- endcomment -%}
      {%- assign desc_text = '' -%}
      {%- if product.description contains 'bfc-desc-specs__desc' -%}
        {%- assign desc_inner = product.description | split: 'bfc-desc-specs__desc">' | last | split: '</div>' | first -%}
        {%- assign desc_text = desc_inner | strip_html | strip -%}
      {%- endif -%}
      {%- if desc_text == blank -%}
        {%- assign desc_text = product.description | split: 'bfc-desc-specs__grid' | first | strip_html | strip -%}
      {%- endif -%}
      {%- if desc_text == blank -%}
        {%- assign desc_text = product.description | strip_html | strip -%}
      {%- endif -%}
      <p class="bfc4-kit-desc">{{ desc_text }}</p>
      <span class="bfc4-free-dev-mini">
        <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="0.5" stroke="#ABCC99" stroke-width="1.2"/><circle cx="7" cy="7" r="2.5" stroke="#ABCC99" stroke-width="1.2"/><line x1="1" y1="4" x2="13" y2="4" stroke="#ABCC99" stroke-width="0.8"/><line x1="1" y1="10" x2="13" y2="10" stroke="#ABCC99" stroke-width="0.8"/></svg>
        Add 2 rolls of film &mdash; get a free developing credit with your order
      </span>
    </div>

    {%- comment -%} 2. Build Your Kit heading {%- endcomment -%}
    <div class="bfc4-kit-head">
      <span class="bfc4-kit-eyebrow">Build Your Kit</span>
      <p class="bfc4-kit-desc">Everything you need to start shooting — no experience required.</p>
    </div>

    {%- comment -%} 3. Starter kit tiles (pre-selected, orange border) + all selectable {%- endcomment -%}
    <div class="bfc4-tiles" id="bfc4-tiles" role="group" aria-label="Kit items">
      {%- comment -%} Camera tile {%- endcomment -%}
      <div class="bfc4-tile is-cam">
        <div class="bfc4-tile-img-wrap">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="" role="presentation" loading="eager"/>
          {%- endif -%}
          <span class="bfc4-tile-cam-badge">Camera</span>
        </div>
        <div class="bfc4-tile-body">
          <span class="bfc4-tile-label">Included</span>
          <span class="bfc4-tile-name">{{ product.title }}</span>
          <span class="bfc4-tile-price" id="bfc4-cam-price">{{ current_variant.price | money }}</span>
        </div>
      </div>

      {%- comment -%} Starter kit tiles only {%- endcomment -%}
      {%- for block in sk_blocks -%}
        {%- if block.type != 'kit_item' or block.settings.product == blank -%}{% continue %}{%- endif -%}
        {%- unless block.settings.is_starter_kit -%}{% continue %}{%- endunless -%}
        {%- if block.settings.only_show_for != blank and block.settings.only_show_for.handle != product.handle -%}{% continue %}{%- endif -%}
        {%- assign sk_bp  = block.settings.product -%}
        {%- assign sk_d   = block.settings.discount_percent -%}
        {%- assign sk_dev = block.settings.is_developing -%}
        {%- assign sk_starter = block.settings.is_starter_kit -%}
        {%- assign sk_dv  = sk_bp.variants.first -%}
        {%- assign sk_col = block.settings.column | default: block.settings.label -%}
        {%- if sk_dev -%}{%- assign sk_sale = 0 -%}
        {%- elsif sk_d > 0 -%}
          {%- assign sk_df = sk_d | times: 1.0 | divided_by: 100 -%}
          {%- assign sk_sv = sk_dv.price | times: sk_df | floor -%}
          {%- assign sk_sale = sk_dv.price | minus: sk_sv -%}
        {%- else -%}{%- assign sk_sale = sk_dv.price -%}{%- endif -%}
        {%- assign sk_popup_imgs = '' -%}
        {%- for media in sk_bp.media limit: 6 -%}
          {%- if media.media_type == 'image' -%}
            {%- assign sk_img_url = media | image_url: width: 600 -%}
            {%- if sk_popup_imgs == '' -%}{%- assign sk_popup_imgs = sk_img_url -%}
            {%- else -%}{%- assign sk_popup_imgs = sk_popup_imgs | append: '||' | append: sk_img_url -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign sk_tile_id = 'bfc4-tile-' | append: forloop.index -%}
        <div class="bfc4-tile{% if sk_starter %} is-sel{% endif %}{% unless sk_dv.available %} is-oos{% endunless %}"
          data-col="{{ sk_col | escape }}"
          data-tile-id="{{ sk_tile_id }}"
          data-variant-id="{{ sk_dv.id }}"
          data-product-title="{{ sk_bp.title | escape }}"
          data-orig="{{ sk_dv.price | default: 0 }}"
          data-sale="{{ sk_dv.price | default: 0 }}"
          data-is-dev="{{ sk_dev | default: false }}"
          data-disc="{{ sk_d | default: 0 }}"
          data-img="{{ sk_bp.featured_image | image_url: width: 400 }}"
          {% if sk_dv.available %}onclick="bfc4TileToggle(this)"{% endif %}
        >
          <div class="bfc4-tile-img-wrap">
            {%- if sk_bp.featured_image -%}
              <img src="{{ sk_bp.featured_image | image_url: width: 400 }}" alt="" role="presentation" loading="lazy"/>
            {%- endif -%}
            {%- if sk_starter -%}<div class="bfc4-tile-sel-check">✓</div>{%- endif -%}
            {%- unless sk_dv.available -%}<span class="bfc4-tile-oos-badge">Out of Stock</span>{%- endunless -%}
            <button class="bfc4-tile-info" onclick="event.stopPropagation(); baOpenPopup('{{ sk_tile_id }}')" aria-label="More info">
              <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg>
            </button>
          </div>
          <div class="bfc4-tile-body">
            <span class="bfc4-tile-label">{{ sk_col }}</span>
            <span class="bfc4-tile-name">{{ block.settings.custom_label | default: sk_bp.title }}</span>
            
            {%- unless sk_dev -%}<span class="bfc4-tile-price">{{ sk_dv.price | money }}</span>{%- endunless -%}
          </div>
        </div>
        <div id="ba-popup-data-{{ sk_tile_id }}" style="display:none"
          data-title="{{ sk_bp.title | escape }}"
          data-desc="{{ sk_bp.description | strip_html | escape }}"
          data-imgs="{{ sk_popup_imgs | escape }}"
        ></div>
      {%- endfor -%}
    </div>

    {%- comment -%} 4. Grade selector (compact) + price + ATC {%- endcomment -%}
    <div class="bfc4-buy">
      {%- if product.variants.size > 1 -%}
        <div class="bfc4-grade-compact">
          <span class="bfc4-grade-label">Grade</span>
          <div class="bfc4-grade-row">
            {%- for variant in product.variants -%}
              <button
                class="bfc4-var-btn{% if variant.id == current_variant.id %} is-active{% endif %}"
                data-variant-id="{{ variant.id }}"
                data-variant-price="{{ variant.price }}"
                data-variant-price-fmt="{{ variant.price | money }}"
                data-variant-available="{{ variant.available }}"
                onclick="bfc4SelectVariant(this)"
                {%- unless variant.available -%}disabled{%- endunless -%}
              >{{ variant.title }}{%- unless variant.available -%}<span class="bfc4-var-btn-oos">Out of Stock</span>{%- endunless -%}</button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
      <div class="bfc4-price-row">
        <span class="bfc4-price-label">Total</span>
        <span class="bfc4-price" id="bfc4-total">{{ sk_total | money }}</span>
      </div>

      <button class="bfc4-atc" id="bfc4-atc" onclick="bfc4AddToCart()">
        <span id="bfc4-atc-text">Add Starter Kit</span>
      </button>
      <button class="bfc4-cam-only" onclick="bfc4CameraOnly()">Camera Only &mdash; {{ current_variant.price | money }}</button>
    </div>

    {%- comment -%} 4b. Ease-of-use strip {%- endcomment -%}
    <div class="bfc4-howto">
      <div class="bfc4-howto-step">
        <div class="bfc4-howto-icon">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="0.5" stroke="currentColor" stroke-width="1.3"/><line x1="2" y1="6.5" x2="14" y2="6.5" stroke="currentColor" stroke-width="0.9"/></svg>
        </div>
        <span class="bfc4-howto-label">Load 600 Film</span>
        <span class="bfc4-howto-sub">Pop in a pack of Polaroid 600 — that's it</span>
      </div>
      <div class="bfc4-howto-step">
        <div class="bfc4-howto-icon">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="5" stroke="currentColor" stroke-width="1.3"/><circle cx="8" cy="8" r="2" fill="currentColor"/><line x1="8" y1="1" x2="8" y2="3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </div>
        <span class="bfc4-howto-label">Point &amp; Shoot</span>
        <span class="bfc4-howto-sub">Built-in flash, auto exposure — just press the button</span>
      </div>
      <div class="bfc4-howto-step">
        <div class="bfc4-howto-icon">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="3" y="3" width="10" height="10" stroke="currentColor" stroke-width="1.3"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/></svg>
        </div>
        <span class="bfc4-howto-label">Watch It Develop</span>
        <span class="bfc4-howto-sub">Photo ejects in seconds — no developing needed</span>
      </div>
    </div>

    {%- comment -%} 5. Starter kit + free developing banners {%- endcomment -%}
    {%- assign has_starter = false -%}
    {%- for block in sk_blocks -%}
      {%- if block.settings.is_starter_kit and block.settings.product != blank -%}{%- assign has_starter = true -%}{%- endif -%}
    {%- endfor -%}
    {%- if has_starter -%}
      <div class="ba-film-promo" style="background: linear-gradient(135deg, #3a1a05 0%, #5a2e0a 100%); border: none;">
        <div class="ba-film-promo-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L11 7H16.5L12.2 10.5L13.9 16L9 12.5L4.1 16L5.8 10.5L1.5 7H7L9 2Z" stroke="#F4A027" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </div>
        <div class="ba-film-promo-text">
          <div class="ba-film-promo-title">Ready to shoot right away</div>
          <div class="ba-film-promo-sub">Film, strap &amp; developing — pre-selected, ready to go.</div>
        </div>
        <button onclick="bfc4ClearTiles()" class="ba-film-promo-status" style="background:none;border:none;cursor:pointer;font-family:var(--sn);white-space:nowrap;">Clear</button>
      </div>
    {%- endif -%}
    <div class="ba-film-promo" id="ba-film-promo" style="display:none">
      <div class="ba-film-promo-icon">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="1" y="1" width="16" height="16" rx="1" stroke="#ABCC99" stroke-width="1.5"/><circle cx="9" cy="9" r="3" stroke="#ABCC99" stroke-width="1.5"/><line x1="1" y1="5" x2="17" y2="5" stroke="#ABCC99" stroke-width="1"/><line x1="1" y1="13" x2="17" y2="13" stroke="#ABCC99" stroke-width="1"/></svg>
      </div>
      <div class="ba-film-promo-text">
        <div class="ba-film-promo-title">Free developing credit unlocked!</div>
        <div class="ba-film-promo-sub">A standard C-41 developing credit will be included with your order.</div>
      </div>
      <div class="ba-film-promo-status" id="ba-promo-status" style="color:var(--ce);">✓ Unlocked</div>
    </div>

    {%- comment -%} 6. Mini specs {%- endcomment -%}
    <div class="bfc4-mini-specs">
      {%- comment -%} Parse spec grid from product description HTML {%- endcomment -%}
      {%- assign desc_has_specs = false -%}
      {%- if product.description contains 'bfc-desc-specs__k' -%}
        {%- assign desc_has_specs = true -%}
        {%- assign spec_items = product.description | split: 'bfc-desc-specs__item"' -%}
        {%- for item in spec_items -%}
          {%- if forloop.first -%}{% continue %}{%- endif -%}
          {%- assign k_raw = item | split: 'bfc-desc-specs__k">' | last | split: '</div>' | first | strip_html | strip -%}
          {%- assign v_raw = item | split: 'bfc-desc-specs__v">' | last | split: '</div>' | first | strip_html | strip -%}
          {%- if k_raw != blank and v_raw != blank -%}
            <div class="bfc4-mini-spec"><span class="bfc4-spec-key">{{ k_raw }}</span><span class="bfc4-spec-val">{{ v_raw }}</span></div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- unless desc_has_specs -%}
        {%- comment -%} Fallback to metafields if no desc spec grid {%- endcomment -%}
        {%- if spec_lens != blank -%}
          <div class="bfc4-mini-spec"><span class="bfc4-spec-key">Lens</span><span class="bfc4-spec-val">{{ spec_lens }}</span></div>
        {%- endif -%}
        {%- if spec_focus != blank -%}
          <div class="bfc4-mini-spec"><span class="bfc4-spec-key">Focus</span><span class="bfc4-spec-val">{{ spec_focus }}</span></div>
        {%- endif -%}
        {%- if spec_flash != blank -%}
          <div class="bfc4-mini-spec"><span class="bfc4-spec-key">Flash</span><span class="bfc4-spec-val">{{ spec_flash }}</span></div>
        {%- endif -%}
        {%- if spec_shutter != blank -%}
          <div class="bfc4-mini-spec"><span class="bfc4-spec-key">Shutter</span><span class="bfc4-spec-val">{{ spec_shutter }}</span></div>
        {%- endif -%}
        {%- if spec_battery != blank -%}
          <div class="bfc4-mini-spec"><span class="bfc4-spec-key">Battery</span><span class="bfc4-spec-val">{{ spec_battery }}</span></div>
        {%- endif -%}
        <div class="bfc4-mini-spec"><span class="bfc4-spec-key">Condition</span><span class="bfc4-spec-val">A Grade</span></div>
      {%- endunless -%}
    </div>

    {%- comment -%} 6b. Extended Warranty {%- endcomment -%}
    {%- liquid
      assign cam_price = current_variant.price
      if cam_price <= 50000
        assign w6_vid = '46108352151724'
        assign w6_price = 1500
        assign w9_vid = '46108352184492'
        assign w9_price = 3000
        assign w12_vid = '46108352217260'
        assign w12_price = 4500
      elsif cam_price <= 100000
        assign w6_vid = '46108381872300'
        assign w6_price = 2000
        assign w9_vid = '46108381970604'
        assign w9_price = 4000
        assign w12_vid = '46108382068908'
        assign w12_price = 8000
      else
        assign w6_vid = '46108381905068'
        assign w6_price = 4000
        assign w9_vid = '46108382003372'
        assign w9_price = 6000
        assign w12_vid = '46108382101676'
        assign w12_price = 12000
      endif
    -%}
    <div class="bfc4-ext-warranty">
      <div class="bfc4-ext-w-head">
        <span class="bfc4-ext-w-eyebrow">Extended Warranty</span>
        <button class="bfc4-tile-info" onclick="baOpenPopup('bfc4-ext-w-popup')" aria-label="Extended warranty details" style="position:relative;bottom:auto;right:auto;flex-shrink:0;">
          <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg>
        </button>
      </div>
      <div class="bfc4-ext-w-baseline">
        <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>Your camera includes a <strong>3-month warranty</strong> — extend your total coverage below:</span>
      </div>
      <div class="bfc4-ext-w-options">
        <button class="bfc4-ext-w-btn" data-months="3" data-total="6" data-price="{{ w6_price }}" data-variant-id="{{ w6_vid }}" onclick="bfc4SelectWarranty(this)">
          <span class="bfc4-ext-w-extend">+3 months</span>
          <span class="bfc4-ext-w-months">6 mo total</span>
          <span class="bfc4-ext-w-price">+{{ w6_price | money_without_trailing_zeros }}</span>
          <span class="bfc4-ext-w-acc">+ Accidental</span>
        </button>
        <button class="bfc4-ext-w-btn" data-months="6" data-total="9" data-price="{{ w9_price }}" data-variant-id="{{ w9_vid }}" onclick="bfc4SelectWarranty(this)">
          <span class="bfc4-ext-w-extend">+6 months</span>
          <span class="bfc4-ext-w-months">9 mo total</span>
          <span class="bfc4-ext-w-price">+{{ w9_price | money_without_trailing_zeros }}</span>
          <span class="bfc4-ext-w-acc">+ Accidental</span>
        </button>
        <button class="bfc4-ext-w-btn" data-months="9" data-total="12" data-price="{{ w12_price }}" data-variant-id="{{ w12_vid }}" onclick="bfc4SelectWarranty(this)">
          <span class="bfc4-ext-w-extend">+9 months</span>
          <span class="bfc4-ext-w-months">1 year total</span>
          <span class="bfc4-ext-w-price">+{{ w12_price | money_without_trailing_zeros }}</span>
          <span class="bfc4-ext-w-acc">+ Accidental</span>
        </button>
      </div>
      <button class="bfc4-ext-w-none" id="bfc4-ext-w-clear" onclick="bfc4ClearWarranty()">&times; Remove Extended Warranty</button>
    </div>
        <div id="ba-popup-data-bfc4-ext-w-popup" style="display:none"
      data-title="Extended Warranty"
      data-desc="Your camera includes a 3-month warranty. Extended warranty adds months on top — select +3 months for 6 months total, +6 for 9 months, or +9 for a full year, all from your purchase date. Extended warranty covers any issues including accidental damage, which the standard warranty does not cover. Approved claims are repaired at no cost. If the camera cannot be repaired, you will receive a BFC gift card at the value you paid, redeemable on any camera in our shop. Warranties are non-transferable and apply to the original purchaser only. Must be purchased within 30 days of your camera purchase."
      data-imgs=""
    ></div>

    {%- comment -%} 7. Quick nav buttons {%- endcomment -%}
    <div class="bfc4-nav-btns">
      <button class="bfc4-customize" onclick="document.getElementById('bfc4-custom').scrollIntoView({behavior:'smooth'})">
        Expand your kit
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M6 2v8M2 6l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/></svg>
      </button>
      <button class="bfc4-customize" onclick="document.getElementById('bfc4-photos').scrollIntoView({behavior:'smooth'})">
        Photos &amp; specs
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M6 2v8M2 6l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/></svg>
      </button>
      <button class="bfc4-customize" onclick="document.getElementById('bfc4-policy-section').scrollIntoView({behavior:'smooth'})">
        Warranty &amp; returns
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M6 2v8M2 6l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/></svg>
      </button>
    </div>

  </div>{%- comment -%} /bfc4-right {%- endcomment -%}
</div>{%- comment -%} /bfc4-split {%- endcomment -%}

{%- comment -%} ── BELOW FOLD ── {%- endcomment -%}
<div class="bfc4-below">
  {%- comment -%} Shot on {%- endcomment -%}
  {%- if g1 or g2 or g3 -%}
  <div class="ba-shot" id="bfc4-photos">
    <div class="ba-shot-head">
      <h2 class="ba-shot-title">Shot on {{ product.title }}</h2>
      <span class="ba-shot-sub">All Photos Taken on {{ product.title }}</span>
    </div>
    <div class="ba-shot-grid">
      {%- if g1 -%}<a href="{{ g1 | image_url: width: 1200 }}" target="_blank" aria-label="View full size photo 1 shot on {{ product.title | escape }}"><img src="{{ g1 | image_url: width: 600 }}" alt="Photo shot on {{ product.title | escape }}, image 1" loading="lazy"/></a>{%- endif -%}
      {%- if g2 -%}<a href="{{ g2 | image_url: width: 1200 }}" target="_blank" aria-label="View full size photo 2 shot on {{ product.title | escape }}"><img src="{{ g2 | image_url: width: 600 }}" alt="Photo shot on {{ product.title | escape }}, image 2" loading="lazy"/></a>{%- endif -%}
      {%- if g3 -%}<a href="{{ g3 | image_url: width: 1200 }}" target="_blank" aria-label="View full size photo 3 shot on {{ product.title | escape }}"><img src="{{ g3 | image_url: width: 600 }}" alt="Photo shot on {{ product.title | escape }}, image 3" loading="lazy"/></a>{%- endif -%}
      {%- if g4 -%}<a href="{{ g4 | image_url: width: 1200 }}" target="_blank" aria-label="View full size photo 4 shot on {{ product.title | escape }}"><img src="{{ g4 | image_url: width: 600 }}" alt="Photo shot on {{ product.title | escape }}, image 4" loading="lazy"/></a>{%- endif -%}
      {%- if g5 -%}<a href="{{ g5 | image_url: width: 1200 }}" target="_blank" aria-label="View full size photo 5 shot on {{ product.title | escape }}"><img src="{{ g5 | image_url: width: 600 }}" alt="Photo shot on {{ product.title | escape }}, image 5" loading="lazy"/></a>{%- endif -%}
      {%- if g6 -%}<a href="{{ g6 | image_url: width: 1200 }}" target="_blank" aria-label="View full size photo 6 shot on {{ product.title | escape }}"><img src="{{ g6 | image_url: width: 600 }}" alt="Photo shot on {{ product.title | escape }}, image 6" loading="lazy"/></a>{%- endif -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} Restoration {%- endcomment -%}
  <div class="ba-restore" id="ba-restore">
    <div class="ba-restore-top">
      <div class="ba-restore-headline">
        <span class="ba-restore-ey">Our Process</span>
        <h2 class="ba-restore-title">Every camera<br/><em>hand-restored</em></h2>
      </div>
      <div class="ba-restore-stats">
        <div class="ba-r-stat"><div class="ba-r-stat-num">3<span>mo</span></div><div class="ba-r-stat-label">Warranty on every camera sold</div></div>
        <div class="ba-r-stat"><div class="ba-r-stat-num">25K<span>+</span></div><div class="ba-r-stat-label">Cameras restored since 2018</div></div>
        <div class="ba-r-stat"><div class="ba-r-stat-num">4.9<span>★</span></div><div class="ba-r-stat-label">Average customer rating</div></div>
      </div>
    </div>
    <div class="ba-restore-steps">
      <div class="ba-r-step"><span class="ba-r-num">01</span><div class="ba-r-title">Full Inspection</div><div class="ba-r-desc">Mechanical and electrical functions tested — shutter, flash, metering, film advance</div></div>
      <div class="ba-r-step"><span class="ba-r-num">02</span><div class="ba-r-title">Light Seal Replacement</div><div class="ba-r-desc">Fresh seals on every camera, no exceptions</div></div>
      <div class="ba-r-step"><span class="ba-r-num">03</span><div class="ba-r-title">Detail Clean</div><div class="ba-r-desc">Lens, viewfinder, and body cleaned inside and out</div></div>
      <div class="ba-r-step"><span class="ba-r-num">04</span><div class="ba-r-title">Final QC</div><div class="ba-r-desc">Tested with professional equipment before it ships</div></div>
    </div>
  </div>

  {%- comment -%} Full specs {%- endcomment -%}
  <div class="ba-specs">
    <div class="ba-specs-head">
      <h2 class="ba-specs-title">Specs</h2>
      <div class="ba-specs-note">{{ product.title }}<br/>{{ product.type }}</div>
    </div>
    <div class="ba-specs-body">
      <div class="ba-specs-table">
        {%- if spec_mount   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Lens Mount</span><span class="ba-spec-val">{{ spec_mount }}</span></div>{%- endif -%}
        {%- if spec_shutter != blank -%}<div class="ba-spec"><span class="ba-spec-key">Shutter</span><span class="ba-spec-val">{{ spec_shutter }}</span></div>{%- endif -%}
        {%- if spec_lens    != blank -%}<div class="ba-spec"><span class="ba-spec-key">Lens</span><span class="ba-spec-val">{{ spec_lens }}</span></div>{%- endif -%}
        {%- if spec_meter   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Metering</span><span class="ba-spec-val">{{ spec_meter }}</span></div>{%- endif -%}
        {%- if spec_battery != blank -%}<div class="ba-spec"><span class="ba-spec-key">Battery</span><span class="ba-spec-val">{{ spec_battery }}</span></div>{%- endif -%}
        {%- if spec_flash   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Flash</span><span class="ba-spec-val">{{ spec_flash }}</span></div>{%- endif -%}
        {%- if spec_focus   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Focus</span><span class="ba-spec-val">{{ spec_focus }}</span></div>{%- endif -%}
        {%- if spec_timer   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Self Timer</span><span class="ba-spec-val">{{ spec_timer }}</span></div>{%- endif -%}
        {%- if spec_tripod  != blank -%}<div class="ba-spec"><span class="ba-spec-key">Tripod</span><span class="ba-spec-val">{{ spec_tripod }}</span></div>{%- endif -%}
        {%- if spec_expcomp != blank -%}<div class="ba-spec"><span class="ba-spec-key">Exp. Comp.</span><span class="ba-spec-val">{{ spec_expcomp }}</span></div>{%- endif -%}
        {%- if spec_dx      != blank -%}<div class="ba-spec"><span class="ba-spec-key">DX Reader</span><span class="ba-spec-val">{{ spec_dx }}</span></div>{%- endif -%}
        <div class="ba-spec"><span class="ba-spec-key">Condition</span><span class="ba-spec-val">A Grade</span></div>
        <div class="ba-spec"><span class="ba-spec-key">Warranty</span><span class="ba-spec-val">{{ warranty_base }} months</span></div>
      </div>
    </div>
  </div>

  {%- comment -%} Custom kit section {%- endcomment -%}
  <section class="bfc4-custom" id="bfc4-custom" aria-label="Build your own kit">
    <div class="bfc4-custom-head">
      <span class="bfc4-custom-eyebrow">Build Your Own</span>
      <h2 class="bfc4-custom-title">Mix &amp; match.</h2>

    </div>

    {%- comment -%} Collect columns {%- endcomment -%}
    {%- assign col_names = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'kit_item' and block.settings.product != blank -%}
        {%- if block.settings.only_show_for == blank or block.settings.only_show_for.handle == product.handle -%}
        {%- assign col = block.settings.column | default: block.settings.label -%}
        {%- unless col_names contains col -%}
          {%- if col_names == '' -%}{%- assign col_names = col -%}
          {%- else -%}{%- assign col_names = col_names | append: '||' | append: col -%}
          {%- endif -%}
        {%- endunless -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign col_name_arr = col_names | split: '||' -%}

    <div class="ba-columns" role="list">
      {%- for col_name in col_name_arr -%}
        <div class="ba-col" id="bfc4-col-{{ forloop.index }}" data-col-name="{{ col_name | escape }}">
          <div class="ba-col-head" onclick="baToggleCol(this.closest('.ba-col'))">
            <div class="ba-col-title">
              {{ col_name }}
              <span class="ba-col-count" id="ba-col-count-{{ forloop.index }}">0</span>
            </div>
            <svg class="ba-col-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
          </div>
          <div class="ba-col-body">
          {%- assign col_item_index = 0 -%}
          {%- assign col_item_total = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'kit_item' and block.settings.product != blank -%}
              {%- if block.settings.only_show_for == blank or block.settings.only_show_for.handle == product.handle -%}
              {%- assign block_col = block.settings.column | default: block.settings.label -%}
              {%- if block_col == col_name -%}{%- assign col_item_total = col_item_total | plus: 1 -%}{%- endif -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- for block in section.blocks -%}
            {%- if block.type != 'kit_item' -%}{% continue %}{%- endif -%}
            {%- assign bp = block.settings.product -%}
            {%- if bp == blank -%}{% continue %}{%- endif -%}
            {%- if block.settings.only_show_for != blank and block.settings.only_show_for.handle != product.handle -%}{% continue %}{%- endif -%}
            {%- assign block_col = block.settings.column | default: block.settings.label -%}
            {%- unless block_col == col_name -%}{% continue %}{%- endunless -%}
            {%- assign col_item_index = col_item_index | plus: 1 -%}

            {%- liquid
              assign is_dev       = block.settings.is_developing
              assign disc         = block.settings.discount_percent
              assign specific_vid = block.settings.variant_id | strip
              assign cat_id       = 'ba-cat-' | append: forloop.index
              assign show_variants = false
              if bp.variants.size > 1 and specific_vid == blank
                assign show_variants = true
              endif
              assign display_variant = bp.variants.first
            -%}
            {%- unless specific_vid == blank -%}
              {%- for v in bp.variants -%}
                {%- assign vid_str = v.id | append: '' -%}
                {%- if vid_str == specific_vid -%}{%- assign display_variant = v -%}{%- endif -%}
              {%- endfor -%}
            {%- endunless -%}
            {%- liquid
              assign orig_cents = display_variant.price
              if is_dev
                assign sale_cents = 0
              elsif disc > 0
                assign disc_float = disc | times: 1.0 | divided_by: 100
                assign save_cents = orig_cents | times: disc_float | floor
                assign sale_cents = orig_cents | minus: save_cents
              else
                assign sale_cents = orig_cents
              endif
            -%}
            {%- assign popup_imgs = '' -%}
            {%- for media in bp.media limit: 6 -%}
              {%- if media.media_type == 'image' -%}
                {%- assign img_url = media | image_url: width: 600 -%}
                {%- if popup_imgs == '' -%}{%- assign popup_imgs = img_url -%}
                {%- else -%}{%- assign popup_imgs = popup_imgs | append: '||' | append: img_url -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            <div
              class="ba-mini-card{% if col_item_index > 2 %} is-hidden{% endif %}{% unless display_variant.available %} is-oos{% endunless %}"
              id="{{ cat_id }}"
              data-variant-id="{{ display_variant.id }}"
              data-product-title="{{ bp.title | escape }}"
              data-orig="{{ orig_cents }}"
              data-sale="{{ orig_cents }}"
              data-is-dev="{{ is_dev }}"
              data-disc="{{ disc }}"
              data-cat="{{ cat_id }}"
              data-col-id="bfc4-col-{{ forloop.parentloop.index }}"
              data-col-name="{{ col_name | escape }}"
              data-starter="{{ block.settings.is_starter_kit }}"
              {% if display_variant.available %}onclick="baMiniSelect(this, event)"{% endif %}
              {{ block.shopify_attributes }}
            >
              <div class="ba-mini-img-wrap">
                {%- if bp.featured_image -%}
                  <img class="ba-mini-img" src="{{ bp.featured_image | image_url: width: 400 }}" alt="" role="presentation" loading="lazy"/>
                {%- else -%}
                  <div class="ba-mini-img-ph"></div>
                {%- endif -%}
                {%- unless display_variant.available -%}<span class="ba-mini-oos">Out of Stock</span>{%- endunless -%}
                <button
                  class="ba-mini-info-icon"
                  onclick="event.stopPropagation(); baOpenPopup('{{ cat_id }}')"
                  aria-label="View details"
                ><svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg></button>
              </div>
              <div class="ba-mini-body">
                <div class="ba-mini-info">
                  <div class="ba-mini-name">{{ block.settings.custom_label | default: bp.title }}</div>
                </div>
                <div class="ba-mini-right">
                  {%- unless is_dev -%}<span class="ba-mini-price">{{ orig_cents | money }}</span>{%- endunless -%}
                </div>
              </div>
              {%- if show_variants -%}
                <div class="ba-mini-vars" onclick="event.stopPropagation()">
                  {%- for variant in bp.variants -%}
                    {%- if variant.available -%}
                      {%- liquid
                        assign v_orig = variant.price
                        if is_dev
                          assign v_sale = 0
                        elsif disc > 0
                          assign v_df = disc | times: 1.0 | divided_by: 100
                          assign v_sv = v_orig | times: v_df | floor
                          assign v_sale = v_orig | minus: v_sv
                        else
                          assign v_sale = v_orig
                        endif
                      -%}
                      <button
                        class="ba-mini-var-btn{% if forloop.first %} is-sel{% endif %}"
                        data-variant-id="{{ variant.id }}"
                        data-product-title="{{ bp.title | escape }}"
                        data-orig="{{ variant.price }}"
                        data-sale="{{ variant.price }}"
                        data-is-dev="{{ is_dev }}"
                        data-disc="{{ disc }}"
                        data-cat="{{ cat_id }}"
                        onclick="baMiniSelectVar(this)"
                      >{{ variant.title }} – {%- if is_dev -%}Free{%- else -%}{{ v_sale | money }}{%- endif -%}</button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
            <div id="ba-popup-data-{{ cat_id }}" style="display:none"
              data-title="{{ bp.title | escape }}"
              data-desc="{{ bp.description | strip_html | escape }}"
              data-imgs="{{ popup_imgs | escape }}"
            ></div>
