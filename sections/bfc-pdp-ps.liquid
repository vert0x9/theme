function baUpdateColCounts() {
var counts = {};
Object.values(STATE.kit).forEach(function(sel) {
if (sel.colId) counts[sel.colId] = (counts[sel.colId] || 0) + 1;
});
document.querySelectorAll('.ba-col-count').forEach(function(el) {
var colEl = el.closest('.ba-col');
if (!colEl) return;
var n = counts[colEl.id] || 0;
el.textContent = n;
el.classList.toggle('is-visible', n > 0);
});
}
window.baRemoveItem = function(catId) {
var card = document.getElementById(catId);
if (card) card.classList.remove('is-sel');
delete STATE.kit[catId];
baUpdateColCounts();
bfc4Render();
};
window.baClearAll = function() {
document.querySelectorAll('.ba-mini-card.is-sel').forEach(function(card) {
baMiniSelect(card, { stopPropagation: function(){} });
});
};
window.baOpenPopup = function(catId) {
var data = document.getElementById('ba-popup-data-' + catId);
if (!data) return;
document.getElementById('ba-popup-title').textContent = data.dataset.title;
var desc = data.dataset.desc;
document.getElementById('ba-popup-desc').innerHTML = desc ? '<p>' + desc.replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br/>') + '</p>' : '';
var imgs = data.dataset.imgs ? data.dataset.imgs.split('||') : [];
document.getElementById('ba-popup-imgs').innerHTML = imgs.map(function(src) { return '<img src="' + src + '" alt="" role="presentation" loading="lazy"/>'; }).join('');
document.getElementById('ba-popup-overlay').classList.add('is-open');
document.body.style.overflow = 'hidden';
};
window.baClosePopup = function() {
document.getElementById('ba-popup-overlay').classList.remove('is-open');
document.body.style.overflow = '';
};
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') baClosePopup(); });
var bfc4Slide_current = 0;
var bfc4Slide_total   = document.querySelectorAll('.bfc4-slide').length;
window.bfc4Slide = function(dir) {
bfc4GoTo((bfc4Slide_current + dir + bfc4Slide_total) % bfc4Slide_total);
};
window.bfc4GoTo = function(idx) {
bfc4Slide_current = idx;
var slides = document.getElementById('bfc4-slides');
if (slides) slides.style.transform = 'translateX(-' + (idx * 100) + '%)';
document.querySelectorAll('.bfc4-dot').forEach(function(d, i) { d.classList.toggle('is-active', i === idx); });
var prev = document.querySelector('.bfc4-arrow.is-prev');
if (prev) prev.style.visibility = idx === 0 ? 'hidden' : 'visible';
};
(function() {
var left = document.querySelector('.bfc4-left');
if (!left || bfc4Slide_total <= 1) return;
var startX = 0;
left.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
left.addEventListener('touchend', function(e) {
var dx = e.changedTouches[0].clientX - startX;
if (Math.abs(dx) > 40) bfc4Slide(dx < 0 ? 1 : -1);
});
})();
function fmt(cents) { return '$' + (cents / 100).toFixed(2).replace(/\.00$/, ''); }
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
if (window.innerWidth <= 900) {
document.querySelectorAll('.ba-col').forEach(function(c) { c.classList.remove('is-open'); });
}
document.querySelectorAll('.bfc4-tile.is-sel:not(.is-cam)').forEach(function(tile) {
var tileId = tile.dataset.tileId || ('sk-' + Math.random().toString(36).slice(2));
tile.dataset.stateKey = tileId;
var col = (tile.dataset.col || '').toLowerCase();
var pt = (tile.dataset.productTitle || '').toLowerCase();
var isFilm = tile.dataset.isDev !== 'true' && (col.indexOf('film') >= 0 || pt.indexOf('film') >= 0 || /\b(portra|tri-x|gold|ultramax|hp5|fp4|delta|t-max|tmax|color|b&w|cinestill|ektar|lomo|lucky|fomapan|kentmere|rollei|jch|dubblefilm|fuji)\b/i.test(pt));
STATE.kit[tileId] = {
variantId: tile.dataset.variantId,
name:      tile.dataset.productTitle || '',
orig:      parseInt(tile.dataset.orig || '0', 10),
sale:      parseInt(tile.dataset.sale || '0', 10),
isDev:     tile.dataset.isDev === 'true',
disc:      parseInt(tile.dataset.disc || '0', 10),
isFilm:    isFilm,
colId:     tileId,
img:       tile.dataset.img || null
};
});
syncAccordionLocks();
bfc4UpdateWarrantyTier(STATE.variantPrice);
bfc4Render();

// ── Sticky ATC Bar (desktop + mobile) ──────────────────
// Scroll-based detection — more reliable than IO across themes.
// Hides automatically when:
//   • the real ATC button is in viewport (no point doubling up the CTA)
//   • a cart drawer / overlay / modal is open (don't block checkout)
//   • scrolled into the theme footer (BFC content is over)
var stickyBar = document.getElementById('bfc4-sticky-bar-outside');
var mainAtc   = document.getElementById('bfc4-atc');
if (stickyBar && mainAtc) {
  // Locate the theme footer once. Cached so we don't re-query on every scroll.
  // Falls back to null if no footer found (footer-visible check just won't trigger).
  var pageFooter = (function() {
    var candidates = document.querySelectorAll('footer, .footer, [role="contentinfo"], .site-footer, .footer-wrapper');
    for (var i = 0; i < candidates.length; i++) {
      if (!candidates[i].closest('.bfc4')) return candidates[i];
    }
    return null;
  })();

  function bfc4UpdateStickyBar() {
    // Cart drawer / overlay open? Hide so checkout button isn't blocked.
    var bodyClasses = document.body.className || '';
    if (/\b(cart-drawer-open|drawer-open|is-cart-open|drawer--open|overlay-open|modal-open|js-drawer-open|cart-open)\b/.test(bodyClasses)) {
      stickyBar.classList.remove('is-visible');
      return;
    }
    var openDrawer = document.querySelector('cart-drawer[open], cart-notification[open], .cart-drawer.is-open, .cart-drawer.active, .drawer.is-active, .drawer.is-open');
    if (openDrawer) {
      stickyBar.classList.remove('is-visible');
      return;
    }
    var vh = window.innerHeight;
    // Hide if ANY ATC button is in viewport — sticky CTA only useful when real one isn't.
    var atcButtons = document.querySelectorAll('.bfc4-atc');
    for (var i = 0; i < atcButtons.length; i++) {
      var rect = atcButtons[i].getBoundingClientRect();
      if (rect.bottom > 0 && rect.top < vh) {
        stickyBar.classList.remove('is-visible');
        return;
      }
    }
    // Hide once user reaches the theme footer — pinning a CTA over copyright/links is intrusive.
    if (pageFooter) {
      var fRect = pageFooter.getBoundingClientRect();
      if (fRect.top < vh) {
        stickyBar.classList.remove('is-visible');
        return;
      }
    }
    // Default: show. User is mid-page with no ATC visible and not yet in footer.
    stickyBar.classList.add('is-visible');
  }
  window.addEventListener('scroll', bfc4UpdateStickyBar, { passive: true });
  window.addEventListener('resize', bfc4UpdateStickyBar);
  // Listen for body class mutations (cart drawer open/close usually toggles a body class)
  if ('MutationObserver' in window) {
    new MutationObserver(bfc4UpdateStickyBar).observe(document.body, { attributes: true, attributeFilter: ['class', 'style'] });
  }
  bfc4UpdateStickyBar();
}
})();
</script>

