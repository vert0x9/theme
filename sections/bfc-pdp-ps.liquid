  // ── Also in collection slider ─────────────────────────────────────────
  (function() {
    var track = document.getElementById('bfc4-also-track');
    if (!track) return;
    var prevBtn = document.querySelector('.bfc4-also-arr.is-prev');
    var nextBtn = document.querySelector('.bfc4-also-arr.is-next');
    function updateArrows() {
      if (prevBtn) prevBtn.disabled = track.scrollLeft <= 4;
      if (nextBtn) nextBtn.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 4;
    }
    window.bfc4AlsoSlide = function(dir) {
