/* ── Sticky ATC Bar (desktop + mobile) ──────────────────
   Lives OUTSIDE the .bfc4 wrapper to escape its overflow-x:hidden clipping,
   so brand vars are re-declared locally. z-index is intentionally low (30)
   so the theme's cart drawer/overlay layers above when it opens. */
.bfc4-sticky-bar {
  --or: #E36E15;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sn: 'Poppins', sans-serif;
  display: none; position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--cv); border-top: 1px solid rgba(32,32,9,0.15);
  padding: 10px 16px;
  z-index: 30;
  align-items: center; gap: 12px; box-shadow: 0 -2px 12px rgba(0,0,0,0.08);
  font-family: var(--sn);
  box-sizing: border-box;
}
.bfc4-sticky-bar * { box-sizing: border-box; }
.bfc4-sticky-info { flex: 1; min-width: 0; }
.bfc4-sticky-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--bk); margin: 0; }
.bfc4-sticky-meta { display: flex; align-items: center; gap: 6px; margin-top: 1px; }
.bfc4-sticky-grade { font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ch); }
.bfc4-sticky-price { font-size: 13px; font-weight: 700; color: var(--or); }
.bfc4-sticky-btn { background: var(--or); color: #fff; border: none; padding: 12px 24px; font-size: 10px; font-weight: 700; font-family: var(--sn); text-transform: uppercase; letter-spacing: 0.14em; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
.bfc4-sticky-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.bfc4-sticky-btn.is-success { background: #2a4820 !important; color: #fff !important; }
.bfc4-sticky-btn.is-success #bfc4-sticky-btn-text-2,
.bfc4-sticky-btn.is-success * { color: #fff !important; }
.bfc4-sticky-bar.is-visible { display: flex; }
@media (max-width: 600px) {
  /* Tighten on small phones so name + meta + button all fit a 360px viewport */
  .bfc4-sticky-bar { padding: 8px 12px; gap: 10px; }
  .bfc4-sticky-info { min-width: 0; overflow: hidden; }
  .bfc4-sticky-name { font-size: 11px; }
  .bfc4-sticky-meta { gap: 5px; min-width: 0; flex-wrap: nowrap; overflow: hidden; }
  .bfc4-sticky-grade { font-size: 8.5px; white-space: nowrap; }
  .bfc4-sticky-price { font-size: 12px; white-space: nowrap; }
  .bfc4-sticky-btn { padding: 10px 14px; font-size: 9.5px; letter-spacing: 0.1em; }
}

