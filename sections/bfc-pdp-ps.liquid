var isFilm = card.dataset.isDev !== 'true' && (colName.indexOf('film') >= 0 || prodTitle.indexOf('film') >= 0 || /\b(portra|tri-x|gold|ultramax|hp5|fp4|delta|t-max|tmax|color|b&w|cinestill|ektar|lomo|lucky|fomapan|kentmere|rollei|jch|dubblefilm|fuji)\b/i.test(prodTitle));
