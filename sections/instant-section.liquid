  <!-- BFC effects: reveal on scroll + press states -->


<script>
(() => {
  const INSTANT_ID  = "SqIOW1Lc6RenVHAD";
  const SECTION_SEL = `.__instant[data-instant-id="${INSTANT_ID}"]`;
  const GRID_SEL    = "#in3HcKOoPwUrGLtoE";
  const MQ          = window.matchMedia("(max-width: 768px)");

  /* ── Helpers ─────────────────────────────────────────── */

  function getSection() {
    return document.querySelector(SECTION_SEL);
  }

  function getSteps(section) {
    const grid = section.querySelector(GRID_SEL);
    if (!grid) return [];
    return Array.from(grid.querySelectorAll(":scope > div[data-instant-type='container']"));
  }

  /* ── Scroll-reveal + press effects ───────────────────── */

  function applyEffects(section) {
    const root = section.querySelector('[data-instant-type="root"]');
    if (!root) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Press effects
    root.querySelectorAll('a[data-instant-type="container"], button[data-instant-type="accordion-header"]')
      .forEach(el => el.classList.add("bfc-press"));

    // Reveal targets
    const revealEls = new Set();
    [...root.children].forEach(el => revealEls.add(el));
    root.querySelectorAll(
      '[data-instant-type="container"][id], [data-instant-type="grid"], [data-instant-type="grid-fixed"], [data-instant-type="image"], [data-instant-type="accordion-container"]'
    ).forEach(el => revealEls.add(el));

    [...revealEls].forEach((el, idx) => {
      el.classList.add("bfc-reveal");
      el.style.setProperty("--bfc-delay", `${Math.min(idx * 60, 300)}ms`);
      if (reduce) el.classList.add("bfc-inview");
    });

    if (!reduce && !root.__bfcObserver) {
      const io = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add("bfc-inview");
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: "0px 0px -10% 0px" });

      [...revealEls].forEach(el => io.observe(el));
      root.__bfcObserver = io;

      requestAnimationFrame(() => {
        [...revealEls].forEach(el => {
          if (el.getBoundingClientRect().top < window.innerHeight * 0.9)
            el.classList.add("bfc-inview");
        });
      });
    }

    // Step cards fade-in on load
    getSteps(section).forEach((el, idx) => {
      if (el.dataset.bfcFadeInit === "1") return;
      el.dataset.bfcFadeInit = "1";
      el.classList.add("bfc-fade-item");
      requestAnimationFrame(() => {
        setTimeout(() => el.classList.add("is-visible"), idx * 120);
      });
    });
  }

  /* ── Mobile accordion: enable ────────────────────────── */

  function enableAccordion(section) {
    getSteps(section).forEach(stepEl => {
      // Already set up — skip
      if (stepEl.dataset.bfcAccordion === "1") return;

      const richTexts = stepEl.querySelectorAll(".instant-rich-text");
      if (richTexts.length < 2) return;

      const titleEl = richTexts[0];
      const bodyEl  = richTexts[1];

      stepEl.classList.add("bfc-step");

      // Inject toggle button into title (once only)
    // The inner div is where the actual text lives
      const titleInner = titleEl.querySelector("div") || titleEl;

      // Inject toggle button into the inner div (once only)
      if (!titleEl.querySelector(".bfc-step-toggle")) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "bfc-step-toggle";
        btn.setAttribute("aria-label", "Toggle step");
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
          <path d="M224,128a8,8,0,0,1-8,8H136v80a8,8,0,0,1-16,0V136H40a8,8,0,0,1,0-16h80V40a8,8,0,0,1,16,0v80h80A8,8,0,0,1,224,128Z"/>
        </svg>`;
        titleInner.appendChild(btn);
      }

      titleInner.classList.add("bfc-step-header");
      bodyEl.classList.add("bfc-step-body");

      titleEl.classList.add("bfc-step-header");
      bodyEl.classList.add("bfc-step-body");

      // Start collapsed
      bodyEl.style.maxHeight = "0px";
      bodyEl.style.opacity   = "0";

      const toggle = (evt) => {
        if (evt.target.closest && evt.target.closest("a")) return;

        // Close all siblings first
        getSteps(section).forEach(s => {
          if (s !== stepEl && s.classList.contains("is-open")) {
            s.classList.remove("is-open");
            const b = s.querySelector(".bfc-step-body");
            if (b) { b.style.maxHeight = "0px"; b.style.opacity = "0"; }
          }
        });

        const opening = !stepEl.classList.contains("is-open");
        stepEl.classList.toggle("is-open", opening);

        if (opening) {
          bodyEl.style.maxHeight = bodyEl.scrollHeight + "px";
          bodyEl.style.opacity   = "1";
          setTimeout(() => { bodyEl.style.maxHeight = bodyEl.scrollHeight + "px"; }, 80);
        } else {
          bodyEl.style.maxHeight = "0px";
          bodyEl.style.opacity   = "0";
        }
      };

      const keydown = (evt) => {
        if (evt.key === "Enter" || evt.key === " ") { evt.preventDefault(); toggle(evt); }
      };

      titleEl.setAttribute("role", "button");
      titleEl.setAttribute("tabindex", "0");
      titleEl.addEventListener("click", toggle);
      titleEl.addEventListener("keydown", keydown);

      // Store refs for clean teardown
      stepEl.__bfcTitleEl   = titleEl;
      stepEl.__bfcBodyEl    = bodyEl;
      stepEl.__bfcToggle    = toggle;
      stepEl.__bfcKeydown   = keydown;
      stepEl.dataset.bfcAccordion = "1";
    });
  }

  /* ── Mobile accordion: disable (on resize to desktop) ── */

  function disableAccordion(section) {
    getSteps(section).forEach(stepEl => {
      if (stepEl.dataset.bfcAccordion !== "1") return;

      const titleEl = stepEl.__bfcTitleEl;
      const bodyEl  = stepEl.__bfcBodyEl;

      stepEl.classList.remove("bfc-step", "is-open");

      if (titleEl) {
const titleInner = titleEl.querySelector("div") || titleEl;
      titleInner.classList.remove("bfc-step-header");        titleEl.removeAttribute("role");
        titleEl.removeAttribute("tabindex");
        titleEl.removeEventListener("click",   stepEl.__bfcToggle);
        titleEl.removeEventListener("keydown", stepEl.__bfcKeydown);
        // Remove the injected toggle button
const btn = titleInner.querySelector(".bfc-step-toggle");        if (btn) btn.remove();
      }

      if (bodyEl) {
        bodyEl.classList.remove("bfc-step-body");
        bodyEl.style.maxHeight = "";
        bodyEl.style.opacity   = "";
        bodyEl.style.overflow  = "";
      }

      delete stepEl.__bfcTitleEl;
      delete stepEl.__bfcBodyEl;
      delete stepEl.__bfcToggle;
      delete stepEl.__bfcKeydown;
      stepEl.dataset.bfcAccordion = "0";
    });
  }

  /* ── Main run ─────────────────────────────────────────── */

  function run() {
    const section = getSection();
    if (!section) return;

    applyEffects(section);

    if (MQ.matches) enableAccordion(section);
    else            disableAccordion(section);
  }

  /* ── Boot ─────────────────────────────────────────────── */

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", run);
  } else {
    run();
  }

  // Re-run on breakpoint change (desktop ↔ mobile resize)
  if (MQ.addEventListener) MQ.addEventListener("change", run);
  else MQ.addListener(run);

  // Re-run after Instant hydration delays
  setTimeout(run, 500);
  setTimeout(run, 1500);

})();

  </script>

