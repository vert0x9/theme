<script>
  (function () {
    var items = document.querySelectorAll('.bfc-ws__faq-item');
    items.forEach(function (item) {
      var btn = item.querySelector('.bfc-ws__faq-q');
      btn.addEventListener('click', function () {
        var isOpen = item.classList.contains('is-open');
        items.forEach(function (i) {
          i.classList.remove('is-open');
          i.querySelector('.bfc-ws__faq-q').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    var ctaLink = document.querySelector('.bfc-ws__btn--light[href="#bfc-ws-inquiry"]');
    if (ctaLink) {
      ctaLink.addEventListener('click', function (e) {
        e.preventDefault();
        var target = document.getElementById('bfc-ws-inquiry');
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  })();
</script>
