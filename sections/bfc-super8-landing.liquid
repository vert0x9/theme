{%- comment -%}
  BFC Super 8 Landing Page
  File: sections/bfc-super8-landing.liquid

  Full landing page for the Super 8 category. Drop onto a page with
  sections enabled (create page "Super 8" and assign a sections-capable
  page template, then add this section).

  Page flow:
    1. Intro header + collection grid
    2. Video feature block
    3. Restoration-focused section (blocks = process steps)
    4. Film pairing with quick-add (collection picker)
    5. Gallery — shot on Super 8 (blocks = gallery photos)
    6. FAQ — good to know (blocks = Q&A items)
    7. Closing (editorial image closer)

  Brand tokens assumed:
    --or #E36E15  --go #F4A027  --ce #ABCC99  --cv #F8F6EE
    --bk #202009  --ch #4E4741  --gr #E3DDDA
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign sid = section.id
  assign grid_collection = collections[s.collection]
  assign product_limit = s.product_limit | default: 12
-%}

<style>
  /* ============ Root ============ */
  .bfc-s8-{{ sid }} {
    --bfc-serif: 'Cormorant Garamond', Georgia, serif;
    --bfc-sans: 'Poppins', system-ui, sans-serif;
    font-family: var(--bfc-sans);
    color: #202009;
    background-color: #F8F6EE;
  }
  .bfc-s8-{{ sid }} * { box-sizing: border-box; }
  .bfc-s8-{{ sid }} .bfc-s8__wrap {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ============ Intro ============ */
  .bfc-s8-{{ sid }} .bfc-s8__intro {
    padding: 40px 0 0;
    text-align: center;
  }

  /* Hero video mode — intro becomes full-bleed with video background */
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap {
    position: relative;
    width: 100%;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: #202009;
  }
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap video,
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap .bfc-s8__hero-video-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap .bfc-s8__hero-video-overlay {
    position: absolute;
    inset: 0;
    background-color: #202009;
    opacity: 0.35;
    z-index: 1;
    pointer-events: none;
  }
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap .bfc-s8__intro {
    position: relative;
    z-index: 2;
    color: #F8F6EE;
    padding: 80px 24px;
    max-width: 820px;
    margin: 0 auto;
  }
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap .bfc-s8__title,
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap .bfc-s8__lead {
    color: #F8F6EE;
  }
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap .bfc-s8__eyebrow,
  .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap .bfc-s8__sublead {
    color: #E3DDDA;
  }
  @media (prefers-reduced-motion: reduce) {
    .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap video { display: none; }
  }

  /* ============ Compact hero mode (for collection pages) ============ */
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__hero-video-wrap {
    min-height: 320px;
  }
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__hero-video-wrap .bfc-s8__intro {
    padding: 40px 24px;
    max-width: 720px;
  }
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__intro {
    padding: 28px 0 0;
  }
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__title {
    font-size: 52px;
    margin-bottom: 16px;
  }
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__lead {
    font-size: 20px;
    margin-bottom: 10px;
  }
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__sublead {
    font-size: 14px;
  }
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__eyebrow {
    margin-bottom: 14px;
  }
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__scroll-arrow {
    display: none;
  }
  .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__grid-section {
    padding-top: 40px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #4E4741;
    margin: 0 0 20px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__title {
    font-family: var(--bfc-serif);
    font-size: 84px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 28px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__lead {
    font-family: var(--bfc-serif);
    font-size: 26px;
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
    max-width: 680px;
    margin: 0 auto 20px;
    color: #202009;
  }
  .bfc-s8-{{ sid }} .bfc-s8__sublead {
    font-size: 15px;
    line-height: 1.6;
    max-width: 580px;
    margin: 0 auto;
    color: #4E4741;
  }

  /* ============ Product Grid ============ */
  .bfc-s8-{{ sid }} .bfc-s8__grid-section {
    padding: 64px 0 96px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px 24px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card-image {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: #E3DDDA;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card:hover .bfc-s8__card-image img {
    transform: scale(1.03);
  }
  .bfc-s8-{{ sid }} .bfc-s8__card-image--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card:hover .bfc-s8__card-image--hover {
    opacity: 1;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #F8F6EE;
    color: #202009;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 6px 10px;
    z-index: 2;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card-title {
    font-family: var(--bfc-serif);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 6px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card-price {
    font-size: 14px;
    font-weight: 500;
    color: #4E4741;
  }
  .bfc-s8-{{ sid }} .bfc-s8__card-price--compare {
    color: #4E4741;
    text-decoration: line-through;
    margin-left: 8px;
    opacity: 0.6;
  }
  .bfc-s8-{{ sid }} .bfc-s8__grid-empty {
    text-align: center;
    padding: 80px 20px;
    color: #4E4741;
  }
  .bfc-s8-{{ sid }} .bfc-s8__grid-footer {
    margin-top: 48px;
    text-align: center;
  }

  /* ============ Video ============ */
  .bfc-s8-{{ sid }} .bfc-s8__video-section {
    background-color: #202009;
    color: #F8F6EE;
    padding: 96px 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__video-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 48px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__video-title {
    font-family: var(--bfc-serif);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.05;
    margin: 0 0 16px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__video-body {
    font-size: 16px;
    line-height: 1.6;
    color: #E3DDDA;
    margin: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    overflow: hidden;
  }
  .bfc-s8-{{ sid }} .bfc-s8__video-frame video,
  .bfc-s8-{{ sid }} .bfc-s8__video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__video-frame .bfc-s8__video-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: pointer;
    z-index: 2;
  }
  .bfc-s8-{{ sid }} .bfc-s8__video-playbtn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    width: 88px;
    height: 88px;
    background: rgba(248, 246, 238, 0.95);
    color: #202009;
    border: 0;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: grid;
    place-items: center;
    font-family: inherit;
  }
  .bfc-s8-{{ sid }} .bfc-s8__video-playbtn:hover { opacity: 0.9; }
  .bfc-s8-{{ sid }} .bfc-s8__video-playbtn svg { width: 32px; height: 32px; }

  /* ============ Restoration ============ */
  .bfc-s8-{{ sid }} .bfc-s8__resto-section {
    padding: 112px 0;
    background-color: #F8F6EE;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 72px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #E36E15;
    margin: 0 0 16px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-title {
    font-family: var(--bfc-serif);
    font-size: 56px;
    font-weight: 500;
    line-height: 1.05;
    margin: 0 0 20px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-body {
    font-size: 17px;
    line-height: 1.6;
    color: #4E4741;
    margin: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px 32px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-step {
    position: relative;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-num {
    font-family: var(--bfc-serif);
    font-size: 72px;
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    color: #E36E15;
    margin: 0 0 16px;
    display: block;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-step-title {
    font-family: var(--bfc-serif);
    font-size: 26px;
    font-weight: 500;
    line-height: 1.15;
    margin: 0 0 12px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-step-body {
    font-size: 15px;
    line-height: 1.6;
    color: #4E4741;
    margin: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__resto-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    margin-bottom: 24px;
    background-color: #E3DDDA;
  }

  /* ============ Film pairing ============ */
  .bfc-s8-{{ sid }} .bfc-s8__film {
    padding: 72px 0 56px;
    background-color: #F8F6EE;
    border-top: 1px solid #E3DDDA;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 32px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-title {
    font-family: var(--bfc-serif);
    font-size: 44px;
    font-weight: 500;
    line-height: 1.05;
    margin: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-title em {
    font-style: italic;
    color: #E36E15;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-sub {
    font-size: 14px;
    color: #4E4741;
    max-width: 320px;
    margin: 0;
    line-height: 1.5;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    position: relative;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-image {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: #E3DDDA;
    overflow: hidden;
    margin-bottom: 14px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-card:hover .bfc-s8__film-image img {
    transform: scale(1.03);
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-info {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-text {
    flex: 1;
    min-width: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-name {
    font-family: var(--bfc-serif);
    font-size: 19px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 4px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-price {
    font-size: 13px;
    color: #4E4741;
    font-weight: 500;
  }
  .bfc-s8-{{ sid }} .bfc-s8__quickadd {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    background-color: #202009;
    color: #F8F6EE;
    border: 0;
    cursor: pointer;
    display: grid;
    place-items: center;
    font-family: var(--bfc-sans);
    font-size: 18px;
    font-weight: 400;
    line-height: 1;
    transition: background-color 0.18s ease, color 0.18s ease;
  }
  .bfc-s8-{{ sid }} .bfc-s8__quickadd:hover:not(:disabled) {
    background-color: #E36E15;
  }
  .bfc-s8-{{ sid }} .bfc-s8__quickadd:disabled {
    background-color: #E3DDDA;
    color: #4E4741;
    cursor: not-allowed;
  }
  .bfc-s8-{{ sid }} .bfc-s8__quickadd[data-state="adding"] {
    background-color: #4E4741;
  }
  .bfc-s8-{{ sid }} .bfc-s8__quickadd[data-state="added"] {
    background-color: #ABCC99;
    color: #202009;
  }
  .bfc-s8-{{ sid }} .bfc-s8__quickadd[data-state="error"] {
    background-color: #E36E15;
  }
  .bfc-s8-{{ sid }} .bfc-s8__film-footer {
    margin-top: 36px;
    text-align: center;
  }

  /* ============ Gallery (shot on super 8) ============ */
  .bfc-s8-{{ sid }} .bfc-s8__gallery {
    padding: 80px 0 72px;
    background-color: #F8F6EE;
    border-top: 1px solid #E3DDDA;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-title-wrap {
    flex: 1;
    min-width: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-eyebrow {
    font-family: var(--bfc-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #4E4741;
    margin: 0 0 14px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-title {
    font-family: var(--bfc-serif);
    font-size: 56px;
    font-weight: 500;
    line-height: 1;
    margin: 0;
    color: #202009;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-title em {
    font-style: italic;
    color: #E36E15;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-sub {
    font-family: var(--bfc-sans);
    font-size: 14px;
    color: #4E4741;
    max-width: 340px;
    margin: 0;
    text-align: right;
    line-height: 1.5;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 180px;
    grid-auto-flow: dense;
    gap: 16px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item {
    position: relative;
    overflow: hidden;
    background-color: #E3DDDA;
    display: block;
    text-decoration: none;
    grid-column: span 2;
    grid-row: span 2;
    color: #F8F6EE;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="wide"]  { grid-column: span 3; grid-row: span 2; }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="tall"]  { grid-column: span 2; grid-row: span 3; }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="large"] { grid-column: span 4; grid-row: span 3; }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="small"] { grid-column: span 2; grid-row: span 2; }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    display: block;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item:hover img {
    transform: scale(1.04);
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(32,32,9,0.55) 0%, rgba(32,32,9,0) 45%);
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item:hover .bfc-s8__gallery-scrim { opacity: 1; }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-item:has(.bfc-s8__gallery-caption) .bfc-s8__gallery-scrim { opacity: 1; }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-caption {
    position: absolute;
    bottom: 14px;
    left: 16px;
    right: 16px;
    z-index: 2;
    font-family: var(--bfc-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1.4;
    color: #F8F6EE;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-footer {
    margin-top: 36px;
    text-align: center;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-footer-link {
    font-family: var(--bfc-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #202009;
    text-decoration: none;
    border-bottom: 1px solid #202009;
    padding-bottom: 3px;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .bfc-s8-{{ sid }} .bfc-s8__gallery-footer-link:hover {
    color: #E36E15;
    border-bottom-color: #E36E15;
  }

  /* ============ FAQ (good to know) ============ */
  .bfc-s8-{{ sid }} .bfc-s8__faq {
    padding: 72px 0;
    background-color: #F8F6EE;
    border-top: 1px solid #E3DDDA;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-header {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
    align-items: end;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-eyebrow {
    font-family: var(--bfc-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #E36E15;
    margin: 0 0 14px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-title {
    font-family: var(--bfc-serif);
    font-size: 52px;
    font-weight: 500;
    line-height: 1.05;
    margin: 0;
    color: #202009;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-title em {
    font-style: italic;
    color: #E36E15;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-helper {
    font-family: var(--bfc-sans);
    font-size: 14px;
    line-height: 1.55;
    color: #4E4741;
    margin: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-helper a {
    color: #E36E15;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px 56px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-item {
    border-top: 1px solid #E3DDDA;
    padding-top: 22px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-q {
    font-family: var(--bfc-serif);
    font-size: 24px;
    font-style: italic;
    font-weight: 500;
    line-height: 1.2;
    color: #202009;
    margin: 0 0 14px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-a {
    font-family: var(--bfc-sans);
    font-size: 15px;
    line-height: 1.65;
    color: #4E4741;
    margin: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-a a {
    color: #202009;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: #E3DDDA;
  }
  .bfc-s8-{{ sid }} .bfc-s8__faq-a a:hover {
    text-decoration-color: #E36E15;
  }

  /* ============ Closing (editorial image closer) ============ */
  .bfc-s8-{{ sid }} .bfc-s8__close {
    position: relative;
    overflow: hidden;
    background-color: #202009;
    color: #F8F6EE;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close--no-image {
    background-color: #F8F6EE;
    color: #202009;
    align-items: center;
    min-height: 400px;
    border-top: 1px solid #E3DDDA;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(32, 32, 9, 0) 0%,
      rgba(32, 32, 9, 0.15) 45%,
      rgba(32, 32, 9, 0.75) 100%
    );
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 64px 0 56px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close--no-image .bfc-s8__close-inner {
    padding: 72px 0;
    text-align: center;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-eyebrow {
    font-family: var(--bfc-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #F4A027;
    margin: 0 0 24px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close--no-image .bfc-s8__close-eyebrow {
    color: #E36E15;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-headline {
    font-family: var(--bfc-serif);
    font-size: 80px;
    font-style: italic;
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.01em;
    margin: 0 0 28px;
    max-width: 11ch;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close--no-image .bfc-s8__close-headline {
    margin-left: auto;
    margin-right: auto;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-body {
    font-family: var(--bfc-sans);
    font-size: 17px;
    line-height: 1.55;
    margin: 0 0 36px;
    max-width: 520px;
    color: inherit;
    opacity: 0.92;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close--no-image .bfc-s8__close-body {
    margin-left: auto;
    margin-right: auto;
    color: #4E4741;
    opacity: 1;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-actions {
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close--no-image .bfc-s8__close-actions {
    justify-content: center;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-btn {
    display: inline-block;
    padding: 16px 44px;
    font-family: var(--bfc-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    background-color: #E36E15;
    color: #F8F6EE;
    border: 0;
    transition: background-color 0.2s ease;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-btn:hover {
    background-color: #F4A027;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-meta {
    font-family: var(--bfc-sans);
    font-size: 13px;
    letter-spacing: 0.02em;
    line-height: 1.5;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    opacity: 0.85;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close--no-image .bfc-s8__close-meta {
    justify-content: center;
    color: #4E4741;
    opacity: 1;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-meta a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: currentColor;
  }
  .bfc-s8-{{ sid }} .bfc-s8__close-dot {
    opacity: 0.5;
    user-select: none;
  }

  /* ============ Scroll arrow (hero video mode) ============ */
  .bfc-s8-{{ sid }} .bfc-s8__scroll-arrow {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    color: #F8F6EE;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 12px;
    font-family: var(--bfc-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
    opacity: 0.88;
  }
  .bfc-s8-{{ sid }} .bfc-s8__scroll-arrow:hover { opacity: 1; }
  .bfc-s8-{{ sid }} .bfc-s8__scroll-arrow svg {
    width: 32px;
    height: 72px;
    animation: bfc-s8-arrow-{{ sid }} 2.4s ease-in-out infinite;
  }
  @keyframes bfc-s8-arrow-{{ sid }} {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50%      { transform: translateY(8px); opacity: 0.6; }
  }
  @media (prefers-reduced-motion: reduce) {
    .bfc-s8-{{ sid }} .bfc-s8__scroll-arrow svg { animation: none; }
  }

  /* ============ Buttons ============ */
  .bfc-s8-{{ sid }} .bfc-s8__btn {
    display: inline-block;
    padding: 14px 36px;
    font-family: var(--bfc-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    transition: opacity 0.18s ease;
  }
  .bfc-s8-{{ sid }} .bfc-s8__btn:hover { opacity: 0.88; }
  .bfc-s8-{{ sid }} .bfc-s8__btn--primary {
    background-color: #4E4741;
    color: #F8F6EE;
  }
  .bfc-s8-{{ sid }} .bfc-s8__btn--outline-dark {
    background: transparent;
    color: #202009;
    border-color: #202009;
  }
  .bfc-s8-{{ sid }} .bfc-s8__btn--outline-light {
    background: transparent;
    color: #F8F6EE;
    border-color: #F8F6EE;
  }
  .bfc-s8-{{ sid }} .bfc-s8__btn--orange {
    background-color: #E36E15;
    color: #F8F6EE;
  }

  /* ============ Tablet ============ */
  @media (max-width: 1023px) {
    .bfc-s8-{{ sid }} .bfc-s8__grid { grid-template-columns: repeat(3, 1fr); }
    .bfc-s8-{{ sid }} .bfc-s8__resto-steps { grid-template-columns: repeat(2, 1fr); gap: 56px 32px; }
    .bfc-s8-{{ sid }} .bfc-s8__title { font-size: 64px; }
    .bfc-s8-{{ sid }} .bfc-s8__resto-title { font-size: 44px; }
    .bfc-s8-{{ sid }} .bfc-s8__video-title { font-size: 40px; }
    .bfc-s8-{{ sid }} .bfc-s8__close-headline { font-size: 60px; }
    .bfc-s8-{{ sid }} .bfc-s8__close { min-height: 480px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-title { font-size: 44px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-grid { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 150px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="large"] { grid-column: span 4; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="wide"]  { grid-column: span 4; }
    .bfc-s8-{{ sid }} .bfc-s8__faq-title { font-size: 40px; }
    .bfc-s8-{{ sid }} .bfc-s8__faq-header { grid-template-columns: 1fr; gap: 20px; }
  }

  /* ============ Mobile ============ */
  @media (max-width: 749px) {
    .bfc-s8-{{ sid }} .bfc-s8__wrap { padding: 0 16px; }
    .bfc-s8-{{ sid }} .bfc-s8__intro { padding: 28px 0 0; }
    .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap { min-height: 440px; }
    .bfc-s8-{{ sid }} .bfc-s8__hero-video-wrap .bfc-s8__intro { padding: 56px 20px; }
    .bfc-s8-{{ sid }} .bfc-s8__title { font-size: 48px; margin-bottom: 20px; }
    .bfc-s8-{{ sid }} .bfc-s8__lead { font-size: 20px; margin-bottom: 16px; }
    .bfc-s8-{{ sid }} .bfc-s8__sublead { font-size: 14px; }
    .bfc-s8-{{ sid }} .bfc-s8__grid { grid-template-columns: repeat(2, 1fr); gap: 24px 12px; }
    .bfc-s8-{{ sid }} .bfc-s8__grid-section { padding: 40px 0 64px; }
    .bfc-s8-{{ sid }} .bfc-s8__card-title { font-size: 18px; }
    .bfc-s8-{{ sid }} .bfc-s8__card-price { font-size: 13px; }
    .bfc-s8-{{ sid }} .bfc-s8__video-section { padding: 64px 0; }
    .bfc-s8-{{ sid }} .bfc-s8__video-title { font-size: 32px; }
    .bfc-s8-{{ sid }} .bfc-s8__video-header { margin-bottom: 32px; }
    .bfc-s8-{{ sid }} .bfc-s8__video-playbtn { width: 64px; height: 64px; }
    .bfc-s8-{{ sid }} .bfc-s8__video-playbtn svg { width: 24px; height: 24px; }
    .bfc-s8-{{ sid }} .bfc-s8__resto-section { padding: 72px 0; }
    .bfc-s8-{{ sid }} .bfc-s8__resto-title { font-size: 36px; }
    .bfc-s8-{{ sid }} .bfc-s8__resto-body { font-size: 15px; }
    .bfc-s8-{{ sid }} .bfc-s8__resto-header { margin-bottom: 48px; }
    .bfc-s8-{{ sid }} .bfc-s8__resto-steps { grid-template-columns: 1fr; gap: 48px; }
    .bfc-s8-{{ sid }} .bfc-s8__resto-num { font-size: 56px; }
    .bfc-s8-{{ sid }} .bfc-s8__resto-step-title { font-size: 22px; }
    .bfc-s8-{{ sid }} .bfc-s8__film { padding: 44px 0 28px; }
    .bfc-s8-{{ sid }} .bfc-s8__film-header { flex-direction: column; align-items: flex-start; gap: 12px; margin-bottom: 28px; }
    .bfc-s8-{{ sid }} .bfc-s8__film-title { font-size: 32px; }
    .bfc-s8-{{ sid }} .bfc-s8__film-grid { grid-template-columns: repeat(2, 1fr); gap: 20px 12px; }
    .bfc-s8-{{ sid }} .bfc-s8__film-name { font-size: 16px; }
    .bfc-s8-{{ sid }} .bfc-s8__quickadd { width: 32px; height: 32px; font-size: 16px; }
    .bfc-s8-{{ sid }} .bfc-s8__close { min-height: 380px; align-items: flex-end; }
    .bfc-s8-{{ sid }} .bfc-s8__close--no-image { min-height: 320px; }
    .bfc-s8-{{ sid }} .bfc-s8__close-inner { padding: 44px 0 36px; }
    .bfc-s8-{{ sid }} .bfc-s8__close--no-image .bfc-s8__close-inner { padding: 52px 0; }
    .bfc-s8-{{ sid }} .bfc-s8__close-headline { font-size: 44px; line-height: 1; margin-bottom: 20px; }
    .bfc-s8-{{ sid }} .bfc-s8__close-body { font-size: 15px; margin-bottom: 28px; }
    .bfc-s8-{{ sid }} .bfc-s8__close-actions { gap: 20px; margin-bottom: 28px; }
    .bfc-s8-{{ sid }} .bfc-s8__close-btn { padding: 14px 32px; width: 100%; text-align: center; }
    .bfc-s8-{{ sid }} .bfc-s8__close--no-image .bfc-s8__close-btn { width: auto; }
    .bfc-s8-{{ sid }} .bfc-s8__close-meta { font-size: 12px; gap: 10px; }
    .bfc-s8-{{ sid }} .bfc-s8__scroll-arrow { bottom: 8px; font-size: 9px; }
    .bfc-s8-{{ sid }} .bfc-s8__scroll-arrow svg { width: 24px; height: 56px; }
    .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__hero-video-wrap { min-height: 220px; }
    .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__hero-video-wrap .bfc-s8__intro { padding: 28px 20px; }
    .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__title { font-size: 36px; margin-bottom: 12px; }
    .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__lead { font-size: 17px; margin-bottom: 8px; }
    .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__sublead { font-size: 13px; }
    .bfc-s8-{{ sid }}.bfc-s8--compact .bfc-s8__grid-section { padding-top: 24px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery { padding: 48px 0 40px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-header { flex-direction: column; align-items: flex-start; gap: 12px; margin-bottom: 32px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-title { font-size: 36px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-sub { text-align: left; max-width: none; font-size: 13px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 160px; gap: 10px; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-item { grid-column: span 1; grid-row: span 2; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="large"],
    .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="wide"]  { grid-column: span 2; grid-row: span 2; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-item[data-size="tall"]  { grid-column: span 1; grid-row: span 2; }
    .bfc-s8-{{ sid }} .bfc-s8__gallery-caption { font-size: 10px; }
    .bfc-s8-{{ sid }} .bfc-s8__faq { padding: 48px 0; }
    .bfc-s8-{{ sid }} .bfc-s8__faq-title { font-size: 32px; }
    .bfc-s8-{{ sid }} .bfc-s8__faq-header { margin-bottom: 40px; }
    .bfc-s8-{{ sid }} .bfc-s8__faq-grid { grid-template-columns: 1fr; gap: 32px; }
    .bfc-s8-{{ sid }} .bfc-s8__faq-q { font-size: 20px; }
    .bfc-s8-{{ sid }} .bfc-s8__faq-a { font-size: 14px; }
  }
</style>

<div class="bfc-s8-{{ sid }}{% if s.hero_compact %} bfc-s8--compact{% endif %}">

  {%- comment -%} ========== 1. Intro + Grid ========== {%- endcomment -%}
  {%- if s.hero_video_mode and s.hero_video != blank -%}
    <div class="bfc-s8__hero-video-wrap">
      {%- if s.hero_video_poster != blank -%}
        <img
          class="bfc-s8__hero-video-poster"
          src="{{ s.hero_video_poster | image_url: width: 2000 }}"
          srcset="
            {{ s.hero_video_poster | image_url: width: 800 }} 800w,
            {{ s.hero_video_poster | image_url: width: 1400 }} 1400w,
            {{ s.hero_video_poster | image_url: width: 2000 }} 2000w
          "
          sizes="100vw"
          alt=""
          loading="eager"
          fetchpriority="high"
          width="{{ s.hero_video_poster.width }}"
          height="{{ s.hero_video_poster.height }}"
        >
      {%- endif -%}
      {{ s.hero_video | video_tag: image_size: '1600x', controls: false, muted: true, autoplay: true, loop: true, playsinline: true, preload: 'metadata' }}
      <div class="bfc-s8__hero-video-overlay"></div>
      <a href="#bfc-s8-scroll-target-{{ sid }}" class="bfc-s8__scroll-arrow" aria-label="Scroll to products" data-scroll-arrow>
        <span>Scroll</span>
        <svg viewBox="0 0 24 56" width="32" height="72" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
          <line x1="12" y1="4" x2="12" y2="42" stroke-linecap="round"/>
          <polyline points="4 38 12 50 20 38" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <div class="bfc-s8__intro">
        {%- if s.intro_eyebrow != blank -%}
          <div class="bfc-s8__eyebrow">{{ s.intro_eyebrow }}</div>
        {%- endif -%}
        {%- if s.intro_title != blank -%}
          <h1 class="bfc-s8__title">{{ s.intro_title }}</h1>
        {%- endif -%}
        {%- if s.intro_lead != blank -%}
          <p class="bfc-s8__lead">{{ s.intro_lead }}</p>
        {%- endif -%}
        {%- if s.intro_sublead != blank -%}
          <p class="bfc-s8__sublead">{{ s.intro_sublead }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    <div class="bfc-s8__intro-section">
      <div class="bfc-s8__wrap">
        <div class="bfc-s8__intro">
          {%- if s.intro_eyebrow != blank -%}
            <div class="bfc-s8__eyebrow">{{ s.intro_eyebrow }}</div>
          {%- endif -%}
          {%- if s.intro_title != blank -%}
            <h1 class="bfc-s8__title">{{ s.intro_title }}</h1>
          {%- endif -%}
          {%- if s.intro_lead != blank -%}
            <p class="bfc-s8__lead">{{ s.intro_lead }}</p>
          {%- endif -%}
          {%- if s.intro_sublead != blank -%}
            <p class="bfc-s8__sublead">{{ s.intro_sublead }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="bfc-s8__grid-section" id="bfc-s8-scroll-target-{{ sid }}">
    <div class="bfc-s8__wrap">
      {%- if grid_collection != blank and grid_collection.products.size > 0 -%}
        {%- assign available_products = grid_collection.products | where: 'available', true -%}
        {%- assign sold_out_products = grid_collection.products | where: 'available', false -%}
        {%- assign sorted_products = available_products | concat: sold_out_products -%}
        <div class="bfc-s8__grid">
          {%- for product in sorted_products limit: product_limit -%}
            <a href="{{ product.url }}" class="bfc-s8__card" aria-label="{{ product.title | escape }}">
              <div class="bfc-s8__card-image">
                {%- if product.available == false -%}
                  <span class="bfc-s8__card-badge">Sold</span>
                {%- elsif product.compare_at_price > product.price -%}
                  <span class="bfc-s8__card-badge">Sale</span>
                {%- endif -%}
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    srcset="
                      {{ product.featured_image | image_url: width: 400 }} 400w,
                      {{ product.featured_image | image_url: width: 800 }} 800w,
                      {{ product.featured_image | image_url: width: 1200 }} 1200w
                    "
                    sizes="(max-width: 749px) 50vw, 25vw"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                  >
                {%- endif -%}
                {%- if product.images[1] -%}
                  <img
                    class="bfc-s8__card-image--hover"
                    src="{{ product.images[1] | image_url: width: 800 }}"
                    alt=""
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
              <h3 class="bfc-s8__card-title">{{ product.title }}</h3>
              <div class="bfc-s8__card-price">
                {%- if product.compare_at_price > product.price -%}
                  {{ product.price | money }}
                  <span class="bfc-s8__card-price--compare">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>

        {%- if s.grid_cta_text != blank -%}
          <div class="bfc-s8__grid-footer">
            <a
              href="{{ s.grid_cta_link | default: grid_collection.url }}"
              class="bfc-s8__btn bfc-s8__btn--outline-dark"
            >{{ s.grid_cta_text }}</a>
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="bfc-s8__grid-empty">
          <p>Select a collection in the section settings to populate the grid.</p>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ========== 2. Video ========== {%- endcomment -%}
  {%- if s.video_upload != blank or s.video_url != blank -%}
    <div class="bfc-s8__video-section">
      <div class="bfc-s8__wrap">
        {%- if s.video_title != blank or s.video_body != blank -%}
          <div class="bfc-s8__video-header">
            {%- if s.video_title != blank -%}
              <h2 class="bfc-s8__video-title">{{ s.video_title }}</h2>
            {%- endif -%}
            {%- if s.video_body != blank -%}
              <p class="bfc-s8__video-body">{{ s.video_body }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="bfc-s8__video-frame" data-video-frame>
          {%- if s.video_upload != blank -%}
            {{ s.video_upload | video_tag: image_size: '1600x', controls: true, muted: false, autoplay: false, loop: false }}
          {%- elsif s.video_url != blank -%}
            {%- if s.video_poster != blank -%}
              <img
                class="bfc-s8__video-poster"
                src="{{ s.video_poster | image_url: width: 1600 }}"
                alt="{{ s.video_title | escape }}"
                loading="lazy"
                data-video-poster
              >
              <button class="bfc-s8__video-playbtn" type="button" aria-label="Play video" data-video-play>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              </button>
            {%- endif -%}
            <iframe
              src="https://www.{{ s.video_url.type }}.com/embed/{{ s.video_url.id }}{% if s.video_url.type == 'vimeo' %}?dnt=1{% else %}?rel=0&modestbranding=1{% endif %}"
              title="{{ s.video_title | escape }}"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
              data-video-iframe
              {% if s.video_poster != blank %}style="visibility: hidden;"{% endif %}
            ></iframe>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- if s.video_url != blank and s.video_poster != blank -%}
      <script>
        (function() {
          var frame = document.querySelector('.bfc-s8-{{ sid }} [data-video-frame]');
          if (!frame) return;
          var btn = frame.querySelector('[data-video-play]');
          var poster = frame.querySelector('[data-video-poster]');
          var iframe = frame.querySelector('[data-video-iframe]');
          if (!btn || !poster || !iframe) return;
          var handler = function() {
            iframe.style.visibility = 'visible';
            var src = iframe.getAttribute('src');
            var joiner = src.indexOf('?') > -1 ? '&' : '?';
            iframe.setAttribute('src', src + joiner + 'autoplay=1');
            poster.style.display = 'none';
            btn.style.display = 'none';
          };
          btn.addEventListener('click', handler);
          poster.addEventListener('click', handler);
        })();
      </script>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} ========== 3. Restoration ========== {%- endcomment -%}
  <div class="bfc-s8__resto-section">
    <div class="bfc-s8__wrap">
      <div class="bfc-s8__resto-header">
        {%- if s.resto_eyebrow != blank -%}
          <div class="bfc-s8__resto-eyebrow">{{ s.resto_eyebrow }}</div>
        {%- endif -%}
        {%- if s.resto_title != blank -%}
          <h2 class="bfc-s8__resto-title">{{ s.resto_title }}</h2>
        {%- endif -%}
        {%- if s.resto_body != blank -%}
          <p class="bfc-s8__resto-body">{{ s.resto_body }}</p>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="bfc-s8__resto-steps">
          {%- for block in section.blocks -%}
            {%- if block.type == 'restoration_step' -%}
              <div class="bfc-s8__resto-step" {{ block.shopify_attributes }}>
                {%- if block.settings.step_image != blank -%}
                  <img
                    class="bfc-s8__resto-image"
                    src="{{ block.settings.step_image | image_url: width: 800 }}"
                    alt="{{ block.settings.step_title | escape }}"
                    loading="lazy"
                    width="{{ block.settings.step_image.width }}"
                    height="{{ block.settings.step_image.height }}"
                  >
                {%- endif -%}
                {%- if block.settings.step_number != blank -%}
                  <span class="bfc-s8__resto-num">{{ block.settings.step_number }}</span>
                {%- endif -%}
                {%- if block.settings.step_title != blank -%}
                  <h3 class="bfc-s8__resto-step-title">{{ block.settings.step_title }}</h3>
                {%- endif -%}
                {%- if block.settings.step_body != blank -%}
                  <p class="bfc-s8__resto-step-body">{{ block.settings.step_body }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ========== 4. Film pairing (quick-add collection) ========== {%- endcomment -%}
  {%- assign film_collection = collections[s.film_collection] -%}
  {%- if film_collection != blank and film_collection.products.size > 0 -%}
    {%- assign film_available = film_collection.products | where: 'available', true -%}
    {%- assign film_sold = film_collection.products | where: 'available', false -%}
    {%- assign film_sorted = film_available | concat: film_sold -%}
    {%- assign film_limit = s.film_limit | default: 4 -%}
    <div class="bfc-s8__film">
      <div class="bfc-s8__wrap">
        <div class="bfc-s8__film-header">
          <h2 class="bfc-s8__film-title">
            {%- if s.film_title != blank -%}
              {{ s.film_title }}
            {%- else -%}
              Now <em>load it</em>.
            {%- endif -%}
          </h2>
          {%- if s.film_sub != blank -%}
            <p class="bfc-s8__film-sub">{{ s.film_sub }}</p>
          {%- endif -%}
        </div>

        <div class="bfc-s8__film-grid">
          {%- for product in film_sorted limit: film_limit -%}
            {%- assign variant = product.selected_or_first_available_variant -%}
            <div class="bfc-s8__film-card">
              <a href="{{ product.url }}" class="bfc-s8__film-image" aria-label="{{ product.title | escape }}">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    srcset="
                      {{ product.featured_image | image_url: width: 300 }} 300w,
                      {{ product.featured_image | image_url: width: 600 }} 600w,
                      {{ product.featured_image | image_url: width: 900 }} 900w
                    "
                    sizes="(max-width: 749px) 50vw, 25vw"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                  >
                {%- endif -%}
              </a>
              <div class="bfc-s8__film-info">
                <div class="bfc-s8__film-text">
                  <h3 class="bfc-s8__film-name">
                    <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">{{ product.title }}</a>
                  </h3>
                  <div class="bfc-s8__film-price">
                    {%- if product.available -%}
                      {{ product.price | money }}
                    {%- else -%}
                      Sold out
                    {%- endif -%}
                  </div>
                </div>
                {%- if product.available and product.has_only_default_variant -%}
                  <form data-quickadd-form>
                    <button
                      type="submit"
                      class="bfc-s8__quickadd"
                      data-quickadd-btn
                      data-variant-id="{{ variant.id }}"
                      aria-label="Add {{ product.title | escape }} to cart"
                    >+</button>
                  </form>
                {%- elsif product.available -%}
                  <a href="{{ product.url }}" class="bfc-s8__quickadd" aria-label="Choose options for {{ product.title | escape }}">+</a>
                {%- else -%}
                  <button class="bfc-s8__quickadd" disabled aria-label="Sold out">—</button>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if s.film_cta_text != blank -%}
          <div class="bfc-s8__film-footer">
            <a href="{{ s.film_cta_link | default: film_collection.url }}" class="bfc-s8__btn bfc-s8__btn--outline-dark">
              {{ s.film_cta_text }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>

    <script>
      (function() {
        var scope = document.querySelector('.bfc-s8-{{ sid }}');
        if (!scope) return;
        scope.querySelectorAll('[data-quickadd-form]').forEach(function(form) {
          form.addEventListener('submit', function(e) {
            e.preventDefault();
            var btn = form.querySelector('[data-quickadd-btn]');
            if (!btn || btn.disabled) return;
            var variantId = btn.getAttribute('data-variant-id');
            if (!variantId) return;
            var originalHTML = btn.innerHTML;
            var checkSVG = '<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 8 7 12 13 4"/></svg>';
            btn.disabled = true;
            btn.setAttribute('data-state', 'adding');
            btn.textContent = '…';
            fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({ id: variantId, quantity: 1 })
            })
            .then(function(r) { return r.ok ? r.json() : Promise.reject(r); })
            .then(function() {
              btn.setAttribute('data-state', 'added');
              btn.innerHTML = checkSVG;
              document.dispatchEvent(new CustomEvent('cart:refresh'));
              document.dispatchEvent(new CustomEvent('cart:updated'));
              setTimeout(function() {
                btn.removeAttribute('data-state');
                btn.innerHTML = originalHTML;
                btn.disabled = false;
              }, 1800);
            })
            .catch(function() {
              btn.setAttribute('data-state', 'error');
              btn.textContent = '!';
              setTimeout(function() {
                btn.removeAttribute('data-state');
                btn.innerHTML = originalHTML;
                btn.disabled = false;
              }, 1800);
            });
          });
        });
      })();
    </script>
  {%- endif -%}

  {%- comment -%} ========== 5. Gallery (shot on Super 8) ========== {%- endcomment -%}
  {%- assign gallery_blocks = section.blocks | where: 'type', 'gallery_photo' -%}
  {%- if gallery_blocks.size > 0 -%}
    <div class="bfc-s8__gallery">
      <div class="bfc-s8__wrap">
        {%- if s.gallery_title != blank or s.gallery_sub != blank -%}
          <div class="bfc-s8__gallery-header">
            <div class="bfc-s8__gallery-title-wrap">
              {%- if s.gallery_eyebrow != blank -%}
                <div class="bfc-s8__gallery-eyebrow">{{ s.gallery_eyebrow }}</div>
              {%- endif -%}
              {%- if s.gallery_title != blank -%}
                <h2 class="bfc-s8__gallery-title">{{ s.gallery_title }}</h2>
              {%- endif -%}
            </div>
            {%- if s.gallery_sub != blank -%}
              <p class="bfc-s8__gallery-sub">{{ s.gallery_sub }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="bfc-s8__gallery-grid">
          {%- for block in gallery_blocks -%}
            {%- if block.settings.image != blank -%}
              {%- assign tag = 'div' -%}
              {%- if block.settings.link != blank -%}{%- assign tag = 'a' -%}{%- endif -%}
              <{{ tag }}
                class="bfc-s8__gallery-item"
                data-size="{{ block.settings.size | default: 'small' }}"
                {% if block.settings.link != blank %}href="{{ block.settings.link }}" target="_blank" rel="noopener"{% endif %}
                {{ block.shopify_attributes }}
              >
                <img
                  src="{{ block.settings.image | image_url: width: 1400 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 500 }} 500w,
                    {{ block.settings.image | image_url: width: 900 }} 900w,
                    {{ block.settings.image | image_url: width: 1400 }} 1400w
                  "
                  sizes="(max-width: 749px) 100vw, 50vw"
                  alt="{{ block.settings.image.alt | default: block.settings.caption | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
                {%- if block.settings.caption != blank -%}
                  <div class="bfc-s8__gallery-scrim"></div>
                  <div class="bfc-s8__gallery-caption">{{ block.settings.caption }}</div>
                {%- endif -%}
              </{{ tag }}>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if s.gallery_footer_text != blank -%}
          <div class="bfc-s8__gallery-footer">
            <a href="{{ s.gallery_footer_link | default: '#' }}" class="bfc-s8__gallery-footer-link">{{ s.gallery_footer_text }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ========== 6. FAQ (good to know) ========== {%- endcomment -%}
  {%- assign faq_blocks = section.blocks | where: 'type', 'faq_item' -%}
  {%- if faq_blocks.size > 0 -%}
    <div class="bfc-s8__faq">
      <div class="bfc-s8__wrap">
        <div class="bfc-s8__faq-header">
          <div>
            {%- if s.faq_eyebrow != blank -%}
              <div class="bfc-s8__faq-eyebrow">{{ s.faq_eyebrow }}</div>
            {%- endif -%}
            {%- if s.faq_title != blank -%}
              <h2 class="bfc-s8__faq-title">{{ s.faq_title }}</h2>
            {%- endif -%}
          </div>
          {%- if s.faq_helper != blank -%}
            <p class="bfc-s8__faq-helper">{{ s.faq_helper }}</p>
          {%- endif -%}
        </div>

        <div class="bfc-s8__faq-grid">
          {%- for block in faq_blocks -%}
            {%- if block.settings.question != blank -%}
              <div class="bfc-s8__faq-item" {{ block.shopify_attributes }}>
                <h3 class="bfc-s8__faq-q">{{ block.settings.question }}</h3>
                {%- if block.settings.answer != blank -%}
                  <p class="bfc-s8__faq-a">{{ block.settings.answer }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ========== 7. Closing (editorial image closer) ========== {%- endcomment -%}
  {%- if s.close_headline != blank or s.close_body != blank -%}
    {%- assign close_has_image = false -%}
    {%- if s.close_image != blank -%}{%- assign close_has_image = true -%}{%- endif -%}
    <div class="bfc-s8__close {% unless close_has_image %}bfc-s8__close--no-image{% endunless %}">
      {%- if close_has_image -%}
        <img
          class="bfc-s8__close-bg"
          src="{{ s.close_image | image_url: width: 2400 }}"
          srcset="
            {{ s.close_image | image_url: width: 900 }} 900w,
            {{ s.close_image | image_url: width: 1400 }} 1400w,
            {{ s.close_image | image_url: width: 2000 }} 2000w,
            {{ s.close_image | image_url: width: 2400 }} 2400w
          "
          sizes="100vw"
          alt="{{ s.close_image.alt | escape }}"
          loading="lazy"
          width="{{ s.close_image.width }}"
          height="{{ s.close_image.height }}"
        >
        <div class="bfc-s8__close-scrim"></div>
      {%- endif -%}
      <div class="bfc-s8__close-inner">
        <div class="bfc-s8__wrap">
          {%- if s.close_eyebrow != blank -%}
            <div class="bfc-s8__close-eyebrow">{{ s.close_eyebrow }}</div>
          {%- endif -%}
          {%- if s.close_headline != blank -%}
            <h2 class="bfc-s8__close-headline">{{ s.close_headline }}</h2>
          {%- endif -%}
          {%- if s.close_body != blank -%}
            <p class="bfc-s8__close-body">{{ s.close_body }}</p>
          {%- endif -%}
          {%- if s.close_cta_text != blank -%}
            <div class="bfc-s8__close-actions">
              <a href="{{ s.close_cta_link | default: '#' }}" class="bfc-s8__close-btn">{{ s.close_cta_text }}</a>
            </div>
          {%- endif -%}
          {%- if s.close_address != blank or s.close_hours != blank or s.close_contact != blank -%}
            <div class="bfc-s8__close-meta">
              {%- if s.close_address != blank -%}
                <span>{{ s.close_address }}</span>
              {%- endif -%}
              {%- if s.close_hours != blank -%}
                {%- if s.close_address != blank -%}<span class="bfc-s8__close-dot">·</span>{%- endif -%}
                <span>{{ s.close_hours }}</span>
              {%- endif -%}
              {%- if s.close_contact != blank -%}
                {%- if s.close_address != blank or s.close_hours != blank -%}<span class="bfc-s8__close-dot">·</span>{%- endif -%}
                <span>{{ s.close_contact }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <script>
    (function() {
      var scope = document.querySelector('.bfc-s8-{{ sid }}');
      if (!scope) return;
      scope.querySelectorAll('[data-scroll-arrow]').forEach(function(link) {
        link.addEventListener('click', function(e) {
          var id = link.getAttribute('href');
          if (!id || id.charAt(0) !== '#') return;
          var target = document.querySelector(id);
          if (!target) return;
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    })();
  </script>

</div>

{% schema %}
{
  "name": "BFC Super 8 Landing",
  "tag": "section",
  "class": "section-bfc-super8",
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "checkbox", "id": "hero_compact", "label": "Compact hero (for collection pages)", "info": "Shrinks the hero height and type size. Use this setting when the section sits above a collection grid as a banner, not a full landing-page hero.", "default": false },
    { "type": "checkbox", "id": "hero_video_mode", "label": "Use autoplay video as hero background", "info": "Shows the intro text over a looping muted video. Upload a short (8-15s) optimized MP4 for best performance. Ignored if no video is uploaded below.", "default": false },
    { "type": "video", "id": "hero_video", "label": "Hero background video", "info": "Keep under 2MB. Muted + looped automatically. Will not load on reduced-motion devices." },
    { "type": "image_picker", "id": "hero_video_poster", "label": "Hero video poster (shown before video loads)" },
    { "type": "text", "id": "intro_eyebrow", "label": "Eyebrow", "default": "Cameras & Film" },
    { "type": "text", "id": "intro_title", "label": "Title", "default": "Super 8" },
    {
      "type": "textarea",
      "id": "intro_lead",
      "label": "Lead (italic serif)",
      "default": "It's the season for videos. Golden hour rooftop hangs, cross-country drives, backyard barbecues."
    },
    {
      "type": "textarea",
      "id": "intro_sublead",
      "label": "Sublead (sans body)",
      "default": "Every camera on this page is fully restored, calibrated on professional bench equipment, and backed by a six-month warranty."
    },

    { "type": "header", "content": "Product grid" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Should be your Super 8 cameras collection." },
    { "type": "range", "id": "product_limit", "label": "Max products to show", "min": 4, "max": 24, "step": 4, "default": 12 },
    { "type": "text", "id": "grid_cta_text", "label": "Below-grid CTA text", "default": "Shop all Super 8" },
    { "type": "url",  "id": "grid_cta_link", "label": "Below-grid CTA link" },

    { "type": "header", "content": "Video" },
    { "type": "text", "id": "video_title", "label": "Title", "default": "Shot on Super 8." },
    { "type": "textarea", "id": "video_body", "label": "Body", "default": "A look at what these cameras can still do, filmed by our team and the BFC Film Club community." },
    { "type": "video", "id": "video_upload", "label": "Video (uploaded)", "info": "Upload an MP4 via Settings → Files." },
    { "type": "video_url", "id": "video_url", "label": "Video URL (YouTube or Vimeo)", "accept": ["youtube", "vimeo"], "info": "Used only if no video is uploaded above." },
    { "type": "image_picker", "id": "video_poster", "label": "Video poster image (recommended for YouTube/Vimeo)" },

    { "type": "header", "content": "Restoration section" },
    { "type": "text", "id": "resto_eyebrow", "label": "Eyebrow", "default": "Every camera, restored in-house" },
    { "type": "text", "id": "resto_title", "label": "Title", "default": "How we restore every Super 8" },
    {
      "type": "textarea",
      "id": "resto_body",
      "label": "Body",
      "default": "Every camera passes through our bench before it reaches yours. No shortcuts, no vague 'cleaned and tested' language — here's exactly what that means."
    },

    { "type": "header", "content": "Film pairing (quick-add)" },
    { "type": "collection", "id": "film_collection", "label": "Film collection", "info": "Point to your Super 8 film collection (or any related film/accessories collection)." },
    { "type": "range", "id": "film_limit", "label": "Max products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "film_title", "label": "Title", "info": "Use <em>word</em> around a word to italicize + orange-tint it.", "default": "Now <em>load it</em>." },
    { "type": "textarea", "id": "film_sub", "label": "Subhead (right-aligned)", "default": "Super 8 cartridges on the shelf, ready to pair with your camera." },
    { "type": "text", "id": "film_cta_text", "label": "Below-grid CTA text", "default": "Shop all Super 8 film" },
    { "type": "url",  "id": "film_cta_link", "label": "Below-grid CTA link" },

    { "type": "header", "content": "Gallery — shot on Super 8" },
    { "type": "text", "id": "gallery_eyebrow", "label": "Eyebrow", "default": "Community · #BFCFilmClub" },
    { "type": "text", "id": "gallery_title", "label": "Title", "info": "Use <em>word</em> to italicize and orange-tint a word.", "default": "Shot on <em>Super 8</em>." },
    { "type": "textarea", "id": "gallery_sub", "label": "Subhead (right-aligned)", "default": "What these cameras are capturing out in the world. Tag #BFCFilmClub on Instagram to be featured." },
    { "type": "text", "id": "gallery_footer_text", "label": "Below-grid link text", "default": "See more on Instagram →" },
    { "type": "url",  "id": "gallery_footer_link", "label": "Below-grid link URL" },

    { "type": "header", "content": "FAQ — good to know" },
    { "type": "text", "id": "faq_eyebrow", "label": "Eyebrow", "default": "Good to know" },
    { "type": "text", "id": "faq_title", "label": "Title", "default": "Common questions, <em>answered</em>." },
    { "type": "textarea", "id": "faq_helper", "label": "Helper text (right side of header)", "default": "Something we didn't cover? <a href=\"mailto:hello@brooklynfilmcamera.com\">Ask us directly.</a>" },

    { "type": "header", "content": "Closing" },
    { "type": "image_picker", "id": "close_image", "label": "Background image", "info": "Recommended: storefront, workshop, or editorial shot. Shot in wide landscape. Without an image, falls back to clean cream layout." },
    { "type": "text", "id": "close_eyebrow", "label": "Eyebrow", "default": "Come by" },
    { "type": "textarea", "id": "close_headline", "label": "Headline (italic serif)", "default": "See you at 855 Grand." },
    { "type": "textarea", "id": "close_body", "label": "Body", "default": "Our team shoots these every day. Pick a brain, try a viewfinder, or just say hi — the shop's open seven days a week." },
    { "type": "text", "id": "close_cta_text", "label": "Button text", "default": "Get directions" },
    { "type": "url",  "id": "close_cta_link", "label": "Button link" },
