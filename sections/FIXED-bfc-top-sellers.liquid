              white-space: nowrap;
            }
            #{{ block_id }} .bfc-ts__add-btn:hover{
              background: color-mix(in srgb, var(--bfc-ts-fg) 7%, transparent);
            }
            #{{ block_id }} .bfc-ts__add-btn[disabled]{ opacity: .45; cursor: not-allowed; }
            #{{ block_id }} .bfc-ts__arrow{
              position: absolute;
              top: 50%;
              transform: translateY(-50%);
              z-index: 3;
              width: 40px;
              height: 40px;
              border-radius: var(--bfc-ts-radius);
              border: 1px solid var(--bfc-ts-border);
              background: {{ base_bg }};
              opacity: .86;
              backdrop-filter: blur(6px);
              cursor: pointer;
              display: none;
              align-items: center;
              justify-content: center;
              font-size: 22px;
              line-height: 1;
              color: var(--bfc-ts-fg);
            }
            #{{ block_id }} .bfc-ts__arrow--prev{ left: 10px; }
            #{{ block_id }} .bfc-ts__arrow--next{ right: 10px; }
            @media (min-width: 990px){
              #{{ block_id }} .bfc-ts__arrow{ display: flex; }
              #{{ block_id }} .bfc-ts__rail{ padding-bottom: 10px; }
            }
            #{{ block_id }} .bfc-ts__fade{
              position: absolute;
              top: 0;
              bottom: 0;
              width: 44px;
              z-index: 2;
              pointer-events: none;
            }
            #{{ block_id }} .bfc-ts__fade--left{
              left: 0;
              background: linear-gradient(to right, {{ base_bg }}, {{ base_bg }}00);
            }
            #{{ block_id }} .bfc-ts__fade--right{
              right: 0;
              background: linear-gradient(to left, {{ base_bg }}, {{ base_bg }}00);
            }
            @media (max-width: 749px){
              #{{ block_id }} .bfc-ts__rail{
                grid-auto-columns: 78vw;
                gap: 12px;
              }
            }
          </style>
          <script>
            (function(){
              const root = document.getElementById('{{ block_id }}');
              if (!root) return;
              const rail = root.querySelector('[data-bfc-ts-rail]');
              const prev = root.querySelector('[data-bfc-ts-prev]');
              const next = root.querySelector('[data-bfc-ts-next]');
              if (!rail) return;
              const prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
              const behavior = prefersReduced ? 'auto' : 'smooth';
              function scrollByAmount(dir) {
                const amount = Math.max(240, Math.floor(rail.clientWidth * 0.85));
                rail.scrollBy({ left: dir * amount, behavior });
              }
              function updateArrows() {
                if (!prev || !next) return;
                const max = rail.scrollWidth - rail.clientWidth - 2;
                prev.disabled = rail.scrollLeft <= 2;
                next.disabled = rail.scrollLeft >= max;
                prev.style.opacity = prev.disabled ? '0.35' : '1';
                next.style.opacity = next.disabled ? '0.35' : '1';
              }
              if (prev) prev.addEventListener('click', () => scrollByAmount(-1));
              if (next) next.addEventListener('click', () => scrollByAmount(1));
              root.addEventListener('submit', function(event) {
                const form = event.target;
                if (!form.classList || !form.classList.contains('bfc-ts__add')) return;
                event.preventDefault();
                const button = form.querySelector('button');
                if (button) { button.disabled = true; button.setAttribute('aria-busy', 'true'); }
                const formData = new FormData(form);
                if (!formData.get('quantity')) formData.append('quantity', '1');
                const body = new URLSearchParams(formData).toString();
                fetch('{{ routes.cart_add_url }}.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8', 'X-Requested-With': 'XMLHttpRequest' },
                  body: body,
                  credentials: 'same-origin'
                })
                .then(res => { if (!res.ok) throw new Error('Add to cart failed'); return res.json(); })
                .then(() => fetch('/cart/update.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                  body: JSON.stringify({ updates: {}, sections: ['cart-drawer', 'cart-icon-bubble'], sections_url: window.location.pathname }),
                  credentials: 'same-origin'
                }))
                .then(res => { if (!res.ok) throw new Error('Cart update failed'); return res.json(); })
                .then(state => {
                  const drawer = document.querySelector('cart-drawer');
                  if (drawer && typeof drawer.renderContents === 'function') drawer.renderContents(state);
                  if (drawer && typeof drawer.open === 'function') drawer.open();
                })
                .catch(err => console.error('Quick add failed', err))
                .finally(() => { if (button) { button.disabled = false; button.removeAttribute('aria-busy'); } });
              });
              rail.addEventListener('scroll', () => window.requestAnimationFrame(updateArrows), { passive: true });
              window.addEventListener('resize', () => window.requestAnimationFrame(updateArrows));
              updateArrows();
            })();
          </script>
        </section>
    {% endcase %}
  {% endfor %}
</section>
