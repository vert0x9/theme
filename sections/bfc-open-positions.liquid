<script>
(function () {
  var root = document.getElementById("bfc-openings-{{ section.id }}");
  if (!root) return;

  var tabs = Array.prototype.slice.call(root.querySelectorAll(".bfc-tab"));
  var panels = {
    fulltime: root.querySelector("#panel-fulltime-{{ section.id }}"),
    parttime: root.querySelector("#panel-parttime-{{ section.id }}"),
    other:    root.querySelector("#panel-other-{{ section.id }}")
  };

  function setActive(key) {
    tabs.forEach(function (t) {
      t.setAttribute("aria-selected", t.getAttribute("data-tab") === key ? "true" : "false");
    });
    Object.keys(panels).forEach(function (k) {
      if (panels[k]) panels[k].hidden = (k !== key);
    });
  }

  // Default to first tab with listings
  var defaultTab = "fulltime";
  var order = ["fulltime", "parttime", "other"];
  for (var i = 0; i < order.length; i++) {
    var p = panels[order[i]];
    if (p && p.querySelectorAll('[data-listing="true"]').length > 0) {
      defaultTab = order[i];
      break;
    }
  }
  setActive(defaultTab);

  tabs.forEach(function (tab) {
    tab.addEventListener("click", function (e) {
      e.preventDefault();
      setActive(tab.getAttribute("data-tab"));
    });
  });

  root.querySelectorAll(".bfc-accordion-toggle").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var expanded = btn.getAttribute("aria-expanded") === "true";
      var content  = root.querySelector("#" + btn.getAttribute("aria-controls"));
      btn.setAttribute("aria-expanded", expanded ? "false" : "true");
      if (content) content.hidden = expanded;
    });
  });

  root.querySelectorAll("[data-email]").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var email = btn.getAttribute("data-email");
      function flash() {
        var prev = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(function () { btn.textContent = prev; }, 1400);
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(email).then(flash).catch(function () { window.prompt("Copy email:", email); });
      } else {
        window.prompt("Copy email:", email);
      }
    });
  });
})();
</script>

