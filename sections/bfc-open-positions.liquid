{%- comment -%}
  BFC Open Positions — Schema-driven Liquid section
  Add, edit, and reorder job listings entirely from the Shopify theme editor.
  No code edits needed for content changes.
{%- endcomment -%}

{%- liquid
  assign ft_count = 0
  assign pt_count = 0
  assign ot_count = 0
  for block in section.blocks
    if block.type == 'job_listing'
      if block.settings.category == 'fulltime'
        assign ft_count = ft_count | plus: 1
      elsif block.settings.category == 'parttime'
        assign pt_count = pt_count | plus: 1
      elsif block.settings.category == 'other'
        assign ot_count = ot_count | plus: 1
      endif
    endif
  endfor
-%}

<div id="bfc-openings-{{ section.id }}" class="bfc-openings" role="region" aria-label="Open Positions">

  <div class="bfc-header">
    <p class="bfc-eyebrow">Brooklyn Film Camera</p>
    <h1 class="bfc-title">Open<br>Positions</h1>
    <div class="bfc-rule" aria-hidden="true"></div>
  </div>

  <!-- Tabs -->
  <div class="bfc-tabs" role="tablist" aria-label="Open Positions Categories">
    <button type="button" id="tab-fulltime-{{ section.id }}" class="bfc-tab" role="tab" data-tab="fulltime"
      aria-controls="panel-fulltime-{{ section.id }}" aria-selected="false">
      <span class="bfc-tab-label">Full Time</span>
      <span class="bfc-tab-count" aria-label="{{ ft_count }} open {{ ft_count | pluralize: 'role', 'roles' }}">{{ ft_count }}</span>
    </button>
    <button type="button" id="tab-parttime-{{ section.id }}" class="bfc-tab" role="tab" data-tab="parttime"
      aria-controls="panel-parttime-{{ section.id }}" aria-selected="false">
      <span class="bfc-tab-label">Part Time</span>
      <span class="bfc-tab-count" aria-label="{{ pt_count }} open {{ pt_count | pluralize: 'role', 'roles' }}">{{ pt_count }}</span>
    </button>
    <button type="button" id="tab-other-{{ section.id }}" class="bfc-tab" role="tab" data-tab="other"
      aria-controls="panel-other-{{ section.id }}" aria-selected="false">
      <span class="bfc-tab-label">Other</span>
      <span class="bfc-tab-count" aria-label="{{ ot_count }} open {{ ot_count | pluralize: 'role', 'roles' }}">{{ ot_count }}</span>
    </button>
  </div>

  <!-- ═══════════════════ FULL TIME ═══════════════════ -->
  <section class="bfc-panel" id="panel-fulltime-{{ section.id }}" role="tabpanel"
    aria-labelledby="tab-fulltime-{{ section.id }}" hidden>
    <div class="bfc-stack">
      {%- if ft_count == 0 -%}
        <article class="bfc-card bfc-card--empty">
          <div class="bfc-empty-icon" aria-hidden="true">—</div>
          <h3 class="bfc-empty-title">No full time roles right now</h3>
          <p class="bfc-muted">
            Check back soon, or send a quick intro to
            <a href="mailto:hello@brooklynfilmcamera.com">hello@brooklynfilmcamera.com</a>.
          </p>
        </article>
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'job_listing' and block.settings.category == 'fulltime' -%}
          {%- liquid
            assign b = block.settings
          -%}
          <article class="bfc-card bfc-accordion" data-listing="true" {{ block.shopify_attributes }}>
            <header class="bfc-card-head">
              <button class="bfc-accordion-toggle" type="button" aria-expanded="false"
                aria-controls="job-content-{{ section.id }}-{{ block.id | replace: '-', '' }}">
                <div class="bfc-card-title-block">
                  <span class="bfc-role-title">{{ b.title }}</span>
                  <span class="bfc-meta-row">
                    {%- assign tag_type_val = b.tag_type | strip -%}{%- if tag_type_val != blank -%}<span class="bfc-tag">{{ tag_type_val }}</span>{%- endif -%}
                    {%- assign tag_location_val = b.tag_location | strip -%}{%- if tag_location_val != blank -%}<span class="bfc-tag">{{ tag_location_val }}</span>{%- endif -%}
                    {%- assign tag_extra_val = b.tag_extra | strip -%}{%- if tag_extra_val != blank -%}<span class="bfc-tag">{{ tag_extra_val }}</span>{%- endif -%}
                    {%- assign tag_pay_val = b.tag_pay | strip -%}{%- if tag_pay_val != blank -%}<span class="bfc-tag bfc-tag--pay">{{ tag_pay_val }}</span>{%- endif -%}
                    {%- assign tag_hours_val = b.tag_hours | strip -%}{%- if tag_hours_val != blank -%}<span class="bfc-tag bfc-tag--hours">{{ tag_hours_val }}</span>{%- endif -%}
                    {%- assign tag_exp_val = b.tag_experience | strip -%}{%- if tag_exp_val != blank -%}<span class="bfc-tag bfc-tag--exp">{{ tag_exp_val }}</span>{%- endif -%}
                  </span>
                </div>
                <svg class="bfc-caret" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M7 10l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </button>
            </header>
            <div id="job-content-{{ section.id }}-{{ block.id | replace: '-', '' }}" class="bfc-accordion-content" hidden>
              <div class="bfc-card-text">
                {%- if b.intro != blank -%}<p class="bfc-intro">{{ b.intro }}</p>{%- endif -%}
                {%- if b.responsibilities != blank -%}
                  <h4>Responsibilities</h4>
                  <ul>
                    {%- assign resp_lines = b.responsibilities | newline_to_br | split: '<br />' -%}
                    {%- for line in resp_lines -%}{%- assign lc = line | strip -%}{%- if lc != blank -%}<li>{{ lc }}</li>{%- endif -%}{%- endfor -%}
                  </ul>
                {%- endif -%}
                {%- if b.requirements != blank -%}
                  <h4>Requirements</h4>
                  <ul>
                    {%- assign req_lines = b.requirements | newline_to_br | split: '<br />' -%}
                    {%- for line in req_lines -%}{%- assign lc = line | strip -%}{%- if lc != blank -%}<li>{{ lc }}</li>{%- endif -%}{%- endfor -%}
                  </ul>
                {%- endif -%}
                {%- if b.nice_to_have != blank -%}
                  <h4>Nice to Have</h4>
                  <ul>
                    {%- assign nth_lines = b.nice_to_have | newline_to_br | split: '<br />' -%}
                    {%- for line in nth_lines -%}{%- assign lc = line | strip -%}{%- if lc != blank -%}<li>{{ lc }}</li>{%- endif -%}{%- endfor -%}
                  </ul>
                {%- endif -%}
                <h4>How to Apply</h4>
                {%- if b.apply_method == 'email' -%}
                  <p>{{ b.apply_label }} Email <a href="mailto:{{ b.apply_email }}?subject={{ b.apply_email_subject | url_encode }}">{{ b.apply_email }}</a>.</p>
                {%- else -%}
                  <p>{{ b.apply_label }}{%- if b.apply_url != blank %} <a href="{{ b.apply_url }}" target="_blank" rel="noopener">Apply here</a>.{%- endif -%}</p>
                {%- endif -%}
              </div>
              <div class="bfc-action-row">
                {%- if b.apply_method == 'email' -%}
                  <a class="bfc-btn bfc-btn--primary" href="mailto:{{ b.apply_email }}?subject={{ b.apply_email_subject | url_encode }}">{{ b.apply_btn_label }}</a>
                  <button type="button" class="bfc-btn bfc-btn--ghost" data-email="{{ b.apply_email }}">Copy Email</button>
                {%- elsif b.apply_url != blank -%}
                  <a class="bfc-btn bfc-btn--primary" href="{{ b.apply_url }}" target="_blank" rel="noopener">{{ b.apply_btn_label }}</a>
                {%- endif -%}
              </div>
            </div>
          </article>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </section>

