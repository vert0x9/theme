<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Poppins:wght@400;500;600;700;900&display=swap');

  #bfc-openings-{{ section.id }} {
    --ink:       #202009;
    --canvas:    #F8F6EE;
    --orange:    #E36E15;
    --golden:    #F4A027;
    --olive:     #525741;
    --celadon:   #ABCC99;
    --border:    rgba(32,32,9,.12);
    --shadow:    0 4px 20px rgba(32,32,9,.07);
    --shadow-lg: 0 10px 32px rgba(32,32,9,.12);
  }

  #bfc-openings-{{ section.id }} {
    font-family: 'Poppins', system-ui, sans-serif;
    color: var(--ink);
    background: var(--canvas);
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(32px, 5vw, 64px) clamp(24px, 4vw, 48px);
  }

  #bfc-openings-{{ section.id }} .bfc-header { margin-bottom: 52px; }

  #bfc-openings-{{ section.id }} .bfc-eyebrow {
    font-family: 'Poppins', sans-serif;
    font-size: .9rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--orange);
    margin: 0 0 14px;
  }

  #bfc-openings-{{ section.id }} .bfc-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(60px, 9vw, 100px);
    font-weight: 700;
    line-height: .92;
    letter-spacing: -.02em;
    margin: 0 0 18px;
    color: var(--ink);
  }

  #bfc-openings-{{ section.id }} .bfc-rule {
    width: 48px;
    height: 3px;
    background: var(--orange);
    border: none;
    margin: 0;
  }

  #bfc-openings-{{ section.id }} .bfc-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 28px;
    border-bottom: 2px solid var(--border);
  }

  #bfc-openings-{{ section.id }} .bfc-tab {
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    padding: .9rem 1.8rem;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: .95rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color .15s, border-color .15s;
    line-height: 1;
    color: color-mix(in srgb, var(--ink) 45%, transparent);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  #bfc-openings-{{ section.id }} .bfc-tab:hover { color: var(--ink); }

  #bfc-openings-{{ section.id }} .bfc-tab[aria-selected="true"] {
    color: var(--ink);
    border-bottom-color: var(--orange);
  }

  #bfc-openings-{{ section.id }} .bfc-tab-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 7px;
    font-family: 'Poppins', sans-serif;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: 0;
    color: color-mix(in srgb, var(--ink) 55%, transparent);
    background: var(--canvas);
    border: 1px solid var(--border);
    transition: background .15s, color .15s, border-color .15s;
  }

  #bfc-openings-{{ section.id }} .bfc-tab[aria-selected="true"] .bfc-tab-count {
    background: var(--orange);
    color: #fff;
    border-color: var(--orange);
  }

  #bfc-openings-{{ section.id }} .bfc-panel[hidden] { display: none !important; }
  #bfc-openings-{{ section.id }} .bfc-stack { display: grid; gap: 18px; }

  #bfc-openings-{{ section.id }} .bfc-card {
    background: #fff;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: box-shadow .2s, transform .2s;
  }

  #bfc-openings-{{ section.id }} .bfc-card[data-listing="true"]:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  #bfc-openings-{{ section.id }} .bfc-card-head { margin: 0; }

  #bfc-openings-{{ section.id }} .bfc-accordion-toggle {
    display: flex;
    align-items: center;
