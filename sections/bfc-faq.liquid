{{ 'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap' | stylesheet_tag }}

<style>
  .bfc-faq-section *,
  .bfc-faq-section *::before,
  .bfc-faq-section *::after {
    box-sizing: border-box;
  }

  .bfc-faq-section {
    position: relative;
    background: {{ section.settings.bg_color }};
    color: #E8E0D4;
    font-family: 'DM Sans', sans-serif;
    overflow: hidden;
  }

  /* Grain overlay */
  .bfc-faq-section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  .bfc-faq__inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
    margin: 0 auto;
    padding: 80px 24px 120px;
  }

  .bfc-faq__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #D4A853;
    margin: 0 0 18px;
  }

  .bfc-faq__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(38px, 6vw, 58px);
    font-weight: 400;
    line-height: 1.1;
    color: #F0E8DC;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .bfc-faq__title em {
    font-style: italic;
    color: #D4A853;
  }

  .bfc-faq__subtitle {
    font-family: 'Lora', Georgia, serif;
    font-size: 16px;
    color: #7A7067;
    line-height: 1.7;
    margin: 0 0 52px;
  }

  .bfc-faq__subtitle a {
    color: #D4A853;
    text-decoration: none;
    border-bottom: 1px solid rgba(212, 168, 83, 0.3);
    transition: border-color 0.2s;
  }

  .bfc-faq__subtitle a:hover {
    border-color: #D4A853;
  }

  /* Search */
  .bfc-faq__search-wrap {
    position: relative;
    margin-bottom: 40px;
  }

  .bfc-faq__search-icon {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    color: #5A5048;
    font-size: 18px;
    pointer-events: none;
    line-height: 1;
  }

  .bfc-faq__search {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 14px 18px 14px 46px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #E8E0D4;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    -webkit-appearance: none;
  }

  .bfc-faq__search::placeholder {
    color: #4A4440;
  }

  .bfc-faq__search:focus {
    border-color: rgba(212, 168, 83, 0.35);
    background: rgba(255, 255, 255, 0.06);
  }

  /* Category filter */
  .bfc-faq__cats {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 36px;
    padding: 0;
    list-style: none;
  }

  .bfc-faq__cat-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 7px 16px;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: transparent;
    color: #7A7067;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    line-height: 1;
  }

  .bfc-faq__cat-btn:hover {
    border-color: rgba(212, 168, 83, 0.35);
    color: #D4A853;
  }

  .bfc-faq__cat-btn[aria-pressed="true"] {
    background: #D4A853;
    border-color: #D4A853;
    color: #1A1714;
  }

  /* Count */
  .bfc-faq__count {
    font-size: 12px;
    font-family: 'DM Sans', sans-serif;
    color: #4A4440;
    letter-spacing: 0.04em;
    margin: 0 0 14px;
    min-height: 18px;
  }

  /* Best answer panel */
  .bfc-faq__best {
    border: 1px solid #D4A853;
    background: rgba(212, 168, 83, 0.06);
    padding: 18px 20px;
    margin: 0 0 22px;
  }
  .bfc-faq__best[hidden] { display: none; }
  .bfc-faq__best-label {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #D4A853;
    margin-bottom: 8px;
  }
  .bfc-faq__best-q {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    line-height: 1.3;
    color: #F0E8DC;
    margin: 0 0 8px;
  }
  .bfc-faq__best-a {
    font-family: 'Lora', serif;
    font-size: 15px;
    line-height: 1.6;
    color: #B8AFA5;
    margin: 0;
  }
  .bfc-faq__best-a a { color: #D4A853; }

  /* Accordion */
  .bfc-faq__list {
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 8px;
    overflow: hidden;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .bfc-faq__item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    transition: background 0.2s;
  }

  .bfc-faq__item:last-child {
    border-bottom: none;
  }

  .bfc-faq__item.is-open {
    background: rgba(255, 255, 255, 0.03);
  }

  .bfc-faq__item[aria-hidden="true"] {
    display: none;
  }

  .bfc-faq__trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 22px 28px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
    color: inherit;
  }

  .bfc-faq__question {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 16px;
    font-weight: 500;
    color: #E8E0D4;
    line-height: 1.45;
    transition: color 0.25s;
    flex: 1;
  }

  .bfc-faq__item.is-open .bfc-faq__question {
    color: #D4A853;
  }

  .bfc-faq__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    margin-top: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7A7067;
    font-size: 22px;
    line-height: 1;
    transition: color 0.25s, transform 0.3s ease;
    transform: rotate(0deg);
    user-select: none;
  }

  .bfc-faq__item.is-open .bfc-faq__icon {
    color: #D4A853;
    transform: rotate(45deg);
  }

  .bfc-faq__body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bfc-faq__item.is-open .bfc-faq__body {
    max-height: 600px;
  }

  .bfc-faq__answer {
    padding: 0 28px 24px;
    font-family: 'Lora', Georgia, serif;
    font-size: 15px;
    line-height: 1.75;
    color: #B8AFA5;
    margin: 0;
    max-width: 640px;
  }

  .bfc-faq__video-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 14px 0 0 28px;
    margin-bottom: 24px;
    font-size: 12px;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #D4A853;
    text-decoration: none;
    border-bottom: 1px solid rgba(212, 168, 83, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .bfc-faq__video-link:hover {
    border-color: #D4A853;
  }

  /* No results */
  .bfc-faq__empty {
    padding: 60px 28px;
    text-align: center;
    color: #4A4440;
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 16px;
    display: none;
  }

  .bfc-faq__empty.is-visible {
    display: block;
  }

  /* Contact strip */
  .bfc-faq__contact {
    margin-top: 52px;
    padding: 28px 32px;
    border: 1px solid rgba(212, 168, 83, 0.15);
    border-radius: 8px;
    background: rgba(212, 168, 83, 0.04);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .bfc-faq__contact-text {
    font-family: 'Lora', serif;
    font-size: 15px;
    color: #7A7067;
    line-height: 1.6;
    margin: 0;
  }

  .bfc-faq__contact-text strong {
    color: #C8C0B5;
    font-weight: 500;
  }

  .bfc-faq__contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #D4A853;
    text-decoration: none;
    white-space: nowrap;
    padding: 10px 20px;
    border: 1px solid rgba(212, 168, 83, 0.4);
    border-radius: 4px;
    transition: background 0.2s, border-color 0.2s;
  }

  .bfc-faq__contact-link:hover {
    background: rgba(212, 168, 83, 0.1);
    border-color: #D4A853;
  }

  @media (max-width: 600px) {
    .bfc-faq__inner {
      padding: 56px 16px 80px;
    }

    .bfc-faq__trigger {
      padding: 18px 20px;
    }

    .bfc-faq__answer {
      padding: 0 20px 20px;
    }

    .bfc-faq__video-link {
      margin-left: 20px;
      margin-bottom: 20px;
    }

    .bfc-faq__contact {
      padding: 22px 20px;
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<section
  class="bfc-faq-section"
  id="bfc-faq-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="bfc-faq__inner">

    <p class="bfc-faq__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="bfc-faq__title">{{ section.settings.title }}</h1>
    <p class="bfc-faq__subtitle">
      {{ section.settings.subtitle }}
      {% if section.settings.contact_email != blank %}
        <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_cta }}</a>
      {% endif %}
    </p>

    <!-- Search -->
    <div class="bfc-faq__search-wrap">
      <span class="bfc-faq__search-icon" aria-hidden="true">&#x2315;</span>
      <input
        class="bfc-faq__search"
        id="bfc-faq-search-{{ section.id }}"
        type="search"
        placeholder="Search questions..."
        aria-label="Search FAQ"
        autocomplete="off"
      >
    </div>

    <!-- Category filters -->
    <ul class="bfc-faq__cats" id="bfc-faq-cats-{{ section.id }}" role="list">
      <li>
        <button class="bfc-faq__cat-btn" data-cat="all" aria-pressed="true">All</button>
      </li>
      {% assign cats_used = '' %}
      {% for block in section.blocks %}
        {% assign cat_key = block.settings.category %}
        {% unless cats_used contains cat_key %}
          {% assign cats_used = cats_used | append: cat_key | append: ',' %}
          <li>
            <button class="bfc-faq__cat-btn" data-cat="{{ cat_key }}" aria-pressed="false">
              {{ block.settings.category_label }}
            </button>
          </li>
        {% endunless %}
      {% endfor %}
    </ul>

    <!-- Count label -->
    <p class="bfc-faq__count" id="bfc-faq-count-{{ section.id }}" aria-live="polite"></p>

    <!-- Best answer panel (shown only while searching, surfaces the top match) -->
    <div class="bfc-faq__best" id="bfc-faq-best-{{ section.id }}" aria-live="polite" hidden>
      <span class="bfc-faq__best-label">Best answer</span>
      <p class="bfc-faq__best-q" id="bfc-faq-best-q-{{ section.id }}"></p>
      <p class="bfc-faq__best-a" id="bfc-faq-best-a-{{ section.id }}"></p>
    </div>

    <!-- Accordion list -->
    <ul class="bfc-faq__list" id="bfc-faq-list-{{ section.id }}" role="list">
      {% for block in section.blocks %}
        <li
          class="bfc-faq__item"
          data-cat="{{ block.settings.category }}"
          data-idx="{{ forloop.index }}"
          data-q="{{ block.settings.question | downcase | escape }}"
          data-a="{{ block.settings.answer | downcase | escape }}"
          data-k="{{ block.settings.keywords | downcase | escape }}"
          {{ block.shopify_attributes }}
        >
          <button
            class="bfc-faq__trigger"
            aria-expanded="false"
            aria-controls="bfc-faq-body-{{ section.id }}-{{ forloop.index }}"
          >
            <span class="bfc-faq__question">{{ block.settings.question }}</span>
            <span class="bfc-faq__icon" aria-hidden="true">+</span>
          </button>

          <div
            class="bfc-faq__body"
            id="bfc-faq-body-{{ section.id }}-{{ forloop.index }}"
            role="region"
          >
            <p class="bfc-faq__answer">{{ block.settings.answer }}</p>
            {% if block.settings.video_url != blank %}
              <a
                class="bfc-faq__video-link"
                href="{{ block.settings.video_url }}"
                target="_blank"
                rel="noopener noreferrer"
              >
                &#x25BA; {{ block.settings.video_label | default: 'Watch video' }}
              </a>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>

    <div class="bfc-faq__empty" id="bfc-faq-empty-{{ section.id }}" aria-live="polite">
      No results found &mdash; try a different search.
    </div>

    <!-- Contact strip -->
    <div class="bfc-faq__contact">
      <p class="bfc-faq__contact-text">
        <strong>{{ section.settings.contact_heading }}</strong><br>
        {{ section.settings.contact_subtext }}
      </p>
      {% if section.settings.contact_email != blank %}
        <a class="bfc-faq__contact-link" href="mailto:{{ section.settings.contact_email }}">
          {{ section.settings.contact_btn_label }} &rarr;
        </a>
      {% endif %}
    </div>

  </div>
</section>

<script>
(function() {
  var sid = {{ section.id | json }};
  var root  = document.getElementById('bfc-faq-' + sid);
  if (!root) return;

  var searchInput = document.getElementById('bfc-faq-search-' + sid);
  var catStrip    = document.getElementById('bfc-faq-cats-' + sid);
  var countEl     = document.getElementById('bfc-faq-count-' + sid);
  var listEl      = document.getElementById('bfc-faq-list-' + sid);
  var emptyEl     = document.getElementById('bfc-faq-empty-' + sid);
  var bestEl      = document.getElementById('bfc-faq-best-' + sid);
  var bestQEl     = document.getElementById('bfc-faq-best-q-' + sid);
  var bestAEl     = document.getElementById('bfc-faq-best-a-' + sid);
  var items       = Array.from(listEl.querySelectorAll('.bfc-faq__item'));
  var catBtns     = Array.from(catStrip.querySelectorAll('.bfc-faq__cat-btn'));

  var activecat = 'all';
  var searchVal = '';

  // ---------- accordion ----------
  listEl.addEventListener('click', function(e) {
    var trigger = e.target.closest('.bfc-faq__trigger');
    if (!trigger) return;
    var item = trigger.closest('.bfc-faq__item');
    var isOpen = item.classList.contains('is-open');

    // close all
    items.forEach(function(i) {
      i.classList.remove('is-open');
      i.querySelector('.bfc-faq__trigger').setAttribute('aria-expanded', 'false');
    });

    if (!isOpen) {
      item.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
    }
  });

  // ---------- category filter ----------
  catStrip.addEventListener('click', function(e) {
    var btn = e.target.closest('.bfc-faq__cat-btn');
    if (!btn) return;
    activecat = btn.getAttribute('data-cat');
    catBtns.forEach(function(b) {
      b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
    });
    applyFilters();
  });

  // ---------- search ----------
  searchInput.addEventListener('input', function() {
    searchVal = this.value.trim().toLowerCase();
    applyFilters();
  });

  // ---------- search helpers (no AI; classic token + synonym matching) ----------
  // Filler words ignored so "can i store my film in the fridge" reduces to
  // the meaningful tokens: store, film, fridge.
  var STOPWORDS = {
    'a':1,'an':1,'and':1,'are':1,'as':1,'at':1,'be':1,'but':1,'by':1,'can':1,
    'could':1,'did':1,'do':1,'does':1,'for':1,'from':1,'get':1,'got':1,'had':1,
    'has':1,'have':1,'how':1,'i':1,'if':1,'in':1,'into':1,'is':1,'it':1,'its':1,
    'just':1,'me':1,'my':1,'of':1,'on':1,'or':1,'our':1,'should':1,'so':1,'than':1,
    'that':1,'the':1,'their':1,'them':1,'then':1,'there':1,'these':1,'they':1,
    'this':1,'to':1,'up':1,'use':1,'want':1,'was':1,'we':1,'what':1,'when':1,
    'where':1,'which':1,'who':1,'will':1,'with':1,'would':1,'you':1,'your':1,'about':1
  };
  // Synonym groups: any term in a group matches the others. Edit freely.
  var SYNONYMS = [
    ['fridge','refrigerator','refrigerate','refrigerated','cold','chilled','freezer','freeze','frozen','store','storage','storing','keep','keeping'],
    ['develop','developing','development','process','processing','dev'],
    ['repair','repairs','fix','fixing','service','servicing','serviced','restore','restoration','cla'],
    ['ship','shipping','mail','mailing','post','send','sending','delivery','deliver'],
    ['price','prices','pricing','cost','costs','fee','fees','charge'],
    ['hours','open','opening','closing','close','schedule'],
    ['location','located','address','directions','visit','find'],
    ['expired','expiry','expiration'],
    ['warranty','guarantee','coverage','covered'],
    ['sx70','sx-70'],
    ['polaroid','instant'],
    ['pickup','collect','collection'],
    ['return','returns','refund','refunds','exchange'],
    ['scan','scans','scanning','digitize','digital','digitise'],
    ['negative','negatives','negs'],
    ['battery','batteries','power','charge','charging'],
    ['leak','leaks','fog','fogging'],
    ['buy','sell','selling','trade','consign','consignment','purchase'],
    ['format','formats','35mm','120'],
    ['membership','member','subscription','subscribe','plan']
  ];
  var SYN_INDEX = {};
  SYNONYMS.forEach(function(group) {
    group.forEach(function(term) {
      (SYN_INDEX[term] = SYN_INDEX[term] || []).push(group);
    });
  });
  function tokenize(str) {
    return (str || '')
      .toLowerCase()
      .replace(/[^a-z0-9\s-]/g, ' ')
      .split(/\s+/)
      .filter(function(w) { return w && !STOPWORDS[w]; });
  }
  function tokenMatches(token, haystack) {
    if (haystack.indexOf(token) !== -1) return true;
    var groups = SYN_INDEX[token];
    if (groups) {
      for (var g = 0; g < groups.length; g++) {
        for (var i = 0; i < groups[g].length; i++) {
          if (haystack.indexOf(groups[g][i]) !== -1) return true;
        }
      }
    }
    return false;
  }

  // Score how well an item matches the query tokens. Higher is better.
  // A hit in the question counts most, then keywords, then the answer body.
  // This lets us rank results and surface the single best one, all without AI.
  function scoreItem(item, queryTokens) {
    if (!queryTokens.length) return 0;
    var q = item.getAttribute('data-q') || '';
    var k = item.getAttribute('data-k') || '';
    var a = item.getAttribute('data-a') || '';
    var score = 0, matched = 0;
    for (var t = 0; t < queryTokens.length; t++) {
      var tok = queryTokens[t];
      var hit = false;
      if (tokenMatches(tok, q)) { score += 5; hit = true; }
      else if (tokenMatches(tok, k)) { score += 3; hit = true; }
      else if (tokenMatches(tok, a)) { score += 1; hit = true; }
      if (hit) matched++;
    }
    // Reward items that match more of the query (covers more of what was asked).
    if (matched === queryTokens.length) score += 4;
    score += matched * 2;
    return score;
  }

  // ---------- filter logic ----------
  function applyFilters() {
    var queryTokens = tokenize(searchVal);
    var searching = queryTokens.length > 0;
    var visible = 0;
    var scored = [];

    items.forEach(function(item) {
      var catMatch = activecat === 'all' || item.getAttribute('data-cat') === activecat;
      var score = searching ? scoreItem(item, queryTokens) : 0;
      // When searching, an item shows if it matches at least one query token.
      // When not searching, all items in the active category show.
      var show = catMatch && (!searching || score > 0);

      item.setAttribute('aria-hidden', show ? 'false' : 'true');
      item.style.display = show ? '' : 'none';

      if (!show) {
        item.classList.remove('is-open');
        item.querySelector('.bfc-faq__trigger').setAttribute('aria-expanded', 'false');
      }
      if (show) {
        visible++;
        if (searching) scored.push({ item: item, score: score });
      }
    });

    // Rank best-first when searching, and reflect that order in the DOM.
    if (searching && scored.length) {
      scored.sort(function(a, b) { return b.score - a.score; });
      scored.forEach(function(entry) { listEl.appendChild(entry.item); });
    } else {
      // Restore original author order when not searching.
      items.forEach(function(item) { listEl.appendChild(item); });
    }

    // Best-answer panel: surface the single top match while searching.
    if (searching && scored.length) {
      var top = scored[0].item;
      var qText = top.querySelector('.bfc-faq__question');
      var aText = top.querySelector('.bfc-faq__answer');
      bestQEl.textContent = qText ? qText.textContent : '';
      bestAEl.innerHTML = aText ? aText.innerHTML : '';
      bestEl.hidden = false;
      // Auto-expand the top match in the list too.
      items.forEach(function(i) {
        i.classList.remove('is-open');
        i.querySelector('.bfc-faq__trigger').setAttribute('aria-expanded', 'false');
      });
      top.classList.add('is-open');
      top.querySelector('.bfc-faq__trigger').setAttribute('aria-expanded', 'true');
    } else {
      bestEl.hidden = true;
      bestQEl.textContent = '';
      bestAEl.innerHTML = '';
    }

    // count label (only when not searching)
    if (!searching) {
      countEl.textContent = visible + (visible === 1 ? ' question' : ' questions');
    } else {
      countEl.textContent = '';
    }

    // empty state
    if (visible === 0) {
      emptyEl.classList.add('is-visible');
      listEl.style.display = 'none';
    } else {
      emptyEl.classList.remove('is-visible');
      listEl.style.display = '';
    }
  }

  // init count
  applyFilters();
})();
</script>

{%- assign faq_has_items = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'faq_item' and block.settings.question != blank and block.settings.answer != blank -%}
    {%- assign faq_has_items = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}
{%- if faq_has_items -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign faq_first = true -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq_item' and block.settings.question != blank and block.settings.answer != blank -%}
        {%- unless faq_first -%},{%- endunless -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }
        {%- assign faq_first = false -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

