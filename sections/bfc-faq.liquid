{{ 'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap' | stylesheet_tag }}

<style>
  .bfc-faq-section *,
  .bfc-faq-section *::before,
  .bfc-faq-section *::after {
    box-sizing: border-box;
  }

  .bfc-faq-section {
    position: relative;
    background: {{ section.settings.bg_color }};
    color: #E8E0D4;
    font-family: 'DM Sans', sans-serif;
    overflow: hidden;
  }

  /* Grain overlay */
  .bfc-faq-section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  .bfc-faq__inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
    margin: 0 auto;
    padding: 80px 24px 120px;
  }

  .bfc-faq__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #D4A853;
    margin: 0 0 18px;
  }

  .bfc-faq__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(38px, 6vw, 58px);
    font-weight: 400;
    line-height: 1.1;
    color: #F0E8DC;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .bfc-faq__title em {
    font-style: italic;
    color: #D4A853;
  }

  .bfc-faq__subtitle {
    font-family: 'Lora', Georgia, serif;
    font-size: 16px;
    color: #7A7067;
    line-height: 1.7;
    margin: 0 0 52px;
  }

  .bfc-faq__subtitle a {
    color: #D4A853;
    text-decoration: none;
    border-bottom: 1px solid rgba(212, 168, 83, 0.3);
    transition: border-color 0.2s;
  }

  .bfc-faq__subtitle a:hover {
    border-color: #D4A853;
  }

  /* Search */
  .bfc-faq__search-wrap {
    position: relative;
    margin-bottom: 40px;
  }

  .bfc-faq__search-icon {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    color: #5A5048;
    font-size: 18px;
    pointer-events: none;
    line-height: 1;
  }

  .bfc-faq__search {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 14px 18px 14px 46px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #E8E0D4;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    -webkit-appearance: none;
  }

  .bfc-faq__search::placeholder {
    color: #4A4440;
  }

  .bfc-faq__search:focus {
    border-color: rgba(212, 168, 83, 0.35);
    background: rgba(255, 255, 255, 0.06);
  }

  /* Category filter */
  .bfc-faq__cats {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 36px;
    padding: 0;
    list-style: none;
  }

  .bfc-faq__cat-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 7px 16px;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: transparent;
    color: #7A7067;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    line-height: 1;
  }

  .bfc-faq__cat-btn:hover {
    border-color: rgba(212, 168, 83, 0.35);
    color: #D4A853;
  }

  .bfc-faq__cat-btn[aria-pressed="true"] {
    background: #D4A853;
    border-color: #D4A853;
    color: #1A1714;
  }

  /* Count */
  .bfc-faq__count {
    font-size: 12px;
    font-family: 'DM Sans', sans-serif;
    color: #4A4440;
    letter-spacing: 0.04em;
    margin: 0 0 14px;
    min-height: 18px;
  }

  /* Accordion */
  .bfc-faq__list {
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 8px;
    overflow: hidden;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .bfc-faq__item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    transition: background 0.2s;
  }

  .bfc-faq__item:last-child {
    border-bottom: none;
  }

  .bfc-faq__item.is-open {
    background: rgba(255, 255, 255, 0.03);
  }

  .bfc-faq__item[aria-hidden="true"] {
    display: none;
  }

  .bfc-faq__trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 22px 28px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
    color: inherit;
  }

  .bfc-faq__question {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 16px;
    font-weight: 500;
    color: #E8E0D4;
    line-height: 1.45;
    transition: color 0.25s;
    flex: 1;
  }

  .bfc-faq__item.is-open .bfc-faq__question {
    color: #D4A853;
  }

  .bfc-faq__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    margin-top: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7A7067;
    font-size: 22px;
    line-height: 1;
    transition: color 0.25s, transform 0.3s ease;
    transform: rotate(0deg);
    user-select: none;
  }

  .bfc-faq__item.is-open .bfc-faq__icon {
    color: #D4A853;
    transform: rotate(45deg);
  }

  .bfc-faq__body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bfc-faq__item.is-open .bfc-faq__body {
    max-height: 600px;
  }

  .bfc-faq__answer {
    padding: 0 28px 24px;
    font-family: 'Lora', Georgia, serif;
    font-size: 15px;
    line-height: 1.75;
    color: #B8AFA5;
    margin: 0;
    max-width: 640px;
  }

  .bfc-faq__video-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 14px 0 0 28px;
    margin-bottom: 24px;
    font-size: 12px;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #D4A853;
    text-decoration: none;
    border-bottom: 1px solid rgba(212, 168, 83, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .bfc-faq__video-link:hover {
    border-color: #D4A853;
  }

  /* No results */
  .bfc-faq__empty {
    padding: 60px 28px;
    text-align: center;
    color: #4A4440;
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 16px;
    display: none;
  }

  .bfc-faq__empty.is-visible {
    display: block;
  }

  /* Contact strip */
  .bfc-faq__contact {
    margin-top: 52px;
    padding: 28px 32px;
    border: 1px solid rgba(212, 168, 83, 0.15);
    border-radius: 8px;
    background: rgba(212, 168, 83, 0.04);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .bfc-faq__contact-text {
    font-family: 'Lora', serif;
    font-size: 15px;
    color: #7A7067;
    line-height: 1.6;
    margin: 0;
  }

  .bfc-faq__contact-text strong {
    color: #C8C0B5;
    font-weight: 500;
  }

  .bfc-faq__contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #D4A853;
    text-decoration: none;
    white-space: nowrap;
    padding: 10px 20px;
    border: 1px solid rgba(212, 168, 83, 0.4);
    border-radius: 4px;
    transition: background 0.2s, border-color 0.2s;
  }

  .bfc-faq__contact-link:hover {
    background: rgba(212, 168, 83, 0.1);
    border-color: #D4A853;
  }

  @media (max-width: 600px) {
    .bfc-faq__inner {
      padding: 56px 16px 80px;
    }

    .bfc-faq__trigger {
      padding: 18px 20px;
    }

    .bfc-faq__answer {
      padding: 0 20px 20px;
    }

    .bfc-faq__video-link {
      margin-left: 20px;
      margin-bottom: 20px;
    }

    .bfc-faq__contact {
      padding: 22px 20px;
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<section
  class="bfc-faq-section"
  id="bfc-faq-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="bfc-faq__inner">

    <p class="bfc-faq__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="bfc-faq__title">{{ section.settings.title }}</h1>
    <p class="bfc-faq__subtitle">
      {{ section.settings.subtitle }}
      {% if section.settings.contact_email != blank %}
        <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_cta }}</a>
      {% endif %}
    </p>

    <!-- Search -->
    <div class="bfc-faq__search-wrap">
      <span class="bfc-faq__search-icon" aria-hidden="true">&#x2315;</span>
      <input
        class="bfc-faq__search"
        id="bfc-faq-search-{{ section.id }}"
        type="search"
        placeholder="Search questions..."
        aria-label="Search FAQ"
        autocomplete="off"
      >
    </div>

    <!-- Category filters -->
    <ul class="bfc-faq__cats" id="bfc-faq-cats-{{ section.id }}" role="list">
      <li>
        <button class="bfc-faq__cat-btn" data-cat="all" aria-pressed="true">All</button>
      </li>
      {% assign cats_used = '' %}
      {% for block in section.blocks %}
        {% assign cat_key = block.settings.category %}
        {% unless cats_used contains cat_key %}
          {% assign cats_used = cats_used | append: cat_key | append: ',' %}
          <li>
            <button class="bfc-faq__cat-btn" data-cat="{{ cat_key }}" aria-pressed="false">
              {{ block.settings.category_label }}
            </button>
          </li>
        {% endunless %}
      {% endfor %}
    </ul>

    <!-- Count label -->
    <p class="bfc-faq__count" id="bfc-faq-count-{{ section.id }}" aria-live="polite"></p>

    <!-- Accordion list -->
    <ul class="bfc-faq__list" id="bfc-faq-list-{{ section.id }}" role="list">
      {% for block in section.blocks %}
        <li
          class="bfc-faq__item"
          data-cat="{{ block.settings.category }}"
          data-q="{{ block.settings.question | downcase | escape }}"
          data-a="{{ block.settings.answer | downcase | escape }}"
          {{ block.shopify_attributes }}
        >
          <button
            class="bfc-faq__trigger"
            aria-expanded="false"
            aria-controls="bfc-faq-body-{{ section.id }}-{{ forloop.index }}"
          >
            <span class="bfc-faq__question">{{ block.settings.question }}</span>
            <span class="bfc-faq__icon" aria-hidden="true">+</span>
          </button>

          <div
            class="bfc-faq__body"
            id="bfc-faq-body-{{ section.id }}-{{ forloop.index }}"
            role="region"
          >
            <p class="bfc-faq__answer">{{ block.settings.answer }}</p>
            {% if block.settings.video_url != blank %}
              <a
                class="bfc-faq__video-link"
                href="{{ block.settings.video_url }}"
                target="_blank"
                rel="noopener noreferrer"
              >
                &#x25BA; {{ block.settings.video_label | default: 'Watch video' }}
              </a>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>

    <div class="bfc-faq__empty" id="bfc-faq-empty-{{ section.id }}" aria-live="polite">
      No results found &mdash; try a different search.
    </div>

    <!-- Contact strip -->
    <div class="bfc-faq__contact">
      <p class="bfc-faq__contact-text">
        <strong>{{ section.settings.contact_heading }}</strong><br>
        {{ section.settings.contact_subtext }}
      </p>
      {% if section.settings.contact_email != blank %}
        <a class="bfc-faq__contact-link" href="mailto:{{ section.settings.contact_email }}">
          {{ section.settings.contact_btn_label }} &rarr;
        </a>
      {% endif %}
    </div>

  </div>
</section>

<script>
(function() {
  var sid = {{ section.id | json }};
  var root  = document.getElementById('bfc-faq-' + sid);
  if (!root) return;

  var searchInput = document.getElementById('bfc-faq-search-' + sid);
  var catStrip    = document.getElementById('bfc-faq-cats-' + sid);
  var countEl     = document.getElementById('bfc-faq-count-' + sid);
  var listEl      = document.getElementById('bfc-faq-list-' + sid);
  var emptyEl     = document.getElementById('bfc-faq-empty-' + sid);
  var items       = Array.from(listEl.querySelectorAll('.bfc-faq__item'));
  var catBtns     = Array.from(catStrip.querySelectorAll('.bfc-faq__cat-btn'));

  var activecat = 'all';
  var searchVal = '';

  // ---------- accordion ----------
  listEl.addEventListener('click', function(e) {
    var trigger = e.target.closest('.bfc-faq__trigger');
    if (!trigger) return;
    var item = trigger.closest('.bfc-faq__item');
    var isOpen = item.classList.contains('is-open');

    // close all
    items.forEach(function(i) {
      i.classList.remove('is-open');
      i.querySelector('.bfc-faq__trigger').setAttribute('aria-expanded', 'false');
    });

    if (!isOpen) {
      item.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
    }
  });

  // ---------- category filter ----------
  catStrip.addEventListener('click', function(e) {
    var btn = e.target.closest('.bfc-faq__cat-btn');
    if (!btn) return;
    activecat = btn.getAttribute('data-cat');
    catBtns.forEach(function(b) {
      b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
    });
    applyFilters();
  });

  // ---------- search ----------
  searchInput.addEventListener('input', function() {
    searchVal = this.value.trim().toLowerCase();
    applyFilters();
  });

  // ---------- filter logic ----------
  function applyFilters() {
    var visible = 0;

    items.forEach(function(item) {
      var catMatch  = activecat === 'all' || item.getAttribute('data-cat') === activecat;
      var q = item.getAttribute('data-q') || '';
      var a = item.getAttribute('data-a') || '';
      var searchMatch = searchVal === '' || q.indexOf(searchVal) !== -1 || a.indexOf(searchVal) !== -1;
      var show = catMatch && searchMatch;

      item.setAttribute('aria-hidden', show ? 'false' : 'true');

      if (!show) {
        item.classList.remove('is-open');
        item.querySelector('.bfc-faq__trigger').setAttribute('aria-expanded', 'false');
      }

      if (show) visible++;
    });

    // count label (only when not searching)
    if (searchVal === '') {
      countEl.textContent = visible + (visible === 1 ? ' question' : ' questions');
    } else {
      countEl.textContent = '';
    }

    // empty state
    if (visible === 0) {
      emptyEl.classList.add('is-visible');
      listEl.style.display = 'none';
    } else {
      emptyEl.classList.remove('is-visible');
      listEl.style.display = '';
    }
  }

  // init count
  applyFilters();
})();
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Brooklyn Film Camera"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (use <em> for italic gold)",
      "default": "Got a <em>question?</em>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Quick answers on repairs, film developing, cameras, and visiting us."
    },
    {
      "type": "text",
      "id": "contact_cta",
      "label": "Subtitle link label",
      "default": "Still stuck? Email us."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1A1714"
    },
    {
      "type": "header",
      "content": "Contact strip"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Heading",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "contact_subtext",
      "label": "Subtext",
      "default": "Our team is at 855 Grand St, Brooklyn — open every day 11–8."
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "default": "hello@brooklynfilmcamera.com"
    },
    {
      "type": "text",
      "id": "contact_btn_label",
      "label": "Button label",
      "default": "Contact Us"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "select",
          "id": "category",
          "label": "Category (used for filtering)",
          "options": [
            { "value": "info",    "label": "Store Info" },
            { "value": "dev",     "label": "Film Dev" },
            { "value": "repairs", "label": "Repairs" },
            { "value": "sx70",    "label": "SX-70" },
            { "value": "cameras", "label": "Cameras" }
          ],
          "default": "info"
        },
        {
          "type": "text",
          "id": "category_label",
          "label": "Category button label",
          "info": "Shown in the filter strip (e.g. 'Store Info', 'Film Dev')",
          "default": "Store Info"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video link (optional)"
        },
        {
          "type": "text",
          "id": "video_label",
          "label": "Video link label",
          "default": "Watch video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "category": "info",
            "category_label": "Store Info",
            "question": "Where are you located and what are your hours?",
            "answer": "Open every day 11:00–8:00. Find us at 855 Grand Street, Brooklyn, NY 11211."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "category": "info",
            "category_label": "Store Info",
            "question": "How does in-store order pickup work?",
            "answer": "Pickup is available during all open hours. We'll email you when your order is fulfilled and ready to collect."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "category": "info",
            "category_label": "Store Info",
            "question": "Do you ship internationally?",
            "answer": "Yes — we ship to most regions worldwide. Free shipping on all US orders over $200."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "category": "info",
            "category_label": "Store Info",
            "question": "Can I sell you my gear?",
            "answer": "Absolutely. Bring your gear in person to our Brooklyn location. Please email photos first to hello@brooklynfilmcamera.com so we can give you a heads-up on interest before you make the trip."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "category": "info",
            "category_label": "Store Info",
            "question": "What is your returns and warranty policy?",
            "answer": "Polaroid cameras and SLRs include a 6-month warranty; point-and-shoots include a 3-month warranty. Warranty excludes body damage, drops, and water or moisture damage. See our full policy at brooklynfilmcamera.com/pages/warranty."
