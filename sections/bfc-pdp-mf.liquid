     ════════════════════════════════════════════════ {%- endcomment -%}
<div class="bfc4-toc" id="bfc4-toc" aria-label="Section navigation" role="navigation">
  <div class="bfc4-toc-inner">
    <ul class="bfc4-toc-links">
      <li><a href="#bfc4-top" data-toc="top" class="is-active">Overview</a></li>
      <li><a href="#bfc4-chapter" data-toc="chapter">Refurbishment</a></li>
      {%- if has_starter -%}<li><a href="#bfc4-custom" data-toc="custom">Kit</a></li>{%- endif -%}
      <li><a href="#bfc4-reviews" data-toc="reviews">Reviews</a></li>
