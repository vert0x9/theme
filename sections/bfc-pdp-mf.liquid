{{- 'section-product.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'product-variants.js' | asset_url }}" defer="defer"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet"/></noscript>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  assign g1 = product.metafields.custom.gallery_1.value
  assign g2 = product.metafields.custom.gallery_2.value
  assign g3 = product.metafields.custom.gallery_3.value
  assign g4 = product.metafields.custom.gallery_4.value
  assign g5 = product.metafields.custom.gallery_5.value
  assign g6 = product.metafields.custom.gallery_6.value

  assign spec_lens    = product.metafields.custom.spec_lens.value
  assign spec_shutter = product.metafields.custom.spec_shutterspeeds.value
  assign spec_mount   = product.metafields.custom.spec_lensmount.value
  assign spec_battery = product.metafields.custom.spec_battery.value
  assign spec_flash   = product.metafields.custom.spec_flash.value
  assign spec_tripod  = product.metafields.custom.spec_tripodmount.value
  assign spec_timer   = product.metafields.custom.spec_selftimer.value
  assign spec_dx      = product.metafields.custom.spec_dxcodereader.value
  assign spec_expcomp = product.metafields.custom.spec_exposurecompensation.value
  assign spec_meter   = product.metafields.custom.spec_meter.value
  assign spec_focus   = product.metafields.custom.spec_focus.value
-%}

<style>
.bfc4 *, .bfc4 *::before, .bfc4 *::after { box-sizing: border-box; margin: 0; padding: 0; }

.bfc4 {
  --or: #E36E15;
  --go: #F4A027;
  --ce: #ABCC99;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --gr: #E3DDDA;
  --sr: 'Cormorant Garamond', Georgia, serif;
  --sn: 'Poppins', sans-serif;
  --t:  0.2s ease;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
  /* overflow-clip clips overflow without creating a scroll container,
     so position: sticky on .bfc4-left still works. 96% browser support. */
  overflow-x: clip;
}

/* ── SPLIT LAYOUT ──────────────────────────── */
.bfc4-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: start;
}

/* ── LEFT: STICKY SLIDER ─────────────────── */
.bfc4-left {
  position: sticky;
  top: 0;
  width: 50vw;
  height: 50vw;
  max-height: 100vh;
  overflow: hidden;
  background: var(--gr);
}
.bfc4-slides {
  display: flex;
  width: 100%;
  height: 100%;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}
.bfc4-slide {
  min-width: 100%;
  height: 100%;
  flex-shrink: 0;
  position: relative;
}
.bfc4-slide img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
}
.bfc4-arrow {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  z-index: 10;
  background: rgba(32,32,9,0.3);
  border: none;
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background var(--t);
  backdrop-filter: blur(4px);
}
.bfc4-arrow:hover { background: rgba(32,32,9,0.6); }
.bfc4-arrow.is-prev { left: 16px; visibility: hidden; }
.bfc4-arrow.is-next { right: 16px; }
.bfc4-arrow svg { display: block; }
.bfc4-dots {
  position: absolute;
  bottom: 16px; left: 50%;
  transform: translateX(-50%);
  display: flex; gap: 6px; z-index: 10;
}
.bfc4-dot {
  width: 6px; height: 6px;
  background: rgba(255,255,255,0.4);
  border: none; cursor: pointer; padding: 0;
  transition: background var(--t), transform var(--t);
}
.bfc4-dot.is-active { background: #fff; transform: scale(1.3); }

/* ── RIGHT: SCROLLABLE CONTENT ───────────── */
.bfc4-right {
  background: var(--cv);
  padding: 18px 40px 56px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* ── FREE DEV MINI NOTE ──────────────────── */
.bfc4-free-dev-mini {
  display: flex; align-items: center; gap: 6px;
  font-size: 10px; color: #ABCC99; font-weight: 600;
  letter-spacing: 0.04em; margin-top: 8px;
}

/* ── GRADE COMPACT ───────────────────────── */
.bfc4-grade-compact {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 4px;
}
.bfc4-grade-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--ch); white-space: nowrap;
}
.bfc4-grade-compact .bfc4-grade-row { flex: 1; }
.bfc4-grade-compact .bfc4-var-btn { padding: 7px 8px; font-size: 10px; }

/* ── LEATHER COVER SWATCHES ──
   Color-circle picker for products with a "Leather Cover" option.
   Mirrors the SX-70 button-color swatch pattern: 22px circle filled
   with the leather's tone, a dark ring when selected, slashed when
   sold out. Color→hex lookup is below; anything not in the table
   falls back to a neutral border with the variant name showing on
   hover (via title attr). */
.bfc4-leather-compact {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 8px;
}
/* Mobile-only leather row sits right under the image so customers can
   see the photo swap when they tap. Hidden on desktop by default. */
.bfc4-leather-mobile {
  display: none;
  padding: 14px 20px 4px;
  background: var(--cv);
}
.bfc4-leather-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--ch); white-space: nowrap;
}
.bfc4-leather-row {
  flex: 1;
  display: flex; align-items: center; gap: 8px;
  flex-wrap: wrap;
}
.bfc4-leather-swatch {
  position: relative;
  width: 22px; height: 22px;
  padding: 0;
  border: 1px solid rgba(82,87,65,0.25);
  border-radius: 50%;
  background: var(--gr);
  cursor: pointer;
  font-size: 0;
  color: transparent;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  flex-shrink: 0;
}
.bfc4-leather-swatch:hover { transform: scale(1.12); }
.bfc4-leather-swatch.is-active {
  box-shadow: 0 0 0 2px var(--cv), 0 0 0 3px var(--bk);
}
.bfc4-leather-swatch[disabled] {
  opacity: 0.35; cursor: not-allowed;
}
.bfc4-leather-swatch[disabled]::after {
  content: '';
  position: absolute;
  inset: -2px;
  border-top: 1px solid var(--ch);
  transform: rotate(45deg);
  top: 50%;
}
/* Color → hex lookup. Add more as you stock more leathers. */
.bfc4-leather-swatch[data-leather="black"]    { background: #1a1a1a; border-color: rgba(0,0,0,0.25); }
.bfc4-leather-swatch[data-leather="brown"]    { background: #5e3a1f; border-color: rgba(0,0,0,0.2); }
.bfc4-leather-swatch[data-leather="tan"]      { background: #b48a5d; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="burgundy"] { background: #7a1f1f; border-color: rgba(0,0,0,0.2); }
.bfc4-leather-swatch[data-leather="bordeaux"] { background: #5e1a25; border-color: rgba(0,0,0,0.25); }
.bfc4-leather-swatch[data-leather="wine"]     { background: #6e1f2c; border-color: rgba(0,0,0,0.25); }
.bfc4-leather-swatch[data-leather="maroon"]   { background: #5d1a1a; border-color: rgba(0,0,0,0.25); }
.bfc4-leather-swatch[data-leather="oxblood"]  { background: #4a181a; border-color: rgba(0,0,0,0.25); }
.bfc4-leather-swatch[data-leather="red"]      { background: #c8362b; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="green"]    { background: #3a5c3a; border-color: rgba(0,0,0,0.2); }
.bfc4-leather-swatch[data-leather="blue"]     { background: #2b4566; border-color: rgba(0,0,0,0.2); }
.bfc4-leather-swatch[data-leather="navy"]     { background: #1f2d4a; border-color: rgba(0,0,0,0.25); }
.bfc4-leather-swatch[data-leather="gray"]     { background: #666660; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="grey"]     { background: #666660; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="cream"]    { background: #e8e2d4; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="white"]    { background: #f0eee6; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="ivory"]    { background: #ece4cf; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="orange"]   { background: #d46818; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="burnt"]    { background: #9c4115; border-color: rgba(0,0,0,0.2); }
.bfc4-leather-swatch[data-leather="rust"]     { background: #8a3a14; border-color: rgba(0,0,0,0.2); }
.bfc4-leather-swatch[data-leather="copper"]   { background: #a8541c; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="yellow"]   { background: #c8a72b; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-swatch[data-leather="purple"]   { background: #503966; border-color: rgba(0,0,0,0.2); }
.bfc4-leather-swatch[data-leather="pink"]     { background: #c97a8c; border-color: rgba(0,0,0,0.15); }
.bfc4-leather-name {
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--ch);
  margin-left: 2px;
}

/* ── TILE SELECTION ──────────────────────── */
.bfc4-tile { cursor: pointer; transition: border-color var(--t), box-shadow var(--t); }
.bfc4-tile.is-sel { border: 2px solid var(--or); box-shadow: 0 0 0 1px rgba(227,110,21,0.15); }
.bfc4-tile-sel-check {
  position: absolute; top: 6px; right: 6px;
  width: 18px; height: 18px; background: var(--or); color: #fff;
  font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center;
}

/* ── SELECTED ROW + BELOW CHECKOUT ───────── */
.bfc4-below-checkout {
  padding: 24px 48px 48px;
  background: var(--cv);

}
.bfc4-selected-row {
  display: flex;
  flex-direction: row;
  gap: 32px;
  align-items: flex-start;
  padding-top: 24px;
}
.bfc4-selected-items {
  flex: 1; min-width: 0;
  display: flex; flex-wrap: nowrap; gap: 12px; align-items: flex-start;
  overflow-x: auto; padding-bottom: 4px;
  justify-content: flex-start;
}
.bfc4-sel-item {
  display: flex; flex-direction: column; align-items: center; gap: 5px;
  width: 120px; flex-shrink: 0; cursor: pointer;
}
.bfc4-sel-item-img {
  width: 120px; height: 90px; object-fit: cover;
  border: 2px solid transparent; background: var(--gr);
  transition: border-color var(--t);
}
.bfc4-sel-item:not(.is-cam):hover .bfc4-sel-item-img { border-color: rgba(227,110,21,0.4); }
.bfc4-sel-item.is-sel .bfc4-sel-item-img { border-color: var(--or); }
.bfc4-sel-item.is-cam .bfc4-sel-item-img { border-color: var(--or); cursor: default; }
.bfc4-sel-item-img.is-placeholder {
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; background: var(--gr);
}
.bfc4-sel-item-name {
  font-size: 9px; color: var(--ch); text-align: center;
  line-height: 1.3; overflow: hidden; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.bfc4-below-atc { width: 220px; flex-shrink: 0; display: flex; flex-direction: column; gap: 8px; }

/* ── PRODUCT HEADER ──────────────────────── */
.bfc4-header {}
.bfc4-eyebrow {
  font-size: 9px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--ch); margin-bottom: 6px; display: block;
}
.bfc4-title {
  font-family: var(--sn); font-size: 28px; font-weight: 600;
  line-height: 1.1; letter-spacing: -0.3px; margin-bottom: 6px;
}
.bfc4-title em { font-style: normal; color: var(--ch); font-weight: 400; }
.bfc4-warranty {
  font-size: 10px; color: var(--ch); letter-spacing: 0.08em;
  display: flex; align-items: center; gap: 6px;
}
.bfc4-warranty::before {
  content: '';
  width: 16px; height: 1px; background: var(--ch); display: block;
}

/* ── BREADCRUMBS ─────────────────────────── */
.bfc4 .bfc4-crumbs {
  display: flex; flex-wrap: wrap; align-items: center;
  gap: 4px 6px;
  font-family: var(--sn);
  font-size: 11px;
  color: var(--ch);
  margin-bottom: 10px;
}
.bfc4 .bfc4-crumb {
  color: var(--ch);
  text-decoration: none;
  transition: color var(--t);
}
.bfc4 .bfc4-crumb:hover { color: var(--or); }
.bfc4 .bfc4-crumb-current {
  color: var(--bk);
  font-weight: 500;
}
.bfc4 .bfc4-crumb-sep {
  color: rgba(32,32,9,0.3);
  user-select: none;
}

/* ── TRUST STRIP (refurbishment differentiators) ─ */
.bfc4 .bfc4-trust-strip {
  display: flex; flex-wrap: wrap;
  gap: 4px 14px;
  list-style: none;
  margin: 12px 0 0;
  padding: 12px 0 0;
  border-top: 1px solid rgba(32,32,9,0.08);
}
.bfc4 .bfc4-trust-strip li {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--sn);
  font-size: 10.5px;
  line-height: 1.3;
  color: var(--ch);
  letter-spacing: 0.01em;
  white-space: nowrap;
}
.bfc4 .bfc4-trust-strip li svg { color: var(--or); flex-shrink: 0; }
/* "Restored inside & out" is a button that opens a popup. Match the other items visually
   (same font/size/color) but add a small (i) icon to telegraph that it's interactive,
   and underline on hover. */
.bfc4 .bfc4-trust-strip li .bfc4-trust-link {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--sn);
  font-size: inherit;
  line-height: inherit;
  color: inherit;
  letter-spacing: inherit;
  white-space: nowrap;
  transition: color 0.15s;
}
.bfc4 .bfc4-trust-strip li .bfc4-trust-link .bfc4-trust-check { color: var(--or); }
.bfc4 .bfc4-trust-strip li .bfc4-trust-link .bfc4-trust-info {
  color: rgba(32,32,9,0.4);
  transition: color 0.15s;
}
.bfc4 .bfc4-trust-strip li .bfc4-trust-link:hover { color: var(--bk); }
.bfc4 .bfc4-trust-strip li .bfc4-trust-link:hover span {
  text-decoration: underline;
  text-underline-offset: 3px;
}
.bfc4 .bfc4-trust-strip li .bfc4-trust-link:hover .bfc4-trust-info { color: var(--bk); }
@media (max-width: 700px) {
  .bfc4 .bfc4-trust-strip { gap: 4px 12px; }
  .bfc4 .bfc4-trust-strip li { font-size: 10px; }
}

/* ── DESCRIPTION CLAMP + READ MORE ───────── */
.bfc4 .bfc4-desc-wrap { position: relative; }
.bfc4 .bfc4-desc-clamp {
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.bfc4 .bfc4-desc-wrap.is-expanded .bfc4-desc-clamp {
  display: block;
  -webkit-line-clamp: unset;
  overflow: visible;
}
.bfc4 .bfc4-desc-toggle {
  background: transparent; border: none; padding: 4px 0;
  margin-top: 4px;
  font-family: var(--sn);
  font-size: 11px;
  font-weight: 600;
  color: var(--or);
  cursor: pointer;
  display: none; /* JS reveals when text overflows the 4-line clamp */
  align-items: center; gap: 4px;
  text-decoration: underline;
  text-underline-offset: 3px;
}
.bfc4 .bfc4-desc-toggle.is-visible { display: inline-flex; }
.bfc4 .bfc4-desc-toggle svg { transition: transform 0.2s ease; }
.bfc4 .bfc4-desc-wrap.is-expanded .bfc4-desc-toggle svg { transform: rotate(180deg); }

/* ── KIT HEADING ─────────────────────────── */
.bfc4-kit-head {
  padding-top: 16px;
}
.bfc4-kit-eyebrow {
  font-size: 9px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--or); margin-bottom: 6px; display: block;
}
.bfc4-kit-desc {
  font-size: 12px; color: var(--ch); line-height: 1.6; margin-top: 4px;
}


/* ── STARTER TILES ────────────────────────── */
.bfc4-tiles {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}
.bfc4-tile {
  display: flex; flex-direction: column;
  background: #fff;
  border: 1px solid rgba(32,32,9,0.08);
  overflow: hidden;
  cursor: default;
  position: relative;
}
.bfc4-tile.is-cam { border: 2px solid var(--or); cursor: default; }
.bfc4-tile-img-wrap {
  aspect-ratio: 3/2;
  overflow: hidden;
  background: var(--gr);
  position: relative;
}
.bfc4-tile-img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.4s ease;
}
.bfc4-tile:hover .bfc4-tile-img-wrap img { transform: scale(1.04); }
.bfc4-tile-body {
  padding: 10px 10px 8px;
  flex: 1; display: flex; flex-direction: column; gap: 2px;
}
.bfc4-tile-label {
  font-size: 8px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--ch);
}
.bfc4-tile-name {
  font-size: 11px; font-weight: 600; line-height: 1.3;
  overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.bfc4-tile-price {
  font-size: 11px; font-weight: 700; color: var(--or); margin-top: 2px;
}
.bfc4-tile-price.is-free { color: #2a4820; }
.bfc4-tile-orig {
  font-size: 9px; color: rgba(32,32,9,0.3); text-decoration: line-through;
}
.bfc4-tile-change {
  margin-top: 6px;
  font-size: 8.5px; font-weight: 600; letter-spacing: 0.08em;
  text-transform: uppercase; color: rgba(32,32,9,0.35);
  background: none; border: none; cursor: pointer; font-family: var(--sn);
  padding: 0; text-align: left; transition: color var(--t);
  display: flex; align-items: center; gap: 3px;
}
.bfc4-tile-change:hover { color: var(--or); }
.bfc4-tile-cam-badge {
  position: absolute; top: 8px; left: 8px;
  font-size: 7px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  background: var(--or); color: #fff; padding: 2px 6px;
}
.bfc4-tile-info {
  position: absolute; bottom: 6px; right: 6px;
  width: 18px; height: 18px;
  background: rgba(255,255,255,0.85); border: none; cursor: pointer; padding: 0;
  color: rgba(32,32,9,0.5); transition: color var(--t);
  display: flex; align-items: center; justify-content: center;
}
.bfc4-tile-info:hover { color: var(--or); }

/* ── GRADE + BUY ─────────────────────────── */
.bfc4-grade-row {
  display: flex; gap: 6px;
}
.bfc4-var-btn {
  flex: 1; padding: 10px 8px;
  border: 1px solid rgba(32,32,9,0.15);
  background: #fff; cursor: pointer; font-family: var(--sn);
  font-size: 11px; font-weight: 600; color: var(--bk);
  transition: all var(--t); text-align: center;
}
.bfc4-var-btn:hover { border-color: var(--or); }
.bfc4-var-btn.is-active { border: 2px solid var(--or); color: var(--or); background: rgba(227,110,21,0.05); }
.bfc4-var-btn[disabled] {
  opacity: 0.35; cursor: not-allowed; text-decoration: line-through;
  border-color: rgba(32,32,9,0.08); color: var(--ch);
}
.bfc4-var-btn[disabled]:hover { border-color: rgba(32,32,9,0.08); }

.bfc4-buy {}
.bfc4-price-row {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 6px;
}
.bfc4-price-label { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ch); }
.bfc4-price {
  font-family: var(--sr); font-size: 40px; font-weight: 300; color: var(--bk); line-height: 1;
}

.bfc4-atc {
  width: 100%; padding: 14px;
  background: var(--or); color: #fff; border: none;
  cursor: pointer; font-family: var(--sn); font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  transition: background var(--t); display: block; text-align: center; margin-bottom: 8px;
}
.bfc4-atc:hover:not([disabled]) { background: #c9600f; }
.bfc4-atc[disabled] { opacity: 0.5; cursor: not-allowed; }
.bfc4-atc.is-success { background: #2a4820 !important; }
.bfc4-cam-only {
  width: 100%; font-size: 9px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(32,32,9,0.3); background: none;
  border: none; cursor: pointer; transition: color var(--t); font-family: var(--sn);
  text-align: center; padding: 4px 0; display: block;
}
.bfc4-cam-only:hover { color: var(--bk); }

/* ── KIT SUMMARY (what's in it) ──────────── */
.bfc4-kit-summary {
  border-top: 1px solid rgba(32,32,9,0.08);
  padding-top: 14px;
  display: flex; flex-direction: column; gap: 4px;
}
.bfc4-ks-label { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ch); margin-bottom: 4px; }
.bfc4-ks-line {
  display: flex; align-items: center; gap: 8px;
}
.bfc4-ks-img { width: 24px; height: 24px; object-fit: cover; background: var(--gr); flex-shrink: 0; }
.bfc4-ks-name { font-size: 10.5px; color: var(--ch); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bfc4-ks-price { font-size: 10.5px; font-weight: 700; color: var(--or); }
.bfc4-ks-price.is-free { color: #2a4820; }
.bfc4-ks-remove {
  background: none; border: none; cursor: pointer; color: rgba(32,32,9,0.2);
  font-size: 13px; padding: 0; flex-shrink: 0; transition: color var(--t);
}
.bfc4-ks-remove:hover { color: var(--bk); }
.bfc4-ks-empty { font-size: 10px; color: rgba(32,32,9,0.25); font-style: italic; }

/* ── MINI SPECS ──────────────────────────── */
.bfc4-mini-specs {
  border-top: 1px solid rgba(32,32,9,0.08);
  padding-top: 16px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 0;
}
.bfc4-mini-spec {
  padding: 8px 0;
  border-bottom: 1px solid rgba(32,32,9,0.06);
  display: flex; flex-direction: column; gap: 2px;
}
.bfc4-mini-spec:nth-child(odd) { padding-right: 16px; }
.bfc4-mini-spec:nth-child(even) { padding-left: 16px; border-left: 1px solid rgba(32,32,9,0.06); }
.bfc4-mini-spec:nth-last-child(-n+2) { border-bottom: none; }
.bfc4-spec-key { font-size: 8px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(32,32,9,0.3); }
.bfc4-spec-val { font-size: 11.5px; font-weight: 500; }

/* ── EXTENDED WARRANTY ───────────────────── */
.bfc4-ext-warranty { border-top: 1px solid rgba(32,32,9,0.08); padding-top: 16px; }
.bfc4-ext-w-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.bfc4-ext-w-eyebrow { font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--or); }
.bfc4-ext-w-baseline { font-size: 10px; color: var(--ch); margin-bottom: 10px; display: flex; align-items: flex-start; gap: 5px; line-height: 1.5; }
.bfc4-ext-w-baseline svg { flex-shrink: 0; color: #2a4820; margin-top: 2px; }
.bfc4-ext-w-baseline strong { color: var(--bk); }
.bfc4-ext-w-options { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; }
.bfc4-ext-w-options.bfc4-ext-w-options--single { grid-template-columns: 1fr; }
.bfc4-ext-w-btn { border: 1px solid rgba(32,32,9,0.1); background: #fff; padding: 10px 8px; cursor: pointer; font-family: var(--sn); text-align: center; transition: border-color var(--t), box-shadow var(--t); display: flex; flex-direction: column; gap: 3px; position: relative; }
.bfc4-ext-w-btn:hover { border-color: var(--or); }
.bfc4-ext-w-btn.is-sel { border: 2px solid var(--or); box-shadow: 0 0 0 1px rgba(227,110,21,0.15); }
.bfc4-ext-w-btn.is-sel::after { content: '✓'; position: absolute; top: 4px; right: 5px; font-size: 8px; font-weight: 700; color: var(--or); }
.bfc4-ext-w-extend { font-size: 11px; font-weight: 700; color: var(--or); line-height: 1; }
.bfc4-ext-w-months { font-size: 9px; color: var(--ch); letter-spacing: 0.04em; line-height: 1; }
.bfc4-ext-w-price { font-size: 11px; font-weight: 700; color: var(--bk); margin-top: 2px; }
.bfc4-ext-w-acc { font-size: 7.5px; color: #2a4820; font-weight: 600; letter-spacing: 0.04em; margin-top: 1px; }
.bfc4-ext-w-none { font-size: 8.5px; color: rgba(32,32,9,0.4); margin-top: 8px; text-align: left; cursor: pointer; background: none; border: none; font-family: var(--sn); transition: color var(--t); padding: 0; display: none; }
.bfc4-ext-w-none.is-vis { display: block; }
.bfc4-ext-w-none:hover { color: var(--bk); }

/* ── WARRANTY & RETURNS POLICY ───────────── */
.bfc4-policy { background: var(--cv); border-top: 1px solid rgba(32,32,9,0.1); }
.bfc4-policy-col { padding: 48px 48px 56px; }

.bfc4-policy-ey { font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--or); margin-bottom: 12px; display: block; }
.bfc4-policy-title { font-family: var(--sr); font-size: 28px; font-weight: 300; line-height: 1.1; margin-bottom: 16px; }
.bfc4-policy-body { font-size: 12px; color: var(--ch); line-height: 1.75; }
.bfc4-policy-body strong { color: var(--bk); font-weight: 600; }
.bfc4-policy-pill { display: inline-flex; align-items: center; gap: 5px; background: rgba(42,72,32,0.08); color: #2a4820; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; padding: 4px 10px; margin-bottom: 14px; }

/* ── CUSTOMIZE LINK ──────────────────────── */
.bfc4-nav-links {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 18px;
}
.bfc4-customize {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
  color: rgba(32,32,9,0.4); cursor: pointer; background: none; border: none;
  font-family: var(--sn); transition: color var(--t); padding: 0;
}
.bfc4-customize:hover { color: var(--or); }
.bfc4-customize svg { transition: transform var(--t); }
.bfc4-customize:hover svg { transform: translateY(3px); }

/* ── BELOW FOLD CHECKOUT ─────────────────── */
.bfc4-below-checkout {
  padding: 32px 48px 48px;
  background: var(--cv);
  border-top: 1px solid rgba(32,32,9,0.1);
}

/* ── BELOW FOLD ───────────────────────────── */
.bfc4-below { background: var(--cv); }

/* Custom kit section */
.bfc4-custom {
  padding: 56px 48px 0;
  border-top: 1px solid rgba(32,32,9,0.1);
}
.bfc4-custom-head {
  margin-bottom: 24px;
  padding-top: 8px;
}
.bfc4-custom-eyebrow {
  font-size: 9px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--or); margin-bottom: 8px; display: block;
}
.bfc4-custom-title {
  font-family: var(--sr); font-size: 36px; font-weight: 300; line-height: 1;
}
.bfc4-custom-title em { font-style: italic; color: var(--ch); }
.bfc4-custom-note {
  font-size: 11px; color: var(--ch); margin-top: 10px; line-height: 1.6;
  max-width: 480px;
}

/* Reuse existing accordion column styles under .bfc4 namespace */
/* ── DESKTOP: categories side by side, items 2-col grid below ── */
.bfc4 .ba-columns {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
  align-items: start;
}
.bfc4 .ba-col {
  background: #fff;
  border: 1px solid rgba(32,32,9,0.1);
  display: flex; flex-direction: column;
  min-width: 0; /* let grid track collapse below intrinsic content width */
  overflow: hidden; /* clip any over-eager child to the column */
}
.bfc4 .ba-col-head {
  padding: 12px 14px 10px;
  border-bottom: 1px solid rgba(32,32,9,0.1);
  background: transparent !important;
  cursor: default;
}
.bfc4 .ba-col-head:hover { background: transparent !important; }
.bfc4 .ba-col-chevron { display: none; }
.bfc4 .ba-col-body {
  display: grid !important;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-top: none;
  min-width: 0; /* permit grid items to shrink */
}
/* Override base 52px grid layout for desktop square tiles */
.bfc4 .ba-col-body .ba-mini-card {
  display: flex !important;
  flex-direction: column !important;
  grid-template-columns: unset !important;
  background: #fff;
  border-bottom: 1px solid rgba(32,32,9,0.07) !important;
  border-right: 1px solid rgba(32,32,9,0.07) !important;
  cursor: pointer;
  position: relative;
  min-width: 0; /* let card shrink in its 1fr grid track */
  overflow: hidden; /* clip mini-img-wrap and text within the tile */
}
.bfc4 .ba-col-body .ba-mini-card:nth-child(3n) { border-right: none !important; }
.bfc4 .ba-col-body .ba-mini-card:last-child { border-bottom: 1px solid rgba(32,32,9,0.07) !important; }
.bfc4 .ba-col-body .ba-mini-img-wrap {
  width: 100% !important;
  aspect-ratio: 1/1 !important;
  height: auto !important;
  align-self: auto !important;
  flex-shrink: 1 !important;
  border-right: none !important;
  border-bottom: 1px solid rgba(32,32,9,0.06) !important;
  position: relative;
}
.bfc4 .ba-col-body .ba-mini-img {
  width: 100% !important;
  height: 100% !important;
  min-height: unset !important;
  object-fit: cover;
  display: block;
  opacity: 1 !important;
}
.bfc4 .ba-col-body .ba-mini-img-ph {
  width: 100% !important; height: 100% !important;
}
.bfc4 .ba-col-body .ba-mini-body {
  flex-direction: column !important;
  gap: 2px !important;
  align-items: center !important;
  padding: 8px 8px 10px !important;
  justify-content: unset !important;
}
.bfc4 .ba-col-body .ba-mini-info { min-width: 0; width: 100%; }
.bfc4 .ba-col-body .ba-mini-name {
  white-space: normal;
  text-align: center;
  font-size: 10px;
  overflow: hidden;
  display: -webkit-box !important;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  width: 100%;
  height: 1.4em;
}
.bfc4 .ba-col-body .ba-mini-right { text-align: center !important; }
.bfc4 .ba-col-body .ba-mini-orig { display: block; text-align: center; }
.bfc4 .ba-col-body .ba-mini-price { display: block; text-align: center; }
.bfc4 .ba-col-body .ba-mini-info-icon { bottom: auto; top: 6px; right: 6px; }
.bfc4 .ba-mini-card.is-hidden { display: flex !important; }
.bfc4 .ba-col-more { display: none !important; }
.bfc4 .ba-mini-vars { flex-wrap: wrap; }
.bfc4 .ba-col.is-highlighted {
  border-color: var(--or);
  box-shadow: 0 0 0 2px rgba(227,110,21,0.15);
}
@keyframes bfc4-highlight {
  0%   { border-color: var(--or); box-shadow: 0 0 0 4px rgba(227,110,21,0.3); }
  100% { border-color: rgba(32,32,9,0.1); box-shadow: none; }
}
.bfc4 .ba-col.flash-highlight { animation: bfc4-highlight 1.5s ease forwards; }
.bfc4 .ba-col-head {
  padding: 14px 16px; cursor: pointer; user-select: none;
  display: flex; align-items: center; justify-content: space-between;
  transition: background var(--t);
}
.bfc4 .ba-col-head:hover { background: rgba(32,32,9,0.02); }
.bfc4 .ba-col-title {
  font-size: 10.5px; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--bk);
  display: flex; align-items: center; gap: 8px;
}
.bfc4 .ba-col-count {
  font-size: 9px; font-weight: 700; color: #fff;
  background: var(--or); padding: 1px 7px; display: none;
}
.bfc4 .ba-col-count.is-visible { display: inline; }
.bfc4 .ba-col-chevron { color: rgba(32,32,9,0.3); transition: transform var(--t); flex-shrink: 0; }
.bfc4 .ba-col.is-open .ba-col-chevron { transform: rotate(180deg); }
.bfc4 .ba-col-body { display: none; border-top: 1px solid rgba(32,32,9,0.08); }
.bfc4 .ba-col.is-open .ba-col-body { display: block; }
.bfc4 .ba-mini-card.is-hidden { display: none; }
.bfc4 .ba-col.is-expanded .ba-mini-card.is-hidden { display: grid; }
.bfc4 .ba-col-more {
  display: none; width: 100%; padding: 9px 14px;
  background: none; border: none; border-top: 1px solid rgba(32,32,9,0.07);
  cursor: pointer; font-family: var(--sn); font-size: 10px; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: rgba(32,32,9,0.4); transition: color var(--t); text-align: left;
}
.bfc4 .ba-col.is-open .ba-col-more { display: block; }
.bfc4 .ba-col-more:hover { color: var(--or); }

/* Mini card styles under bfc4 */
.bfc4 .ba-mini-img-wrap {
  position: relative; flex-shrink: 0;
  width: 52px; align-self: stretch;
  border-right: 1px solid rgba(32,32,9,0.06);
}
.bfc4 .ba-mini-card {
  display: grid; grid-template-columns: 52px 1fr;
  background: #fff; border-bottom: 1px solid rgba(32,32,9,0.07);
  cursor: pointer; transition: background var(--t); position: relative;
}
.bfc4 .ba-mini-card:last-child { border-bottom: none; }
.bfc4 .ba-mini-card:hover { background: rgba(227,110,21,0.025); }
.bfc4 .ba-mini-card.is-sel { background: rgba(227,110,21,0.05); }
.bfc4 .ba-mini-card.is-sel::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--or);
}
.bfc4 .ba-mini-img {
  width: 52px; height: 100%; min-height: 52px; object-fit: cover; display: block;
  opacity: 0.75; transition: opacity var(--t);
}
.bfc4 .ba-mini-card:hover .ba-mini-img,
.bfc4 .ba-mini-card.is-sel .ba-mini-img { opacity: 1; }
.bfc4 .ba-mini-img-ph { width: 52px; height: 52px; background: var(--gr); }
.bfc4 .ba-mini-info-icon {
  position: absolute; bottom: 4px; right: 4px;
  width: 16px; height: 16px;
  background: rgba(255,255,255,0.85); border: none; cursor: pointer; padding: 0;
  color: rgba(32,32,9,0.4); transition: color var(--t);
  display: flex; align-items: center; justify-content: center; z-index: 2;
}
.bfc4 .ba-mini-info-icon:hover { color: var(--or); }
.bfc4 .ba-mini-body {
  padding: 10px 12px; display: flex; align-items: center; justify-content: space-between;
  gap: 8px; min-width: 0;
}
.bfc4 .ba-mini-info { min-width: 0; flex: 1; }
.bfc4 .ba-mini-name {
  font-size: 11.5px; font-weight: 500; line-height: 1.3;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  color: var(--ch); transition: color var(--t);
}
.bfc4 .ba-mini-card:hover .ba-mini-name,
.bfc4 .ba-mini-card.is-sel .ba-mini-name { color: var(--bk); font-weight: 600; }
.bfc4 .ba-mini-right { flex-shrink: 0; text-align: right; }
.bfc4 .ba-mini-price { font-size: 12px; font-weight: 700; color: var(--or); display: block; }
.bfc4 .ba-mini-price.is-free { color: #2a4820; }
.bfc4 .ba-mini-orig { font-size: 9px; color: rgba(32,32,9,0.3); text-decoration: line-through; display: block; }
.bfc4 .ba-mini-vars {
  display: none; padding: 6px 10px 8px; flex-wrap: wrap; gap: 4px;
  background: rgba(227,110,21,0.03); border-top: 1px solid rgba(32,32,9,0.06);
}
.bfc4 .ba-mini-card.is-sel .ba-mini-vars { display: flex; }
.bfc4 .ba-mini-card.is-oos { pointer-events: none; opacity: 0.5; }
.bfc4 .ba-mini-card.is-oos .ba-mini-name { text-decoration: line-through; }
.bfc4-oos-badge {
  position: absolute; top: 4px; left: 4px;
  background: var(--ch); color: #fff;
  font-size: 7px; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; padding: 2px 5px; z-index: 2;
}
.bfc4 .ba-mini-var-btn {
  font-size: 10px; font-weight: 500; padding: 3px 8px;
  border: 1px solid rgba(32,32,9,0.12); background: #fff;
  cursor: pointer; font-family: var(--sn); transition: all var(--t);
}
.bfc4 .ba-mini-var-btn:hover { border-color: var(--or); }
.bfc4 .ba-mini-var-btn.is-sel { border-color: var(--or); background: rgba(227,110,21,0.06); font-weight: 600; }

/* Film promo banners */
.bfc4-promos { padding: 0 48px; display: flex; flex-direction: column; gap: 0; }
.bfc4 .ba-film-promo {
  background: linear-gradient(135deg, #2a4820 0%, #3a6230 100%);
  padding: 14px 20px; display: flex; align-items: center; gap: 12px;
  box-sizing: border-box; width: 100%; overflow: hidden;
  border-top: 1px solid rgba(32,32,9,0.08); border-bottom: 1px solid rgba(32,32,9,0.08);
}
.bfc4 .ba-film-promo-icon {
  width: 32px; height: 32px; background: rgba(255,255,255,0.12);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.bfc4 .ba-film-promo-text { flex: 1; min-width: 0; }
.bfc4 .ba-film-promo-title { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 1px; overflow-wrap: break-word; }
.bfc4 .ba-film-promo-sub   { font-size: 10.5px; color: rgba(255,255,255,0.95); overflow-wrap: break-word; }
.bfc4 .ba-film-promo-status { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ce); flex-shrink: 0; }

/* Shot on */
.bfc4 .ba-shot { background: var(--cv); border-top: 1px solid rgba(32,32,9,0.1); }
.bfc4 .ba-shot-head { padding: 48px 48px 24px; display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid rgba(32,32,9,0.1); }
.bfc4 .ba-shot-title { font-family: var(--sr); font-size: 40px; font-weight: 300; }
.bfc4 .ba-shot-sub { font-size: 11px; color: var(--ch); font-style: italic; }
.bfc4 .ba-shot-grid { display: grid; grid-template-columns: repeat(6, 1fr); }
.bfc4 .ba-shot-grid a { display: block; overflow: hidden; border-right: 1px solid rgba(32,32,9,0.08); line-height: 0; font-size: 0; height: 100%; }
.bfc4 .ba-shot-grid a:last-child { border-right: none; }
.bfc4 .ba-shot-grid img { width: 100%; height: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; vertical-align: bottom; transition: transform 0.4s ease; }
.bfc4 .ba-shot-grid a:hover img { transform: scale(1.04); }

/* Restoration */
/* ── CHAPTER WRAPPER (SX-70 style, dark) — 3-col layout ──── */
.bfc4 .bfc4-chapter {
  background: var(--bk);
  color: #fff;
  position: relative;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
/* Header column (left) — replaces standalone centered header */
.bfc4 .bfc4-chapter-header {
  padding: 64px 48px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}
.bfc4 .bfc4-chapter-eyebrow {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin-bottom: 18px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(255,255,255,0.15);
  align-self: flex-start;
}
.bfc4 .bfc4-chapter-title {
  font-family: var(--sr);
  font-size: 30px;
  font-weight: 300;
  color: #fff;
  margin: 0 0 18px;
  line-height: 1.15;
  letter-spacing: -0.005em;
}
.bfc4 .bfc4-chapter-title em {
  font-style: normal;
  color: rgba(255,255,255,0.6);
  font-weight: 300;
}
.bfc4 .bfc4-chapter-sub {
  font-size: 13.5px;
  color: rgba(255,255,255,0.7);
  line-height: 1.6;
  margin: 0 0 28px;
}
.bfc4 .bfc4-chapter-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 22px;
  background: transparent;
  border: 1px solid rgba(227,110,21,0.6);
  color: var(--or);
  font-family: var(--sn);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
  align-self: flex-start;
}
.bfc4 .bfc4-chapter-toggle:hover {
  background: rgba(227,110,21,0.1);
  border-color: var(--or);
}
.bfc4 .bfc4-chapter-toggle-icon {
  transition: transform 0.3s ease;
}
.bfc4 .bfc4-chapter-toggle[aria-expanded="true"] .bfc4-chapter-toggle-icon {
  transform: rotate(180deg);
}

/* ── Per-column toggle (mobile only) ──
   On mobile, the global "View full process & all specs" button is hidden and each
   column gets its own scoped toggle. This way users expand only the section they're
   currently scrolled to, instead of expanding all three at once way up at the top. */
.bfc4 .bfc4-chapter-col-toggle {
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  width: 100%;
  margin-top: 22px;
  padding: 11px 16px;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.22);
  color: rgba(255,255,255,0.85);
  font-family: var(--sn);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
}
.bfc4 .bfc4-chapter-col-toggle:hover {
  background: rgba(255,255,255,0.05);
  border-color: rgba(255,255,255,0.4);
  color: #fff;
}
.bfc4 .bfc4-chapter-col-toggle-icon {
  transition: transform 0.3s ease;
  flex-shrink: 0;
}
.bfc4 .bfc4-chapter-col-toggle[aria-expanded="true"] .bfc4-chapter-col-toggle-icon {
  transform: rotate(180deg);
}

/* Per-extra .is-open expansion — works alongside the global body.is-open rule.
   This lets per-col toggles on mobile open just one extra at a time. */
.bfc4 .bfc4-chapter-extra.is-open {
  max-height: 6000px;
  opacity: 1;
  margin-top: 28px;
}
.bfc4 .bfc4-chapter-body {
  /* No top border — grid columns provide their own dividers */
}

/* THREE-column grid: header | process | specs */
.bfc4 .bfc4-chapter-grid {
  display: grid;
  grid-template-columns: 1.1fr 1fr 1fr;
  max-width: 1380px;
  margin: 0 auto;
  padding: 0;
}
.bfc4 .bfc4-chapter-col {
  padding: 64px 48px;
  min-width: 0;
  border-left: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-col:first-child {
  border-left: none;
}
.bfc4 .bfc4-chapter-col-head {
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-col-ey {
  display: block;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin-bottom: 12px;
}
.bfc4 .bfc4-chapter-col-title {
  font-family: var(--sr);
  font-size: 26px;
  font-weight: 300;
  color: #fff;
  line-height: 1.15;
  letter-spacing: -0.005em;
  margin: 0;
}
.bfc4 .bfc4-chapter-col-title em {
  font-style: normal;
  color: rgba(255,255,255,0.55);
  font-weight: 300;
}
.bfc4 .bfc4-chapter-col-sub {
  font-family: var(--sn);
  font-size: 12.5px;
  color: rgba(255,255,255,0.55);
  line-height: 1.55;
  margin: 12px 0 0;
}


/* Process: short list always visible */
.bfc4 .bfc4-chapter-process-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.bfc4 .bfc4-chapter-process-list li {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 16px;
  align-items: baseline;
  font-family: var(--sn);
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
}
.bfc4 .bfc4-chapter-process-list .num {
  font-family: var(--sr);
  font-size: 20px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  line-height: 1;
}

/* Specs: 4 quick specs in 2x2 grid, always visible */
.bfc4 .bfc4-chapter-specs-quick {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border-top: 1px solid rgba(255,255,255,0.1);
  border-left: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-quick > div {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 18px 20px;
  border-right: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-quick .key {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}
.bfc4 .bfc4-chapter-specs-quick .val {
  font-family: var(--sr);
  font-size: 16px;
  font-weight: 400;
  color: #fff;
  line-height: 1.3;
}

/* Extras hidden by default — both expand together when chapter body has .is-open */
.bfc4 .bfc4-chapter-extra {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.6s ease, opacity 0.4s ease, margin-top 0.4s ease;
  margin-top: 0;
}
.bfc4 .bfc4-chapter-body.is-open .bfc4-chapter-extra {
  max-height: 6000px;
  opacity: 1;
  margin-top: 36px;
}

/* Restoration extra content (left col) */
.bfc4 .bfc4-chapter-process-extra .ba-restore-photo {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: rgba(255,255,255,0.04);
  overflow: hidden;
  margin-bottom: 28px;
}
.bfc4 .bfc4-chapter-process-extra .ba-restore-photo img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.bfc4 .bfc4-chapter-process-extra .ba-restore-prose {
  font-family: var(--sn);
  font-size: 13.5px;
  color: rgba(255,255,255,0.78);
  line-height: 1.7;
  margin-bottom: 28px;
}
.bfc4 .bfc4-chapter-process-extra .ba-restore-prose p { margin-bottom: 12px; }
.bfc4 .bfc4-chapter-process-extra .ba-restore-prose p:last-child { margin-bottom: 0; }
.bfc4 .bfc4-chapter-process-detail {
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding-top: 24px;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter-process-detail-step {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 16px;
  align-items: baseline;
}
.bfc4 .bfc4-chapter-process-detail-step .num {
  font-family: var(--sr);
  font-size: 20px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  line-height: 1;
}
.bfc4 .bfc4-chapter-process-detail-step .body strong {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4px;
  font-family: var(--sn);
}
.bfc4 .bfc4-chapter-process-detail-step .body p {
  font-size: 12px;
  color: rgba(255,255,255,0.6);
  line-height: 1.55;
  margin: 0;
}

/* Specs extra rows (right col, full table) */
.bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full {
  display: grid;
  grid-template-columns: 1fr;
  border-top: 1px solid rgba(255,255,255,0.1);
  border-left: 1px solid rgba(255,255,255,0.1);
  border-right: 1px solid rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full > div {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  align-items: baseline;
}
.bfc4 .bfc4-chapter-specs-extra .key {
  font-size: 8.5px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}
.bfc4 .bfc4-chapter-specs-extra .val {
  font-family: var(--sr);
  font-size: 14px;
  color: #fff;
  line-height: 1.3;
}

/* Mobile: stack columns */

/* Header column extras (photo + prose appear here when expanded) */
.bfc4 .bfc4-chapter-header-extra .ba-restore-photo {
  width: 100%;
  aspect-ratio: 4 / 3;
  background: rgba(255,255,255,0.04);
  overflow: hidden;
  margin-bottom: 24px;
}
.bfc4 .bfc4-chapter-header-extra .ba-restore-photo img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose {
  font-family: var(--sn);
  font-size: 13px;
  color: rgba(255,255,255,0.7);
  line-height: 1.7;
  text-align: left;
  max-width: none;
  margin: 0;
}
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose p { margin-bottom: 12px; }
.bfc4 .bfc4-chapter-header-extra .ba-restore-prose p:last-child { margin-bottom: 0; }

@media (max-width: 900px) {
  .bfc4 .bfc4-chapter-grid { grid-template-columns: 1fr; }
  .bfc4 .bfc4-chapter-col { padding: 40px 24px; }
  .bfc4 .bfc4-chapter-col:nth-child(2) {
    border-left: none;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .bfc4 .bfc4-chapter-col-title { font-size: 26px; }
  .bfc4 .bfc4-chapter-specs-quick { grid-template-columns: 1fr; }
  .bfc4 .bfc4-chapter-specs-extra .bfc4-chapter-specs-full { grid-template-columns: 1fr; }
}

/* ── Dark overrides for nested ba-restore + ba-specs ── */

/* Restoration in dark chapter */
.bfc4 .bfc4-chapter .ba-restore {
  background: transparent;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 0 48px;
}
.bfc4 .bfc4-chapter .ba-restore-inner { max-width: 1100px; margin: 0 auto; }
.bfc4 .bfc4-chapter .ba-restore-photo {
  margin: 56px 0 40px;
  background: rgba(255,255,255,0.04);
}
.bfc4 .bfc4-chapter .ba-restore-top {
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter .ba-restore-headline {
  padding: 56px 48px 56px 0;
}
.bfc4 .bfc4-chapter .ba-restore-ey {
  color: var(--or);
}
.bfc4 .bfc4-chapter .ba-restore-title {
  color: #fff;
}
.bfc4 .bfc4-chapter .ba-restore-title em {
  color: rgba(255,255,255,0.4);
}
.bfc4 .bfc4-chapter .ba-restore-stats {
  padding: 56px 0 56px 48px;
}
.bfc4 .bfc4-chapter .ba-r-stat {
  border-left-color: rgba(255,255,255,0.08);
}
.bfc4 .bfc4-chapter .ba-r-stat-num {
  color: #fff;
}
.bfc4 .bfc4-chapter .ba-r-stat-num span {
  color: var(--or);
}
.bfc4 .bfc4-chapter .ba-r-stat-label {
  color: rgba(255,255,255,0.5);
}
.bfc4 .bfc4-chapter .ba-restore-prose {
  color: rgba(255,255,255,0.78);
}
.bfc4 .bfc4-chapter .ba-restore-steps {
}
.bfc4 .bfc4-chapter .ba-r-step {
  border-right-color: rgba(255,255,255,0.06);
}
.bfc4 .bfc4-chapter .ba-r-num {
  color: rgba(227,110,21,0.5);
}
.bfc4 .bfc4-chapter .ba-r-title {
  color: #fff;
}
.bfc4 .bfc4-chapter .ba-r-desc {
  color: rgba(255,255,255,0.55);
}

/* Specs in dark chapter */
.bfc4 .bfc4-chapter .ba-specs {
  background: transparent;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 72px 48px 80px;
}
.bfc4 .bfc4-chapter .ba-specs-inner { max-width: 1100px; margin: 0 auto; }
.bfc4 .bfc4-chapter .ba-specs-eyebrow {
  color: var(--or);
}
.bfc4 .bfc4-chapter .ba-specs-title {
  color: #fff;
}
.bfc4 .bfc4-chapter .ba-specs-note {
  color: rgba(255,255,255,0.5);
}
.bfc4 .bfc4-chapter .ba-specs-table {
  border-top-color: rgba(255,255,255,0.1);
  border-left-color: rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter .ba-spec {
  border-right-color: rgba(255,255,255,0.1);
  border-bottom-color: rgba(255,255,255,0.1);
}
.bfc4 .bfc4-chapter .ba-spec:hover {
  background: rgba(227,110,21,0.06);
}
.bfc4 .bfc4-chapter .ba-spec-key {
  color: var(--or);
}
.bfc4 .bfc4-chapter .ba-spec-val {
  color: #fff;
}

/* Mobile */
@media (max-width: 900px) {
  .bfc4 .bfc4-chapter-grid { grid-template-columns: 1fr; }
  .bfc4 .bfc4-chapter-col { padding: 36px 24px; border-left: none; }
  .bfc4 .bfc4-chapter-col + .bfc4-chapter-col { border-top: 1px solid rgba(255,255,255,0.08); }
  .bfc4 .bfc4-chapter-header { padding: 44px 24px 32px; }
  .bfc4 .bfc4-chapter-title { font-size: 28px; }
  .bfc4 .bfc4-chapter-sub { font-size: 13.5px; }
  .bfc4 .bfc4-chapter-col-title { font-size: 24px; }
  .bfc4 .bfc4-chapter .ba-restore-photo { aspect-ratio: 4/3; }
  /* Swap global → per-column toggles on mobile */
  .bfc4 .bfc4-chapter-toggle { display: none; }
  .bfc4 .bfc4-chapter-col-toggle { display: inline-flex; }
}

/* Popup
   Lives OUTSIDE .bfc4 wrapper (overflow:clip on .bfc4 was clipping the fixed-position
   overlay and breaking the info icons). All popup descendant rules are scoped to
   `.ba-popup-overlay` so they beat any theme-level selectors on width/height.
   `!important` on max-width/max-height for the same reason — the Release theme has
   broad rules that were stretching the popup full-width and full-height. */
.ba-popup-overlay {
  --or: #E36E15;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --sr: 'Cormorant Garamond', Georgia, serif;
  --sn: 'Poppins', sans-serif;
  font-family: var(--sn);
  color: var(--bk);
  position: fixed; inset: 0;
  background: rgba(32,32,9,0.55); z-index: 9999; display: none;
  align-items: center; justify-content: center; backdrop-filter: blur(3px);
  box-sizing: border-box;
  padding: 24px;
}
.ba-popup-overlay * { box-sizing: border-box; }
.ba-popup-overlay.is-open { display: flex; }
.ba-popup-overlay .ba-popup {
  background: #fff;
  width: 90% !important;
  max-width: 680px !important;
  max-height: 85vh !important;
  display: flex; flex-direction: column;
  overflow: hidden;
  animation: bfc4-popup-in 0.2s ease;
  position: relative;
}
@keyframes bfc4-popup-in { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform: translateY(0); } }
.ba-popup-overlay .ba-popup-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid rgba(32,32,9,0.1);
  flex-shrink: 0;
  background: #fff;
}
.ba-popup-overlay .ba-popup-title { font-size: 14px; font-weight: 700; color: var(--bk); }
.ba-popup-overlay .ba-popup-close {
  background: none; border: none; cursor: pointer; padding: 4px;
  color: var(--ch); display: flex; align-items: center;
  width: auto !important; min-width: 0 !important;
}
.ba-popup-overlay .ba-popup-body {
  overflow-y: auto;
  flex: 1 1 auto;
  min-height: 0; /* allow flex child to shrink and scroll, critical for overflow */
}
.ba-popup-overlay .ba-popup-imgs { display: grid; grid-template-columns: repeat(3, 1fr); }
.ba-popup-overlay .ba-popup-imgs img { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; border-right: 1px solid rgba(32,32,9,0.07); border-bottom: 1px solid rgba(32,32,9,0.07); }
.ba-popup-overlay .ba-popup-desc { padding: 20px; font-size: 12.5px; color: var(--ch); line-height: 1.7; border-top: 1px solid rgba(32,32,9,0.08); }
.ba-popup-overlay .ba-popup-desc p { margin-bottom: 10px; }

/* ── MOBILE ───────────────────────────────── */
@media (max-width: 900px) {
  .bfc4-split { grid-template-columns: 1fr; min-height: 0; }
  .bfc4-left { position: relative; width: 100%; height: 100vw; max-height: 520px; }
  .bfc4-arrow { display: none; }
  .bfc4-right { padding: 28px 20px 48px; gap: 24px; overflow-y: visible; }
  /* Swap leather row placement on mobile: hide the one inside the buy box,
     show the one rendered directly under the image slider. */
  .bfc4-right .bfc4-leather-compact:not(.bfc4-leather-mobile) { display: none; }
  .bfc4-leather-mobile { display: flex; }
  .bfc4-title { font-size: 36px; }
  .bfc4-tiles { grid-template-columns: repeat(4, 1fr); gap: 6px; }
  .bfc4-tile-img-wrap { aspect-ratio: 1/1; }
  .bfc4-tile-body { padding: 6px 6px 5px; gap: 1px; }
  .bfc4-tile-name { font-size: 9px; }
  .bfc4-tile-price { font-size: 9px; }
  .bfc4-tile-orig { font-size: 8px; }
  .bfc4-tile-change { display: none; }
  .bfc4-custom { padding: 36px 20px 0; }
  .bfc4 .ba-columns { display: flex; flex-direction: column; gap: 0; width: 100%; }
  .bfc4 .ba-col { background: #fff; border: 1px solid rgba(32,32,9,0.1); margin-bottom: 8px; width: 100%; }
  .bfc4 .ba-col-head { cursor: pointer; border-bottom: none; }
  .bfc4 .ba-col-head:hover { background: rgba(32,32,9,0.02) !important; }
  .bfc4 .ba-col-chevron { display: block !important; }
  .bfc4 .ba-col-body { display: none !important; grid-template-columns: 1fr !important; padding: 0; border-top: 1px solid rgba(32,32,9,0.08); }
  .bfc4 .ba-col.is-open .ba-col-body { display: block !important; }
  .bfc4 .ba-mini-card { display: grid !important; grid-template-columns: 52px 1fr; flex-direction: unset; border: none; border-bottom: 1px solid rgba(32,32,9,0.07) !important; }
  .bfc4 .ba-col-body .ba-mini-img-wrap { width: 52px !important; aspect-ratio: unset !important; height: 52px !important; min-height: 52px !important; border-right: 1px solid rgba(32,32,9,0.06) !important; border-bottom: none !important; flex-shrink: 0 !important; background: #fff !important; }
  .bfc4 .ba-col-body .ba-mini-img { width: 52px !important; height: 52px !important; min-height: 52px !important; object-fit: contain !important; padding: 4px !important; }
  .bfc4 .ba-col-body .ba-mini-card { display: grid !important; flex-direction: unset !important; grid-template-columns: 52px 1fr !important; }
  .bfc4 .ba-col-body .ba-mini-body { flex-direction: row !important; align-items: center !important; padding: 10px 12px !important; }
  .bfc4 .ba-col-body .ba-mini-right { text-align: right !important; }
  .bfc4 .ba-col-body .ba-mini-name { white-space: normal !important; text-align: left !important; height: auto !important; -webkit-line-clamp: 2 !important; }
  .bfc4 .ba-mini-body { flex-direction: row; align-items: center; padding: 10px 12px; }
  .bfc4 .ba-mini-right { text-align: right; }
  .bfc4-promos { padding: 0 20px; }
  .bfc4-below-checkout { padding: 24px 20px 40px; overflow: hidden; }
  .bfc4-selected-row { flex-direction: column; gap: 16px; }
  .bfc4-selected-items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    overflow-x: visible;
    flex-wrap: unset;
  }
  .bfc4-sel-item { width: 100%; }
  .bfc4-sel-item-img { width: 100%; height: auto; aspect-ratio: 4/3; }
  .bfc4-below-atc { width: 100%; max-width: 100%; }
  .bfc4-below-atc .bfc4-price { font-size: 32px; }
  .bfc4 .ba-shot-head { padding: 36px 20px 16px; flex-direction: column; gap: 4px; }
  .bfc4 .ba-shot-title { font-size: 28px; }
  .bfc4 .ba-shot-grid { grid-template-columns: repeat(3, 1fr); }
  .bfc4-mini-specs { grid-template-columns: 1fr; }
  .bfc4-mini-spec:nth-child(odd) { padding-right: 0; }
  .bfc4-mini-spec:nth-child(even) { padding-left: 0; border-left: none; }
  .bfc4 .ba-film-promo-icon { display: none; }
  .bfc4 .ba-film-promo-text { flex: 1 1 auto; min-width: 0; }
  /* Keep "✓ UNLOCKED" on one line — don't let flex shrink it and don't allow wrapping.
     Tighter letter-spacing so it fits the narrow column without breaking. */
  .bfc4 .ba-film-promo-status {
    flex: 0 0 auto;
    text-align: right;
    font-size: 9px;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  /* Trust strip — 2x2 grid on mobile so items align cleanly instead of wrapping
     unevenly (the "Restored inside & out (i)" item is wider than the others). */
  .bfc4 .bfc4-trust-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 14px;
    padding-top: 14px;
  }
  .bfc4 .bfc4-trust-strip li { font-size: 11.5px; }
  /* Read more — bump font + add real tap target on mobile (11px was too small to tap). */
  .bfc4 .bfc4-desc-toggle {
    font-size: 13px;
    padding: 8px 0;
  }
  /* Camera Only — was a 9px text link; on mobile make it a proper outlined button
     so it reads as a real "skip the kit" choice next to the orange ATC. */
  .bfc4-cam-only {
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--ch);
    background: transparent;
    border: 1px solid rgba(32,32,9,0.15);
    padding: 14px;
    margin-top: 8px;
  }
  .bfc4-cam-only:hover {
    color: var(--bk);
    border-color: rgba(32,32,9,0.4);
    background: rgba(32,32,9,0.02);
  }
  .bfc4-ext-w-options { grid-template-columns: repeat(2, 1fr); }
  
  .bfc4-policy-col { padding: 32px 20px 36px; }
  .bfc4-policy-col:last-child { border-bottom: none; }
}

/* ── Sticky Mobile ATC Bar ────────────────── */
.bfc4-sticky-bar { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--cv); border-top: 1px solid rgba(32,32,9,0.15); padding: 10px 16px; z-index: 100; align-items: center; gap: 12px; box-shadow: 0 -2px 12px rgba(0,0,0,0.08); }
.bfc4-sticky-info { flex: 1; min-width: 0; }
.bfc4-sticky-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--bk); }
.bfc4-sticky-meta { display: flex; align-items: center; gap: 6px; margin-top: 1px; }
.bfc4-sticky-grade { font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ch); }
.bfc4-sticky-price { font-size: 13px; font-weight: 700; color: var(--or); }
.bfc4-sticky-btn { background: var(--or); color: #fff; border: none; padding: 12px 24px; font-size: 10px; font-weight: 700; font-family: var(--sn); text-transform: uppercase; letter-spacing: 0.14em; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
.bfc4-sticky-btn:disabled { opacity: 0.5; cursor: not-allowed; }
@media (max-width: 900px) {
  .bfc4-sticky-bar.is-visible { display: flex; }
}

/* ── STICKY TOC ──
   Top-of-viewport anchor nav. Shows once buy box scrolls out of view. Hides on mobile
   (the bottom sticky ATC covers the same affordance there). Lives outside .bfc4 so
   the overflow: clip on .bfc4 can't clip it. */
.bfc4-toc {
  --or: #E36E15;
  --cv: #F8F6EE;
  --bk: #202009;
  --ch: #4E4741;
  --sn: 'Poppins', sans-serif;
  position: fixed;
  top: 0; left: 0; right: 0; width: 100%;
  z-index: 30;
  background: var(--cv);
  border-bottom: 1px solid rgba(32,32,9,0.12);
  font-family: var(--sn);
  transform: translateY(-100%);
  transition: transform 0.25s ease;
  pointer-events: none;
  visibility: hidden;
  box-sizing: border-box;
}
.bfc4-toc * { box-sizing: border-box; }
.bfc4-toc.is-visible {
  transform: translateY(0);
  pointer-events: auto;
  visibility: visible;
}
.bfc4-toc-inner {
  display: flex; align-items: center; justify-content: space-between;
  gap: 24px;
  padding: 11px 28px;
  max-width: 1400px;
  margin: 0 auto;
}
.bfc4-toc-links {
  display: flex; gap: 28px;
  list-style: none; margin: 0; padding: 0;
  flex-wrap: nowrap; overflow-x: auto;
  scrollbar-width: none;
}
.bfc4-toc-links::-webkit-scrollbar { display: none; }
.bfc4-toc-links a {
  display: inline-block;
  padding: 4px 0;
  font-size: 11.5px; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--ch); text-decoration: none;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: color 0.15s, border-color 0.15s;
}
.bfc4-toc-links a:hover { color: var(--bk); }
.bfc4-toc-links a.is-active {
  color: var(--bk);
  border-bottom-color: var(--or);
}
.bfc4-toc-atc {
  flex-shrink: 0;
  padding: 9px 18px;
  background: var(--or); color: #fff;
  border: none;
  font-family: var(--sn);
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  cursor: pointer;
  transition: background 0.15s;
}
.bfc4-toc-atc:hover { background: #c9600f; }
.bfc4-toc-atc:disabled { opacity: 0.7; cursor: not-allowed; }
.bfc4-toc-atc.is-success { background: #2a4820 !important; color: #fff !important; }
.bfc4-toc-atc.is-success * { color: #fff !important; }
@media (max-width: 900px) {
  .bfc4-toc { display: none !important; }
}
@media (max-width: 700px) {
  .bfc4-toc-inner { padding: 9px 14px; gap: 12px; }
  .bfc4-toc-links { gap: 18px; }
  .bfc4-toc-links a { font-size: 10.5px; letter-spacing: 0.06em; }
  .bfc4-toc-atc { padding: 7px 12px; font-size: 10px; letter-spacing: 0.06em; }
}

/* ── PHOTO LIGHTBOX ──
   Used by both the hero photo slider and the Shot On gallery. Lives outside .bfc4
   so overflow: clip can't clip the close button or arrows. Full-screen overlay,
   click image to toggle zoom, scroll/swipe to pan while zoomed. */
.ba-lightbox {
  --or: #E36E15;
  --sn: 'Poppins', sans-serif;
  position: fixed; inset: 0;
  background: rgba(32,32,9,0.94);
  z-index: 99998;
  display: none;
  align-items: center; justify-content: center;
  padding: 60px 40px;
  cursor: zoom-out;
  font-family: var(--sn);
  box-sizing: border-box;
}
.ba-lightbox * { box-sizing: border-box; }
.ba-lightbox.is-open { display: flex; }
.ba-lightbox-inner {
  position: relative;
  width: 100%; height: 100%;
  max-width: 100vw; max-height: 100vh;
  cursor: default;
  display: flex; align-items: center; justify-content: center;
}
.ba-lightbox-imgwrap {
  position: relative;
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  overflow: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.3) transparent;
}
.ba-lightbox-imgwrap::-webkit-scrollbar { width: 8px; height: 8px; }
.ba-lightbox-imgwrap::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.3); }
.ba-lightbox-img {
  max-width: 100%; max-height: 100%;
  object-fit: contain;
  display: block;
  background: #000;
  cursor: zoom-in;
  transition: max-width 0.2s ease, max-height 0.2s ease;
  user-select: none;
  -webkit-user-drag: none;
}
.ba-lightbox-img.is-zoomed {
  cursor: grab;
  max-width: 250%;
  max-height: 250%;
}
.ba-lightbox-img.is-zoomed:active { cursor: grabbing; }
.ba-lightbox-close {
  position: fixed; top: 20px; right: 20px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: #fff;
  width: 40px; height: 40px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s ease;
  z-index: 100000;
}
.ba-lightbox-close:hover { background: rgba(255,255,255,0.2); }
.ba-lightbox-arrow {
  position: fixed; top: 50%;
  transform: translateY(-50%);
  width: 56px; height: 56px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s ease;
  z-index: 100000;
}
.ba-lightbox-arrow:hover { background: rgba(255,255,255,0.2); }
.ba-lightbox-arrow.is-prev { left: 24px; }
.ba-lightbox-arrow.is-next { right: 24px; }
.ba-lightbox-counter {
  position: fixed; bottom: 20px; left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.7);
  font-size: 11px; letter-spacing: 0.12em;
  font-family: var(--sn);
  z-index: 100000;
}
@media (max-width: 900px) {
  .ba-lightbox { padding: 60px 8px; }
  .ba-lightbox-arrow.is-prev { left: 8px; }
  .ba-lightbox-arrow.is-next { right: 8px; }
  .ba-lightbox-arrow { width: 44px; height: 44px; background: rgba(255,255,255,0.15); }
  .ba-lightbox-close { top: 12px; right: 12px; }
}
</style>

<div class="bfc4">

{%- comment -%} ── Collect starter kit blocks ── {%- endcomment -%}
{%- assign sk_blocks = section.blocks | where: 'type', 'kit_item' -%}
{%- assign has_starter = false -%}
{%- for block in sk_blocks -%}
  {%- if block.settings.is_starter_kit and block.settings.product != blank -%}
    {%- assign has_starter = true -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Compute kit total for starter {%- endcomment -%}
{%- liquid
  assign sk_total = current_variant.price
  for block in sk_blocks
    if block.settings.is_starter_kit and block.settings.product != blank
      assign sk_bp  = block.settings.product
      assign sk_dv  = sk_bp.variants.first
      unless sk_dv.available
        for v in sk_bp.variants
          if v.available
            assign sk_dv = v
            break
          endif
        endfor
      endunless
      assign sk_d   = block.settings.discount_percent
      assign sk_dev = block.settings.is_developing
      if sk_dev
        assign sk_sale = 0
      elsif sk_d > 0
        assign sk_df   = sk_d | times: 1.0 | divided_by: 100
        assign sk_sv   = sk_dv.price | times: sk_df | floor
        assign sk_sale = sk_dv.price | minus: sk_sv
      else
        assign sk_sale = sk_dv.price
      endif
      assign sk_total = sk_total | plus: sk_dv.price
    endif
  endfor
-%}

{%- comment -%} ── Detect a "Leather Cover" / "Leather" / "Cover" option ──
     Hoisted to file scope so it's available to the mobile placement (above
     the buy box), the desktop placement (inside the buy box), and the
     secondary below-ATC placement. Reading inside one block doesn't make
     it available to the others — Liquid scope is top-down. {%- endcomment -%}
{%- assign leather_opt_idx = null -%}
{%- assign leather_opt_name = '' -%}
{%- assign current_leather = '' -%}
{%- for opt in product.options_with_values -%}
  {%- assign opt_name_lower = opt.name | downcase -%}
  {%- if opt_name_lower contains 'leather' or opt_name_lower == 'cover' -%}
    {%- assign leather_opt_idx = forloop.index0 -%}
    {%- assign leather_opt_name = opt.name -%}
  {%- endif -%}
{%- endfor -%}
{%- if leather_opt_idx != null -%}
  {%- assign current_leather = current_variant.options[leather_opt_idx] -%}
{%- endif -%}

{%- comment -%} ── SPLIT: left image + right content ── {%- endcomment -%}
<div class="bfc4-split">

  {%- comment -%} LEFT: sticky slider — uses section image pickers if set, falls back to product.media {%- endcomment -%}
  <div class="bfc4-left" id="bfc4-top">
    {%- comment -%} Check if any section images are set {%- endcomment -%}
    {%- assign has_section_imgs = false -%}
    {%- for i in (1..5) -%}
      {%- assign img_key = 'slide_' | append: i -%}
      {%- if section.settings[img_key] != blank -%}{%- assign has_section_imgs = true -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_section_imgs -%}
      {%- comment -%} Count section slides {%- endcomment -%}
      {%- assign slide_images = '' -%}
      {%- for i in (1..5) -%}
        {%- assign img_key = 'slide_' | append: i -%}
        {%- if section.settings[img_key] != blank -%}{%- assign slide_images = slide_images | append: '1' -%}{%- endif -%}
      {%- endfor -%}
      {%- assign total_slides = slide_images | size -%}

      <div class="bfc4-slides" id="bfc4-slides">
        {%- for i in (1..5) -%}
          {%- assign img_key = 'slide_' | append: i -%}
          {%- assign img_mob_key = 'slide_' | append: i | append: '_mobile' -%}
          {%- assign img_val = section.settings[img_key] -%}
          {%- assign img_mob = section.settings[img_mob_key] -%}
          {%- if img_val != blank -%}
            <div class="bfc4-slide">
              <picture>
                {%- if img_mob != blank -%}
                  <source media="(max-width: 767px)" srcset="{{ img_mob | image_url: width: 900 }}"/>
                {%- endif -%}
                <img
                  src="{{ img_val | image_url: width: 900 }}"
                  srcset="{{ img_val | image_url: width: 600 }} 600w, {{ img_val | image_url: width: 900 }} 900w, {{ img_val | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 900px) 100vw, 50vw"
                  data-zoom="{{ img_val | image_url: width: 1600 }}"
                  alt="{{ product.title | escape }}"
                  width="900" height="900"
                  {%- if i == 1 -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
                />
              </picture>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- comment -%} Fallback: use product.media images. Each slide gets
           tagged with data-media-id so the variant→image swap logic can
           find and jump to the right slide when a variant is selected. {%- endcomment -%}
      {%- assign media_images = product.media | where: 'media_type', 'image' -%}
      {%- assign total_slides = media_images | size -%}

      <div class="bfc4-slides" id="bfc4-slides">
        {%- for media in media_images limit: 8 -%}
          <div class="bfc4-slide" data-media-id="{{ media.id }}">
            <img
              src="{{ media | image_url: width: 900 }}"
              srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 900px) 100vw, 50vw"
              data-zoom="{{ media | image_url: width: 1600 }}"
              alt="{{ product.title | escape }}"
              width="900" height="900"
              {%- if forloop.first -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
            />
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if total_slides > 1 -%}
      <button class="bfc4-arrow is-prev" onclick="bfc4Slide(-1)" aria-label="Previous">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8L10 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
      <button class="bfc4-arrow is-next" onclick="bfc4Slide(1)" aria-label="Next">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 3L11 8L6 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
      <div class="bfc4-dots" id="bfc4-dots">
        {%- for i in (1..total_slides) -%}
          <button class="bfc4-dot{% if forloop.first %} is-active{% endif %}" onclick="bfc4GoTo({{ forloop.index0 }})"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Mobile-only leather swatches ──
       Lives BETWEEN the image column and the right panel so on mobile,
       where the image stacks above the buy box, the swatches appear
       directly under the photo. Hidden on desktop where the buy-box
       version is shown instead. {%- endcomment -%}
  {%- if leather_opt_idx != null -%}
    {%- assign leather_opt_m = product.options_with_values[leather_opt_idx] -%}
    <div class="bfc4-leather-compact bfc4-leather-mobile">
      <span class="bfc4-leather-label">{{ leather_opt_name }}</span>
      <div class="bfc4-leather-row">
        {%- for v_value in leather_opt_m.values -%}
          {%- assign v_available = false -%}
          {%- for var in product.variants -%}
            {%- assign var_v_value = var.options[leather_opt_idx] -%}
            {%- if var_v_value == v_value and var.available -%}{%- assign v_available = true -%}{%- endif -%}
          {%- endfor -%}
          {%- assign v_color = v_value | downcase | split: ' ' | first | split: '/' | first -%}
          <button
            type="button"
            class="bfc4-leather-swatch{% if v_value == current_leather %} is-active{% endif %}"
            data-leather="{{ v_color }}"
            data-leather-value="{{ v_value | escape }}"
            data-opt-index="{{ leather_opt_idx }}"
            onclick="bfc4SelectLeather(this)"
            title="{{ v_value | escape }}{% unless v_available %} (sold out){% endunless %}"
            aria-label="{{ leather_opt_name }}: {{ v_value | escape }}"
            {%- unless v_available -%}disabled{%- endunless -%}
          >{{ v_value }}</button>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} RIGHT: product content {%- endcomment -%}
  <div class="bfc4-right">

    {%- comment -%} 1. Product header + description {%- endcomment -%}
    <div class="bfc4-header">
      {%- comment -%}
        Breadcrumbs hardcoded for the medium format PDP: Home > Cameras > Medium Format Cameras > Product.
        Doesn't use Shopify's `collection` global since this file is specifically the MF template.
      {%- endcomment -%}
      <nav class="bfc4-crumbs" aria-label="Breadcrumb">
        <a href="/" class="bfc4-crumb">Home</a>
        <span class="bfc4-crumb-sep" aria-hidden="true">/</span>
        <a href="/collections/cameras" class="bfc4-crumb">Cameras</a>
        <span class="bfc4-crumb-sep" aria-hidden="true">/</span>
        <a href="/collections/medium-format-cameras" class="bfc4-crumb">Medium Format Cameras</a>
        <span class="bfc4-crumb-sep" aria-hidden="true">/</span>
        <span class="bfc4-crumb bfc4-crumb-current" aria-current="page">{{ product.title }}</span>
      </nav>
      <h1 class="bfc4-title">{{ product.title }}</h1>
      <span id="bfc4-star-placeholder"></span>
      {%- comment -%} Extract prose only from __desc, skipping spec grid {%- endcomment -%}
      {%- assign desc_text = '' -%}
      {%- if product.description contains 'bfc-desc-specs__desc' -%}
        {%- assign desc_inner = product.description | split: 'bfc-desc-specs__desc">' | last | split: '</div>' | first -%}
        {%- assign desc_text = desc_inner | strip_html | strip -%}
      {%- endif -%}
      {%- if desc_text == blank -%}
        {%- assign desc_text = product.description | split: 'bfc-desc-specs__grid' | first | strip_html | strip -%}
      {%- endif -%}
      {%- if desc_text == blank -%}
        {%- assign desc_text = product.description | strip_html | strip -%}
      {%- endif -%}
      {%- comment -%}
        Description with 4-line clamp + Read more toggle. The button visibility is decided
        in Liquid based on character count (~280 chars ≈ 4 lines at this column width). This
        bypasses unreliable JS overflow detection on -webkit-box clamped elements (Safari
        sometimes reports scrollHeight === clientHeight even when text is clipped).
      {%- endcomment -%}
      {%- assign desc_len = desc_text | strip | size -%}
      {%- assign needs_read_more = false -%}
      {%- if desc_len > 280 -%}{%- assign needs_read_more = true -%}{%- endif -%}
      <div class="bfc4-desc-wrap" id="bfc4-desc-wrap">
        <p class="bfc4-kit-desc{% if needs_read_more %} bfc4-desc-clamp{% endif %}" id="bfc4-desc">{{ desc_text }}</p>
        {%- if needs_read_more -%}
          <button type="button" class="bfc4-desc-toggle is-visible" id="bfc4-desc-toggle" onclick="bfc4ToggleDesc()" aria-expanded="false" aria-controls="bfc4-desc">
            <span class="bfc4-desc-toggle-label">Read more</span>
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        {%- endif -%}
      </div>
      {%- comment -%}
        Refurbishment trust strip. No battery mention since most MF cameras are fully
        mechanical and a "new battery" claim would be misleading.
      {%- endcomment -%}
      <ul class="bfc4-trust-strip">
        <li>
          <button type="button" class="bfc4-trust-link" onclick="baOpenPopup('bfc4-restoration-popup')" aria-label="Learn how we restore each camera">
            <svg class="bfc4-trust-check" viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path fill="currentColor" d="M6.5 11.5 3 8l1-1 2.5 2.5L12 4l1 1z"/></svg>
            <span>Restored inside &amp; out</span>
            <svg class="bfc4-trust-info" width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg>
          </button>
        </li>
        <li><svg viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path fill="currentColor" d="M6.5 11.5 3 8l1-1 2.5 2.5L12 4l1 1z"/></svg>Bench-tested by techs</li>
        <li><svg viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path fill="currentColor" d="M6.5 11.5 3 8l1-1 2.5 2.5L12 4l1 1z"/></svg>New light seals</li>
        <li><svg viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path fill="currentColor" d="M6.5 11.5 3 8l1-1 2.5 2.5L12 4l1 1z"/></svg>6-month warranty</li>
      </ul>
      {%- comment -%}
        Hidden popup data div consumed by baOpenPopup() (same popup system used by kit-item info icons).
        Click "Restored inside & out" anywhere in the trust strip → this content opens in the shared modal.
      {%- endcomment -%}
      <div id="ba-popup-data-bfc4-restoration-popup" style="display:none"
        data-title="How We Restore Each Camera"
        data-desc="Every camera in our shop is fully serviced by our in-house technicians before it leaves Brooklyn. We open up each body, replace light seals and foam, adjust shutter speeds across the full range, fix any malfunctioning functions, and modify circuitry when needed. Lenses are cleaned, lubricated, and adjusted. Mirrors and viewfinders cleared. Every reading, click, and motion is checked and tuned against professional bench equipment. All necessary fixes are made, and every camera is brought back to factory specs before it ships. This is the standard for every camera we sell, regardless of model or age."
        data-imgs=""
      ></div>
    </div>

    {%- comment -%} 2. Build Your Kit heading {%- endcomment -%}
    <div class="bfc4-kit-head">
      <span class="bfc4-kit-eyebrow">Build Your Kit</span>
    </div>

    {%- comment -%} 3. Starter kit tiles (pre-selected, orange border) + all selectable {%- endcomment -%}
    <div class="bfc4-tiles" id="bfc4-tiles">
      {%- comment -%} Camera tile {%- endcomment -%}
      <div class="bfc4-tile is-cam">
        <div class="bfc4-tile-img-wrap">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="eager"/>
          {%- endif -%}
          <span class="bfc4-tile-cam-badge">Camera</span>
        </div>
        <div class="bfc4-tile-body">
          <span class="bfc4-tile-label">Included</span>
          <span class="bfc4-tile-name">{{ product.title }}</span>
          <span class="bfc4-tile-price" id="bfc4-cam-price">{{ current_variant.price | money }}</span>
        </div>
      </div>

      {%- comment -%} Starter kit tiles only {%- endcomment -%}
      {%- for block in sk_blocks -%}
        {%- if block.type != 'kit_item' or block.settings.product == blank -%}{% continue %}{%- endif -%}
        {%- unless block.settings.is_starter_kit -%}{% continue %}{%- endunless -%}
        {%- assign sk_bp  = block.settings.product -%}
        {%- assign sk_d   = block.settings.discount_percent -%}
        {%- assign sk_dev = block.settings.is_developing -%}
        {%- assign sk_starter = block.settings.is_starter_kit -%}
        {%- assign sk_dv  = sk_bp.variants.first -%}
        {%- unless sk_dv.available -%}
          {%- for v in sk_bp.variants -%}
            {%- if v.available -%}{%- assign sk_dv = v -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
        {%- endunless -%}
        {%- assign sk_col = block.settings.column | default: block.settings.label -%}
        {%- if sk_dev -%}{%- assign sk_sale = 0 -%}
        {%- elsif sk_d > 0 -%}
          {%- assign sk_df = sk_d | times: 1.0 | divided_by: 100 -%}
          {%- assign sk_sv = sk_dv.price | times: sk_df | floor -%}
          {%- assign sk_sale = sk_dv.price | minus: sk_sv -%}
        {%- else -%}{%- assign sk_sale = sk_dv.price -%}{%- endif -%}
        {%- assign sk_popup_imgs = '' -%}
        {%- for media in sk_bp.media limit: 6 -%}
          {%- if media.media_type == 'image' -%}
            {%- assign sk_img_url = media | image_url: width: 600 -%}
            {%- if sk_popup_imgs == '' -%}{%- assign sk_popup_imgs = sk_img_url -%}
            {%- else -%}{%- assign sk_popup_imgs = sk_popup_imgs | append: '||' | append: sk_img_url -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign sk_tile_id = 'bfc4-tile-' | append: forloop.index -%}
        <div class="bfc4-tile{% if sk_starter %} is-sel{% endif %}"
          data-col="{{ sk_col | escape }}"
          data-tile-id="{{ sk_tile_id }}"
          data-variant-id="{{ sk_dv.id }}"
          data-product-title="{{ sk_bp.title | escape }}"
          data-orig="{{ sk_dv.price | default: 0 }}"
          data-sale="{{ sk_dv.price | default: 0 }}"
          data-is-dev="{{ sk_dev | default: false }}"
          data-disc="{{ sk_d | default: 0 }}"
          data-img="{{ sk_bp.featured_image | image_url: width: 400 }}"
          onclick="bfc4TileToggle(this)"
        >
          <div class="bfc4-tile-img-wrap">
            {%- if sk_bp.featured_image -%}
              <img src="{{ sk_bp.featured_image | image_url: width: 400 }}" alt="{{ sk_bp.title | escape }}" loading="lazy"/>
            {%- endif -%}
            {%- if sk_starter -%}<div class="bfc4-tile-sel-check">✓</div>{%- endif -%}
            <button class="bfc4-tile-info" onclick="event.stopPropagation(); baOpenPopup('{{ sk_tile_id }}')" aria-label="More info">
              <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg>
            </button>
          </div>
          <div class="bfc4-tile-body">
            <span class="bfc4-tile-label">{{ sk_col }}</span>
            <span class="bfc4-tile-name">{{ block.settings.custom_label | default: sk_bp.title }}</span>
            
            {%- unless sk_dev -%}<span class="bfc4-tile-price">{{ sk_dv.price | money }}</span>{%- endunless -%}
          </div>
        </div>
        <div id="ba-popup-data-{{ sk_tile_id }}" style="display:none"
          data-title="{{ sk_bp.title | escape }}"
          data-desc="{{ sk_bp.description | strip_html | escape }}"
          data-imgs="{{ sk_popup_imgs | escape }}"
        ></div>
      {%- endfor -%}
    </div>

    {%- comment -%} 4. Grade selector (compact) + price + ATC {%- endcomment -%}
    <div class="bfc4-buy">
      {%- if leather_opt_idx != null -%}
        {%- assign leather_opt = product.options_with_values[leather_opt_idx] -%}
        <div class="bfc4-leather-compact">
          <span class="bfc4-leather-label">{{ leather_opt_name }}</span>
          <div class="bfc4-leather-row">
            {%- for v_value in leather_opt.values -%}
              {%- comment -%} Determine if this value has any available variant. {%- endcomment -%}
              {%- assign v_available = false -%}
              {%- assign v_match_variant = null -%}
              {%- for var in product.variants -%}
                {%- assign var_v_value = var.options[leather_opt_idx] -%}
                {%- if var_v_value == v_value -%}
                  {%- if var.available -%}{%- assign v_available = true -%}{%- endif -%}
                  {%- if v_match_variant == null -%}{%- assign v_match_variant = var -%}{%- endif -%}
                {%- endif -%}
              {%- endfor -%}
              {%- assign v_color = v_value | downcase | split: ' ' | first | split: '/' | first -%}
              <button
                type="button"
                class="bfc4-leather-swatch{% if v_value == current_leather %} is-active{% endif %}"
                data-leather="{{ v_color }}"
                data-leather-value="{{ v_value | escape }}"
                data-opt-index="{{ leather_opt_idx }}"
                onclick="bfc4SelectLeather(this)"
                title="{{ v_value | escape }}{% unless v_available %} (sold out){% endunless %}"
                aria-label="{{ leather_opt_name }}: {{ v_value | escape }}{% unless v_available %} (sold out){% endunless %}"
                {%- unless v_available -%}disabled{%- endunless -%}
              >{{ v_value }}</button>
            {%- endfor -%}
            <span class="bfc4-leather-name" id="bfc4-leather-name">{{ current_leather }}</span>
          </div>
        </div>
      {%- endif -%}

      {%- if product.variants.size > 1 -%}
        {%- comment -%} ── Grade row ── shown only if there's a Grade option
             (or if leather is the only option, we skip this since it'd
             duplicate the leather swatches). {%- endcomment -%}
        {%- assign show_grade_row = false -%}
        {%- for opt in product.options_with_values -%}
          {%- assign opt_name_lower = opt.name | downcase -%}
          {%- if opt_name_lower contains 'grade' or opt_name_lower contains 'condition' -%}
            {%- assign show_grade_row = true -%}
          {%- endif -%}
        {%- endfor -%}
        {%- comment -%} If there's no leather option AND no explicit grade option,
             still render the legacy variant row (back-compat for products that
             use the default "Title" option). {%- endcomment -%}
        {%- if leather_opt_idx == null and show_grade_row == false -%}
          {%- assign show_grade_row = true -%}
        {%- endif -%}
        {%- if show_grade_row -%}
        <div class="bfc4-grade-compact">
          <span class="bfc4-grade-label">Grade</span>
          <div class="bfc4-grade-row">
            {%- for variant in product.variants -%}
              <button
                class="bfc4-var-btn{% if variant.id == current_variant.id %} is-active{% endif %}"
                data-variant-id="{{ variant.id }}"
                data-variant-price="{{ variant.price }}"
                data-variant-price-fmt="{{ variant.price | money }}"
                data-variant-available="{{ variant.available }}"
                onclick="bfc4SelectVariant(this)"
                {%- unless variant.available -%}disabled{%- endunless -%}
              >{{ variant.title }}</button>
            {%- endfor -%}
          </div>
        </div>
        {%- endif -%}
      {%- endif -%}
      <div class="bfc4-price-row">
        <span class="bfc4-price-label">Total</span>
        <span class="bfc4-price" id="bfc4-total">{{ sk_total | money }}</span>
      </div>

      <button class="bfc4-atc" id="bfc4-atc" onclick="bfc4AddToCart()">
        <span id="bfc4-atc-text">Add Starter Kit</span>
      </button>
      <button class="bfc4-cam-only" onclick="bfc4CameraOnly()">Camera Only &mdash; {{ current_variant.price | money }}</button>
    </div>

    {%- comment -%} 5. Starter kit + free developing banners {%- endcomment -%}
    {%- assign has_starter = false -%}
    {%- for block in sk_blocks -%}
      {%- if block.settings.is_starter_kit and block.settings.product != blank -%}{%- assign has_starter = true -%}{%- endif -%}
    {%- endfor -%}
    {%- comment -%}
      Dev credit banner sits ABOVE the starter-kit banner. Hidden by default; bfc4Render shows it
      when 2+ rolls of film are in the kit (filmCount >= 2). When visible, the user reads:
      "You unlocked a free developing credit" → THEN → "We put together a starter kit for you".
    {%- endcomment -%}
    <div class="ba-film-promo" id="ba-film-promo" style="display:none">
      <div class="ba-film-promo-icon">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="1" y="1" width="16" height="16" rx="1" stroke="#ABCC99" stroke-width="1.5"/><circle cx="9" cy="9" r="3" stroke="#ABCC99" stroke-width="1.5"/><line x1="1" y1="5" x2="17" y2="5" stroke="#ABCC99" stroke-width="1"/><line x1="1" y1="13" x2="17" y2="13" stroke="#ABCC99" stroke-width="1"/></svg>
      </div>
      <div class="ba-film-promo-text">
        <div class="ba-film-promo-title">You unlocked a free developing credit</div>
        <div class="ba-film-promo-sub">A standard developing credit will be included with your order.</div>
      </div>
      <div class="ba-film-promo-status" id="ba-promo-status" style="color:var(--ce);">✓ Unlocked</div>
    </div>
    {%- if has_starter -%}
      <div class="ba-film-promo" style="background: linear-gradient(135deg, #3a1a05 0%, #5a2e0a 100%); border: none;">
        <div class="ba-film-promo-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L11 7H16.5L12.2 10.5L13.9 16L9 12.5L4.1 16L5.8 10.5L1.5 7H7L9 2Z" stroke="#F4A027" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </div>
        <div class="ba-film-promo-text">
          <div class="ba-film-promo-title">We put together a starter kit for you</div>
          <div class="ba-film-promo-sub">Our recommended add-ons, pre-selected for you.</div>
        </div>
        <button onclick="bfc4ClearTiles()" class="ba-film-promo-status" style="background:none;border:none;cursor:pointer;font-family:var(--sn);white-space:nowrap;">Clear</button>
      </div>
    {%- endif -%}

    {%- comment -%} 6. (Mini-specs removed above-fold; see chapter quick-view below) {%- endcomment -%}

    {%- comment -%} 6b. Extended Warranty
        Tier pricing/variant IDs from snippets/bfc-warranty-tiers.liquid.
        MF cameras only offer a +6 month extension (single button) since base
        warranty is already 6 months. {%- endcomment -%}
    {%- assign cam_price = current_variant.price -%}
    {% include 'bfc-warranty-tiers', category: 'mf', cam_price: cam_price %}
    {%- liquid
      assign w12_vid = w_w12_vid
      assign w12_price = w_w12_price
    -%}
    <div class="bfc4-ext-warranty">
      <div class="bfc4-ext-w-head">
        <span class="bfc4-ext-w-eyebrow">Extended Warranty</span>
        <button class="bfc4-tile-info" onclick="baOpenPopup('bfc4-ext-w-popup')" aria-label="Extended warranty details" style="position:relative;bottom:auto;right:auto;flex-shrink:0;">
          <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg>
        </button>
      </div>
      <div class="bfc4-ext-w-baseline">
        <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>Your camera includes a <strong>6-month warranty</strong> — extend to a full year below:</span>
      </div>
      <div class="bfc4-ext-w-options bfc4-ext-w-options--single">
        <button class="bfc4-ext-w-btn" data-months="6" data-total="12" data-price="{{ w12_price }}" data-variant-id="{{ w12_vid }}" onclick="bfc4SelectWarranty(this)">
          <span class="bfc4-ext-w-extend">+6 months</span>
          <span class="bfc4-ext-w-months">1 year total</span>
          <span class="bfc4-ext-w-price">+{{ w12_price | money_without_trailing_zeros }}</span>
          <span class="bfc4-ext-w-acc">+ Accidental</span>
        </button>
      </div>
      <button class="bfc4-ext-w-none" id="bfc4-ext-w-clear" onclick="bfc4ClearWarranty()">&times; Remove Extended Warranty</button>
    </div>
    <div id="ba-popup-data-bfc4-ext-w-popup" style="display:none"
      data-title="Extended Warranty"
      data-desc="Your camera includes a 6-month warranty. Extended warranty adds 6 months on top, for a full year of coverage from your purchase date. Extended warranty covers any issues including accidental damage, which the standard warranty does not cover. Approved claims are repaired at no cost. If the camera cannot be repaired, you will receive a BFC gift card at the value you paid, redeemable on any camera in our shop. Warranties are non-transferable and apply to the original purchaser only. Must be purchased within 30 days of your camera purchase."
      data-imgs=""
    ></div>

    {%- comment -%} 7. Nav links {%- endcomment -%}
    <div class="bfc4-nav-links">
    <button class="bfc4-customize" onclick="document.getElementById('bfc4-custom').scrollIntoView({behavior:'smooth'})">
      Expand your kit
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 2v8M2 6l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/></svg>
    </button>
    <button class="bfc4-customize" onclick="document.getElementById('bfc4-policy-section').scrollIntoView({behavior:'smooth'})">
      Warranty
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 2v8M2 6l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/></svg>
    </button>
    </div>

  </div>{%- comment -%} /bfc4-right {%- endcomment -%}
</div>{%- comment -%} /bfc4-split {%- endcomment -%}

{%- comment -%} ── BELOW FOLD ── {%- endcomment -%}
<div class="bfc4-below">

  {%- comment -%} Shot on {%- endcomment -%}
  {%- if g1 or g2 or g3 -%}
  <div class="ba-shot">
    <div class="ba-shot-head">
      {%- assign shot_title = product.title | split: ' | ' | first | split: ' + ' | first | split: ' Prism' | first | split: ' with ' | first | strip -%}
      <h2 class="ba-shot-title">Shot on {{ shot_title }}</h2>
      <span class="ba-shot-sub">All Photos Taken on {{ shot_title }}</span>
    </div>
    <div class="ba-shot-grid" id="ba-shot-grid">
      {%- if g1 -%}<a href="{{ g1 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="0" onclick="bfc4OpenShotLightbox(event, 0)"><img src="{{ g1 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g2 -%}<a href="{{ g2 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="1" onclick="bfc4OpenShotLightbox(event, 1)"><img src="{{ g2 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g3 -%}<a href="{{ g3 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="2" onclick="bfc4OpenShotLightbox(event, 2)"><img src="{{ g3 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g4 -%}<a href="{{ g4 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="3" onclick="bfc4OpenShotLightbox(event, 3)"><img src="{{ g4 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g5 -%}<a href="{{ g5 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="4" onclick="bfc4OpenShotLightbox(event, 4)"><img src="{{ g5 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      {%- if g6 -%}<a href="{{ g6 | image_url: width: 1600 }}" data-lightbox="gallery" data-idx="5" onclick="bfc4OpenShotLightbox(event, 5)"><img src="{{ g6 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ════════════════════════════════════════════════
       CHAPTER — Restoration process + Camera specs (combined)
       Centered dark header with toggle button (SX-70 style)
       ════════════════════════════════════════════════ {%- endcomment -%}
  <div class="bfc4-chapter" id="bfc4-chapter">
    <div class="bfc4-chapter-body" id="bfc4-chapter-body">
      <div class="bfc4-chapter-grid">

        {%- comment -%} ── LEFT: HEADER ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-header">
          <h2 class="bfc4-chapter-title">{{ product.title | escape }}</h2>
          <p class="bfc4-chapter-sub">We started Brooklyn Film Camera to take the guesswork out of buying a film camera. Most shops give you a wipe-down and, at best, replace the light seals &mdash; that isn't enough. Decades-old mechanical cameras need real work to shoot like they did the day they left the factory.</p>
          <button type="button" class="bfc4-chapter-toggle" id="bfc4-chapter-toggle" aria-expanded="false" aria-controls="bfc4-chapter-body" onclick="bfc4ToggleChapter()">
            <span class="bfc4-chapter-toggle-text">View full process &amp; all specs</span>
            <svg class="bfc4-chapter-toggle-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide story" data-closed-label="View full story" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View full story</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="bfc4-chapter-extra bfc4-chapter-header-extra">
            {%- if section.settings.restoration_photo != blank -%}
              <div class="ba-restore-photo">
                <img src="{{ section.settings.restoration_photo | image_url: width: 1200 }}" alt="Restoration in progress at Brooklyn Film Camera" loading="lazy"/>
              </div>
            {%- endif -%}

            {%- if section.settings.restoration_prose != blank -%}
              <div class="ba-restore-prose">{{ section.settings.restoration_prose }}</div>
            {%- else -%}
              <div class="ba-restore-prose">
                <p>Every camera we sell passes through our in-house technicians. We adjust shutter speeds back to factory spec, modify circuitry when the original components have aged out, replace parts when needed, and bench-test every function before anything ships. Years of research and development go into the process, and we keep refining it.</p>
                <p>You're not gambling on whether the camera works. You're getting a tool brought back to pristine condition by people who've spent careers learning how.</p>
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ── MIDDLE: PROCESS (MF-tuned steps) ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-process" id="ba-restore">
          <div class="bfc4-chapter-col-head">
            <span class="bfc4-chapter-col-ey">Our Process</span>
            <h3 class="bfc4-chapter-col-title">Hand-restored in Brooklyn</h3>
            <p class="bfc4-chapter-col-sub">Each camera goes through four checkpoints before it ships.</p>
          </div>

          <ul class="bfc4-chapter-process-list">
            <li><span class="num">01</span><span>Full mechanical inspection</span></li>
            <li><span class="num">02</span><span>Film back service &amp; seal replacement</span></li>
            <li><span class="num">03</span><span>Lens &amp; optics serviced</span></li>
            <li><span class="num">04</span><span>Tested on professional bench equipment</span></li>
          </ul>

          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide steps" data-closed-label="View all steps" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View all steps</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="bfc4-chapter-extra bfc4-chapter-process-extra">
            <div class="bfc4-chapter-process-detail">
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">01</span>
                <div class="body"><strong>Full Inspection</strong><p>Body, lens, and film back &mdash; every mechanical function tested and verified on professional bench equipment.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">02</span>
                <div class="body"><strong>Film Back Service</strong><p>Dark slides checked, seals replaced, film transport verified. No light leaks, no exceptions.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">03</span>
                <div class="body"><strong>Lens &amp; Optics</strong><p>Cleaned, inspected, and serviced. Optics checked for fungus, haze, and oil on aperture blades.</p></div>
              </div>
              <div class="bfc4-chapter-process-detail-step">
                <span class="num">04</span>
                <div class="body"><strong>Final QC</strong><p>Tested with professional equipment before it ships from Brooklyn.</p></div>
              </div>
            </div>
          </div>
        </div>

        {%- comment -%} ── RIGHT: SPECS ── {%- endcomment -%}
        <div class="bfc4-chapter-col bfc4-chapter-specs">
          <div class="bfc4-chapter-col-head">
            <h3 class="bfc4-chapter-col-title">Specifications</h3>
            <p class="bfc4-chapter-col-sub">The exact technical details of this camera.</p>
          </div>

          <div class="bfc4-chapter-specs-quick">
            {%- comment -%} Quick view: fall through up to 4 specs. MF tunes priority order
                to put Mount and Shutter first since lens mount is a major buying decision
                for medium format. Universal fallbacks fill any empty slots. {%- endcomment -%}
            {%- assign qs_count = 0 -%}
            {%- if spec_mount != blank and qs_count < 4 -%}
              <div><span class="key">Mount</span><span class="val">{{ spec_mount }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_shutter != blank and qs_count < 4 -%}
              <div><span class="key">Shutter</span><span class="val">{{ spec_shutter }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_lens != blank and qs_count < 4 -%}
              <div><span class="key">Lens</span><span class="val">{{ spec_lens }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_meter != blank and qs_count < 4 -%}
              <div><span class="key">Metering</span><span class="val">{{ spec_meter }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_focus != blank and qs_count < 4 -%}
              <div><span class="key">Focus</span><span class="val">{{ spec_focus }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_battery != blank and qs_count < 4 -%}
              <div><span class="key">Battery</span><span class="val">{{ spec_battery }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if spec_flash != blank and qs_count < 4 -%}
              <div><span class="key">Flash</span><span class="val">{{ spec_flash }}</span></div>
              {%- assign qs_count = qs_count | plus: 1 -%}
            {%- endif -%}
            {%- if qs_count < 4 -%}<div><span class="key">Warranty</span><span class="val">6 months</span></div>{%- assign qs_count = qs_count | plus: 1 -%}{%- endif -%}
            {%- if qs_count < 4 -%}<div><span class="key">Condition</span><span class="val">{% if product.variants.size > 1 %}A &amp; B Grade{% else %}Verified{% endif %}</span></div>{%- assign qs_count = qs_count | plus: 1 -%}{%- endif -%}
          </div>

          <button type="button" class="bfc4-chapter-col-toggle" aria-expanded="false" data-open-label="Hide specs" data-closed-label="View all specs" onclick="bfc4ToggleChapterCol(this)">
            <span class="bfc4-chapter-col-toggle-label">View all specs</span>
            <svg class="bfc4-chapter-col-toggle-icon" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="bfc4-chapter-extra bfc4-chapter-specs-extra">
            <div class="bfc4-chapter-specs-full">
              {%- if spec_lens    != blank -%}<div><span class="key">Lens</span><span class="val">{{ spec_lens }}</span></div>{%- endif -%}
              {%- if spec_meter   != blank -%}<div><span class="key">Metering</span><span class="val">{{ spec_meter }}</span></div>{%- endif -%}
              {%- if spec_focus   != blank -%}<div><span class="key">Focus</span><span class="val">{{ spec_focus }}</span></div>{%- endif -%}
              {%- if spec_timer   != blank -%}<div><span class="key">Self Timer</span><span class="val">{{ spec_timer }}</span></div>{%- endif -%}
              {%- if spec_tripod  != blank -%}<div><span class="key">Tripod</span><span class="val">{{ spec_tripod }}</span></div>{%- endif -%}
              {%- if spec_expcomp != blank -%}<div><span class="key">Exp. Comp.</span><span class="val">{{ spec_expcomp }}</span></div>{%- endif -%}
              {%- if spec_dx      != blank -%}<div><span class="key">DX Reader</span><span class="val">{{ spec_dx }}</span></div>{%- endif -%}
              <div><span class="key">Condition</span><span class="val">{% if product.variants.size > 1 %}A &amp; B Grade &mdash; Fully Refurbished{% else %}Fully Refurbished{% endif %}</span></div>
            </div>
          </div>
        </div>

      </div>
    </div>{%- comment -%} /bfc4-chapter-body {%- endcomment -%}
  </div>{%- comment -%} /bfc4-chapter {%- endcomment -%}

  {%- comment -%} Custom kit section {%- endcomment -%}
  <div class="bfc4-custom" id="bfc4-custom">
    <div class="bfc4-custom-head">
      <span class="bfc4-custom-eyebrow">Build Your Own</span>
      <h2 class="bfc4-custom-title">Build your kit.</h2>

    </div>

    {%- comment -%} Collect columns {%- endcomment -%}
    {%- assign col_names = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'kit_item' and block.settings.product != blank -%}
        {%- assign col = block.settings.column | default: block.settings.label -%}
        {%- unless col_names contains col -%}
          {%- if col_names == '' -%}{%- assign col_names = col -%}
          {%- else -%}{%- assign col_names = col_names | append: '||' | append: col -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign col_name_arr = col_names | split: '||' -%}

    <div class="ba-columns">
      {%- for col_name in col_name_arr -%}
        <div class="ba-col" id="bfc4-col-{{ forloop.index }}" data-col-name="{{ col_name | escape }}">
          <div class="ba-col-head" onclick="baToggleCol(this.closest('.ba-col'))">
            <div class="ba-col-title">
              {{ col_name }}
              <span class="ba-col-count" id="ba-col-count-{{ forloop.index }}">0</span>
            </div>
            <svg class="ba-col-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
          </div>
          <div class="ba-col-body">
          {%- assign col_item_index = 0 -%}
          {%- assign col_item_total = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'kit_item' and block.settings.product != blank -%}
              {%- assign block_col = block.settings.column | default: block.settings.label -%}
              {%- if block_col == col_name -%}{%- assign col_item_total = col_item_total | plus: 1 -%}{%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- for block in section.blocks -%}
            {%- if block.type != 'kit_item' -%}{% continue %}{%- endif -%}
            {%- assign bp = block.settings.product -%}
            {%- if bp == blank -%}{% continue %}{%- endif -%}
            {%- assign block_col = block.settings.column | default: block.settings.label -%}
            {%- unless block_col == col_name -%}{% continue %}{%- endunless -%}
            {%- assign col_item_index = col_item_index | plus: 1 -%}

            {%- liquid
              assign is_dev       = block.settings.is_developing
              assign disc         = block.settings.discount_percent
              assign specific_vid = block.settings.variant_id | strip
              assign cat_id       = 'ba-cat-' | append: forloop.index
              assign show_variants = false
              if bp.variants.size > 1 and specific_vid == blank
                assign show_variants = true
              endif
              assign display_variant = bp.variants.first
            -%}
            {%- unless specific_vid == blank -%}
              {%- for v in bp.variants -%}
                {%- assign vid_str = v.id | append: '' -%}
                {%- if vid_str == specific_vid -%}{%- assign display_variant = v -%}{%- endif -%}
              {%- endfor -%}
            {%- endunless -%}
            {%- liquid
              assign orig_cents = display_variant.price
              if is_dev
                assign sale_cents = 0
              elsif disc > 0
                assign disc_float = disc | times: 1.0 | divided_by: 100
                assign save_cents = orig_cents | times: disc_float | floor
                assign sale_cents = orig_cents | minus: save_cents
              else
                assign sale_cents = orig_cents
              endif
            -%}
            {%- assign popup_imgs = '' -%}
            {%- for media in bp.media limit: 6 -%}
              {%- if media.media_type == 'image' -%}
                {%- assign img_url = media | image_url: width: 600 -%}
                {%- if popup_imgs == '' -%}{%- assign popup_imgs = img_url -%}
                {%- else -%}{%- assign popup_imgs = popup_imgs | append: '||' | append: img_url -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- assign is_available = display_variant.available -%}
            <div
              class="ba-mini-card{% if col_item_index > 2 %} is-hidden{% endif %}{% unless is_available %} is-oos{% endunless %}"
              id="{{ cat_id }}"
              data-variant-id="{{ display_variant.id }}"
              data-product-title="{{ bp.title | escape }}"
              data-orig="{{ orig_cents }}"
              data-sale="{{ orig_cents }}"
              data-is-dev="{{ is_dev }}"
              data-disc="{{ disc }}"
              data-cat="{{ cat_id }}"
              data-col-id="bfc4-col-{{ forloop.parentloop.index }}"
              data-col-name="{{ col_name | escape }}"
              data-starter="{{ block.settings.is_starter_kit }}"
              onclick="baMiniSelect(this, event)"
              {{ block.shopify_attributes }}
            >
              <div class="ba-mini-img-wrap">
                {%- if bp.featured_image -%}
                  <img class="ba-mini-img" src="{{ bp.featured_image | image_url: width: 400 }}" alt="{{ bp.title | escape }}" loading="lazy"/>
                {%- else -%}
                  <div class="ba-mini-img-ph"></div>
                {%- endif -%}
                {%- unless is_available -%}
                  <div class="bfc4-oos-badge">Sold Out</div>
                {%- endunless -%}
                <button
                  class="ba-mini-info-icon"
                  onclick="event.stopPropagation(); baOpenPopup('{{ cat_id }}')"
                  aria-label="View details"
                ><svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg></button>
              </div>
              <div class="ba-mini-body">
                <div class="ba-mini-info">
                  <div class="ba-mini-name">{{ block.settings.custom_label | default: bp.title }}</div>
                </div>
                <div class="ba-mini-right">
                  {%- unless is_available -%}<span style="font-size:9px;color:rgba(32,32,9,0.55);font-weight:600;letter-spacing:0.06em;text-transform:uppercase;">Sold Out</span>
                  {%- else -%}
                  {%- unless is_dev -%}<span class="ba-mini-price">{{ orig_cents | money }}</span>{%- endunless -%}
                  {%- endunless -%}
                </div>
              </div>
              {%- if show_variants -%}
                <div class="ba-mini-vars" onclick="event.stopPropagation()">
                  {%- for variant in bp.variants -%}
                    {%- if variant.available -%}
                      {%- liquid
                        assign v_orig = variant.price
                        if is_dev
                          assign v_sale = 0
                        elsif disc > 0
                          assign v_df = disc | times: 1.0 | divided_by: 100
                          assign v_sv = v_orig | times: v_df | floor
                          assign v_sale = v_orig | minus: v_sv
                        else
                          assign v_sale = v_orig
                        endif
                      -%}
                      <button
                        class="ba-mini-var-btn{% if forloop.first %} is-sel{% endif %}"
                        data-variant-id="{{ variant.id }}"
                        data-product-title="{{ bp.title | escape }}"
                        data-orig="{{ variant.price }}"
                        data-sale="{{ variant.price }}"
                        data-is-dev="{{ is_dev }}"
                        data-disc="{{ disc }}"
                        data-cat="{{ cat_id }}"
                        onclick="baMiniSelectVar(this)"
                      >{{ variant.title }} – {%- if is_dev -%}Free{%- else -%}{{ v_sale | money }}{%- endif -%}</button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
            <div id="ba-popup-data-{{ cat_id }}" style="display:none"
              data-title="{{ bp.title | escape }}"
              data-desc="{{ bp.description | strip_html | escape }}"
              data-imgs="{{ popup_imgs | escape }}"
            ></div>
          {%- endfor -%}
          {%- if col_item_total > 2 -%}
            <button class="ba-col-more" onclick="event.stopPropagation(); baExpandCol(this.closest('.ba-col'))">
              <span class="ba-col-more-text">{{ col_item_total | minus: 2 }} more &rsaquo;</span>
            </button>
          {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Promo banners {%- endcomment -%}


    {%- comment -%} Selected add-ons row + checkout {%- endcomment -%}
    <div class="bfc4-below-checkout">
      <div class="bfc4-selected-row" id="bfc4-selected-row">
        <div class="bfc4-selected-items" id="bfc4-selected-items">
          {%- comment -%} Populated by JS {%- endcomment -%}
        </div>
        <div class="bfc4-below-atc">
          {%- comment -%} ── Leather Cover swatches (mirror of primary buy box) ── {%- endcomment -%}
          {%- if leather_opt_idx != null -%}
            {%- assign leather_opt2 = product.options_with_values[leather_opt_idx] -%}
            <div class="bfc4-leather-compact">
              <span class="bfc4-leather-label">{{ leather_opt_name }}</span>
              <div class="bfc4-leather-row">
                {%- for v_value in leather_opt2.values -%}
                  {%- assign v_available = false -%}
                  {%- for var in product.variants -%}
                    {%- assign var_v_value = var.options[leather_opt_idx] -%}
                    {%- if var_v_value == v_value and var.available -%}{%- assign v_available = true -%}{%- endif -%}
                  {%- endfor -%}
                  {%- assign v_color = v_value | downcase | split: ' ' | first | split: '/' | first -%}
                  <button
                    type="button"
                    class="bfc4-leather-swatch{% if v_value == current_leather %} is-active{% endif %}"
                    data-leather="{{ v_color }}"
                    data-leather-value="{{ v_value | escape }}"
                    data-opt-index="{{ leather_opt_idx }}"
                    onclick="bfc4SelectLeather(this)"
                    title="{{ v_value | escape }}{% unless v_available %} (sold out){% endunless %}"
                    aria-label="{{ leather_opt_name }}: {{ v_value | escape }}"
                    {%- unless v_available -%}disabled{%- endunless -%}
                  >{{ v_value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
          {%- if product.variants.size > 1 and show_grade_row -%}
            <div class="bfc4-grade-compact">
              <span class="bfc4-grade-label">Grade</span>
              <div class="bfc4-grade-row">
                {%- for variant in product.variants -%}
                  <button
                    class="bfc4-var-btn{% if variant.id == current_variant.id %} is-active{% endif %}"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price }}"
                    data-variant-price-fmt="{{ variant.price | money }}"
                    data-variant-available="{{ variant.available }}"
                    onclick="bfc4SelectVariant(this)"
                    {%- unless variant.available -%}disabled{%- endunless -%}
                  >{{ variant.title }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
          <div class="bfc4-price-row">
            <span class="bfc4-price-label">Total</span>
            <span class="bfc4-price" id="bfc4-total-2">{{ sk_total | money }}</span>
          </div>

          <button class="bfc4-atc" onclick="bfc4AddToCart()">
            <span>Add Starter Kit</span>
          </button>
          <button class="bfc4-cam-only" onclick="bfc4CameraOnly()">Camera Only &mdash; {{ current_variant.price | money }}</button>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Reviews {%- endcomment -%}
  <div id="bfc4-reviews">
    {% render 'bfc-pdp-reviews', pdp_handle: product.handle, pdp_title: product.title %}
  </div>

  {%- comment -%} Warranty policy {%- endcomment -%}
  <div class="bfc4-policy" id="bfc4-policy-section">
    <div class="bfc4-policy-col">
      <span class="bfc4-policy-ey">Warranty</span>
      <h2 class="bfc4-policy-title">We stand behind every camera.</h2>
      <div class="bfc4-policy-pill">
        <svg width="10" height="10" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        6-Month Warranty Included
      </div>
      <div class="bfc4-policy-body">
        <p>Every medium format camera we sell includes a <strong>6-month warranty</strong> covering mechanical and electrical defects. If something goes wrong, we'll repair it or replace it with the exact same camera you purchased.</p>
        <p style="margin-top:10px">To open a claim, visit the Shipping Label tab in your <a href="https://account.brooklynfilmcamera.com" style="color:inherit;text-decoration:underline;text-underline-offset:2px;">BFC account</a>, or come into the store anytime.</p>
        <p style="margin-top:10px;color:rgba(78,71,65,0.6);font-size:11px">Return shipping is covered by BFC within the first 30 days. After 30 days, the buyer is responsible for return shipping on warranty claims.</p>
        <p style="margin-top:12px"><a href="https://brooklynfilmcamera.com/pages/warranty" style="font-size:11px;color:var(--or);font-weight:600;letter-spacing:0.06em;text-decoration:underline;text-underline-offset:2px;">View full warranty policy &rsaquo;</a></p>
      </div>
    </div>
  </div>

</div>{%- comment -%} /bfc4-below {%- endcomment -%}

{%- comment -%} Sticky Mobile ATC Bar {%- endcomment -%}
<div class="bfc4-sticky-bar" id="bfc4-sticky-bar">
  <div class="bfc4-sticky-info">
    <div class="bfc4-sticky-name">{{ product.title }}</div>
    <div class="bfc4-sticky-meta">
      {%- unless current_variant.title == 'Default Title' -%}
        <span class="bfc4-sticky-grade" id="bfc4-sticky-grade">{{ current_variant.title }}</span>
      {%- endunless -%}
      <span class="bfc4-sticky-price" id="bfc4-sticky-price">{{ current_variant.price | money }}</span>
    </div>
  </div>
  <button class="bfc4-sticky-btn" id="bfc4-sticky-btn" onclick="bfc4AddToCart()"{% unless current_variant.available %} disabled{% endunless %}><span id="bfc4-sticky-btn-text">Add to Cart</span></button>
</div>

{%- comment -%} Hidden product form {%- endcomment -%}
{%- assign bfc4_form_id = 'bfc4-form-' | append: section.id -%}
<div style="display:none">
  <product-form class="product-form" data-hide-errors="false" data-section-id="{{ section.id }}">
    {%- form 'product', product, id: bfc4_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id" id="bfc4-variant-input"/>
      <div class="product-form__buttons" data-display-quantity="false" data-display-layout="seperate" data-display-dynamics="false">
        <button id="ProductSubmitButton-{{ section.id }}" type="submit" name="add" class="product-form__submit button button--filled">
          <span>Add to Cart</span>
          <div class="loading__spinner hidden">
            <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66"><circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
          </div>
