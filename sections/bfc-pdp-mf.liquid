  // ── Popup ────────────────────────────────────────
  window.baOpenPopup = function(catId) {
    var data = document.getElementById('ba-popup-data-' + catId);
    if (!data) return;
    document.getElementById('ba-popup-title').textContent = data.dataset.title;
    var desc = data.dataset.desc;
    document.getElementById('ba-popup-desc').innerHTML = desc ? '<p>' + desc.replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br/>') + '</p>' : '';
    var imgs = data.dataset.imgs ? data.dataset.imgs.split('||') : [];
    document.getElementById('ba-popup-imgs').innerHTML = imgs.map(function(src) { return '<img src="' + src + '" loading="lazy"/>'; }).join('');
    document.getElementById('ba-popup-overlay').classList.add('is-open');
    document.body.style.overflow = 'hidden';
  };
  window.baClosePopup = function() {
    document.getElementById('ba-popup-overlay').classList.remove('is-open');
    document.body.style.overflow = '';
  };
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') baClosePopup(); });

  // ── Image slider ─────────────────────────────────
  var bfc4Slide_current = 0;
  var bfc4Slide_total   = document.querySelectorAll('.bfc4-slide').length;
  window.bfc4Slide = function(dir) {
    bfc4GoTo((bfc4Slide_current + dir + bfc4Slide_total) % bfc4Slide_total);
  };
  window.bfc4GoTo = function(idx) {
    bfc4Slide_current = idx;
    var slides = document.getElementById('bfc4-slides');
    if (slides) slides.style.transform = 'translateX(-' + (idx * 100) + '%)';
    document.querySelectorAll('.bfc4-dot').forEach(function(d, i) { d.classList.toggle('is-active', i === idx); });
    var prev = document.querySelector('.bfc4-arrow.is-prev');
    if (prev) prev.style.visibility = idx === 0 ? 'hidden' : 'visible';
  };
  (function() {
    var left = document.querySelector('.bfc4-left');
    if (!left || bfc4Slide_total <= 1) return;
    var startX = 0;
    left.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
    left.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) bfc4Slide(dx < 0 ? 1 : -1);
    });
  })();

  function fmt(cents) { return '$' + (cents / 100).toFixed(2).replace(/\.00$/, ''); }
  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // Collapse custom kit columns on mobile
  if (window.innerWidth <= 900) {
    document.querySelectorAll('.ba-col').forEach(function(c) { c.classList.remove('is-open'); });
  }

  // Seed pre-selected starter tiles into STATE — skip OOS tiles
  document.querySelectorAll('.bfc4-tile.is-sel:not(.is-cam)').forEach(function(tile) {
    if (tile.classList.contains('is-oos')) {
      tile.classList.remove('is-sel');
      var check = tile.querySelector('.bfc4-tile-sel-check');
      if (check) check.remove();
      return;
    }
    var tileId = tile.dataset.tileId || ('sk-' + Math.random().toString(36).slice(2));
    tile.dataset.stateKey = tileId;
    var col = (tile.dataset.col || '').toLowerCase();
      var pt = (tile.dataset.productTitle || '').toLowerCase();
      var isFilm = tile.dataset.isDev !== 'true' && (col.indexOf('film') >= 0 || pt.indexOf('film') >= 0 || /\b(portra|tri-x|gold|ultramax|hp5|fp4|delta|t-max|tmax|color|b&w|cinestill|ektar|lomo|lucky|fomapan|kentmere|rollei|jch|dubblefilm|fuji|velvia|provia|ektachrome|acros|pro 400|pro 800|pan f)\b/i.test(pt));
    STATE.kit[tileId] = {
      variantId: tile.dataset.variantId,
      name:      tile.dataset.productTitle || '',
      orig:      parseInt(tile.dataset.orig || '0', 10),
      sale:      parseInt(tile.dataset.sale || '0', 10),
      isDev:     tile.dataset.isDev === 'true',
      disc:      parseInt(tile.dataset.disc || '0', 10),
      isFilm:    isFilm,
      colId:     tileId,
      img:       tile.dataset.img || null
    };
  });

  // Mark accordion cards for starter kit items
  syncAccordionLocks();

  // ── Extended Warranty ─────────────────────────
  // Warranty tier table — sourced from snippets/bfc-warranty-tiers-js.liquid.
  // Medium Format pricing, 9 brackets. Same shape as before.
  {% render 'bfc-warranty-tiers-js', category: 'mf' %}
  function bfc4GetWarrantyTier(price) {
    for (var i = 0; i < BFC_WARRANTY_TIERS.length; i++) {
      if (price <= BFC_WARRANTY_TIERS[i].max) return BFC_WARRANTY_TIERS[i];
    }
    return BFC_WARRANTY_TIERS[BFC_WARRANTY_TIERS.length - 1];
  }
  function bfc4UpdateWarrantyTier(variantPrice) {
    var tier = bfc4GetWarrantyTier(variantPrice);
    // MF: single +6 month button (1 year total). Pulls v12/p12 only.
    document.querySelectorAll('.bfc4-ext-w-btn').forEach(function(btn) {
      btn.dataset.variantId = tier.v12;
      btn.dataset.price = tier.p12;
      var el = btn.querySelector('.bfc4-ext-w-price');
      if (el) el.textContent = '+$' + (tier.p12 / 100).toFixed(0);
      if (btn.classList.contains('is-sel') && STATE.extWarranty) {
        STATE.extWarranty.variantId = tier.v12;
        STATE.extWarranty.price = tier.p12;
      }
    });
    bfc4Render();
  }
  window.bfc4SelectWarranty = function(btn) {
    var wasSelected = btn.classList.contains('is-sel');
    document.querySelectorAll('.bfc4-ext-w-btn').forEach(function(b) { b.classList.remove('is-sel'); });
    var clearBtn = document.getElementById('bfc4-ext-w-clear');
    if (wasSelected) {
      STATE.extWarranty = null;
      if (clearBtn) clearBtn.classList.remove('is-vis');
    } else {
      btn.classList.add('is-sel');
      STATE.extWarranty = {
        months: parseInt(btn.dataset.months, 10),
        total:  parseInt(btn.dataset.total, 10),
        price:  parseInt(btn.dataset.price, 10),
        variantId: btn.dataset.variantId || null
      };
      if (clearBtn) clearBtn.classList.add('is-vis');
    }
    bfc4Render();
  };
  window.bfc4ClearWarranty = function() {
    document.querySelectorAll('.bfc4-ext-w-btn').forEach(function(b) { b.classList.remove('is-sel'); });
    STATE.extWarranty = null;
    var clearBtn = document.getElementById('bfc4-ext-w-clear');
    if (clearBtn) clearBtn.classList.remove('is-vis');
    bfc4Render();
  };
  bfc4UpdateWarrantyTier(STATE.variantPrice);

  bfc4Render();

  // ── Sticky Mobile ATC Bar ──────────────────────
  var stickyBar = document.getElementById('bfc4-sticky-bar');
  var mainAtc   = document.getElementById('bfc4-atc');
  if (stickyBar && mainAtc && window.innerWidth <= 900) {
    new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        stickyBar.classList.toggle('is-visible', !e.isIntersecting);
      });
    }, { threshold: 0 }).observe(mainAtc);
  }

  // ── Description "Read more" toggle ──
  // Button visibility is decided server-side in Liquid (based on description length).
  // This handler only manages the click-to-expand-collapse interaction.
  window.bfc4ToggleDesc = function() {
    var wrap = document.getElementById('bfc4-desc-wrap');
    if (!wrap) return;
    var btn = document.getElementById('bfc4-desc-toggle');
    var label = btn && btn.querySelector('.bfc4-desc-toggle-label');
    var expanded = wrap.classList.toggle('is-expanded');
    if (label) label.textContent = expanded ? 'Read less' : 'Read more';
    if (btn) btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
  };
  // Verification pass: the Liquid character-count heuristic is coarse (some 280-380
  // char descriptions actually fit in 4 lines if the words are short). Measure the
  // real heights after layout settles. If text fits, drop the clamp and hide the
  // button. This is HIDE-ONLY — JS never reveals the button, only removes it when
  // the measurement confirms no overflow. Safer than the show-based approach which
  // had timing issues with -webkit-box.
  (function() {
    function verifyDescOverflow() {
      var desc = document.getElementById('bfc4-desc');
      var toggle = document.getElementById('bfc4-desc-toggle');
      var wrap = document.getElementById('bfc4-desc-wrap');
      if (!desc || !toggle || !wrap) return;
      if (wrap.classList.contains('is-expanded')) return;
      if (!desc.classList.contains('bfc4-desc-clamp')) return;
      // Measure clamped height first
      var clampedH = desc.clientHeight;
      // Temporarily remove the clamp to measure full unclamped height. Without
      // -webkit-box, the element is a normal block, so clientHeight === full height.
      desc.classList.remove('bfc4-desc-clamp');
      // Force a layout recalc so the next measurement is accurate
      void desc.offsetHeight;
      var fullH = desc.clientHeight;
      // If the unclamped height is essentially the same as the clamped height,
      // the text fit in 4 lines anyway. Leave the clamp off and remove the button.
      if (fullH <= clampedH + 2) {
        toggle.remove();
        // .bfc4-desc-clamp stays off intentionally so the text shows in full
      } else {
        // Text really does overflow. Put the clamp back.
        desc.classList.add('bfc4-desc-clamp');
      }
    }
    function schedule() {
      requestAnimationFrame(verifyDescOverflow);
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(verifyDescOverflow);
      }
      setTimeout(verifyDescOverflow, 400);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', schedule);
    } else {
      schedule();
    }
  })();
})();

/* ─── PHOTO LIGHTBOX — used by hero slider + Shot On gallery ─── */
(function() {
  window.__bfc4Lb = window.__bfc4Lb || { srcs: [], cur: 0 };
  var grid = document.getElementById('ba-shot-grid');
  if (grid) {
    var anchors = grid.querySelectorAll('a[data-lightbox="gallery"]');
    anchors.forEach(function(a) { window.__bfc4Lb.srcs.push(a.getAttribute('href')); });
  }

  window.bfc4Lightbox = function(event, idx) {
    if (event) { event.preventDefault(); event.stopPropagation(); }
    var lb = window.__bfc4Lb;
    if (!lb.srcs.length) return;
    lb.cur = idx;
    var box = document.getElementById('ba-lightbox');
    var img = document.getElementById('ba-lightbox-img');
    var wrap = document.getElementById('ba-lightbox-imgwrap');
    var counter = document.getElementById('ba-lightbox-counter');
    if (img) {
      img.classList.remove('is-zoomed');
      img.src = lb.srcs[lb.cur];
    }
    if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
    if (counter) counter.textContent = (lb.cur + 1) + ' / ' + lb.srcs.length;
    if (box) box.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    // Preload all srcs so arrow nav is instant
    lb.srcs.forEach(function(src) { var pre = new Image(); pre.src = src; });
  };

  window.bfc4LightboxClose = function(event, force) {
    if (force !== true) {
      if (!event || !event.target) return;
      var t = event.target;
      if (t.tagName === 'IMG') return;
      if (t.closest('button')) return;
    }
    var box = document.getElementById('ba-lightbox');
    var img = document.getElementById('ba-lightbox-img');
    var wrap = document.getElementById('ba-lightbox-imgwrap');
    if (img) img.classList.remove('is-zoomed');
    if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
    if (box) box.classList.remove('is-open');
    document.body.style.overflow = '';
  };

  window.bfc4LightboxNav = function(event, dir) {
    if (event) event.stopPropagation();
    var lb = window.__bfc4Lb;
    if (!lb.srcs.length) return;
    lb.cur = (lb.cur + dir + lb.srcs.length) % lb.srcs.length;
    var img = document.getElementById('ba-lightbox-img');
    var wrap = document.getElementById('ba-lightbox-imgwrap');
    var counter = document.getElementById('ba-lightbox-counter');
    if (img) {
      img.classList.remove('is-zoomed');
      img.src = lb.srcs[lb.cur];
    }
    if (wrap) { wrap.scrollLeft = 0; wrap.scrollTop = 0; }
    if (counter) counter.textContent = (lb.cur + 1) + ' / ' + lb.srcs.length;
  };

  // Click image → toggle zoom. While zoomed, wrapper's overflow:auto lets the
  // user pan via scroll/swipe. Click position is preserved as the focal point.
  window.bfc4LightboxToggleZoom = function(event) {
    event.stopPropagation();
    var img = document.getElementById('ba-lightbox-img');
    var wrap = document.getElementById('ba-lightbox-imgwrap');
    if (!img || !wrap) return;
    if (img.classList.contains('is-zoomed')) {
      img.classList.remove('is-zoomed');
      wrap.scrollLeft = 0;
      wrap.scrollTop = 0;
    } else {
      var rect = img.getBoundingClientRect();
      var fracX = (event.clientX - rect.left) / rect.width;
      var fracY = (event.clientY - rect.top) / rect.height;
      img.classList.add('is-zoomed');
      requestAnimationFrame(function() {
        var newW = img.offsetWidth;
        var newH = img.offsetHeight;
        var ww = wrap.clientWidth;
        var wh = wrap.clientHeight;
        wrap.scrollLeft = Math.max(0, fracX * newW - ww / 2);
        wrap.scrollTop  = Math.max(0, fracY * newH - wh / 2);
      });
    }
  };

  // Wire lightbox image to toggle zoom on click
  (function() {
    var img = document.getElementById('ba-lightbox-img');
    if (img) img.addEventListener('click', window.bfc4LightboxToggleZoom);
  })();

  // Hero click → repopulate srcs from hero <img> data-zoom attrs, then open
  window.bfc4OpenHeroLightbox = function(idx) {
    var slideImgs = document.querySelectorAll('.bfc4-slide img');
    if (!slideImgs.length) return;
    window.__bfc4Lb.srcs = Array.prototype.map.call(slideImgs, function(img) {
      return img.dataset.zoom || img.currentSrc || img.src;
    });
    bfc4Lightbox(null, idx || 0);
  };

  // Shot-on grid click → repopulate srcs from grid anchors. Necessary because
  // srcs is shared with the hero lightbox — a prior hero open would have replaced
  // them, so a later Shot On click would otherwise show hero photos.
  window.bfc4OpenShotLightbox = function(event, idx) {
    if (event) { event.preventDefault(); event.stopPropagation(); }
    var g = document.getElementById('ba-shot-grid');
    if (!g) return;
    var anchors = g.querySelectorAll('a[data-lightbox="gallery"]');
    if (!anchors.length) return;
    window.__bfc4Lb.srcs = Array.prototype.map.call(anchors, function(a) {
      return a.getAttribute('href');
    });
    bfc4Lightbox(null, idx || 0);
  };

  document.addEventListener('keydown', function(e) {
    var box = document.getElementById('ba-lightbox');
    if (!box || !box.classList.contains('is-open')) return;
    if (e.key === 'Escape') bfc4LightboxClose(null, true);
    else if (e.key === 'ArrowLeft') bfc4LightboxNav(null, -1);
    else if (e.key === 'ArrowRight') bfc4LightboxNav(null, 1);
  });

  // Wire hero slide images so clicking opens the lightbox
  document.querySelectorAll('.bfc4-slide img').forEach(function(img, i) {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', function(e) {
      e.preventDefault();
      bfc4OpenHeroLightbox(i);
    });
  });
})();

/* ─── STICKY TOC — section tracking + smooth scroll ─── */
(function() {
  var toc = document.getElementById('bfc4-toc');
  if (!toc) return;
  var anchors = ['top', 'chapter', 'custom', 'reviews'];
  var sections = anchors
    .map(function(id) { return { id: id, el: document.getElementById('bfc4-' + id) }; })
    .filter(function(s) { return s.el; });

  function setActive(id) {
    toc.querySelectorAll('a[data-toc]').forEach(function(a) {
      a.classList.toggle('is-active', a.dataset.toc === id);
    });
  }

  // Detect theme header height so we can sit BELOW it (not over it).
  function getThemeHeaderHeight() {
    var selectors = [
      'sticky-header', '.shopify-section-header-sticky',
      'header.shopify-section', 'header.site-header',
      '.header-wrapper', 'header[role="banner"]', '.section-header'
    ];
    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (el) {
        var pos = getComputedStyle(el).position;
        if (pos === 'fixed' || pos === 'sticky') {
          var h = el.offsetHeight;
          if (h > 0 && h < 200) return h;
        }
      }
    }
    return 0;
  }

  var themeHeaderHeight = 0;
  function refreshHeaderOffset() {
    themeHeaderHeight = getThemeHeaderHeight();
    toc.style.top = (themeHeaderHeight > 0 ? themeHeaderHeight - 1 : 0) + 'px';
  }

  // Smooth scroll. Overview tab goes to absolute page top — no offset, no gap.
  toc.querySelectorAll('a[data-toc]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.getElementById('bfc4-' + a.dataset.toc);
      if (!target) return;
      e.preventDefault();
      if (a.dataset.toc === 'top') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      var offset = (toc.offsetHeight || 48) + themeHeaderHeight + 12;
      var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: top, behavior: 'smooth' });
    });
  });

  var topEl = document.getElementById('bfc4-top');

  function isOverlayOpen() {
    var bodyClasses = document.body.className || '';
    if (/\b(cart-drawer-open|drawer-open|is-cart-open|drawer--open|overlay-open|modal-open|js-drawer-open|cart-open)\b/.test(bodyClasses)) return true;
    var drawer = document.querySelector(
      'cart-drawer[open], cart-notification[open], .cart-drawer.is-open, .cart-drawer.active, ' +
      '.cart-drawer.drawer--active, .drawer.is-active, .drawer.is-open, [data-cart-drawer].is-open, ' +
      'cart-drawer.active'
    );
    if (drawer) return true;
    return false;
  }

  function updateTocVisibility() {
    if (isOverlayOpen()) {
      toc.classList.remove('is-visible');
      return;
    }
    if (!topEl) {
      toc.classList.toggle('is-visible', window.pageYOffset > 200);
      return;
    }
    var rect = topEl.getBoundingClientRect();
    toc.classList.toggle('is-visible', rect.bottom < themeHeaderHeight + 80);
  }

  function updateActiveSection() {
    if (!sections.length) return;
    var threshold = themeHeaderHeight + (toc.offsetHeight || 48) + 20;
    var current = sections[0].id;
    sections.forEach(function(s) {
      var rect = s.el.getBoundingClientRect();
      if (rect.top <= threshold) current = s.id;
    });
    setActive(current);
  }

  function onScroll() {
    updateTocVisibility();
    updateActiveSection();
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', function() { refreshHeaderOffset(); onScroll(); });
  if ('MutationObserver' in window) {
    new MutationObserver(onScroll).observe(document.body, { attributes: true, attributeFilter: ['class', 'style'] });
  }
  refreshHeaderOffset();
  onScroll();
  setTimeout(function() { refreshHeaderOffset(); onScroll(); }, 600);
})();

window.bfc4TocAddToCart = function() {
  if (typeof window.bfc4AddToCart === 'function') {
    window.bfc4AddToCart();
  }
};
</script>

{%- render 'bfc-product-schema' -%}

{% schema %}
{
  "name": "BFC Medium Format PDP",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "slide_1", "label": "Hero slide 1" },
    { "type": "image_picker", "id": "slide_2", "label": "Hero slide 2" },
    { "type": "image_picker", "id": "slide_3", "label": "Hero slide 3" },
    { "type": "image_picker", "id": "slide_4", "label": "Hero slide 4" },
    { "type": "image_picker", "id": "slide_5", "label": "Hero slide 5" },
    { "type": "header", "content": "Mobile slides (optional)" },
    { "type": "image_picker", "id": "slide_1_mobile", "label": "Mobile slide 1" },
    { "type": "image_picker", "id": "slide_2_mobile", "label": "Mobile slide 2" },
    { "type": "image_picker", "id": "slide_3_mobile", "label": "Mobile slide 3" },
    { "type": "image_picker", "id": "slide_4_mobile", "label": "Mobile slide 4" },
    { "type": "image_picker", "id": "slide_5_mobile", "label": "Mobile slide 5" },
    { "type": "image_picker", "id": "restoration_photo", "label": "Restoration photo (16:9 landscape works best)" },
    { "type": "richtext",     "id": "restoration_prose", "label": "Restoration narrative (optional override)" }
  ],
  "blocks": [
    {
      "type": "kit_item",
      "name": "Kit Item",
      "settings": [
        { "type": "select", "id": "label", "label": "Category", "default": "Film", "options": [
            { "value": "Film", "label": "Film" },
            { "value": "Strap", "label": "Strap" },
            { "value": "Bag", "label": "Bag" },
            { "value": "Developing", "label": "Developing" },
            { "value": "Accessories", "label": "Accessories" },
            { "value": "Lens", "label": "Lens" },
            { "value": "More", "label": "More" }
          ]
        },
        { "type": "text", "id": "custom_label", "label": "Custom display name", "info": "Overrides the product title in the kit tiles. Leave blank to use product title." },
        { "type": "text", "id": "column", "label": "Column group" },
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "variant_id", "label": "Specific variant ID (optional)" },
        { "type": "range", "id": "discount_percent", "min": 0, "max": 50, "step": 5, "unit": "%", "label": "Discount %", "default": 10 },
        { "type": "checkbox", "id": "is_developing", "label": "Is free developing", "default": false },
        { "type": "checkbox", "id": "is_starter_kit", "label": "Include in Starter Kit", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "BFC Medium Format PDP",
      "blocks": [
        { "type": "kit_item", "settings": { "label": "Film", "column": "Film", "discount_percent": 10, "is_developing": false, "is_starter_kit": true } },
        { "type": "kit_item", "settings": { "label": "Film", "column": "Film", "discount_percent": 10, "is_developing": false, "is_starter_kit": true } },
        { "type": "kit_item", "settings": { "label": "Strap", "column": "Strap", "discount_percent": 15, "is_developing": false, "is_starter_kit": true } },
        { "type": "kit_item", "settings": { "label": "Developing", "column": "Developing Credits", "discount_percent": 0, "is_developing": true, "is_starter_kit": false } }
      ]
    }
  ]
}
{% endschema %}
