      <img class="ba-lightbox-img" id="ba-lightbox-img" src="" alt="" draggable="false"/>
    </div>
    <div class="ba-lightbox-counter" id="ba-lightbox-counter"></div>
  </div>
</div>

<script>
(function() {
  'use strict';

  // ── XHR helper (bypasses Judge.me monkey-patching of window.fetch) ─────
  function bfc4Xhr(url, opts) {
    opts = opts || {};
    return new Promise(function(resolve, reject) {
      var xhr = new XMLHttpRequest();
      xhr.open(opts.method || 'GET', url, true);
      xhr.withCredentials = true;
      if (opts.headers) Object.keys(opts.headers).forEach(function(k){xhr.setRequestHeader(k, opts.headers[k]);});
      xhr.setRequestHeader('X-Requested-With','XMLHttpRequest');
      xhr.onload = function() {
        resolve({
          ok: xhr.status>=200 && xhr.status<300,
          status: xhr.status,
          json: function(){ try{return Promise.resolve(JSON.parse(xhr.responseText));}catch(e){return Promise.resolve({});} },
          text: function(){ return Promise.resolve(xhr.responseText); }
        });
      };
      xhr.onerror = function(){ reject(new Error('Network error')); };
      xhr.send(opts.body || null);
    });
  }

  var STATE = {
    variantId:    {{ current_variant.id }},
    variantPrice: {{ current_variant.price }},
    kit: {},
    extWarranty: null
  };

  // Variant lookup table for the Leather Cover swatch handler.
  // Needed when a product has multiple options (Grade + Leather) so we
  // can find the correct variant given the cross-product of selections.
  // featured_media_id lets us jump the image slider to the variant's
  // assigned image when the customer changes leather/variant.
  window.__bfc4Variants = [
    {%- for v in product.variants -%}
    { id: {{ v.id }}, price: {{ v.price }}, price_fmt: {{ v.price | money | json }}, available: {{ v.available }}, options: [{% for o in v.options %}{{ o | json }}{% unless forloop.last %},{% endunless %}{% endfor %}], featured_media_id: {% if v.featured_media %}{{ v.featured_media.id }}{% else %}null{% endif %} }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  // Jump the image slider to a variant's assigned image, if there is one.
  // Strategy:
  //   1. Look up the variant in __bfc4Variants
  //   2. If variant has featured_media_id, find the slide with matching
  //      data-media-id and jump to it (only works on product.media fallback,
  //      not when section image pickers are in use)
  //   3. As a fallback, try to find a slide whose alt text contains the
  //      variant's option title (e.g. "Brown" or "Burgundy"). This works
  //      even with section-image PDPs where images aren't formally linked
  //      to variants in Shopify Admin — they're matched by alt text instead.
  // If neither works, this is a no-op and the slider stays put. Safer than
  // guessing.
  window.bfc4JumpToVariantImage = function(variantId) {
    var v = window.__bfc4Variants && window.__bfc4Variants.find(function(x) { return x.id === variantId; });
    if (!v) return;
    var slides = document.querySelectorAll('.bfc4-slide');

    // Strategy 1: featured_media_id match (best when present)
    if (v.featured_media_id) {
      for (var i = 0; i < slides.length; i++) {
        if (String(slides[i].dataset.mediaId) === String(v.featured_media_id)) {
          if (typeof window.bfc4GoTo === 'function') window.bfc4GoTo(i);
          return;
        }
      }
    }

    // Strategy 2: alt-text match — try each option value (in case variant
    // is named "Brown / Grade A", we want to match on "Brown"). Use the
    // FIRST option value that produces a hit. Case-insensitive substring.
    if (v.options && v.options.length) {
      for (var oi = 0; oi < v.options.length; oi++) {
        var optVal = (v.options[oi] || '').toLowerCase().trim();
        if (!optVal || optVal === 'default title') continue;
        for (var si = 0; si < slides.length; si++) {
          var img = slides[si].querySelector('img');
          if (img && img.alt && img.alt.toLowerCase().indexOf(optVal) > -1) {
            if (typeof window.bfc4GoTo === 'function') window.bfc4GoTo(si);
            return;
          }
        }
      }
    }
  };

  // ── Clear stale kit attributes on page load ─────
  // Defense in depth: when a customer lands on this PDP, wipe any kit-bundle
  // cart attributes left over from a previous session. Without this, a
  // customer who had `_free_developing_credit: true` set from an earlier kit
  // purchase (e.g. on V4 or PS PDP) would carry that flag into a fresh order
  // unless they go through the kit ATC flow which overwrites it. The kit ATC
  // already awaits its own attribute set; this clears the slate up front so
  // any other path (default form submit, abandoned checkout return, etc.)
  // starts clean.
  (function() {
    try {
      bfc4Xhr('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ attributes: { '_kit_bundle': '', '_kit_camera': '', '_free_developing_credit': '' } })
      });
    } catch (e) { /* non-critical */ }
  })();

  // Starter kit STATE seeded from tile data-attributes on load (see bottom of script)

  // ── Tile toggle (top tiles = add-ons) ──────────
  function syncAccordionLocks() {
    var starterVariantIds = [];
    document.querySelectorAll('.bfc4-tile.is-sel:not(.is-cam)').forEach(function(tile) {
      if (tile.dataset.variantId) starterVariantIds.push(tile.dataset.variantId);
    });
    document.querySelectorAll('.ba-mini-card').forEach(function(card) {
      var inKit = starterVariantIds.indexOf(card.dataset.variantId) >= 0;
      card.classList.toggle('is-sel', inKit);
      card.style.pointerEvents = inKit ? 'none' : '';
      card.style.opacity = inKit ? '0.7' : '';
      var badge = card.querySelector('.bfc4-in-kit-badge');
      if (inKit && !badge) {
        badge = document.createElement('div');
        badge.className = 'bfc4-in-kit-badge';
        badge.style.cssText = 'position:absolute;top:4px;left:4px;background:var(--or);color:#fff;font-size:7px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:2px 5px;z-index:2;';
        badge.textContent = 'In Kit';
        card.style.position = 'relative';
        card.appendChild(badge);
      } else if (!inKit && badge) {
        badge.remove();
      }
    });
  }

  window.bfc4TileToggle = function(tile) {
    var wasSel = tile.classList.contains('is-sel');
    tile.classList.toggle('is-sel', !wasSel);
    var check = tile.querySelector('.bfc4-tile-sel-check');
    if (!wasSel) {
      // add to STATE
      var tileId = tile.dataset.tileId || ('tile-' + Math.random());
      var col = (tile.dataset.col || '').toLowerCase();
      var pt = (tile.dataset.productTitle || '').toLowerCase();
      var isFilm = tile.dataset.isDev !== 'true' && (col.indexOf('film') >= 0 || pt.indexOf('film') >= 0 || /\b(portra|tri-x|gold|ultramax|hp5|fp4|delta|t-max|tmax|color|b&w|cinestill|ektar|lomo|lucky|fomapan|kentmere|rollei|jch|dubblefilm|fuji|velvia|provia|ektachrome|acros|pro 400|pro 800|pan f)\b/i.test(pt));
      if (!check) {
        check = document.createElement('div');
        check.className = 'bfc4-tile-sel-check';
        check.textContent = '✓';
        tile.querySelector('.bfc4-tile-img-wrap').appendChild(check);
      }
      STATE.kit[tileId] = {
        variantId: tile.dataset.variantId,
        name:      tile.dataset.productTitle,
        orig:      parseInt(tile.dataset.orig || '0', 10),
        sale:      parseInt(tile.dataset.sale || '0', 10),
        isDev:     tile.dataset.isDev === 'true',
        disc:      parseInt(tile.dataset.disc || '0', 10),
        isFilm:    isFilm,
        colId:     tile.dataset.tileId,
        img:       tile.dataset.img || null
      };
      tile.dataset.stateKey = tileId;
    } else {
      // remove from STATE
      var key = tile.dataset.stateKey;
      if (key) delete STATE.kit[key];
      if (check) check.remove();
    }
    bfc4Render();
    syncAccordionLocks();
  };

  window.bfc4ClearTiles = function() {
    document.querySelectorAll('.bfc4-tile.is-sel:not(.is-cam)').forEach(function(tile) {
      tile.classList.remove('is-sel');
      var check = tile.querySelector('.bfc4-tile-sel-check');
      if (check) check.remove();
      var key = tile.dataset.stateKey;
      if (key) delete STATE.kit[key];
    });
    bfc4Render();
    syncAccordionLocks();
  };

  // ── Variant selector ────────────────────────────
  window.bfc4SelectVariant = function(btn) {
    if (btn.dataset.variantAvailable === 'false') return;
    document.querySelectorAll('.bfc4-var-btn').forEach(function(b) { b.classList.remove('is-active'); });
    btn.classList.add('is-active');
    STATE.variantId    = parseInt(btn.dataset.variantId, 10);
    STATE.variantPrice = parseInt(btn.dataset.variantPrice, 10);
    var inp = document.getElementById('bfc4-variant-input');
    if (inp) inp.value = STATE.variantId;
    var camPriceEl = document.getElementById('bfc4-cam-price');
    var ksCamEl    = document.getElementById('bfc4-ks-cam-price');
    if (camPriceEl) camPriceEl.textContent = btn.dataset.variantPriceFmt;
    if (ksCamEl)    ksCamEl.textContent    = btn.dataset.variantPriceFmt;
    var stickyGrade = document.getElementById('bfc4-sticky-grade');
    if (stickyGrade) stickyGrade.textContent = btn.textContent.trim();
    bfc4UpdateWarrantyTier(STATE.variantPrice);
    bfc4JumpToVariantImage(STATE.variantId);
  };

  // ── Leather Cover swatch handler ──
  // When a leather swatch is clicked, we need to find the variant whose
  // chosen options match the currently-selected Grade (if present) AND
  // the new leather value. The variants list is rendered as a JS object
  // below (`window.__bfc4Variants`) so we can look up by option pair.
  window.bfc4SelectLeather = function(btn) {
    if (btn.disabled) return;
    var newLeather = btn.dataset.leatherValue;
    var optIdx = parseInt(btn.dataset.optIndex, 10);
    document.querySelectorAll('.bfc4-leather-swatch').forEach(function(b) { b.classList.remove('is-active'); });
    btn.classList.add('is-active');

    var nameEl = document.getElementById('bfc4-leather-name');
    if (nameEl) nameEl.textContent = newLeather;

    // Build the target options array: keep all other option values from the
    // currently selected variant, swap in the new leather at its index.
    if (!window.__bfc4Variants) return;
    var currentVariant = window.__bfc4Variants.find(function(v) { return v.id === STATE.variantId; });
    if (!currentVariant) return;
    var newOpts = currentVariant.options.slice();
    newOpts[optIdx] = newLeather;
    var match = window.__bfc4Variants.find(function(v) {
      for (var i = 0; i < newOpts.length; i++) {
        if (v.options[i] !== newOpts[i]) return false;
      }
      return true;
    });
    if (!match || !match.available) return;

    STATE.variantId    = match.id;
    STATE.variantPrice = match.price;
    var inp = document.getElementById('bfc4-variant-input');
    if (inp) inp.value = STATE.variantId;
    var camPriceEl = document.getElementById('bfc4-cam-price');
    var ksCamEl    = document.getElementById('bfc4-ks-cam-price');
    var priceFmt = match.price_fmt;
    if (camPriceEl) camPriceEl.textContent = priceFmt;
    if (ksCamEl)    ksCamEl.textContent    = priceFmt;
    // If a Grade row exists, sync its is-active to the matching variant
    document.querySelectorAll('.bfc4-var-btn').forEach(function(b) {
      b.classList.toggle('is-active', parseInt(b.dataset.variantId, 10) === match.id);
    });
    bfc4UpdateWarrantyTier(STATE.variantPrice);
    bfc4JumpToVariantImage(match.id);
  };

  // ── Also keep existing baSelectVariant alias ────
  window.baSelectVariant = window.bfc4SelectVariant;

  // ── "Choose different" scrolls to column ────────
  window.bfc4ChangeItem = function(colName) {
    var customSec = document.getElementById('bfc4-custom');
    if (customSec) customSec.scrollIntoView({ behavior: 'smooth' });
    // Find matching column and flash-highlight it
    setTimeout(function() {
      var cols = document.querySelectorAll('.ba-col[data-col-name]');
      cols.forEach(function(col) {
        if (col.dataset.colName === colName) {
          col.classList.add('is-open');
          col.classList.add('flash-highlight');
          setTimeout(function() { col.classList.remove('flash-highlight'); }, 1600);
        }
      });
    }, 600);
  };

  // ── Render total + kit summary ──────────────────
  function bfc4Render() {
    var total   = STATE.variantPrice;

    var filmCount = 0;
    Object.values(STATE.kit).forEach(function(sel) {
      total   += sel.sale;

      if (sel.isFilm) filmCount++;
    });
    var devValue = filmCount >= 2 ? 1800 : 0; // $18 free developing credit value
    if (STATE.extWarranty) total += STATE.extWarranty.price;
    var totalEl   = document.getElementById('bfc4-total');
    var totalEl2  = document.getElementById('bfc4-total-2');

    if (totalEl)   totalEl.textContent   = fmt(total);
    if (totalEl2)  totalEl2.textContent  = fmt(total);
    var stickyPrice = document.getElementById('bfc4-sticky-price');
    if (stickyPrice) stickyPrice.textContent = fmt(STATE.variantPrice);


    var promoEl = document.getElementById('ba-film-promo');
    if (promoEl) promoEl.style.display = filmCount >= 2 ? 'flex' : 'none';

    // Selected items row below fold
    var selEl = document.getElementById('bfc4-selected-items');
    if (selEl) {
      var html = '';
      var camImg = document.querySelector('#bfc4-tiles .bfc4-tile.is-cam img');
      html += '<div class="bfc4-sel-item is-cam is-sel">'
            + (camImg ? '<img class="bfc4-sel-item-img" src="' + camImg.src + '" alt=""/>' : '<div class="bfc4-sel-item-img is-placeholder">📷</div>')
            + '<span class="bfc4-sel-item-name">{{ product.title | escape }}</span>'
            + '</div>';
      Object.entries(STATE.kit).forEach(function(entry) {
        var key = entry[0], sel = entry[1];
        html += '<div class="bfc4-sel-item is-sel" onclick="bfc4RemoveSel(\'' + key + '\')" title="Click to remove">'
              + (sel.img ? '<img class="bfc4-sel-item-img" src="' + sel.img + '" alt=""/>' : '<div class="bfc4-sel-item-img is-placeholder">+</div>')
              + '<span class="bfc4-sel-item-name">' + esc(sel.name) + '</span>'
              + '</div>';
      });
      selEl.innerHTML = html;
    }
  }

  window.bfc4RemoveSel = function(key) {
    delete STATE.kit[key];
    // Deselect the matching top tile
    document.querySelectorAll('.bfc4-tile[data-state-key="' + key + '"]').forEach(function(tile) {
      tile.classList.remove('is-sel');
      var check = tile.querySelector('.bfc4-tile-sel-check');
      if (check) check.remove();
    });
    bfc4Render();
    syncAccordionLocks();
  };

  // ── ATC ─────────────────────────────────────────
  window.bfc4AddToCart = async function() {
    var btn    = document.getElementById('bfc4-atc');
    var textEl = document.getElementById('bfc4-atc-text');
    var stickyBtn  = document.getElementById('bfc4-sticky-btn');
    var stickyText = document.getElementById('bfc4-sticky-btn-text');
    if (btn) { btn.disabled = true; }
    if (stickyBtn) { stickyBtn.disabled = true; }
    if (textEl) { textEl.textContent = 'Adding\u2026'; }
    if (stickyText) { stickyText.textContent = 'Adding\u2026'; }

    var items = [];
    var filmCount = 0;
    // First pass: count film
    Object.values(STATE.kit).forEach(function(sel) {
      if (sel.isFilm) filmCount++;
    });
    // Second pass: build items — skip developing if < 2 film rolls
    Object.values(STATE.kit).forEach(function(sel) {
      if (!sel.variantId) return; // skip items with no variant
      var vid = parseInt(sel.variantId, 10);
      if (isNaN(vid) || vid === 0) return;
      if (sel.isDev && filmCount < 2) return; // skip free developing if not enough film
      var props = { _kit_bundle: 'true' };
      if (sel.isDev) {
        props._free_developing      = 'true';
        props._bundle_discount_type = 'free_developing';
      }
      items.push({ id: vid, quantity: 1, properties: props });
    });

    console.log('[BFC4] Adding to cart:', { items: items, filmCount: filmCount, STATE: STATE.kit });

    // Add extended warranty if selected
    if (STATE.extWarranty && STATE.extWarranty.variantId) {
      items.push({ id: parseInt(STATE.extWarranty.variantId, 10), quantity: 1, properties: { _extended_warranty: 'true' } });
    }

    try {
      // Cart attributes — AWAIT this. Previously fire-and-forget which created
      // a race condition: if the page navigated before cart/update completed,
      // stale attributes from prior sessions (e.g. _free_developing_credit: true
      // from an earlier kit with film) would survive and corrupt the current
      // order. Awaiting guarantees the attrs reflect THIS order's state.
      var cartAttrs = { attributes: { '_kit_bundle': 'true', '_kit_camera': '{{ product.title | escape }}', '_free_developing_credit': filmCount >= 2 ? 'true' : 'false' } };
      await bfc4Xhr('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(cartAttrs) });
      if (items.length > 0) {
        var res = await bfc4Xhr('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ items: items }) });
        if (!res.ok) {
          var errBody = await res.json().catch(function() { return {}; });
          console.error('[BFC4] cart/add.js error:', res.status, errBody);
          throw new Error(res.status);
        }
      }
      var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
      if (submitBtn) submitBtn.click();
      if (btn) { btn.classList.add('is-success'); }
      if (textEl) { textEl.textContent = 'Added!'; }
      if (stickyText) { stickyText.textContent = 'Added!'; }
      setTimeout(function() {
        if (btn) { btn.classList.remove('is-success'); btn.disabled = false; }
        if (stickyBtn) { stickyBtn.disabled = false; }
        if (textEl) { textEl.textContent = 'Add Starter Kit'; }
        if (stickyText) { stickyText.textContent = 'Add to Cart'; }
      }, 2400);
    } catch(e) {
      console.error('[BFC4] ATC error:', e);
      if (btn) { btn.disabled = false; }
      if (stickyBtn) { stickyBtn.disabled = false; }
      if (textEl) { textEl.textContent = 'Add Starter Kit'; }
      if (stickyText) { stickyText.textContent = 'Add to Cart'; }
    }
  };

  window.bfc4CameraOnly = function() {
    var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
    if (submitBtn) submitBtn.click();
  };

  // ── Accordion (shared with custom kit) ──────────
  window.baToggleCol = function(col) {
    var isMobile = window.innerWidth <= 900;
    if (!isMobile) return; // desktop: always open, no toggle
    col.classList.toggle('is-open');
  };

  // ── Chapter toggle (process + specs) ──────────────
  window.bfc4ToggleChapter = function() {
    var btn = document.getElementById('bfc4-chapter-toggle');
    var body = document.getElementById('bfc4-chapter-body');
    var txt = btn ? btn.querySelector('.bfc4-chapter-toggle-text') : null;
    if (!btn || !body) return;
    var isOpen = body.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    if (txt) txt.textContent = isOpen ? 'Hide details' : 'View full process & all specs';
  };

  // ── Per-column chapter toggle (mobile only) ──
  window.bfc4ToggleChapterCol = function(btn) {
    if (!btn) return;
    var col = btn.closest('.bfc4-chapter-col');
    if (!col) return;
    var extra = col.querySelector('.bfc4-chapter-extra');
    if (!extra) return;
    var isOpen = extra.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    var label = btn.querySelector('.bfc4-chapter-col-toggle-label');
    if (label) {
      var openLabel   = btn.dataset.openLabel   || 'Hide';
      var closedLabel = btn.dataset.closedLabel || 'Show more';
      label.textContent = isOpen ? openLabel : closedLabel;
    }
  };


  window.baExpandCol = function(col) {
    col.classList.toggle('is-expanded');
    var btn = col.querySelector('.ba-col-more-text');
    if (!btn) return;
    var hidden = col.querySelectorAll('.ba-mini-card.is-hidden').length;
    btn.textContent = col.classList.contains('is-expanded') ? 'Show less \u2039' : hidden + ' more \u203a';
  };

  // ── Mini card selection (custom kit) ────────────
  window.baMiniSelect = function(card, e) {
    var catId = card.dataset.cat;
    var wasSelected = card.classList.contains('is-sel');
    document.querySelectorAll('[data-cat="' + catId + '"].ba-mini-card').forEach(function(c) { c.classList.remove('is-sel'); });
    if (wasSelected) {
      delete STATE.kit[catId];
    } else {
      card.classList.add('is-sel');
      var colName = (card.dataset.colName || '').toLowerCase();
      var prodTitle = (card.dataset.productTitle || '').toLowerCase();
      var isFilm = card.dataset.isDev !== 'true' && (colName.indexOf('film') >= 0 || prodTitle.indexOf('film') >= 0 || /\b(portra|tri-x|gold|ultramax|hp5|fp4|delta|t-max|tmax|color|b&w|cinestill|ektar|lomo|lucky|fomapan|kentmere|rollei|jch|dubblefilm|fuji|velvia|provia|ektachrome|acros|pro 400|pro 800|pan f)\b/i.test(prodTitle));
      var imgEl = card.querySelector('.ba-mini-img');
      STATE.kit[catId] = {
        variantId: card.dataset.variantId,
        name:      card.dataset.productTitle,
        orig:      parseInt(card.dataset.orig, 10),
        sale:      parseInt(card.dataset.sale, 10),
        isDev:     card.dataset.isDev === 'true',
        disc:      parseInt(card.dataset.disc, 10),
        isFilm:    isFilm,
        colId:     card.dataset.colId,
        img:       imgEl ? imgEl.src : null
      };
    }
    baUpdateColCounts();
    bfc4Render();
  };

  window.baMiniSelectVar = function(btn) {
    var catId = btn.dataset.cat;
    var card  = document.getElementById(catId);
    card.querySelectorAll('.ba-mini-var-btn').forEach(function(b) { b.classList.remove('is-sel'); });
    btn.classList.add('is-sel');
    card.dataset.variantId    = btn.dataset.variantId;
    card.dataset.productTitle = btn.dataset.productTitle;
    card.dataset.orig         = btn.dataset.orig;
    card.dataset.sale         = btn.dataset.sale;
    if (card.classList.contains('is-sel')) {
      STATE.kit[catId].variantId = btn.dataset.variantId;
      STATE.kit[catId].name      = btn.dataset.productTitle;
      STATE.kit[catId].orig      = parseInt(btn.dataset.orig, 10);
      STATE.kit[catId].sale      = parseInt(btn.dataset.sale, 10);
      bfc4Render();
    }
  };

  function baUpdateColCounts() {
    var counts = {};
    Object.values(STATE.kit).forEach(function(sel) {
      if (sel.colId) counts[sel.colId] = (counts[sel.colId] || 0) + 1;
    });
    document.querySelectorAll('.ba-col-count').forEach(function(el) {
      var colEl = el.closest('.ba-col');
      if (!colEl) return;
      var n = counts[colEl.id] || 0;
      el.textContent = n;
      el.classList.toggle('is-visible', n > 0);
    });
  }

  window.baRemoveItem = function(catId) {
    var card = document.getElementById(catId);
    if (card) card.classList.remove('is-sel');
    delete STATE.kit[catId];
    baUpdateColCounts();
    bfc4Render();
  };

