<script>
// Hasselblad collection rail — exact top sellers pattern
(function () {
  var root = document.querySelector('.hbc-collection [data-bfc-ts]');
  if (!root) return;
  var rail = root.querySelector('[data-bfc-ts-rail]');
  var prev = root.querySelector('[data-bfc-ts-prev]');
  var next = root.querySelector('[data-bfc-ts-next]');
  if (!rail) return;
  var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var behavior = prefersReduced ? 'auto' : 'smooth';
  function scrollByAmount(dir) {
    var amount = Math.max(240, Math.floor(rail.clientWidth * 0.85));
    rail.scrollBy({ left: dir * amount, behavior: behavior });
  }
  function updateArrows() {
    if (!prev || !next) return;
    var max = rail.scrollWidth - rail.clientWidth - 2;
    prev.disabled = rail.scrollLeft <= 2;
    next.disabled = rail.scrollLeft >= max;
    prev.style.opacity = prev.disabled ? '0.35' : '1';
    next.style.opacity = next.disabled ? '0.35' : '1';
  }
  if (prev) prev.addEventListener('click', function () { scrollByAmount(-1); });
  if (next) next.addEventListener('click', function () { scrollByAmount(1); });
  rail.addEventListener('scroll', function () { window.requestAnimationFrame(updateArrows); }, { passive: true });
  window.addEventListener('resize', function () { window.requestAnimationFrame(updateArrows); });
  updateArrows();
})();
</script>

<script>
// Clear any lingering hash so the browser doesn't auto-scroll to an anchor on load
(function(){
  if(window.location.hash && window.location.hash.indexOf('hbc-')!==-1){
    if(window.history && window.history.replaceState){
      window.history.replaceState(null,'',window.location.pathname+window.location.search);
    }
  }
})();
</script>

<script>
(function(){
  var SID='{{ section.id }}';
  var root=document.getElementById('hb-cls-'+SID);
  if(!root)return;

  // Nav scroll
  var nav=document.getElementById('hbc-nav-'+SID);
  window.addEventListener('scroll',function(){nav.classList.toggle('scrolled',window.scrollY>60);},{passive:true});

  // Showcase
  var slides=root.querySelectorAll('.hbc-showcase__slide');
  var thumbs=root.querySelectorAll('.hbc-showcase__thumb');
  var counterCur=root.querySelector('#hbc-counter-'+SID+' .hbc-showcase__counter-cur');
  var pName=document.getElementById('hbc-pname-'+SID);
  var pType=document.getElementById('hbc-ptype-'+SID);
  var pPrice=document.getElementById('hbc-pprice-'+SID);
  var pLink=document.getElementById('hbc-plink-'+SID);
  var cur=0;
  var total=slides.length;
  var autoTimer=null;

  function pad(n){return n<10?'0'+n:String(n);}

  function goTo(i,skipAuto){
    if(i<0)i=total-1;
    if(i>=total)i=0;
    var prev=cur;
    cur=i;

    // Swap slides
    slides[prev].classList.remove('active');
    slides[cur].classList.add('active');

    // Thumbs
    thumbs.forEach(function(t){t.classList.remove('active');});
    if(thumbs[cur])thumbs[cur].classList.add('active');

    // Scroll thumb strip horizontally (without moving the page)
    if(thumbs[cur]){
      var strip=thumbs[cur].parentNode;
      if(strip){
        var thumbLeft=thumbs[cur].offsetLeft;
        var thumbW=thumbs[cur].offsetWidth;
        var stripW=strip.offsetWidth;
        strip.scrollLeft=thumbLeft-(stripW/2)+(thumbW/2);
      }
    }

    // Counter
    if(counterCur)counterCur.textContent=pad(cur+1);

    // Right panel — fade out, swap, fade in
    var slide=slides[cur];
    var newTitle=slide.getAttribute('data-title')||'';
    var newType=slide.getAttribute('data-type')||'';
    var newPrice=slide.getAttribute('data-price')||'';
    var newUrl=slide.getAttribute('data-url')||'#';

    [pName,pType,pPrice,pLink].forEach(function(el){if(el)el.classList.add('switching');});
    setTimeout(function(){
      if(pName)pName.textContent=newTitle;
      if(pType)pType.textContent=newType;
      if(pPrice)pPrice.textContent=newPrice;
      if(pLink)pLink.setAttribute('href',newUrl);
      [pName,pType,pPrice,pLink].forEach(function(el){if(el)el.classList.remove('switching');});
    },280);

    if(!skipAuto)resetAuto();
  }

  function resetAuto(){
    clearInterval(autoTimer);
    if(total>1)autoTimer=setInterval(function(){goTo(cur+1,true);},5000);
  }

  // Thumb clicks
  thumbs.forEach(function(t){
    t.addEventListener('click',function(){
      goTo(parseInt(t.getAttribute('data-index')||0));
    });
  });

  // Arrow buttons
  var btnPrev=document.getElementById('hbc-prev-'+SID);
  var btnNext=document.getElementById('hbc-next-'+SID);
  if(btnPrev)btnPrev.addEventListener('click',function(){goTo(cur-1);});
  if(btnNext)btnNext.addEventListener('click',function(){goTo(cur+1);});

  // Keyboard
  document.addEventListener('keydown',function(e){
    if(e.key==='ArrowLeft')goTo(cur-1);
    if(e.key==='ArrowRight')goTo(cur+1);
  });

  // Touch swipe on left panel
  var touchStartX=0;
  var leftPanel=root.querySelector('.hbc-showcase__left');
  if(leftPanel){
    leftPanel.addEventListener('touchstart',function(e){touchStartX=e.touches[0].clientX;},{passive:true});
    leftPanel.addEventListener('touchend',function(e){
      var dx=e.changedTouches[0].clientX-touchStartX;
      if(Math.abs(dx)>40){dx<0?goTo(cur+1):goTo(cur-1);}
    },{passive:true});
  }

  // Set initial link
  if(slides[0]&&pLink)pLink.setAttribute('href',slides[0].getAttribute('data-url')||'#');

  // Start auto
  resetAuto();

  // Scroll reveal
  var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.12});
  root.querySelectorAll('.hbc-reveal').forEach(function(el){obs.observe(el);});

  // Smooth scroll for anchor links
  root.querySelectorAll('a[href^="#hbc-"]').forEach(function(a){
    a.addEventListener('click',function(e){
      var t=document.getElementById(a.getAttribute('href').substring(1));
      if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth'});}
    });
  });
})();
</script>

