.hbc-usecase:last-child{border-bottom:none}.hbc-usecase__num{font-family:var(--f-head);font-size:16px;color:var(--c-accent-light);flex-shrink:0;width:20px;font-weight:500}

/* VARIANTS */
.hbc-variants{padding:80px 48px;background:var(--c-card);border-top:1px solid var(--c-border-light)}.hbc-variants__inner{max-width:1080px;margin:0 auto}
.hbc-variants__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-top:48px;background:var(--c-border-light)}
