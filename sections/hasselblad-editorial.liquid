.hbc-cla__step:hover{background:#1a1a1a}
.hbc-cla__step-letter{font-family:var(--f-head);font-size:72px;font-weight:400;line-height:1;color:rgba(196,180,154,0.08);position:absolute;top:24px;right:28px;letter-spacing:-0.04em;pointer-events:none;transition:color 0.3s}
.hbc-cla__step:hover .hbc-cla__step-letter{color:rgba(196,180,154,0.14)}
.hbc-cla__step-title{font-family:var(--f-body);font-size:15px;font-weight:600;color:var(--c-dark-text);margin-bottom:14px;padding-top:4px;text-transform:uppercase;letter-spacing:0.06em}
.hbc-cla__step::before{content:'';display:block;width:28px;height:2px;background:var(--c-accent);margin-bottom:16px}
.hbc-cla__step-desc{font-size:14px;line-height:1.75;color:rgba(245,242,238,0.55);font-weight:400}

.hbc-cla__proof{display:grid;grid-template-columns:1fr auto 1fr auto 1fr auto 1fr;align-items:center;gap:0;border:1px solid rgba(255,255,255,0.08);margin-bottom:56px}
.hbc-cla__proof-item{padding:28px 24px;text-align:center}
.hbc-cla__proof-num{font-family:var(--f-body);font-size:22px;font-weight:600;color:var(--c-dark-text);margin-bottom:6px;letter-spacing:-0.01em}
.hbc-cla__proof-label{font-size:12px;color:rgba(245,242,238,0.45);font-weight:400;line-height:1.4}
.hbc-cla__proof-divider{width:1px;height:50px;background:rgba(255,255,255,0.08);flex-shrink:0}

.hbc-cla__callout{border-left:2px solid rgba(255,255,255,0.15);padding:24px 32px;background:rgba(255,255,255,0.03)}
.hbc-cla__callout-text{font-family:var(--f-body);font-size:14px;font-weight:400;color:rgba(245,242,238,0.7);line-height:1.7;margin-bottom:12px}
.hbc-cla__callout-attr{font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:rgba(245,242,238,0.35)}

/* PROCESS */
.hbc-process{padding:80px 48px;background:var(--c-card)}.hbc-process__inner{max-width:1080px;margin:0 auto}
.hbc-process__hero-img{margin:32px 0 48px;overflow:hidden;max-height:400px}.hbc-process__hero-img img{width:100%;height:100%;object-fit:cover;display:block}
.hbc-process__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;margin-top:16px;background:var(--c-border-light)}
.hbc-process__card{background:var(--c-bg);padding:36px 28px;transition:background 0.3s}.hbc-process__card:hover{background:var(--c-card)}
.hbc-process__card-img{margin:-36px -28px 20px;overflow:hidden;aspect-ratio:16/10}.hbc-process__card-img img{width:100%;height:100%;object-fit:cover}
