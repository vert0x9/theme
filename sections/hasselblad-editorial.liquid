.hbc-process__title{font-family:var(--f-head);font-size:20px;font-weight:500;color:var(--c-text);margin-bottom:8px}
.hbc-process__rule{width:24px;height:1px;background:var(--c-accent-light);margin-bottom:12px}
.hbc-process__desc{font-size:13px;line-height:1.7;color:var(--c-muted);font-weight:300}

/* EDITORIAL */
.hbc-editorial{padding:80px 48px}.hbc-editorial__inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:64px;align-items:start}
.hbc-editorial__sidebar{padding:40px;border:1px solid var(--c-border);background:var(--c-card)}
.hbc-editorial__sidebar-img{margin:-40px -40px 0;overflow:hidden;aspect-ratio:16/10}.hbc-editorial__sidebar-img img{width:100%;height:100%;object-fit:cover}
