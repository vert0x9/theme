.hbc-variant__badge{position:absolute;top:14px;right:14px;font-size:10px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--c-accent);padding:4px 10px;background:rgba(139,115,85,0.08);border:1px solid rgba(139,115,85,0.15)}
.hbc-variant__img{margin-bottom:18px;aspect-ratio:1/1;max-width:160px;margin-left:auto;margin-right:auto}.hbc-variant__img img{width:100%;height:100%;object-fit:contain}
.hbc-variant__name{font-family:var(--f-head);font-size:19px;font-weight:500;color:var(--c-text);margin-bottom:6px}
.hbc-variant__sub{font-size:13px;color:var(--c-faint);font-weight:300;margin-bottom:14px}
.hbc-variant__rule{width:20px;height:1px;background:var(--c-accent-light);margin:0 auto 14px}
.hbc-variant__price{font-family:var(--f-head);font-size:26px;color:var(--c-text);margin-bottom:18px;font-weight:400}
.hbc-variants__note{font-size:12px;color:var(--c-faint);text-align:center;margin-top:32px;font-weight:300}
.hbc-variants__shopall{text-align:center;margin-top:20px}

/* CREATIVE SHOOTS GALLERY */
.hbc-shoots{background:var(--c-dark);padding:6px}
.hbc-shoots__grid{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:280px;gap:6px}
@media(max-width:768px){.hbc-shoots__grid{grid-template-columns:repeat(2,1fr);grid-auto-rows:220px}}

/* Default: 1 row. Tall spans 2 rows to match 2 stacked short images */
.hbc-shoots__item{overflow:hidden;background:var(--c-dark);grid-row:span 1}
.hbc-shoots__item--tall,
.hbc-shoots__item--feature{grid-row:span 2}
/* Reset unused span classes */
.hbc-shoots__item--1,.hbc-shoots__item--2,.hbc-shoots__item--3,
.hbc-shoots__item--wide,.hbc-shoots__item--full{grid-column:unset}

.hbc-shoots__img-wrap{width:100%;height:100%;overflow:hidden}
.hbc-shoots__img-wrap img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.7s cubic-bezier(0.25,1,0.5,1)}
.hbc-shoots__item:hover .hbc-shoots__img-wrap img{transform:scale(1.04);filter:brightness(0.85)}

.hbc-shoots__caption{position:absolute;bottom:0;left:0;right:0;padding:10px 14px;font-family:var(--f-body);font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:rgba(245,242,238,0.7);background:linear-gradient(transparent,rgba(0,0,0,0.55));opacity:0;transition:opacity 0.3s}
.hbc-shoots__item:hover .hbc-shoots__caption{opacity:1}

/* CTA */
.hbc-cta{padding:80px 48px;border-top:1px solid var(--c-border-light)}.hbc-cta__inner{max-width:560px;margin:0 auto}
.hbc-cta__img{margin-bottom:28px;overflow:hidden;max-width:300px;margin-left:auto;margin-right:auto}.hbc-cta__img img{width:100%;height:auto;display:block}

/* FOOTER */
.hbc-footer{padding:40px 48px;text-align:center;border-top:1px solid var(--c-border-light);font-size:12px;color:var(--c-faint);font-weight:300}

/* RESPONSIVE */
@media(max-width:768px){
  .hbc-collection__header{padding:0 24px;flex-direction:column;align-items:flex-start;gap:12px}
  .hbc-collection__title{font-size:28px}
  .hbc-rail{grid-auto-columns:78vw;scroll-padding-left:24px;padding-left:24px}
  .hbc-hero{grid-template-columns:1fr;min-height:unset}
  .hbc-showcase__left{height:72vw;min-height:unset;border-right:none;border-bottom:1px solid var(--c-border-light)}
  .hbc-showcase__thumbs{display:none}
  .hbc-showcase__right{padding:28px 24px}
  .hbc-showcase__product-name{font-size:24px}
  .hbc-showcase__price{font-size:22px}
  .hbc-specs__inner,.hbc-editorial__inner{grid-template-columns:1fr;gap:48px}
  .hbc-process__grid{grid-template-columns:1fr 1fr}.hbc-variants__grid{grid-template-columns:1fr}
  .hbc-gallery{grid-template-columns:1fr 1fr}.hbc-heading{font-size:30px}
  .hbc-quote__text{font-size:22px}.hbc-nav__links{display:none}
  .hbc-hero__meta{flex-direction:column;gap:8px;align-items:flex-start}.hbc-hero__meta-sep{display:none}
  .hbc-specs,.hbc-process,.hbc-editorial,.hbc-variants,.hbc-cta{padding-left:24px;padding-right:24px}
  .hbc-shoots__header{padding:0 24px 36px}
  .hbc-cla{padding:72px 24px}
  .hbc-cla__steps{grid-template-columns:1fr}
  .hbc-cla__proof{grid-template-columns:1fr 1fr;grid-template-rows:auto auto}.hbc-cla__proof-divider{display:none}
  .hbc-cla__header .hbc-heading{font-size:28px}
  .hbc-cla__callout-text{font-size:18px}
}
