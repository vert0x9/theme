<div id="hb-cls-{{ section.id }}" class="hb-cls" data-section-id="{{ section.id }}">

  <nav class="hbc-nav" id="hbc-nav-{{ section.id }}">
    <a href="/" class="hbc-nav__logo">Brooklyn Film Camera</a>
    <div class="hbc-nav__links">
      <a href="#hbc-specs-{{ section.id }}" class="hbc-nav__link">Specs</a>
      <a href="#hbc-cla-{{ section.id }}" class="hbc-nav__link">CLA</a>
      <a href="#hbc-process-{{ section.id }}" class="hbc-nav__link">Process</a>
      <a href="#hbc-showcase-{{ section.id }}" class="hbc-nav__link">Browse</a>
    </div>
  </nav>

  {%- comment -%} Compute min price from available Hasselblad products {%- endcomment -%}
  {%- assign hb_min_price = nil -%}
  {%- assign hb_product_count = 0 -%}
  {%- if section.settings.collection != blank -%}
    {%- for product in section.settings.collection.products -%}
      {%- if product.available and product.metafields.custom.brand == 'Hasselblad' -%}
        {%- assign hb_product_count = hb_product_count | plus: 1 -%}
        {%- if hb_min_price == nil or product.price < hb_min_price -%}
          {%- assign hb_min_price = product.price -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  <section class="hbc-collection">

    <div class="hbc-ts__header" style="padding: calc(60px + 32px) 0 0; margin-left: 48px; margin-right: 48px;">
      <div class="hbc-ts__header-row">
        <h1 class="hbc-ts__title bfc-heading">Hasselblad Medium Format</h1>
        <a class="hbc-ts__viewall" href="https://brooklynfilmcamera.com/collections/medium-format-cameras?sort_by=manual&filter.p.m.custom.brand=Hasselblad">View all</a>
      </div>
      <p class="hbc-ts__subheading">
        {%- if hb_product_count > 0 -%}
          {{ hb_product_count }} camera{% if hb_product_count != 1 %}s{% endif %} in stock{%- if hb_min_price != nil %} &middot; from {{ hb_min_price | money_without_trailing_zeros }}{%- endif %} &middot; full CLA &middot; 6-month warranty
        {%- else -%}
          Restored medium format cameras &middot; full CLA &middot; 6-month warranty
        {%- endif -%}
      </p>
    </div>

    <div class="hbc-ts__rail-wrap" data-bfc-ts style="margin-top: 20px;">
      <button class="hbc-ts__arrow hbc-ts__arrow--prev" type="button" aria-label="Scroll left" data-bfc-ts-prev>‹</button>
      <button class="hbc-ts__arrow hbc-ts__arrow--next" type="button" aria-label="Scroll right" data-bfc-ts-next>›</button>
      <div class="hbc-ts__rail" role="list" data-bfc-ts-rail>
        {%- if hb_product_count > 0 -%}
          {%- for product in section.settings.collection.products -%}
            {%- if product.available and product.metafields.custom.brand == 'Hasselblad' -%}
              <article class="hbc-ts__card" role="listitem">
                <a class="hbc-ts__img" href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1" aria-hidden="true">
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 720 }}"
                         srcset="{{ product.featured_image | image_url: width: 360 }} 360w, {{ product.featured_image | image_url: width: 540 }} 540w, {{ product.featured_image | image_url: width: 720 }} 720w"
                         sizes="(min-width: 990px) 260px, 70vw"
                         alt="{{ product.title | escape }}"
                         loading="{% if forloop.index <= 3 %}eager{% else %}lazy{% endif %}"
                         width="{{ product.featured_image.width }}"
                         height="{{ product.featured_image.height }}">
                  {%- endif -%}
                </a>
                <div class="hbc-ts__meta">
                  <div class="hbc-ts__vendor">{{ product.product_type }}</div>
                  <a class="hbc-ts__name" href="{{ product.url }}" aria-label="{{ product.title | escape }}">{{ product.title | escape }}</a>
                  <div class="hbc-ts__bottom">
                    <div class="hbc-ts__price">
                      <span class="hbc-ts__price-now">{{ product.price | money }}</span>
                    </div>
                  </div>
                </div>
              </article>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'variant' -%}
              <article class="hbc-ts__card" role="listitem" {{ block.shopify_attributes }}>
                <a class="hbc-ts__img" href="{{ block.settings.variant_url }}" aria-label="{{ block.settings.variant_name | escape }}" tabindex="-1" aria-hidden="true">
                  {%- if block.settings.variant_image != blank -%}
                    <img src="{{ block.settings.variant_image | image_url: width: 720 }}" alt="{{ block.settings.variant_name | escape }}" loading="lazy">
                  {%- endif -%}
                </a>
                <div class="hbc-ts__meta">
                  <div class="hbc-ts__vendor">{{ block.settings.variant_subtitle }}</div>
                  <a class="hbc-ts__name" href="{{ block.settings.variant_url }}" aria-label="{{ block.settings.variant_name | escape }}">{{ block.settings.variant_name | escape }}</a>
                  <div class="hbc-ts__bottom">
                    <div class="hbc-ts__price">
                      <span class="hbc-ts__price-now">${{ block.settings.variant_price }}</span>
                    </div>
                  </div>
                </div>
              </article>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
      <span class="hbc-ts__fade hbc-ts__fade--left" aria-hidden="true"></span>
      <span class="hbc-ts__fade hbc-ts__fade--right" aria-hidden="true"></span>
    </div>

  </section>

  {%- assign shoot_images = section.blocks | where: 'type', 'shoot_image' -%}
  {%- if shoot_images.size > 0 -%}
  <section class="hbc-shoots">
    <div class="hbc-shoots__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'shoot_image' -%}
          <div class="hbc-shoots__item hbc-shoots__item--{{ block.settings.image_span }}" {{ block.shopify_attributes }}>
            <div class="hbc-shoots__img-wrap">
              <img src="{{ block.settings.image | image_url: width: 1200 }}"
                   alt="{{ block.settings.image_alt | default: 'Shot on Hasselblad' }}"
                   loading="lazy">
              {%- if block.settings.caption != blank -%}
                <div class="hbc-shoots__caption">{{ block.settings.caption }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}

  <section class="hbc-marquee">
    <div class="hbc-marquee__inner">
      <span>Hasselblad</span><span class="hbc-marquee__dot">&bull;</span>
      <span>500C/M</span><span class="hbc-marquee__dot">&bull;</span>
      <span>Zeiss Optics</span><span class="hbc-marquee__dot">&bull;</span>
      <span>6x6 Medium Format</span><span class="hbc-marquee__dot">&bull;</span>
      <span>Fully Mechanical</span><span class="hbc-marquee__dot">&bull;</span>
      <span>V-System</span><span class="hbc-marquee__dot">&bull;</span>
      <span>Brooklyn Restored</span><span class="hbc-marquee__dot">&bull;</span>
      <span>Hasselblad</span><span class="hbc-marquee__dot">&bull;</span>
      <span>500C/M</span><span class="hbc-marquee__dot">&bull;</span>
      <span>Zeiss Optics</span><span class="hbc-marquee__dot">&bull;</span>
      <span>6x6 Medium Format</span><span class="hbc-marquee__dot">&bull;</span>
      <span>Fully Mechanical</span>
    </div>
  </section>

  <section class="hbc-quote hbc-reveal" id="hbc-quote-{{ section.id }}">
    <div class="hbc-quote__inner">
      {%- if section.settings.quote_image != blank -%}
        <img class="hbc-quote__img" src="{{ section.settings.quote_image | image_url: width: 200 }}" alt="">
      {%- endif -%}
      <p class="hbc-quote__text">{{ section.settings.quote_text | default: 'The default Hasselblad setup for a reason &mdash; fast, sharp, and flexible.' }}</p>
      <div class="hbc-quote__rule"></div>
      <div class="hbc-quote__attr">{{ section.settings.quote_attribution | default: 'Brooklyn Film Camera' }}</div>
    </div>
  </section>

  <section class="hbc-specs hbc-reveal" id="hbc-specs-{{ section.id }}">
    <div class="hbc-specs__inner">
      <div class="hbc-specs__header">
        {%- if section.settings.specs_image != blank -%}
          <div class="hbc-specs__img"><img src="{{ section.settings.specs_image | image_url: width: 800 }}" alt="{{ section.settings.product_name }}"></div>
        {%- endif -%}
        <div class="hbc-overline">Specifications</div>
        <h2 class="hbc-heading">{{ section.settings.specs_title_1 | default: 'Built to last another 50 years.' }}</h2>
        <p class="hbc-body">{{ section.settings.specs_description }}</p>
      </div>
      <div class="hbc-specs__table">
        {%- for block in section.blocks -%}
          {%- if block.type == 'spec' -%}
            <div class="hbc-specs__row" {{ block.shopify_attributes }}>
              <span class="hbc-specs__label">{{ block.settings.spec_label }}</span>
              <span class="hbc-specs__value">{{ block.settings.spec_value }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="hbc-gallery">
    {%- for block in section.blocks -%}
      {%- if block.type == 'gallery_image' -%}
        <div class="hbc-gallery__item" {{ block.shopify_attributes }}>
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image_alt | default: section.settings.product_name }}" loading="lazy">
        </div>
      {%- endif -%}
    {%- endfor -%}
  </section>

  <!-- ============================================================
       CLA SECTION — PROMINENT DEDICATED BLOCK
  ============================================================ -->
  <section class="hbc-cla hbc-reveal" id="hbc-cla-{{ section.id }}">
    <div class="hbc-cla__inner">
      <div class="hbc-cla__header">
        <div class="hbc-overline" style="text-align:center;">Our Standard</div>
        <h2 class="hbc-heading" style="text-align:center;max-width:none;">A Quality Guarantee</h2>
        <p class="hbc-cla__lead">{{ section.settings.cla_description | default: 'A lot of cameras get sold with no service history and no accountability. Every Hasselblad body we sell receives a full CLA in our shop. Lenses and accessories are cleaned and serviced as needed before they ship.' }}</p>
      </div>

      <div class="hbc-cla__steps">
        <div class="hbc-cla__step">
          <div class="hbc-cla__step-letter">C</div>
          <h3 class="hbc-cla__step-title">Clean</h3>
          <p class="hbc-cla__step-desc">Every body is fully disassembled. Old lubricants, dust, fungal haze, and decades of oxidation are removed from the shutter blades, mirror box, focusing screen, film rails, and all optical elements. Zeiss glass is cleaned element by element.</p>
        </div>
        <div class="hbc-cla__step">
          <div class="hbc-cla__step-letter">L</div>
          <h3 class="hbc-cla__step-title">Lubricate</h3>
          <p class="hbc-cla__step-desc">The right lubricant in the right place is what separates a camera that works from one that lasts. We re-lubricate every gear, cam, and bearing to Hasselblad's original specifications — using professional-grade greases that won't migrate to shutter blades or film plane.</p>
        </div>
        <div class="hbc-cla__step">
          <div class="hbc-cla__step-letter">A</div>
          <h3 class="hbc-cla__step-title">Adjust</h3>
          <p class="hbc-cla__step-desc">Shutter speeds calibrated across all settings. Mirror alignment checked. Film plane parallelism verified. Infinity focus confirmed. Flash sync tested. Every timing measurement is confirmed with precision instruments — not guesswork.</p>
        </div>
      </div>

      <div class="hbc-cla__proof">
        <div class="hbc-cla__proof-item">
          <div class="hbc-cla__proof-num">CLA'd</div>
          <div class="hbc-cla__proof-label">on most units before sale</div>
        </div>
        <div class="hbc-cla__proof-divider"></div>
        <div class="hbc-cla__proof-item">
          <div class="hbc-cla__proof-num">6-Mo</div>
          <div class="hbc-cla__proof-label">warranty covers mechanical function</div>
        </div>
        <div class="hbc-cla__proof-divider"></div>
        <div class="hbc-cla__proof-item">
          <div class="hbc-cla__proof-num">Tested</div>
          <div class="hbc-cla__proof-label">with professional equipment before shipping</div>
        </div>
        <div class="hbc-cla__proof-divider"></div>
        <div class="hbc-cla__proof-item">
          <div class="hbc-cla__proof-num">In-House</div>
          <div class="hbc-cla__proof-label">done by our Brooklyn technicians</div>
        </div>
      </div>

      <div class="hbc-cla__callout">
        <p class="hbc-cla__callout-text">{{ section.settings.cla_quote | default: 'Most Hasselblads on the market haven&rsquo;t been serviced in years. Ours have.' }}</p>
        <div class="hbc-cla__callout-attr">{{ section.settings.cla_quote_attr | default: '— Brooklyn Film Camera Technicians' }}</div>
      </div>
    </div>
  </section>

  <section class="hbc-process hbc-reveal" id="hbc-process-{{ section.id }}">
    <div class="hbc-process__inner">
      <div class="hbc-overline" style="text-align:center;">Our Restoration Process</div>
      <h2 class="hbc-heading" style="text-align:center;max-width:none;">{{ section.settings.process_title_1 | default: 'How we restore every camera.' }}</h2>
      {%- if section.settings.process_image != blank -%}
        <div class="hbc-process__hero-img"><img src="{{ section.settings.process_image | image_url: width: 1200 }}" alt="Our restoration process"></div>
      {%- endif -%}
      <div class="hbc-process__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'process_step' -%}
            <div class="hbc-process__card" {{ block.shopify_attributes }}>
              {%- if block.settings.step_image != blank -%}
                <div class="hbc-process__card-img"><img src="{{ block.settings.step_image | image_url: width: 400 }}" alt="{{ block.settings.step_title }}"></div>
              {%- endif -%}
              <div class="hbc-process__num">{{ block.settings.step_number }}</div>
              <h3 class="hbc-process__title">{{ block.settings.step_title }}</h3>
              <div class="hbc-process__rule"></div>
              <p class="hbc-process__desc">{{ block.settings.step_description }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="hbc-editorial hbc-reveal" id="hbc-editorial-{{ section.id }}">
    <div class="hbc-editorial__inner">
      <div class="hbc-editorial__text">
        <div class="hbc-overline">{{ section.settings.why_tag | default: 'Why Hasselblad' }}</div>
        <h2 class="hbc-heading">{{ section.settings.why_title_1 | default: 'Why shoot Hasselblad' }}</h2>
        <p class="hbc-body">{{ section.settings.why_description_1 }}</p>
        <p class="hbc-body" style="margin-top:16px;">{{ section.settings.why_description_2 }}</p>
      </div>
      <div class="hbc-editorial__sidebar">
        {%- if section.settings.why_image != blank -%}
          <div class="hbc-editorial__sidebar-img"><img src="{{ section.settings.why_image | image_url: width: 800 }}" alt="Why Hasselblad"></div>
        {%- endif -%}
        <div class="hbc-overline" style="margin-top:24px;">Ideal For</div>
        {%- assign uc_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'use_case' -%}
            {%- assign uc_index = uc_index | plus: 1 -%}
            <div class="hbc-usecase" {{ block.shopify_attributes }}>
              <span class="hbc-usecase__num">{{ uc_index }}</span>
              {{ block.settings.use_case_text }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="hbc-hero hbc-reveal" id="hbc-showcase-{{ section.id }}">
    <div class="hbc-showcase__header">
      <div class="hbc-overline">Browse in Detail</div>
    </div>

    {%- assign showcase_count = 0 -%}

    <div class="hbc-showcase__left">
      <div class="hbc-showcase__images" id="hbc-images-{{ section.id }}">
        {%- if hb_product_count > 0 -%}
          {%- for product in section.settings.collection.products -%}
            {%- if product.available and product.metafields.custom.brand == 'Hasselblad' -%}
              {%- if product.featured_image != blank -%}
                <div class="hbc-showcase__slide {% if showcase_count == 0 %}active{% endif %}"
                     data-index="{{ showcase_count }}"
                     data-title="{{ product.title | escape }}"
                     data-price="{{ product.price | money_without_trailing_zeros }}"
                     data-url="{{ product.url }}"
                     data-type="{{ product.product_type | escape }}"
                     data-desc="{{ product.description | strip_html | truncate: 160 | escape }}">
                  <img src="{{ product.featured_image | image_url: width: 1200 }}"
                       alt="{{ product.title }}"
                       loading="lazy">
                </div>
                {%- assign showcase_count = showcase_count | plus: 1 -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'hero_image' -%}
              <div class="hbc-showcase__slide {% if forloop.first %}active{% endif %}"
                   data-index="{{ forloop.index0 }}"
                   data-title="{{ section.settings.product_name | escape }}"
                   data-price="{{ section.settings.starting_price | default: '3,150' }}"
                   data-url="#"
                   data-type="Medium Format Camera"
                   data-desc=""
                   {{ block.shopify_attributes }}>
                <img src="{{ block.settings.image | image_url: width: 1200 }}"
                     alt="{{ block.settings.image_alt | default: section.settings.product_name }}"
                     loading="lazy">
              </div>
              {%- assign showcase_count = showcase_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button class="hbc-showcase__arrow hbc-showcase__arrow--prev" id="hbc-prev-{{ section.id }}" aria-label="Previous camera">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="hbc-showcase__arrow hbc-showcase__arrow--next" id="hbc-next-{{ section.id }}" aria-label="Next camera">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4L14 10L8 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <div class="hbc-showcase__counter" id="hbc-counter-{{ section.id }}">
        <span class="hbc-showcase__counter-cur">01</span>
        <span class="hbc-showcase__counter-sep">/</span>
        <span class="hbc-showcase__counter-total">{{ showcase_count | prepend: '0' | slice: -2, 2 }}</span>
      </div>

      <div class="hbc-showcase__thumbs" id="hbc-thumbs-{{ section.id }}">
        {%- if hb_product_count > 0 -%}
          {%- assign ti = 0 -%}
          {%- for product in section.settings.collection.products -%}
            {%- if product.available and product.metafields.custom.brand == 'Hasselblad' -%}
              {%- if product.featured_image != blank -%}
                <button class="hbc-showcase__thumb {% if ti == 0 %}active{% endif %}" data-index="{{ ti }}" aria-label="{{ product.title }}">
                  <img src="{{ product.featured_image | image_url: width: 100 }}" alt="{{ product.title }}">
                </button>
                {%- assign ti = ti | plus: 1 -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign ti = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'hero_image' -%}
              <button class="hbc-showcase__thumb {% if ti == 0 %}active{% endif %}" data-index="{{ ti }}">
                <img src="{{ block.settings.image | image_url: width: 100 }}" alt="">
              </button>
              {%- assign ti = ti | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <div class="hbc-showcase__right" id="hbc-info-{{ section.id }}">
      <div class="hbc-hero__overline">{{ section.settings.hero_tag | default: 'Medium Format &middot; 120 Film &middot; 6x6' }}</div>
      <div class="hbc-showcase__product-name" id="hbc-pname-{{ section.id }}">
        {%- if hb_product_count > 0 -%}
          {%- assign first_shown = false -%}
          {%- for product in section.settings.collection.products -%}
            {%- if product.available and product.metafields.custom.brand == 'Hasselblad' and first_shown == false -%}
              {{ product.title }}{%- assign first_shown = true -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {{ section.settings.hero_title_1 | default: 'Hasselblad' }} {{ section.settings.hero_title_2 | default: '500C/M' }}
        {%- endif -%}
      </div>
      <div class="hbc-showcase__product-type" id="hbc-ptype-{{ section.id }}">
        {%- if hb_product_count > 0 -%}
          {%- assign first_shown = false -%}
          {%- for product in section.settings.collection.products -%}
            {%- if product.available and product.metafields.custom.brand == 'Hasselblad' and first_shown == false -%}
              {{ product.product_type }}{%- assign first_shown = true -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
      <div class="hbc-hero__rule"></div>
      <p class="hbc-hero__desc">{{ section.settings.hero_description }}</p>
      <div class="hbc-showcase__price-row">
        <div class="hbc-showcase__price" id="hbc-pprice-{{ section.id }}">
          {%- if hb_product_count > 0 -%}
            {%- assign first_shown = false -%}
            {%- for product in section.settings.collection.products -%}
              {%- if product.available and product.metafields.custom.brand == 'Hasselblad' and first_shown == false -%}
                {{ product.price | money_without_trailing_zeros }}{%- assign first_shown = true -%}
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            ${{ section.settings.starting_price | default: '3,150' }}
          {%- endif -%}
        </div>
        <div class="hbc-showcase__price-note">Fully restored &middot; 6-mo warranty</div>
      </div>
      <div class="hbc-hero__actions">
        <a href="#" class="hbc-btn hbc-showcase__view-btn" id="hbc-plink-{{ section.id }}">View This Camera</a>
        <a href="https://brooklynfilmcamera.com/collections/medium-format-cameras?sort_by=manual&filter.p.m.custom.brand=Hasselblad" class="hbc-btn hbc-btn--ghost">All Hasselblad</a>
      </div>
      <div class="hbc-hero__meta">
        <div class="hbc-hero__meta-item"><strong>6-Month</strong> Warranty</div>
        <div class="hbc-hero__meta-sep"></div>
        <div class="hbc-hero__meta-item"><strong>Full CLA</strong> Every Unit</div>
        <div class="hbc-hero__meta-sep"></div>
        <div class="hbc-hero__meta-item"><strong>A-Grade</strong> Condition</div>
      </div>
    </div>
  </section>

  <section class="hbc-cta hbc-reveal">
    <div class="hbc-cta__inner">
      {%- if section.settings.cta_image != blank -%}
        <div class="hbc-cta__img"><img src="{{ section.settings.cta_image | image_url: width: 600 }}" alt="Visit us"></div>
      {%- endif -%}
      <div class="hbc-overline" style="text-align:center;">Come See Us</div>
