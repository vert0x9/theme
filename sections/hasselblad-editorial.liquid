</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Poppins:wght@300;400;500;600&display=swap');
.hb-cls{--c-bg:#faf9f7;--c-text:#1a1a1a;--c-muted:#6b6560;--c-faint:#a39e98;--c-accent:#8b7355;--c-accent-light:#c4b49a;--c-border:#e0dcd6;--c-border-light:#ece9e3;--c-card:#fff;--c-dark:#111;--c-dark-text:#f5f2ee;--f-body:'Poppins',sans-serif;--f-head:'EB Garamond',Georgia,serif;font-family:var(--f-body);background:var(--c-bg);color:var(--c-text);overflow-x:hidden;-webkit-font-smoothing:antialiased}
.hb-cls *,.hb-cls *::before,.hb-cls *::after{box-sizing:border-box;margin:0;padding:0}
.hb-cls ::selection{background:rgba(139,115,85,0.15)}
@keyframes hbcFadeUp{from{opacity:0;transform:translateY(36px)}to{opacity:1;transform:translateY(0)}}
@keyframes hbcMarquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.hbc-reveal{opacity:0;transform:translateY(36px);transition:opacity 0.8s cubic-bezier(0.25,1,0.5,1),transform 0.8s cubic-bezier(0.25,1,0.5,1)}.hbc-reveal.visible{opacity:1;transform:translateY(0)}

/* NAV */
.hbc-nav{position:fixed;top:0;left:0;right:0;z-index:100;height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;background:rgba(250,249,247,0.92);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-bottom:1px solid var(--c-border-light);transition:all 0.3s}
.hbc-nav.scrolled{box-shadow:0 1px 12px rgba(0,0,0,0.04)}
.hbc-nav__logo{font-family:var(--f-head);font-size:16px;font-weight:600;color:var(--c-text);text-decoration:none;letter-spacing:0.01em}
.hbc-nav__links{display:flex;gap:32px}.hbc-nav__link{font-family:var(--f-body);font-size:12px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--c-muted);text-decoration:none;transition:color 0.3s}.hbc-nav__link:hover{color:var(--c-text)}

/* COLLECTION RAIL — exact top sellers pattern */
.hbc-collection{ background: var(--c-bg); border-bottom: 1px solid var(--c-border-light); }

.hbc-collection .hbc-ts__header{ margin-bottom: 0; }
.hbc-collection .hbc-ts__header-row{ display:flex;align-items:baseline;justify-content:space-between;gap:16px; }
.hbc-collection .hbc-ts__title{ margin:0;letter-spacing:-0.02em;font-family:var(--f-head);font-size:28px;font-weight:500;color:var(--c-text); }
.hbc-collection .hbc-ts__viewall{ color:var(--c-text);text-decoration:none;font-size:12px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;opacity:.7; }
.hbc-collection .hbc-ts__viewall:hover{ opacity:1; }
.hbc-collection .hbc-ts__subheading{ margin:8px 0 0;color:var(--c-muted);font-size:13px;line-height:1.35; }

.hbc-collection .hbc-ts__rail-wrap{ position:relative;margin-top:0;width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);--bfc-ts-left-pad:48px; }
.hbc-collection .hbc-ts__rail{ display:grid;grid-auto-flow:column;grid-auto-columns:clamp(220px,24vw,280px);gap:16px;overflow-x:auto;overscroll-behavior-x:contain;scroll-snap-type:x mandatory;scroll-padding-left:var(--bfc-ts-left-pad);padding-left:var(--bfc-ts-left-pad);padding-right:0;padding-top:20px;padding-bottom:24px;-webkit-overflow-scrolling:touch;scrollbar-width:none; }
.hbc-collection .hbc-ts__rail::-webkit-scrollbar{ display:none; }

.hbc-collection .hbc-ts__card{ scroll-snap-align:start;scroll-snap-stop:always;background:var(--c-bg);border:1px solid var(--c-border-light);overflow:hidden;display:grid;grid-template-rows:auto 1fr;min-height:100%; }
.hbc-collection .hbc-ts__img{ position:relative;display:block;aspect-ratio:4/3;background:var(--c-card);overflow:hidden;text-decoration:none; }
.hbc-collection .hbc-ts__img img{ width:100%;height:100%;object-fit:cover;padding:0;display:block;transform:scale(1);transition:transform .25s ease; }
.hbc-collection .hbc-ts__card:hover .hbc-ts__img img{ transform:scale(1.03); }

.hbc-collection .hbc-ts__meta{ padding:14px 16px 16px;display:grid;gap:6px;border-top:1px solid var(--c-border-light); }
.hbc-collection .hbc-ts__vendor{ font-size:10px;color:var(--c-faint);text-transform:uppercase;letter-spacing:.1em;font-weight:500; }
.hbc-collection .hbc-ts__name{ color:var(--c-text);text-decoration:none;font-family:var(--f-head);font-size:17px;line-height:1.25;font-weight:500;letter-spacing:-0.01em; }
.hbc-collection .hbc-ts__name:hover{ text-decoration:underline; }
.hbc-collection .hbc-ts__bottom{ margin-top:2px; }
.hbc-collection .hbc-ts__price-now{ font-size:15px;font-weight:600;color:var(--c-text); }

.hbc-collection .hbc-ts__arrow{ position:absolute;top:42%;transform:translateY(-50%);z-index:3;width:40px;height:40px;border:1px solid var(--c-border);background:rgba(250,249,247,.9);backdrop-filter:blur(6px);cursor:pointer;display:none;align-items:center;justify-content:center;font-size:22px;line-height:1;color:var(--c-text); }
.hbc-collection .hbc-ts__arrow--prev{ left:10px; }
.hbc-collection .hbc-ts__arrow--next{ right:10px; }
@media(min-width:990px){ .hbc-collection .hbc-ts__arrow{ display:flex; } }

.hbc-collection .hbc-ts__fade{ position:absolute;top:0;bottom:0;width:56px;z-index:2;pointer-events:none; }
.hbc-collection .hbc-ts__fade--left{ left:0;background:linear-gradient(to right,var(--c-bg),transparent); }
.hbc-collection .hbc-ts__fade--right{ right:0;background:linear-gradient(to left,var(--c-bg),transparent); }

@media(max-width:749px){
  .hbc-collection .hbc-ts__rail{ grid-auto-columns:78vw;gap:12px;--bfc-ts-left-pad:24px; }
  .hbc-collection .hbc-ts__header{ margin-left:24px!important;margin-right:24px!important; }
}

/* SHOWCASE — mid-page detail browser */
.hbc-hero{display:grid;grid-template-columns:1.15fr 1fr;min-height:640px;border-top:1px solid var(--c-border-light)}
.hbc-showcase__header{display:none}
.hbc-showcase__left{position:relative;overflow:hidden;background:var(--c-card)}
.hbc-showcase__images{position:absolute;inset:0}
.hbc-showcase__slide{position:absolute;inset:0;opacity:0;transition:opacity 0.6s ease}
.hbc-showcase__slide.active{opacity:1}
.hbc-showcase__slide img{width:100%;height:100%;object-fit:cover}

/* Arrows */
.hbc-showcase__arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:10;width:44px;height:44px;background:rgba(250,249,247,0.9);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);border:1px solid var(--c-border);color:var(--c-text);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.25s;padding:0}
.hbc-showcase__arrow:hover{background:#fff;border-color:var(--c-accent);color:var(--c-accent)}
.hbc-showcase__arrow--prev{left:20px}
.hbc-showcase__arrow--next{right:20px}

/* Counter */
.hbc-showcase__counter{position:absolute;top:20px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:6px;background:rgba(250,249,247,0.88);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);padding:6px 14px;border:1px solid var(--c-border-light);font-family:var(--f-body);font-size:11px;font-weight:500;letter-spacing:0.08em;color:var(--c-muted)}
.hbc-showcase__counter-cur{color:var(--c-text)}
.hbc-showcase__counter-sep{color:var(--c-border)}

/* Thumbnail strip */
.hbc-showcase__thumbs{position:absolute;bottom:0;left:0;right:0;display:flex;gap:0;border-top:1px solid var(--c-border-light);background:rgba(250,249,247,0.92);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);overflow-x:auto;scrollbar-width:none}
.hbc-showcase__thumbs::-webkit-scrollbar{display:none}
.hbc-showcase__thumb{flex:0 0 80px;height:72px;border:none;border-right:1px solid var(--c-border-light);background:transparent;cursor:pointer;padding:6px;transition:background 0.2s;position:relative}
.hbc-showcase__thumb img{width:100%;height:100%;object-fit:contain}
.hbc-showcase__thumb::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:transparent;transition:background 0.2s}
.hbc-showcase__thumb.active::after,.hbc-showcase__thumb:hover::after{background:var(--c-accent)}
.hbc-showcase__thumb.active{background:rgba(139,115,85,0.06)}

/* Right panel */
.hbc-showcase__right{display:flex;flex-direction:column;justify-content:center;padding:64px 56px}

/* Dynamic product name */
.hbc-showcase__product-name{font-family:var(--f-head);font-size:40px;font-weight:500;line-height:1.1;color:var(--c-text);letter-spacing:-0.01em;margin-bottom:8px;transition:opacity 0.3s}
.hbc-showcase__product-name.switching{opacity:0}

/* Product type tag */
.hbc-showcase__product-type{font-family:var(--f-body);font-size:13px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--c-muted);margin-bottom:20px;transition:opacity 0.3s}
.hbc-showcase__product-type.switching{opacity:0}

/* Price row */
.hbc-showcase__price-row{margin-bottom:28px;display:flex;align-items:baseline;gap:16px}
.hbc-showcase__price{font-family:var(--f-head);font-size:32px;color:var(--c-text);font-weight:500;transition:opacity 0.3s}
.hbc-showcase__price.switching{opacity:0}
.hbc-showcase__price-note{font-size:11px;color:var(--c-faint);font-weight:400}

/* View button transition */
.hbc-showcase__view-btn.switching{opacity:0.5}

/* Shared hero/right panel styles */
.hbc-hero__overline{font-family:var(--f-body);font-size:11px;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;color:var(--c-accent);margin-bottom:16px}
.hbc-hero__rule{width:40px;height:1px;background:var(--c-border);margin:20px 0}
.hbc-hero__desc{font-size:14px;line-height:1.75;color:var(--c-muted);max-width:400px;margin-bottom:28px;font-weight:400}
.hbc-hero__actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px}
.hbc-hero__meta{display:flex;gap:20px;align-items:center}.hbc-hero__meta-item{font-size:12px;color:var(--c-muted);font-weight:400}.hbc-hero__meta-item strong{font-weight:600;color:var(--c-text)}.hbc-hero__meta-sep{width:1px;height:16px;background:var(--c-border)}

/* BUTTONS */
.hbc-btn{display:inline-block;background:var(--c-text);color:#fff;padding:14px 36px;font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;font-family:var(--f-body);border:1px solid var(--c-text);transition:all 0.3s ease;cursor:pointer}.hbc-btn:hover{background:var(--c-accent);border-color:var(--c-accent)}
.hbc-btn--ghost{background:transparent;color:var(--c-text);border:1px solid var(--c-border)}.hbc-btn--ghost:hover{border-color:var(--c-text);background:rgba(0,0,0,0.02)}
.hbc-btn--sm{padding:10px 28px;font-size:11px}
.hbc-btn--light{background:#fff;color:var(--c-dark);border-color:#fff}.hbc-btn--light:hover{background:var(--c-accent-light);border-color:var(--c-accent-light);color:#fff}
.hbc-btn--ghost-light{background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.4)}.hbc-btn--ghost-light:hover{background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.7)}

/* SHARED TYPOGRAPHY */
.hbc-overline{font-family:var(--f-body);font-size:11px;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;color:var(--c-accent);margin-bottom:14px}
.hbc-heading{font-family:var(--f-head);font-size:36px;font-weight:500;line-height:1.2;color:var(--c-text);max-width:480px;margin-bottom:20px;letter-spacing:-0.01em}.hbc-heading em{font-style:normal;font-weight:500;color:var(--c-text)}
.hbc-body{font-size:14px;line-height:1.75;color:var(--c-muted);max-width:440px;font-weight:400}

/* MARQUEE */
.hbc-marquee{overflow:hidden;border-top:1px solid var(--c-border-light);border-bottom:1px solid var(--c-border-light);padding:16px 0;white-space:nowrap}
.hbc-marquee__inner{display:inline-flex;gap:0;animation:hbcMarquee 30s linear infinite}
.hbc-marquee__inner span{font-family:var(--f-head);font-size:14px;font-weight:400;color:var(--c-faint);letter-spacing:0.05em;padding:0 16px}.hbc-marquee__dot{color:var(--c-accent-light);padding:0 8px}

/* QUOTE */
.hbc-quote{padding:48px 48px;text-align:center;background:var(--c-card);border-bottom:1px solid var(--c-border-light)}
.hbc-quote__inner{max-width:640px;margin:0 auto}
.hbc-quote__img{width:56px;height:56px;border-radius:50%;object-fit:cover;margin:0 auto 14px;display:block;border:1px solid var(--c-border-light)}
.hbc-quote__text{font-family:var(--f-head);font-size:20px;font-weight:500;line-height:1.5;color:var(--c-text)}
.hbc-quote__rule{width:24px;height:1px;background:var(--c-border);margin:16px auto}.hbc-quote__attr{font-family:var(--f-body);font-size:11px;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--c-faint)}

/* SPECS */
.hbc-specs{padding:80px 48px}.hbc-specs__inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1fr 1.2fr;gap:64px;align-items:start}
.hbc-specs__img{margin-bottom:24px;overflow:hidden}.hbc-specs__img img{width:100%;height:auto;display:block}
.hbc-specs__table{border-top:1px solid var(--c-border)}
.hbc-specs__row{display:flex;justify-content:space-between;padding:16px 0;border-bottom:1px solid var(--c-border-light);transition:background 0.2s}.hbc-specs__row:hover{background:rgba(0,0,0,0.01)}
.hbc-specs__label{font-size:13px;font-weight:500;color:var(--c-muted);text-transform:uppercase;letter-spacing:0.06em}
.hbc-specs__value{font-family:var(--f-head);font-size:17px;color:var(--c-text);font-weight:400}

/* GALLERY */
.hbc-gallery{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--c-border-light);border-top:1px solid var(--c-border-light);border-bottom:1px solid var(--c-border-light)}
.hbc-gallery__item{background:var(--c-card);aspect-ratio:1/1;overflow:hidden;display:flex;align-items:center;justify-content:center}
.hbc-gallery__item img{width:80%;height:80%;object-fit:contain;transition:transform 0.6s cubic-bezier(0.25,1,0.5,1)}.hbc-gallery__item:hover img{transform:scale(1.05)}

/* ============================================================
   CLA SECTION — DARK FULL-WIDTH FEATURE
============================================================ */
.hbc-cla{background:var(--c-dark);padding:88px 48px}
.hbc-cla__inner{max-width:1080px;margin:0 auto}
.hbc-cla .hbc-overline{color:var(--c-accent-light)}
.hbc-cla__header{text-align:center;margin-bottom:60px}
.hbc-cla__header .hbc-heading{color:var(--c-dark-text);max-width:none;font-size:38px;line-height:1.15;margin-bottom:20px}
.hbc-cla__header .hbc-heading em{color:var(--c-accent-light)}
.hbc-cla__lead{font-size:15px;line-height:1.75;color:rgba(245,242,238,0.65);max-width:600px;margin:0 auto;font-weight:400;text-align:center}

.hbc-cla__steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,0.06);margin-bottom:60px}
