{{- 'section-product.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'product-variants.js' | asset_url }}" defer="defer"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet"/></noscript>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  assign g1 = product.metafields.custom.gallery_1.value
  assign g2 = product.metafields.custom.gallery_2.value
  assign g3 = product.metafields.custom.gallery_3.value
  assign g4 = product.metafields.custom.gallery_4.value
  assign g5 = product.metafields.custom.gallery_5.value
  assign g6 = product.metafields.custom.gallery_6.value

  assign spec_lens    = product.metafields.custom.spec_lens.value
  assign spec_shutter = product.metafields.custom.spec_shutterspeeds.value
  assign spec_mount   = product.metafields.custom.spec_lensmount.value
  assign spec_battery = product.metafields.custom.spec_battery.value
  assign spec_flash   = product.metafields.custom.spec_flash.value
  assign spec_tripod  = product.metafields.custom.spec_tripodmount.value
  assign spec_timer   = product.metafields.custom.spec_selftimer.value
  assign spec_dx      = product.metafields.custom.spec_dxcodereader.value
  assign spec_expcomp = product.metafields.custom.spec_exposurecompensation.value
  assign spec_meter   = product.metafields.custom.spec_meter.value
  assign spec_focus   = product.metafields.custom.spec_focus.value
-%}

<style>
.bfc-a *,
.bfc-a *::before,
.bfc-a *::after { box-sizing: border-box; margin: 0; padding: 0; }

.bfc-a {
  --or:  #E36E15;
  --go:  #F4A027;
  --ce:  #ABCC99;
  --cv:  #F8F6EE;
  --bk:  #202009;
  --ch:  #4E4741;
  --gr:  #E3DDDA;
  --sr:  'Cormorant Garamond', Georgia, serif;
  --sn:  'Poppins', sans-serif;
  --t:   0.2s ease;
  font-family: var(--sn);
  color: var(--bk);
  background: var(--cv);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ── HERO ─────────────────────────────────────── */
.ba-hero {
  position: relative;
  width: 100%;
  height: 70vh;
  overflow: hidden;
  background: var(--gr);
}
/* Slider track */
.ba-hero-slides {
  display: flex;
  height: 100%;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}
.ba-hero-slide {
  min-width: 100%;
  height: 100%;
  position: relative;
  flex-shrink: 0;
}
.ba-hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}
/* Prev / next arrows */
.ba-hero-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  background: rgba(32,32,9,0.35);
  border: none;
  width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background var(--t);
  backdrop-filter: blur(4px);
}
.ba-hero-arrow:hover { background: rgba(32,32,9,0.65); }
.ba-hero-arrow.is-prev { left: 20px; visibility: hidden; }
.ba-hero-arrow.is-next { right: 20px; }
.ba-hero-arrow svg { display: block; }
/* Dot indicators */
.ba-hero-dots {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 6px;
  z-index: 10;
}
.ba-hero-dot {
  width: 6px; height: 6px;
  background: rgba(255,255,255,0.4);
  border: none; cursor: pointer; padding: 0;
  transition: background var(--t), transform var(--t);
}
.ba-hero-dot.is-active {
  background: #fff;
  transform: scale(1.3);
}
.ba-hero-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 40px 48px;
  background: linear-gradient(to top, rgba(32,32,9,0.55) 0%, transparent 100%);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24px;
}
.ba-hero-text { display: block; }
.ba-hero-top { display: block; }
.ba-hero-eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8px;
  display: block;
}
.ba-hero-title {
  font-family: var(--sr);
  font-size: 72px;
  font-weight: 300;
  color: #fff;
  line-height: 0.95;
  letter-spacing: -1px;
}
.ba-hero-title em {
  font-style: italic;
  color: rgba(255,255,255,0.7);
}
.ba-hero-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.75);
  line-height: 1.6;
  max-width: 400px;
  max-height: 120px;
  overflow-y: auto;
  margin-top: 12px;
}
.ba-hero-scroll-group {
  display: flex; align-items: center; gap: 20px; flex-shrink: 0;
}
.ba-hero-scroll {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  flex-shrink: 0;
  cursor: pointer;
  transition: color var(--t);
}
.ba-hero-scroll:hover { color: rgba(255,255,255,0.9); }
.ba-hero-scroll svg { display: block; animation: ba-bounce 1.6s ease infinite; }
@keyframes ba-bounce {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(4px); }
}

/* ── BODY ─────────────────────────────────────── */
/* ── KIT SECTION ──────────────────────────────── */
.ba-kit {
  display: grid;
  grid-template-columns: 2fr 1fr;
  grid-template-rows: auto 1fr;
  align-items: start;
  gap: 24px;
  padding: 48px;
  border-top: 1px solid rgba(32,32,9,0.1);
  background: var(--cv);
}
.ba-kit-heading-block { grid-column: 1; grid-row: 1; min-width: 0; }
.ba-kit-banner-slot   { grid-column: 2; grid-row: 1; min-width: 0; }
.ba-kit-left          { grid-column: 1; grid-row: 2; min-width: 0; overflow: hidden; }
.ba-kit-right         { grid-column: 2; grid-row: 2; position: sticky; bottom: 20px; }
.ba-kit-eyebrow {
  font-size: 10px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--or); margin-bottom: 10px; display: block;
}
.ba-kit-heading {
  font-family: var(--sr); font-size: 44px; font-weight: 300;
  line-height: 1; margin-bottom: 8px;
}
.ba-kit-heading em { font-style: italic; color: var(--ch); }
.ba-kit-sub {
  font-size: 12.5px; color: var(--ch); line-height: 1.6;
  max-width: 100%; margin-bottom: 24px;
}

/* Column groups — separated by gap, accordion */
.ba-columns {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}
.ba-col {
  background: #fff;
  border: 1px solid rgba(32,32,9,0.1);
  display: flex; flex-direction: column;
}
.ba-col-head {
  padding: 14px 16px;
  cursor: pointer;
  user-select: none;
  display: flex; align-items: center; justify-content: space-between;
  transition: background var(--t);
}
.ba-col-head:hover { background: rgba(32,32,9,0.02); }
.ba-col-title {
  font-size: 10.5px; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--bk);
  display: flex; align-items: center; gap: 8px;
}
.ba-col-count {
  font-size: 9px; font-weight: 700; color: #fff;
  background: var(--or); padding: 1px 7px; display: none;
}
.ba-col-count.is-visible { display: inline; }
.ba-col-chevron {
  color: rgba(32,32,9,0.3);
  transition: transform var(--t);
  flex-shrink: 0;
}
.ba-col.is-open .ba-col-chevron { transform: rotate(180deg); }
.ba-col-body {
  display: none;
}
.ba-col.is-open .ba-col-body { display: block; }
.ba-mini-card.is-hidden { display: none; }
.ba-col.is-expanded .ba-mini-card.is-hidden { display: grid; }
.ba-col-more {
  display: none;
  width: 100%; padding: 9px 14px;
  background: none; border: none; border-top: 1px solid rgba(32,32,9,0.07);
  cursor: pointer; font-family: var(--sn); font-size: 10px; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: rgba(32,32,9,0.4); transition: color var(--t); text-align: left;
}
.ba-col.is-open .ba-col-more { display: block; }
.ba-col.is-expanded .ba-col-more { color: rgba(32,32,9,0.3); }
.ba-col-more:hover { color: var(--or); }

/* Mini product cards — clean and simple */
.ba-mini-card {
  display: grid;
  grid-template-columns: 52px 1fr;
  background: #fff;
  border-bottom: 1px solid rgba(32,32,9,0.06);
  cursor: pointer;
  transition: background var(--t);
  position: relative;
}
.ba-mini-card:last-child { border-bottom: none; }
.ba-mini-card:hover { background: rgba(227,110,21,0.03); }
.ba-mini-card.is-sel { background: rgba(227,110,21,0.05); }
.ba-mini-card.is-sel::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px; background: var(--or);
}
.ba-mini-img {
  width: 52px; height: 100%; min-height: 52px; object-fit: cover; display: block;
  flex-shrink: 0; align-self: stretch; opacity: 0.75; transition: opacity var(--t);
}
.ba-mini-card:hover .ba-mini-img,
.ba-mini-card.is-sel .ba-mini-img { opacity: 1; }
.ba-mini-img-ph { width: 52px; height: 52px; background: var(--gr); }

/* Info icon */
.ba-mini-img-wrap {
  position: relative; flex-shrink: 0;
  width: 52px; align-self: stretch;
  border-right: 1px solid rgba(32,32,9,0.06);
}
.ba-mini-info-icon {
  position: absolute; bottom: 4px; right: 4px;
  width: 16px; height: 16px;
  background: rgba(255,255,255,0.85); border: none; cursor: pointer; padding: 0;
  color: rgba(32,32,9,0.4); transition: color var(--t);
  display: flex; align-items: center; justify-content: center;
  z-index: 2;
}
.ba-mini-info-icon:hover { color: var(--or); }
.ba-mini-info-icon svg { display: block; }
.ba-mini-body {
  padding: 10px 12px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 8px; min-width: 0;
}
.ba-mini-info { min-width: 0; flex: 1; }
.ba-mini-name {
  font-size: 11.5px; font-weight: 500; line-height: 1.3;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  color: var(--ch); transition: color var(--t);
}
.ba-mini-card:hover .ba-mini-name,
.ba-mini-card.is-sel .ba-mini-name { color: var(--bk); font-weight: 600; }
.ba-mini-right { flex-shrink: 0; text-align: right; }
.ba-mini-price { font-size: 12px; font-weight: 700; color: var(--or); display: block; }
.ba-mini-price.is-free { color: #2a4820; }
.ba-mini-orig { font-size: 9px; color: rgba(32,32,9,0.3); text-decoration: line-through; display: block; }

/* Variant pills — only shown when card is selected */
.ba-mini-vars {
  display: none;
  padding: 6px 10px 8px;
  flex-wrap: wrap; gap: 4px;
  background: rgba(227,110,21,0.03);
  border-top: 1px solid rgba(32,32,9,0.06);
}
.ba-mini-card.is-sel .ba-mini-vars { display: flex; }
.ba-mini-var-btn {
  font-size: 10px; font-weight: 500; padding: 3px 8px;
  border: 1px solid rgba(32,32,9,0.12); background: #fff;
  cursor: pointer; font-family: var(--sn); transition: all var(--t);
}
.ba-mini-var-btn:hover { border-color: var(--or); }
.ba-mini-var-btn.is-sel { border-color: var(--or); background: rgba(227,110,21,0.06); font-weight: 600; }

/* 2-roll promo */
.ba-film-promo {
  background: linear-gradient(135deg, #2a4820 0%, #3a6230 100%);
  padding: 12px 14px;
  display: flex; align-items: center; gap: 10px;
  margin-top: 10px;
}
.ba-film-promo-icon {
  width: 26px; height: 26px; background: rgba(255,255,255,0.12);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ba-film-promo-text { flex: 1; }
.ba-film-promo-title { font-size: 11px; font-weight: 700; color: #fff; margin-bottom: 1px; }
.ba-film-promo-sub   { font-size: 9.5px; color: rgba(255,255,255,0.7); }
.ba-film-promo-status {
  font-size: 9.5px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ce); flex-shrink: 0; white-space: nowrap;
}

/* ── KIT RIGHT CARD ──────────────────────────── */
.ba-kit-right {
  position: sticky;
  bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.ba-kit-card {
  background: #fff;
  border: 1px solid rgba(32,32,9,0.12);
  display: flex; flex-direction: column;
}

/* Camera row */
.ba-kp-cam {
  padding: 12px 14px;
  border-bottom: 1px solid rgba(32,32,9,0.07);
}
.ba-kp-cam-row {
  display: flex; align-items: center; gap: 10px; margin-bottom: 8px;
}
.ba-kp-cam-img {
  width: 36px; height: 36px; background: var(--gr);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden;
}
.ba-kp-cam-img img { width: 100%; height: 100%; object-fit: contain; }
.ba-kp-cam-name { font-size: 12px; font-weight: 600; color: var(--bk); }
.ba-kp-cam-sub  { font-size: 9px; color: var(--ch); margin-top: 1px; }
.ba-kp-variants { display: flex; gap: 4px; }
.ba-var-btn {
  flex: 1; padding: 5px 6px;
  border: 1px solid rgba(32,32,9,0.15);
  background: var(--cv); cursor: pointer; font-family: var(--sn);
  font-size: 10px; font-weight: 600; color: var(--bk); transition: all var(--t); text-align: center;
}
.ba-var-btn:hover { border-color: var(--or); }
.ba-var-btn.is-active { border-color: var(--or); border-width: 2px; color: var(--or); background: rgba(227,110,21,0.05); }

/* Line items */
.ba-kp-items {
  padding: 10px 14px;
  display: flex; flex-direction: column; gap: 2px;
  min-height: 60px;
}
.ba-kp-section-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.16em;
  text-transform: uppercase; color: rgba(32,32,9,0.3);
  margin-bottom: 5px; display: block;
}
.ba-kp-cam-line {
  display: flex; justify-content: space-between; align-items: baseline;
  padding-bottom: 7px; margin-bottom: 2px;
  border-bottom: 1px solid rgba(32,32,9,0.07);
}
.ba-kp-cam-line-name { font-size: 11px; font-weight: 600; color: var(--bk); }
.ba-kp-cam-line-price { font-size: 11.5px; font-weight: 700; color: var(--bk); }

.ba-kp-line {
  display: flex; align-items: center; gap: 6px; padding: 3px 0;
}
.ba-kp-line-img { width: 26px; height: 26px; object-fit: cover; background: var(--gr); flex-shrink: 0; }
.ba-kp-line-name { font-size: 10px; color: var(--ch); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ba-kp-line-price { font-size: 10.5px; font-weight: 700; color: var(--or); flex-shrink: 0; }
.ba-kp-line-price.is-free { color: #2a4820; }
.ba-kp-line-remove {
  background: none; border: none; cursor: pointer; color: rgba(32,32,9,0.2);
  font-size: 13px; line-height: 1; padding: 0; flex-shrink: 0; transition: color var(--t);
}
.ba-kp-line-remove:hover { color: var(--bk); }
.ba-kp-empty { font-size: 10px; color: rgba(32,32,9,0.25); font-style: italic; }

/* Footer */
.ba-kp-foot {
  padding: 10px 14px 14px;
  border-top: 1px solid rgba(32,32,9,0.08);
}
.ba-kp-total-row {
  display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px;
}
.ba-kp-total-label { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ch); }
.ba-kp-total-price { font-family: var(--sr); font-size: 30px; font-weight: 300; color: var(--bk); line-height: 1; }
.ba-kp-savings { font-size: 10px; color: #2a4820; font-weight: 600; min-height: 13px; margin-bottom: 10px; }

.ba-atc {
  width: 100%; padding: 12px;
  background: var(--or); color: #fff; border: none;
  cursor: pointer; font-family: var(--sn);
  font-size: 10.5px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  transition: background var(--t); display: block; text-align: center; margin-bottom: 6px;
}
.ba-atc:hover:not([disabled]) { background: #c9600f; }
.ba-atc[disabled] { opacity: 0.5; cursor: not-allowed; }
.ba-atc.is-success { background: #2a4820 !important; }
.ba-cam-only {
  width: 100%; font-size: 9px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(32,32,9,0.3); background: none;
  border: none; cursor: pointer; transition: color var(--t); font-family: var(--sn);
  text-align: center; padding: 3px 0; display: block;
}
.ba-cam-only:hover { color: var(--bk); }

/* ── POPUP ───────────────────────────────────── */
.ba-popup-overlay {
  position: fixed; inset: 0;
  background: rgba(32,32,9,0.55);
  z-index: 200; display: none;
  align-items: center; justify-content: center;
  backdrop-filter: blur(3px);
}
.ba-popup-overlay.is-open { display: flex; }
.ba-popup {
  background: #fff;
  max-width: 680px; width: 90%;
  max-height: 85vh;
  display: flex; flex-direction: column;
  overflow: hidden;
  animation: ba-popup-in 0.2s ease;
}
@keyframes ba-popup-in {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
.ba-popup-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px; border-bottom: 1px solid rgba(32,32,9,0.1);
  flex-shrink: 0;
}
.ba-popup-title { font-size: 14px; font-weight: 700; }
.ba-popup-close {
  background: none; border: none; cursor: pointer; padding: 4px;
  color: var(--ch); display: flex; align-items: center;
}
.ba-popup-body { overflow-y: auto; flex: 1; }
.ba-popup-imgs {
  display: grid; grid-template-columns: repeat(3, 1fr);
}
.ba-popup-imgs img {
  width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block;
  border-right: 1px solid rgba(32,32,9,0.07);
  border-bottom: 1px solid rgba(32,32,9,0.07);
}
.ba-popup-desc {
  padding: 20px;
  font-size: 12.5px; color: var(--ch); line-height: 1.7;
  border-top: 1px solid rgba(32,32,9,0.08);
}
.ba-popup-desc p { margin-bottom: 10px; }
.ba-popup-desc p:last-child { margin-bottom: 0; }

/* 2-rolls promo banner */
.ba-film-promo {
  background: linear-gradient(135deg, #2a4820 0%, #3a6230 100%);
  padding: 14px 20px;
  display: flex; align-items: center; gap: 12px;
  border-top: 1px solid rgba(32,32,9,0.08);
  border-bottom: 1px solid rgba(32,32,9,0.08);
  box-sizing: border-box; width: 100%; overflow: hidden;
}
.ba-film-promo-icon {
  width: 32px; height: 32px; background: rgba(255,255,255,0.12);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ba-film-promo-text { flex: 1; }
.ba-film-promo-title { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 1px; overflow-wrap: break-word; word-break: break-word; }
.ba-film-promo-sub   { font-size: 10.5px; color: rgba(255,255,255,0.7); overflow-wrap: break-word; word-break: break-word; }
.ba-film-promo-status {
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--ce); flex-shrink: 0;
}

/* ── SHOT ON ──────────────────────────────────── */
.ba-shot { background: var(--cv); border-top: 1px solid rgba(32,32,9,0.1); }
.ba-shot-head {
  padding: 48px 48px 24px;
  display: flex; justify-content: space-between; align-items: baseline;
  border-bottom: 1px solid rgba(32,32,9,0.1);
}
.ba-shot-title { font-family: var(--sr); font-size: 40px; font-weight: 300; }
.ba-shot-sub { font-size: 11px; color: var(--ch); font-style: italic; }
.ba-shot-grid { display: grid; grid-template-columns: repeat(6, 1fr); }
.ba-shot-grid a { display: block; overflow: hidden; border-right: 1px solid rgba(32,32,9,0.08); line-height: 0; font-size: 0; }
.ba-shot-grid a:last-child { border-right: none; }
.ba-shot-grid img { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; transition: transform 0.4s ease; }
.ba-shot-grid a:hover img { transform: scale(1.04); }

/* ── RESTORATION ──────────────────────────────── */
.ba-restore { background: var(--bk); }

.ba-restore-top {
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding: 56px 48px 40px;
  gap: 48px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.ba-restore-headline {
  display: flex; flex-direction: column; justify-content: flex-end;
}
.ba-restore-ey {
  font-size: 9px; font-weight: 700; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--go);
  margin-bottom: 16px; display: block;
}
.ba-restore-title {
  font-family: var(--sr); font-size: 42px; font-weight: 300;
  color: #fff; line-height: 1.05;
}
.ba-restore-title em { font-style: italic; color: rgba(255,255,255,0.3); }

.ba-restore-stats {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 0;
}
.ba-r-stat {
  padding: 0 24px;
  border-left: 1px solid rgba(255,255,255,0.07);
  display: flex; flex-direction: column; justify-content: center;
}
.ba-r-stat:first-child { border-left: none; padding-left: 0; }
.ba-r-stat-num {
  font-family: var(--sr); font-size: 52px; font-weight: 300;
  color: #fff; line-height: 1; margin-bottom: 8px;
}
.ba-r-stat-num span { color: var(--go); font-size: 0.6em; }
.ba-r-stat-label { font-size: 10.5px; color: rgba(255,255,255,0.3); line-height: 1.5; max-width: 100px; }

.ba-restore-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid rgba(255,255,255,0.06);
}
.ba-r-step {
  padding: 28px 32px 28px 48px;
  border-right: 1px solid rgba(255,255,255,0.06);
  position: relative;
}
.ba-r-step:first-child { padding-left: 48px; }
.ba-r-step:last-child { border-right: none; }
.ba-r-num {
  font-family: var(--sr); font-size: 36px; font-weight: 300;
  color: rgba(255,255,255,0.08); line-height: 1;
  margin-bottom: 12px; display: block;
}
.ba-r-title { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.75); margin-bottom: 4px; }
.ba-r-desc { font-size: 10.5px; color: rgba(255,255,255,0.3); line-height: 1.5; }

/* ── SPECS ────────────────────────────────────── */
.ba-specs {
  background: var(--bk);
  border-top: 1px solid rgba(255,255,255,0.06);
  display: grid;
  grid-template-columns: 280px 1fr;
}
.ba-specs-head {
  padding: 48px 40px 48px 48px;
  border-right: 1px solid rgba(255,255,255,0.06);
  display: flex; flex-direction: column; justify-content: flex-start;
}
.ba-specs-title {
  font-family: var(--sr); font-size: 36px; font-weight: 300;
  color: #fff; line-height: 1; margin-bottom: 10px;
}
.ba-specs-note { font-size: 10px; color: rgba(255,255,255,0.2); line-height: 1.5; }
.ba-specs-body { padding: 48px 48px 48px 40px; }
.ba-specs-table {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}
.ba-spec {
  display: flex; align-items: baseline; gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.ba-spec:nth-child(odd) { padding-right: 32px; }
.ba-spec:nth-child(even) { padding-left: 32px; border-left: 1px solid rgba(255,255,255,0.05); }
.ba-spec:nth-last-child(-n+2) { border-bottom: none; }
.ba-spec-key {
  font-size: 9px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(255,255,255,0.2);
  flex-shrink: 0; min-width: 100px;
}
.ba-spec-val { font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.7); }

/* ── MOBILE ───────────────────────────────────── */
@media (max-width: 900px) {
  .ba-hero { height: 105vw; min-height: 0; max-height: 580px; }
  .ba-hero-img { object-position: center top; }
  .ba-hero-title { font-size: 18px; letter-spacing: 0; line-height: 1.1; }
  .ba-hero-title em { font-size: 16px; }
  .ba-hero-title br { display: none; }
  .ba-hero-arrow { display: none; }
  .ba-hero-desc { display: block; font-size: 10px; max-height: 52px; max-width: 100%; margin-top: 4px; }
  .ba-hero-overlay {
    top: 0; left: 0; right: 0; bottom: 0;
    padding: 20px 16px;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    background: linear-gradient(to bottom, rgba(32,32,9,0.5) 0%, transparent 45%, rgba(32,32,9,0.3) 100%);
  }
  .ba-hero-left { display: flex; flex-direction: column; justify-content: flex-start; }
  .ba-hero-text { margin-top: auto; }
  .ba-hero-scroll { display: none; }
  .ba-hero-scroll-group { display: none; }
  .ba-film-promo { padding: 10px 14px; gap: 10px; align-items: flex-start; }
  .ba-film-promo-icon { display: none; }
  .ba-film-promo-text { flex: 1; }
  .ba-film-promo-title { font-size: 11px; }
  .ba-film-promo-sub { font-size: 9px; }
  .ba-film-promo-status { display: block; width: 100%; text-align: left; font-size: 9px; letter-spacing: 0.08em; margin-top: 4px; flex: none; }
  .ba-film-promo { flex-wrap: wrap; }
  .ba-kit { grid-template-columns: 1fr; grid-template-rows: auto; padding: 32px 20px; gap: 20px; overflow: hidden; max-width: 100%; }
  .ba-kit-heading-block { grid-column: 1; grid-row: 1; }
  .ba-kit-banner-slot   { grid-column: 1; grid-row: 2; }
  .ba-kit-left          { grid-column: 1; grid-row: 3; max-width: 100%; overflow: hidden; }
  .ba-kit-right         { grid-column: 1; grid-row: 4; position: static; max-width: 100%; overflow: hidden; }
  .ba-columns { grid-template-columns: 1fr; max-width: 100%; }
  .ba-col, .ba-col-body, .ba-mini-card, .ba-film-promo { max-width: 100%; }
  .ba-shot-head { padding: 36px 20px 16px; flex-direction: column; gap: 4px; }
  .ba-shot-title { font-size: 28px; }
  .ba-shot-grid { grid-template-columns: repeat(3, 1fr); }
  .ba-restore-top { grid-template-columns: 1fr; gap: 24px; padding: 32px 20px 24px; }
  .ba-restore-stats { grid-template-columns: repeat(3, 1fr); }
  .ba-restore-title { font-size: 28px; }
  .ba-restore-steps { grid-template-columns: 1fr 1fr; }
  .ba-r-step { padding: 20px 16px; }
  .ba-r-num { font-size: 24px; }
  .ba-specs { grid-template-columns: 1fr; }
  .ba-specs-head { padding: 24px 20px 16px; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .ba-specs-body { padding: 16px 20px 24px; }
  .ba-specs-table { grid-template-columns: 1fr; }
  .ba-spec { padding: 10px 0; }
  .ba-spec:nth-child(odd) { padding-right: 0; }
  .ba-spec:nth-child(even) { padding-left: 0; border-left: none; }
  .ba-spec:nth-last-child(-n+2) { border-bottom: 1px solid rgba(255,255,255,0.05); }
  .ba-spec:last-child { border-bottom: none; }
  .ba-specs-title { font-size: 24px; }
}
</style>

<div class="bfc-a">

    <div class="ba-hero" id="ba-top">
      {%- comment -%} Manual slides from section settings {%- endcomment -%}
      {%- assign slide_images = '' -%}
      {%- for i in (1..5) -%}
        {%- assign img_key = 'slide_' | append: i -%}
        {%- assign img_val = section.settings[img_key] -%}
        {%- if img_val != blank -%}
          {%- assign slide_images = slide_images | append: '1' -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign total_slides = slide_images | size -%}

      <div class="ba-hero-slides" id="ba-slides">
        {%- for i in (1..5) -%}
          {%- assign img_key = 'slide_' | append: i -%}
          {%- assign img_mob_key = 'slide_' | append: i | append: '_mobile' -%}
          {%- assign img_val = section.settings[img_key] -%}
          {%- assign img_mob = section.settings[img_mob_key] -%}
          {%- if img_val != blank -%}
            <div class="ba-hero-slide">
              <picture>
                {%- if img_mob != blank -%}
                  <source media="(max-width: 767px)" srcset="{{ img_mob | image_url: width: 900 }}"/>
                {%- endif -%}
                <img
                  class="ba-hero-img"
                  src="{{ img_val | image_url: width: 1800 }}"
                  alt="{{ product.title | escape }}"
                  {%- if i == 1 -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
                />
              </picture>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- comment -%} Arrows — only render if more than 1 image {%- endcomment -%}
      {%- if total_slides > 1 -%}
        <button class="ba-hero-arrow is-prev" onclick="baSlide(-1)" aria-label="Previous image">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8L10 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
        </button>
        <button class="ba-hero-arrow is-next" onclick="baSlide(1)" aria-label="Next image">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3L11 8L6 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
        </button>
        <div class="ba-hero-dots" id="ba-dots">
          {%- for i in (1..total_slides) -%}
            <button class="ba-hero-dot{% if forloop.first %} is-active{% endif %}" onclick="baGoTo({{ forloop.index0 }})" aria-label="Slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="ba-hero-overlay">
        <div class="ba-hero-left">
          <div class="ba-hero-top">
            <span class="ba-hero-eyebrow">{{ product.type | default: '35mm SLR' }} &mdash; Professionally Restored</span>
            <h1 class="ba-hero-title">
              {{ product.title | split: ' ' | first }}<br/>
              <em>{{ product.title | split: ' ' | slice: 1, 10 | join: ' ' }}</em>
            </h1>
          </div>
          <div class="ba-hero-text">
            <p class="ba-hero-desc">{{ product.description | strip_html }}</p>
          </div>
        </div>
        <div class="ba-hero-scroll-group">
          <div class="ba-hero-scroll" onclick="document.getElementById('ba-kit').scrollIntoView({behavior:'smooth'})">
            Build your kit
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3v10M3 8l5 5 5-5" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
          </div>
          <div class="ba-hero-scroll" onclick="document.getElementById('ba-restore').scrollIntoView({behavior:'smooth'})">
            More info
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3v10M3 8l5 5 5-5" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg>
          </div>
        </div>
      </div>
    </div>

    <div class="ba-kit" id="ba-kit">
      {%- comment -%} Row 1 left: heading {%- endcomment -%}
      <div class="ba-kit-heading-block">
        <span class="ba-kit-eyebrow">Build Your Kit</span>
        <h2 class="ba-kit-heading">Ready to shoot.<br/><em>Here's what you need.</em></h2>
        <p class="ba-kit-sub">Select what you want to bundle. Discounts apply automatically &mdash; and your first developing roll is on us.</p>
      </div>

      {%- comment -%} Row 1 right: starter banner (or empty) {%- endcomment -%}
      <div class="ba-kit-banner-slot">
        {%- assign has_starter = false -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.is_starter_kit and block.settings.product != blank -%}
            {%- assign has_starter = true -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if has_starter -%}
          <div class="ba-film-promo" style="background: linear-gradient(135deg, #3a1a05 0%, #5a2e0a 100%); border: none; margin-top: 0;">
            <div class="ba-film-promo-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L11 7H16.5L12.2 10.5L13.9 16L9 12.5L4.1 16L5.8 10.5L1.5 7H7L9 2Z" stroke="#F4A027" stroke-width="1.5" stroke-linejoin="round"/></svg>
            </div>
            <div class="ba-film-promo-text">
              <div class="ba-film-promo-title">We put together a starter kit for you</div>
              <div class="ba-film-promo-sub">Our favourite add-ons, pre-selected with discounts.</div>
            </div>
            <button onclick="baClearAll()" class="ba-film-promo-status" style="background:none;border:none;cursor:pointer;font-family:var(--sn);text-align:right;">Clear</button>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Row 2 left: columns {%- endcomment -%}
      <div class="ba-kit-left">

      {%- comment -%} Collect unique column names in order {%- endcomment -%}
      {%- assign col_names = '' -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'kit_item' and block.settings.product != blank -%}
          {%- assign col = block.settings.column | default: block.settings.label -%}
          {%- unless col_names contains col -%}
            {%- if col_names == '' -%}
              {%- assign col_names = col -%}
            {%- else -%}
              {%- assign col_names = col_names | append: '||' | append: col -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}

      {%- assign col_name_arr = col_names | split: '||' -%}

      <div class="ba-columns">
        {%- for col_name in col_name_arr -%}
          <div class="ba-col is-open" id="ba-col-{{ forloop.index }}">
            <div class="ba-col-head" onclick="baToggleCol(this.closest('.ba-col'))">
              <div class="ba-col-title">
                {{ col_name }}
                <span class="ba-col-count" id="ba-col-count-{{ forloop.index }}">0</span>
              </div>
              <svg class="ba-col-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </div>
            <div class="ba-col-body">
            {%- assign col_item_index = 0 -%}
            {%- assign col_item_total = 0 -%}
            {%- comment -%} Count total items in this column {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'kit_item' and block.settings.product != blank -%}
                {%- assign block_col = block.settings.column | default: block.settings.label -%}
                {%- if block_col == col_name -%}
                  {%- assign col_item_total = col_item_total | plus: 1 -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- for block in section.blocks -%}
              {%- if block.type != 'kit_item' -%}{% continue %}{%- endif -%}
              {%- assign bp = block.settings.product -%}
              {%- if bp == blank -%}{% continue %}{%- endif -%}
              {%- assign block_col = block.settings.column | default: block.settings.label -%}
              {%- unless block_col == col_name -%}{% continue %}{%- endunless -%}
              {%- assign col_item_index = col_item_index | plus: 1 -%}

              {%- liquid
                assign is_dev       = block.settings.is_developing
                assign disc         = block.settings.discount_percent
                assign specific_vid = block.settings.variant_id | strip
                assign cat_id       = 'ba-cat-' | append: forloop.index
                assign show_variants = false
                if bp.variants.size > 1 and specific_vid == blank
                  assign show_variants = true
                endif
                assign display_variant = bp.variants.first
              -%}
              {%- unless specific_vid == blank -%}
                {%- for v in bp.variants -%}
                  {%- assign vid_str = v.id | append: '' -%}
                  {%- if vid_str == specific_vid -%}{%- assign display_variant = v -%}{%- endif -%}
                {%- endfor -%}
              {%- endunless -%}
              {%- liquid
                assign orig_cents = display_variant.price
                if is_dev
                  assign sale_cents = 0
                elsif disc > 0
                  assign disc_float = disc | times: 1.0 | divided_by: 100
                  assign save_cents = orig_cents | times: disc_float | floor
                  assign sale_cents = orig_cents | minus: save_cents
                else
                  assign sale_cents = orig_cents
                endif
              -%}
              {%- comment -%} Popup images {%- endcomment -%}
              {%- assign popup_imgs = '' -%}
              {%- for media in bp.media limit: 6 -%}
                {%- if media.media_type == 'image' -%}
                  {%- assign img_url = media | image_url: width: 600 -%}
                  {%- if popup_imgs == '' -%}
                    {%- assign popup_imgs = img_url -%}
                  {%- else -%}
                    {%- assign popup_imgs = popup_imgs | append: '||' | append: img_url -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              <div
                class="ba-mini-card{% if col_item_index > 2 %} is-hidden{% endif %}"
                id="{{ cat_id }}"
                data-variant-id="{{ display_variant.id }}"
                data-product-title="{{ bp.title | escape }}"
                data-orig="{{ orig_cents }}"
                data-sale="{{ sale_cents }}"
                data-is-dev="{{ is_dev }}"
                data-disc="{{ disc }}"
                data-cat="{{ cat_id }}"
                data-col-id="ba-col-{{ forloop.parentloop.index }}"
                data-col-name="{{ col_name | escape }}"
                data-starter="{{ block.settings.is_starter_kit }}"
                onclick="baMiniSelect(this, event)"
                {{ block.shopify_attributes }}
              >
                <div class="ba-mini-img-wrap">
                  {%- if bp.featured_image -%}
                    <img class="ba-mini-img" src="{{ bp.featured_image | image_url: width: 120 }}" alt="{{ bp.title | escape }}" loading="lazy"/>
                  {%- else -%}
                    <div class="ba-mini-img-ph"></div>
                  {%- endif -%}
                  <button
                    class="ba-mini-info-icon"
                    onclick="event.stopPropagation(); baOpenPopup('{{ cat_id }}')"
                    title="View details"
                    aria-label="View product details"
                  ><svg width="11" height="11" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><line x1="7" y1="6.5" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="7" cy="4" r="0.7" fill="currentColor"/></svg></button>
                </div>
                <div class="ba-mini-body">
                  <div class="ba-mini-info">
                    <div class="ba-mini-name">{{ bp.title }}</div>
                  </div>
                  <div class="ba-mini-right">
                    {%- if is_dev or disc > 0 -%}
                      <span class="ba-mini-orig">{{ orig_cents | money }}</span>
                    {%- endif -%}
                    {%- if is_dev -%}
                      <span class="ba-mini-price is-free">Free</span>
                    {%- else -%}
                      <span class="ba-mini-price">{{ sale_cents | money }}</span>
                    {%- endif -%}
                  </div>
                </div>

                {%- if show_variants -%}
                  <div class="ba-mini-vars" onclick="event.stopPropagation()">
                    {%- for variant in bp.variants -%}
                      {%- if variant.available -%}
                        {%- liquid
                          assign v_orig = variant.price
                          if is_dev
                            assign v_sale = 0
                          elsif disc > 0
                            assign v_df = disc | times: 1.0 | divided_by: 100
                            assign v_sv = v_orig | times: v_df | floor
                            assign v_sale = v_orig | minus: v_sv
                          else
                            assign v_sale = v_orig
                          endif
                        -%}
                        <button
                          class="ba-mini-var-btn{% if forloop.first %} is-sel{% endif %}"
                          data-variant-id="{{ variant.id }}"
                          data-product-title="{{ bp.title | escape }}"
                          data-orig="{{ variant.price }}"
                          data-sale="{{ v_sale }}"
                          data-is-dev="{{ is_dev }}"
                          data-disc="{{ disc }}"
                          data-cat="{{ cat_id }}"
                          onclick="baMiniSelectVar(this)"
                        >{{ variant.title }} &ndash; {%- if is_dev -%}Free{%- else -%}{{ v_sale | money }}{%- endif -%}</button>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>

              {%- comment -%} Popup data {%- endcomment -%}
              <div
                id="ba-popup-data-{{ cat_id }}"
                style="display:none"
                data-title="{{ bp.title | escape }}"
                data-desc="{{ bp.description | strip_html | escape }}"
                data-imgs="{{ popup_imgs | escape }}"
              ></div>

            {%- endfor -%}
            {%- if col_item_total > 2 -%}
              <button class="ba-col-more" onclick="event.stopPropagation(); baExpandCol(this.closest('.ba-col'))">
                <span class="ba-col-more-text">{{ col_item_total | minus: 2 }} more &rsaquo;</span>
              </button>
            {%- endif -%}
          </div>{%- comment -%} /ba-col-body {%- endcomment -%}
          </div>{%- comment -%} /ba-col {%- endcomment -%}
        {%- endfor -%}
      </div>{%- comment -%} /ba-columns {%- endcomment -%}

      {%- comment -%} ── 2-ROLL PROMO BANNER ── {%- endcomment -%}
      <div class="ba-film-promo" id="ba-film-promo">
        <div class="ba-film-promo-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="1" y="1" width="16" height="16" rx="1" stroke="#ABCC99" stroke-width="1.5"/><circle cx="9" cy="9" r="3" stroke="#ABCC99" stroke-width="1.5"/><line x1="1" y1="5" x2="17" y2="5" stroke="#ABCC99" stroke-width="1"/><line x1="1" y1="13" x2="17" y2="13" stroke="#ABCC99" stroke-width="1"/></svg>
        </div>
        <div class="ba-film-promo-text">
          <div class="ba-film-promo-title">Add 2 rolls of film — get a free developing credit</div>
          <div class="ba-film-promo-sub">Select any 2 film rolls above and we'll include a standard C-41 developing credit with your order.</div>
        </div>
        <div class="ba-film-promo-status" id="ba-promo-status">0 of 2 rolls selected</div>
      </div>{%- comment -%} /ba-film-promo {%- endcomment -%}

      </div>{%- comment -%} /ba-kit-left {%- endcomment -%}

      {%- comment -%} Row 2 right: checkout card {%- endcomment -%}
      <div class="ba-kit-right">
        <div class="ba-kit-card">

        <div class="ba-kp-cam">
          <div class="ba-kp-cam-row">
            <div class="ba-kp-cam-img">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title | escape }}"/>
              {%- endif -%}
            </div>
            <div>
              <div class="ba-kp-cam-name">{{ product.title }}</div>
              <div class="ba-kp-cam-sub">CLA'd &middot; 6-month warranty</div>
            </div>
          </div>
          {%- if product.variants.size > 1 -%}
            <div class="ba-kp-variants">
              {%- for variant in product.variants -%}
                <button
                  class="ba-var-btn{% if variant.id == current_variant.id %} is-active{% endif %}"
                  data-variant-id="{{ variant.id }}"
                  data-variant-price="{{ variant.price }}"
                  data-variant-price-fmt="{{ variant.price | money }}"
                  data-variant-available="{{ variant.available }}"
                  onclick="baSelectVariant(this)"
                  {%- unless variant.available -%}disabled{%- endunless -%}
                >{{ variant.title }}</button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="ba-kp-items" id="ba-kp-items">
          <span class="ba-kp-section-label">Your Kit</span>
          <div class="ba-kp-cam-line">
            <span class="ba-kp-cam-line-name" id="ba-kp-cam-name">{{ product.title }}</span>
            <span class="ba-kp-cam-line-price" id="ba-kp-cam-price">{{ current_variant.price | money }}</span>
          </div>
          <div id="ba-kp-lines">
            <span class="ba-kp-empty">No add-ons yet &mdash; select items on the left</span>
          </div>
        </div>

        <div class="ba-kp-foot">
          <div class="ba-kp-total-row">
            <span class="ba-kp-total-label">Total</span>
            <span class="ba-kp-total-price" id="ba-total">{{ current_variant.price | money }}</span>
          </div>
          <div class="ba-kp-savings" id="ba-savings"></div>
          <button class="ba-atc" id="ba-atc" onclick="baAddToCart()">
            <span id="ba-atc-text">Add Kit to Cart</span>
          </button>
          <button class="ba-cam-only" onclick="baCameraOnly()">Camera Only</button>
        </div>

        </div>{%- comment -%} /ba-kit-card {%- endcomment -%}

      </div>

    </div>{%- comment -%} /ba-kit {%- endcomment -%}

    {%- comment -%} ── SHOT ON ── {%- endcomment -%}
    {%- if g1 or g2 or g3 -%}
    <div class="ba-shot">
      <div class="ba-shot-head">
        <h2 class="ba-shot-title">Shot on {{ product.title }}</h2>
        <span class="ba-shot-sub">All Photos Taken on {{ product.title }}</span>
      </div>
      <div class="ba-shot-grid">
        {%- if g1 -%}<a href="{{ g1 | image_url: width: 1200 }}" target="_blank"><img src="{{ g1 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
        {%- if g2 -%}<a href="{{ g2 | image_url: width: 1200 }}" target="_blank"><img src="{{ g2 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
        {%- if g3 -%}<a href="{{ g3 | image_url: width: 1200 }}" target="_blank"><img src="{{ g3 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
        {%- if g4 -%}<a href="{{ g4 | image_url: width: 1200 }}" target="_blank"><img src="{{ g4 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
        {%- if g5 -%}<a href="{{ g5 | image_url: width: 1200 }}" target="_blank"><img src="{{ g5 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
        {%- if g6 -%}<a href="{{ g6 | image_url: width: 1200 }}" target="_blank"><img src="{{ g6 | image_url: width: 600 }}" alt="" loading="lazy"/></a>{%- endif -%}
      </div>
    </div>
    {%- endif -%}

    {%- comment -%} ── RESTORATION ── {%- endcomment -%}
    <div class="ba-restore" id="ba-restore">
      <div class="ba-restore-top">
        <div class="ba-restore-headline">
          <span class="ba-restore-ey">Our Process</span>
          <h2 class="ba-restore-title">Every camera<br/><em>hand-restored</em></h2>
        </div>
        <div class="ba-restore-stats">
          <div class="ba-r-stat">
            <div class="ba-r-stat-num">6<span>mo</span></div>
            <div class="ba-r-stat-label">Warranty on every camera sold</div>
          </div>
          <div class="ba-r-stat">
            <div class="ba-r-stat-num">5K<span>+</span></div>
            <div class="ba-r-stat-label">Cameras restored since 2018</div>
          </div>
          <div class="ba-r-stat">
            <div class="ba-r-stat-num">4.9<span>★</span></div>
            <div class="ba-r-stat-label">Average customer rating</div>
          </div>
        </div>
      </div>
      <div class="ba-restore-steps">
        <div class="ba-r-step">
          <span class="ba-r-num">01</span>
          <div class="ba-r-title">Mechanical Inspection</div>
          <div class="ba-r-desc">Shutter, film advance, rewind — every function tested</div>
        </div>
        <div class="ba-r-step">
          <span class="ba-r-num">02</span>
          <div class="ba-r-title">Light Seal Replacement</div>
          <div class="ba-r-desc">Fresh seals on every camera, no exceptions</div>
        </div>
        <div class="ba-r-step">
          <span class="ba-r-num">03</span>
          <div class="ba-r-title">Lens CLA</div>
          <div class="ba-r-desc">Clean, lubricate and adjust for sharp, accurate shots</div>
        </div>
        <div class="ba-r-step">
          <span class="ba-r-num">04</span>
          <div class="ba-r-title">Final QC</div>
          <div class="ba-r-desc">Tested with professional equipment before it ships</div>
        </div>
      </div>
    </div>

    {%- comment -%} ── SPECS ── {%- endcomment -%}
    <div class="ba-specs">
      <div class="ba-specs-head">
        <h2 class="ba-specs-title">Specs</h2>
        <div class="ba-specs-note">{{ product.title }}<br/>{{ product.type }}</div>
      </div>
      <div class="ba-specs-body">
        <div class="ba-specs-table">
          {%- if spec_mount   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Lens Mount</span><span class="ba-spec-val">{{ spec_mount }}</span></div>{%- endif -%}
          {%- if spec_shutter != blank -%}<div class="ba-spec"><span class="ba-spec-key">Shutter</span><span class="ba-spec-val">{{ spec_shutter }}</span></div>{%- endif -%}
          {%- if spec_lens    != blank -%}<div class="ba-spec"><span class="ba-spec-key">Lens</span><span class="ba-spec-val">{{ spec_lens }}</span></div>{%- endif -%}
          {%- if spec_meter   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Metering</span><span class="ba-spec-val">{{ spec_meter }}</span></div>{%- endif -%}
          {%- if spec_battery != blank -%}<div class="ba-spec"><span class="ba-spec-key">Battery</span><span class="ba-spec-val">{{ spec_battery }}</span></div>{%- endif -%}
          {%- if spec_flash   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Flash</span><span class="ba-spec-val">{{ spec_flash }}</span></div>{%- endif -%}
          {%- if spec_focus   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Focus</span><span class="ba-spec-val">{{ spec_focus }}</span></div>{%- endif -%}
          {%- if spec_timer   != blank -%}<div class="ba-spec"><span class="ba-spec-key">Self Timer</span><span class="ba-spec-val">{{ spec_timer }}</span></div>{%- endif -%}
          {%- if spec_tripod  != blank -%}<div class="ba-spec"><span class="ba-spec-key">Tripod</span><span class="ba-spec-val">{{ spec_tripod }}</span></div>{%- endif -%}
          {%- if spec_expcomp != blank -%}<div class="ba-spec"><span class="ba-spec-key">Exp. Comp.</span><span class="ba-spec-val">{{ spec_expcomp }}</span></div>{%- endif -%}
          {%- if spec_dx      != blank -%}<div class="ba-spec"><span class="ba-spec-key">DX Reader</span><span class="ba-spec-val">{{ spec_dx }}</span></div>{%- endif -%}
          <div class="ba-spec"><span class="ba-spec-key">Condition</span><span class="ba-spec-val">A &amp; B Grade &mdash; CLA'd</span></div>
        </div>
      </div>
    </div>


{%- comment -%} Product info popup {%- endcomment -%}
<div class="ba-popup-overlay" id="ba-popup-overlay" onclick="baClosePopup()">
  <div class="ba-popup" onclick="event.stopPropagation()">
    <div class="ba-popup-head">
      <span class="ba-popup-title" id="ba-popup-title"></span>
      <button class="ba-popup-close" onclick="baClosePopup()">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 3L13 13M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
      </button>
    </div>
    <div class="ba-popup-body">
      <div class="ba-popup-imgs" id="ba-popup-imgs"></div>
      <div class="ba-popup-desc" id="ba-popup-desc"></div>
    </div>
  </div>
</div>

{%- comment -%} Hidden product-form for cart drawer {%- endcomment -%}
{%- assign ba_form_id = 'ba-product-form-' | append: section.id -%}
<div style="display:none">
  <product-form class="product-form" data-hide-errors="false" data-section-id="{{ section.id }}">
    {%- form 'product', product, id: ba_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id" id="ba-variant-input"/>
      <div class="product-form__buttons" data-display-quantity="false" data-display-layout="seperate" data-display-dynamics="false">
        <button id="ProductSubmitButton-{{ section.id }}" type="submit" name="add" class="product-form__submit button button--filled">
          <span>Add to Cart</span>
          <div class="loading__spinner hidden">
            <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66"><circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
          </div>
        </button>
      </div>
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <span class="product-form__error-message"></span>
      </div>
    {%- endform -%}
  </product-form>
</div>

</div>{%- comment -%} .bfc-a {%- endcomment -%}

<script>
(function() {
  'use strict';

  var STATE = {
    variantId:    {{ current_variant.id }},
    variantPrice: {{ current_variant.price }},
    kit: {}
  };

  window.baClearAll = function() {
    document.querySelectorAll('.ba-mini-card.is-sel').forEach(function(card) {
      baMiniSelect(card, { stopPropagation: function(){} });
    });
  };

  // ── Accordion ───────────────────────────────────
  window.baToggleCol = function(col) {
    var isMobile = window.innerWidth <= 900;
    if (isMobile) {
      col.classList.toggle('is-open');
    } else {
      var isOpen = col.classList.contains('is-open');
      document.querySelectorAll('.ba-col').forEach(function(c) {
        c.classList.toggle('is-open', !isOpen);
      });
    }
  };

  window.baExpandCol = function(col) {
    col.classList.toggle('is-expanded');
    var btn = col.querySelector('.ba-col-more-text');
    if (!btn) return;
    var hidden = col.querySelectorAll('.ba-mini-card.is-hidden').length;
    if (col.classList.contains('is-expanded')) {
      btn.textContent = 'Show less \u2039';
    } else {
      btn.textContent = hidden + ' more \u203a';
    }
  };

  window.baSelectVariant = function(btn) {
    if (btn.dataset.variantAvailable === 'false') return;
    document.querySelectorAll('.ba-var-btn').forEach(function(b) { b.classList.remove('is-active'); });
    btn.classList.add('is-active');
    STATE.variantId    = parseInt(btn.dataset.variantId, 10);
    STATE.variantPrice = parseInt(btn.dataset.variantPrice, 10);
    var inp = document.getElementById('ba-variant-input');
    if (inp) inp.value = STATE.variantId;
    var camPrice = document.getElementById('ba-kp-cam-price');
    if (camPrice) camPrice.textContent = btn.dataset.variantPriceFmt;
    baRender();
  };

  window.baMiniSelect = function(card, e) {
    var catId = card.dataset.cat;
    var wasSelected = card.classList.contains('is-sel');
    // Only one card per cat can be selected (each cat has 1 card in column layout)
    document.querySelectorAll('[data-cat="' + catId + '"].ba-mini-card').forEach(function(c) {
      c.classList.remove('is-sel');
    });
    if (wasSelected) {
      delete STATE.kit[catId];
    } else {
      card.classList.add('is-sel');
      var isFilm = (card.dataset.colName || '').toLowerCase().indexOf('film') >= 0 && card.dataset.isDev !== 'true';
      var imgEl = card.querySelector('.ba-mini-img');
      STATE.kit[catId] = {
        variantId: card.dataset.variantId,
        name:      card.dataset.productTitle,
        orig:      parseInt(card.dataset.orig, 10),
        sale:      parseInt(card.dataset.sale, 10),
        isDev:     card.dataset.isDev === 'true',
        disc:      parseInt(card.dataset.disc, 10),
        isFilm:    isFilm,
        colId:     card.dataset.colId,
        img:       imgEl ? imgEl.src : null
      };
    }
    baUpdateColCounts();
    baRender();
  };

  window.baMiniSelectVar = function(btn) {
    var catId = btn.dataset.cat;
    var card  = document.getElementById(catId);
    card.querySelectorAll('.ba-mini-var-btn').forEach(function(b) { b.classList.remove('is-sel'); });
    btn.classList.add('is-sel');
    card.dataset.variantId    = btn.dataset.variantId;
    card.dataset.productTitle = btn.dataset.productTitle;
    card.dataset.orig         = btn.dataset.orig;
    card.dataset.sale         = btn.dataset.sale;
    if (card.classList.contains('is-sel')) {
      STATE.kit[catId].variantId = btn.dataset.variantId;
      STATE.kit[catId].name      = btn.dataset.productTitle;
      STATE.kit[catId].orig      = parseInt(btn.dataset.orig, 10);
      STATE.kit[catId].sale      = parseInt(btn.dataset.sale, 10);
      baRender();
    }
  };

  function baUpdateColCounts() {
    // Count selections per column
    var counts = {};
    Object.values(STATE.kit).forEach(function(sel) {
      if (sel.colId) counts[sel.colId] = (counts[sel.colId] || 0) + 1;
    });
    document.querySelectorAll('.ba-col-count').forEach(function(el) {
      var colEl = el.closest('.ba-col');
      if (!colEl) return;
      var n = counts[colEl.id] || 0;
      el.textContent = n;
      el.classList.toggle('is-visible', n > 0);
    });
  }

  window.baSelect = window.baMiniSelect;

  function baRender() {
    var linesEl   = document.getElementById('ba-kp-lines');
    var totalEl   = document.getElementById('ba-total');
    var savingsEl = document.getElementById('ba-savings');
    var total = STATE.variantPrice, savings = 0, html = '';
    var filmCount = 0;

    Object.entries(STATE.kit).forEach(function(entry) {
      var catId = entry[0], sel = entry[1];
      total   += sel.sale;
      savings += sel.orig - sel.sale;
      if (sel.isFilm) filmCount++;
      var priceStr = sel.isDev ? '<span class="ba-kp-line-price is-free">Free</span>'
                               : '<span class="ba-kp-line-price">' + fmt(sel.sale) + '</span>';
      html += '<div class="ba-kp-line">'
            + (sel.img ? '<img class="ba-kp-line-img" src="' + sel.img + '" loading="lazy"/>' : '<div class="ba-kp-line-img"></div>')
            + '<span class="ba-kp-line-name">' + esc(sel.name) + '</span>'
            + priceStr
            + '<button class="ba-kp-line-remove" onclick="baRemoveItem(\'' + catId + '\')" title="Remove">&times;</button>'
            + '</div>';
    });

    linesEl.innerHTML = html || '<span class="ba-kp-empty">No add-ons yet &mdash; select items on the left</span>';
    totalEl.textContent   = fmt(total);
    savingsEl.textContent = savings > 0 ? 'You save ' + fmt(savings) : '';

    var promoEl = document.getElementById('ba-promo-status');
    if (promoEl) {
      if (filmCount >= 2) {
        promoEl.textContent = '✓ Free developing unlocked!';
        promoEl.style.color = '#ABCC99';
      } else {
        promoEl.textContent = filmCount + ' of 2 rolls selected';
        promoEl.style.color = '';
      }
    }
  }

  window.baRemoveItem = function(catId) {
    var card = document.getElementById(catId);
    if (card) card.classList.remove('is-sel');
    delete STATE.kit[catId];
    baUpdateColCounts();
    baRender();
  };

  window.baAddToCart = async function() {
    var btn    = document.getElementById('ba-atc');
    var textEl = document.getElementById('ba-atc-text');
    btn.disabled = true;
    textEl.textContent = 'Adding\u2026';
    var items = [];
    var filmCount = 0;
    Object.values(STATE.kit).forEach(function(sel) {
      if (sel.isFilm) filmCount++;
      var props = { _kit_bundle: 'true' };
      if (sel.isDev) {
        props._free_developing      = 'true';
        props._bundle_discount_type = 'free_developing';
      } else if (sel.disc > 0) {
        props._bundle_discount_pct  = String(sel.disc);
        props._bundle_discount_type = 'kit_bundle';
      }
      items.push({ id: parseInt(sel.variantId, 10), quantity: 1, properties: props });
    });
    // Auto-add free developing credit when 2+ film rolls selected
    console.log('[BFC Kit] filmCount:', filmCount, 'items:', STATE.kit);
    try {
      // First set cart attributes so Flow can read them on the order
      var cartAttrs = {
        attributes: {
          '_kit_bundle': 'true',
          '_kit_camera': '{{ product.title | escape }}'
        }
      };
      if (filmCount >= 2) {
        cartAttrs.attributes['_free_developing_credit'] = 'true';
      }
      await fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(cartAttrs)
      });

      // Add kit add-ons (not the camera — that goes via the form)
      if (items.length > 0) {
        var res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ items: items })
        });
        if (!res.ok) throw new Error(res.status);
      }
      // Camera added via hidden product form (opens cart drawer)
      var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
      if (submitBtn) submitBtn.click();
      btn.classList.add('is-success');
      textEl.textContent = 'Added!';
      setTimeout(function() { btn.classList.remove('is-success'); btn.disabled = false; textEl.textContent = 'Add Kit to Cart'; }, 2400);
    } catch(e) {
      console.error('[BA]', e);
      btn.disabled = false;
      textEl.textContent = 'Add Kit to Cart';
    }
  };

  window.baCameraOnly = function() {
    var submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
    if (submitBtn) submitBtn.click();
  };

  // ── Product info popup ──────────────────────────
  window.baOpenPopup = function(catId) {
    var data = document.getElementById('ba-popup-data-' + catId);
    if (!data) return;
    document.getElementById('ba-popup-title').textContent = data.dataset.title;
    var desc = data.dataset.desc;
    document.getElementById('ba-popup-desc').innerHTML = desc
      ? '<p>' + desc.replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br/>') + '</p>'
      : '';
    var imgs = data.dataset.imgs ? data.dataset.imgs.split('||') : [];
    document.getElementById('ba-popup-imgs').innerHTML = imgs
      .map(function(src) { return '<img src="' + src + '" loading="lazy"/>'; })
      .join('');
    document.getElementById('ba-popup-overlay').classList.add('is-open');
    document.body.style.overflow = 'hidden';
  };
  window.baClosePopup = function() {
    document.getElementById('ba-popup-overlay').classList.remove('is-open');
    document.body.style.overflow = '';
  };
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') baClosePopup();
  });

  // ── Hero slider ─────────────────────────────────
  var baCurrentSlide = 0;
  var baTotalSlides  = document.querySelectorAll('.ba-hero-slide').length;

  window.baSlide = function(dir) {
    baGoTo((baCurrentSlide + dir + baTotalSlides) % baTotalSlides);
  };
  window.baGoTo = function(idx) {
    baCurrentSlide = idx;
    var slides = document.getElementById('ba-slides');
    if (slides) slides.style.transform = 'translateX(-' + (idx * 100) + '%)';
    document.querySelectorAll('.ba-hero-dot').forEach(function(d, i) {
      d.classList.toggle('is-active', i === idx);
    });
    var prev = document.querySelector('.ba-hero-arrow.is-prev');
    if (prev) prev.style.visibility = idx === 0 ? 'hidden' : 'visible';
  };
  (function() {
    var hero = document.getElementById('ba-top');
    if (!hero || baTotalSlides <= 1) return;
    var startX = 0;
    hero.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
    hero.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) baSlide(dx < 0 ? 1 : -1);
    });
  })();

  function fmt(cents) { return '$' + (cents / 100).toFixed(2).replace(/\.00$/, ''); }
  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // On mobile, collapse all columns by default
  if (window.innerWidth <= 900) {
    document.querySelectorAll('.ba-col').forEach(function(c) {
      c.classList.remove('is-open');
    });
  }

  // Auto-select starter kit items on load
  document.querySelectorAll('.ba-mini-card[data-starter="true"]').forEach(function(card) {
    if (!card.classList.contains('is-sel')) {
      baMiniSelect(card, { stopPropagation: function(){} });
    }
  });

  baRender();
})();
</script>

{% schema %}
{
  "name": "BFC Kit Page",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "slide_1", "label": "Hero slide 1" },
    { "type": "image_picker", "id": "slide_2", "label": "Hero slide 2" },
    { "type": "image_picker", "id": "slide_3", "label": "Hero slide 3" },
    { "type": "image_picker", "id": "slide_4", "label": "Hero slide 4" },
    { "type": "image_picker", "id": "slide_5", "label": "Hero slide 5" },
    { "type": "header", "content": "Mobile slides (optional)" },
    { "type": "image_picker", "id": "slide_1_mobile", "label": "Mobile slide 1" },
    { "type": "image_picker", "id": "slide_2_mobile", "label": "Mobile slide 2" },
    { "type": "image_picker", "id": "slide_3_mobile", "label": "Mobile slide 3" },
    { "type": "image_picker", "id": "slide_4_mobile", "label": "Mobile slide 4" },
    { "type": "image_picker", "id": "slide_5_mobile", "label": "Mobile slide 5" }
  ],
  "blocks": [
    {
      "type": "kit_item",
      "name": "Kit Item",
      "settings": [
        { "type": "select", "id": "label", "label": "Category", "default": "Film", "options": [
            { "value": "Film", "label": "Film" },
            { "value": "Strap", "label": "Strap" },
            { "value": "Bag", "label": "Bag" },
            { "value": "Developing", "label": "Developing" },
            { "value": "Accessories", "label": "Accessories" },
            { "value": "Lens", "label": "Lens" },
            { "value": "More", "label": "More" }
          ]
        },
        { "type": "text", "id": "column", "label": "Column group", "info": "Group items into columns by giving them the same name, e.g. Film, Strap, More. Defaults to the Category if blank." },
        { "type": "product", "id": "product", "label": "Product" },
