
{% liquid
  assign base_text = section.settings.text_color | default: '#111111'
  assign base_bg = section.settings.background_color | default: '#F7F4F0'
  assign page_width_px = settings.page_width | default: 1200
  assign horizontal_pad = section.settings.horizontal_padding | default: 24
  assign heading_size_preset = section.settings.heading_size_preset | default: 'default'
  case heading_size_preset
    when 'sm'
      assign header_size_mobile = '1.4'
      assign header_size_desktop = '2.0'
    when 'md'
      assign header_size_mobile = '1.6'
      assign header_size_desktop = '2.4'
    when 'lg'
      assign header_size_mobile = '2.0'
      assign header_size_desktop = '3.2'
    when 'xl'
      assign header_size_mobile = '2.4'
      assign header_size_desktop = '3.8'
    when 'xxl'
      assign header_size_mobile = '2.8'
      assign header_size_desktop = '4.4'
    else
      assign header_size_mobile = '1.75'
      assign header_size_desktop = '2.75'
  endcase
  assign header_weight = section.settings.header_font_weight | default: 600
  assign body_weight = section.settings.body_font_weight | default: 400
  assign body_size = section.settings.body_font_size | default: 16
  assign body_size_small = section.settings.body_font_size_small | default: 12
  assign header_line_height = section.settings.header_line_height | default: '1.05'
  assign header_letter_spacing = section.settings.header_letter_spacing | default: 0
  assign heading_color = section.settings.heading_color | default: base_text
  assign body_line_height = section.settings.body_line_height | default: '1.5'
  assign body_letter_spacing = section.settings.body_letter_spacing | default: 0
  assign section_pad_top = section.settings.section_padding_top | default: 40
  assign section_pad_bottom = section.settings.section_padding_bottom | default: 40
  assign accent_color = section.settings.accent_color | default: '#E36E15'
  assign secondary_text_color = section.settings.secondary_text_color | default: '#82906B'
  assign item_title_font = section.settings.item_title_font
%}
<section id="bfc-trust-bar-{{ section.id }}" class="bfc-combined" aria-label="{{ section.settings.section_label | default: 'BFC Trust Bar' }}">
  <style>
    {{ item_title_font | font_face: font_display: 'swap' }}

    /* Fix shopify-section wrapper background & spacing */
    #shopify-section-{{ section.id }} {
      background-color: {{ base_bg }};
      margin: 0;
      padding: {{ section_pad_top }}px 0 {{ section_pad_bottom }}px;
      width: 100%;
    }
    #bfc-trust-bar-{{ section.id }}{
      --bfc-header-family: var(--font-heading-family, inherit);
      --bfc-body-family: var(--font-body-family, inherit);
      --bfc-header-weight: {{ header_weight }};
      --bfc-body-weight: {{ body_weight }};
      --bfc-header-size-mobile: {{ header_size_mobile }}rem;
      --bfc-header-size-desktop: {{ header_size_desktop }}rem;
      --bfc-horizontal-pad: {{ horizontal_pad }}px;
      --bfc-page-width: {{ page_width_px }}px;
      --bfc-align-pad: clamp(
        var(--bfc-horizontal-pad),
        calc((100vw - min(100vw, var(--bfc-page-width))) / 2 + var(--bfc-horizontal-pad)),
        120px
      );
      --bfc-body-size: {{ body_size }}px;
      --bfc-body-size-small: {{ body_size_small }}px;
      --bfc-text: {{ base_text }};
      --bfc-bg: {{ base_bg }};
      --bfc-heading-color: {{ heading_color }};
      --bfc-header-letter-spacing: {{ header_letter_spacing }}px;
      --bfc-header-line-height: {{ header_line_height }};
      --bfc-body-letter-spacing: {{ body_letter_spacing }}px;
      --bfc-body-line-height: {{ body_line_height }};
      --bfc-accent: {{ accent_color }};
      --bfc-secondary-text: {{ secondary_text_color }};
      --bfc-item-title-family: {{ item_title_font.family | default: 'Poppins' }}, {{ item_title_font.fallback_families | default: 'sans-serif' }};
      --bfc-item-title-weight: {{ item_title_font.weight | default: 500 }};
      color: var(--bfc-text);
      background: var(--bfc-bg);
      font-family: var(--bfc-body-family);
      font-weight: var(--bfc-body-weight);
      font-size: var(--bfc-body-size);
    }
    #bfc-trust-bar-{{ section.id }} .bfc-heading{
      font-family: var(--bfc-header-family, inherit);
      font-size: clamp(var(--bfc-header-size-mobile, 1.75rem), 3.5vw, var(--bfc-header-size-desktop, 2.75rem));
      font-weight: var(--bfc-header-weight, 300);
      line-height: var(--bfc-header-line-height, 1.05);
      letter-spacing: var(--bfc-header-letter-spacing, -0.02em);
      margin: 0;
      color: var(--bfc-heading-color, #111111);
    }
        #bfc-trust-bar-{{ section.id }} .bfc-block{
      margin: 0 auto;
    }
    #bfc-trust-bar-{{ section.id }} .bfc-block + .bfc-block{
      margin-top: 24px;
    }
    #bfc-trust-bar-{{ section.id }} .visually-hidden{
      position: absolute;width: 1px;height: 1px;padding: 0;margin: -1px;overflow: hidden;clip: rect(0,0,0,0);white-space: nowrap;border: 0;
    }
    #bfc-trust-bar-{{ section.id }} a:focus-visible,
    #bfc-trust-bar-{{ section.id }} button:focus-visible,
    #bfc-trust-bar-{{ section.id }} input:focus-visible{
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }
    @media (prefers-reduced-motion: reduce){
      #bfc-trust-bar-{{ section.id }} *{
        animation-duration: .01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: .01ms !important;
      }
    }
  
    #bfc-trust-bar-{{ section.id }} .bfc-eyebrow{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bfc-secondary-text);
      margin: 0 0 10px;
    }
    #bfc-trust-bar-{{ section.id }} .bfc-item-title{
      font-family: var(--bfc-item-title-family);
      font-weight: var(--bfc-item-title-weight);
      font-size: var(--bfc-body-size);
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--bfc-text);
    }

    #bfc-trust-bar-{{ section.id }} .bfc-detail-text{
      font-family: var(--bfc-body-family);
      font-size: var(--bfc-body-size-small);
      font-weight: var(--bfc-body-weight);
      letter-spacing: var(--bfc-body-letter-spacing);
      line-height: var(--bfc-body-line-height);
      color: var(--bfc-secondary-text);
      margin: 0;
    }

  </style>
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'trust_bar' %}
        {% liquid
          assign tb_bg   = block.settings.background_color | default: '#202009'
          assign tb_stat = block.settings.stat_color | default: '#F4A027'
          assign tb_pad  = block.settings.vertical_padding | default: 20
        %}
        <section
          class="bfc-block bfc-tb"
          aria-label="Trust indicators"
          style="background:{{ tb_bg }};padding:{{ tb_pad }}px 0;border-top:1px solid rgba(255,255,255,0.07);border-bottom:1px solid rgba(255,255,255,0.07);"
          {{ block.shopify_attributes }}
        >
          <style>
            .bfc-tb__inner{
              max-width:var(--bfc-page-width,1200px);
              margin:0 auto;
              padding:0 var(--bfc-align-pad,24px);
              display:flex;
              align-items:center;
              justify-content:center;
              flex-wrap:wrap;
            }
            .bfc-tb__item{
              display:flex;
              align-items:center;
              gap:12px;
              padding:12px 32px;
              flex:1 1 180px;
              max-width:280px;
              position:relative;
            }
            .bfc-tb__item + .bfc-tb__item::before{
              content:'';position:absolute;left:0;top:50%;
              transform:translateY(-50%);height:30px;width:1px;
              background:rgba(255,255,255,0.1);
            }
            .bfc-tb__icon{ flex-shrink:0;width:28px;height:28px;display:flex;align-items:center;justify-content:center; }
            .bfc-tb__icon svg{ width:20px;height:20px; }
            .bfc-tb__text{ display:flex;flex-direction:column;gap:2px; }
            .bfc-tb__stat{
              font-family:'Cormorant Garamond',Georgia,serif;
              font-size:20px;font-weight:400;line-height:1;
              color:{{ tb_stat }};letter-spacing:-0.01em;
            }
            .bfc-tb__label{
              font-size:9.5px;font-weight:500;letter-spacing:0.1em;
              text-transform:uppercase;
              color:rgba(248,246,238,0.42);line-height:1.3;
            }
            @media(max-width:768px){
              .bfc-tb__item{ flex:1 1 calc(50% - 40px);max-width:none;padding:14px 16px; }
              .bfc-tb__item:nth-child(odd)::before{ display:none; }
              .bfc-tb__item:nth-child(3),
              .bfc-tb__item:nth-child(4){ border-top:1px solid rgba(255,255,255,0.07); }
            }
            @media(max-width:480px){
              .bfc-tb__item{ flex:1 1 100%;max-width:100%; }
              .bfc-tb__item + .bfc-tb__item::before{ display:none; }
              .bfc-tb__item + .bfc-tb__item{ border-top:1px solid rgba(255,255,255,0.07); }
              .bfc-tb__item:nth-child(3),
              .bfc-tb__item:nth-child(4){ border-top:1px solid rgba(255,255,255,0.07); }
            }
          </style>
          <svg style="display:none" aria-hidden="true" focusable="false"><defs><symbol id="bfc-tb-warranty" viewBox="0 0 24 24"><path d="M12 2L3 6v6c0 5.25 3.75 10.15 9 11.25C17.25 22.15 21 17.25 21 12V6l-9-4z" stroke="#ABCC99" stroke-width="1.5" stroke-linejoin="round" fill="none"/><path d="M8.5 12l2.5 2.5 4.5-4.5" stroke="#ABCC99" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></symbol><symbol id="bfc-tb-camera" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" stroke="#ABCC99" stroke-width="1.5" fill="none"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2" stroke="#ABCC99" stroke-width="1.5"/><circle cx="12" cy="14" r="3.5" stroke="#ABCC99" stroke-width="1.5"/><circle cx="12" cy="14" r="1.25" fill="#ABCC99"/></symbol><symbol id="bfc-tb-film" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2" stroke="#ABCC99" stroke-width="1.5" fill="none"/><rect x="5" y="7" width="3" height="3" rx="0.5" fill="#ABCC99"/><rect x="5" y="14" width="3" height="3" rx="0.5" fill="#ABCC99"/><rect x="16" y="7" width="3" height="3" rx="0.5" fill="#ABCC99"/><rect x="16" y="14" width="3" height="3" rx="0.5" fill="#ABCC99"/><rect x="10" y="8" width="4" height="8" rx="1" stroke="#ABCC99" stroke-width="1.25" fill="none"/></symbol><symbol id="bfc-tb-shipping" viewBox="0 0 24 24"><path d="M3 9h14v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="#ABCC99" stroke-width="1.5" fill="none"/><path d="M17 12h2.4a1 1 0 01.8.4l1.6 2.133A1 1 0 0122 15v3a2 2 0 01-2 2h-3" stroke="#ABCC99" stroke-width="1.5" stroke-linejoin="round" fill="none"/><circle cx="7" cy="20" r="1.5" fill="#ABCC99"/><circle cx="18" cy="20" r="1.5" fill="#ABCC99"/><path d="M3 9V7a2 2 0 012-2h9a2 2 0 012 2v2" stroke="#ABCC99" stroke-width="1.5"/></symbol><symbol id="bfc-tb-star" viewBox="0 0 24 24"><path d="M12 2l2.9 6.26L22 9.27l-5 5.14 1.18 7.09L12 18.5l-6.18 2.99L7 14.41 2 9.27l7.1-1.01L12 2z" stroke="#ABCC99" stroke-width="1.5" stroke-linejoin="round" fill="none"/></symbol><symbol id="bfc-tb-location" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="#ABCC99" stroke-width="1.5" fill="none"/><circle cx="12" cy="9" r="2.5" stroke="#ABCC99" stroke-width="1.5"/></symbol><symbol id="bfc-tb-default" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke="#ABCC99" stroke-width="1.5" fill="none"/></symbol></defs></svg>
          <div class="bfc-tb__inner">
            {% assign tb_icon_color = '#ABCC99' %}
            {%- if block.settings.stat_1 != blank -%}
            <div class="bfc-tb__item">
              <div class="bfc-tb__icon">
                {%- assign _bfc_tb_icon = block.settings.icon_1 | default: 'default' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false"><use href="#bfc-tb-{{ _bfc_tb_icon }}"/></svg>
              </div>
              <div class="bfc-tb__text">
                <span class="bfc-tb__stat">{{ block.settings.stat_1 }}</span>
                <span class="bfc-tb__label">{{ block.settings.label_1 }}</span>
              </div>
            </div>
            {%- endif -%}
            {%- if block.settings.stat_2 != blank -%}
            <div class="bfc-tb__item">
              <div class="bfc-tb__icon">
                {%- assign _bfc_tb_icon = block.settings.icon_2 | default: 'default' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false"><use href="#bfc-tb-{{ _bfc_tb_icon }}"/></svg>
              </div>
              <div class="bfc-tb__text">
                <span class="bfc-tb__stat">{{ block.settings.stat_2 }}</span>
                <span class="bfc-tb__label">{{ block.settings.label_2 }}</span>
              </div>
            </div>
            {%- endif -%}
            {%- if block.settings.stat_3 != blank -%}
            <div class="bfc-tb__item">
              <div class="bfc-tb__icon">
                {%- assign _bfc_tb_icon = block.settings.icon_3 | default: 'default' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false"><use href="#bfc-tb-{{ _bfc_tb_icon }}"/></svg>
              </div>
              <div class="bfc-tb__text">
                <span class="bfc-tb__stat">{{ block.settings.stat_3 }}</span>
                <span class="bfc-tb__label">{{ block.settings.label_3 }}</span>
              </div>
            </div>
            {%- endif -%}
            {%- if block.settings.stat_4 != blank -%}
            <div class="bfc-tb__item">
              <div class="bfc-tb__icon">
                {%- assign _bfc_tb_icon = block.settings.icon_4 | default: 'default' -%}
              <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false"><use href="#bfc-tb-{{ _bfc_tb_icon }}"/></svg>
              </div>
              <div class="bfc-tb__text">
                <span class="bfc-tb__stat">{{ block.settings.stat_4 }}</span>
                <span class="bfc-tb__label">{{ block.settings.label_4 }}</span>
              </div>
            </div>
            {%- endif -%}
          </div>
        </section>
    {% endcase %}
  {% endfor %}
</section>
{% schema %}
{
  "name": "BFC Trust Bar",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "header_font_weight",
      "label": "Header font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "SemiBold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "body_font_weight",
      "label": "Body font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "body_font_size_small",
      "label": "Small text size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Base text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Base background color",
      "default": "#F7F4F0"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_size_preset",
      "label": "Heading size",
      "info": "Controls heading size at all screen widths consistently.",
      "options": [
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "xl",
          "label": "X-Large"
        },
        {
          "value": "xxl",
          "label": "XX-Large"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "header_line_height",
      "label": "Heading line height",
      "options": [
        {
          "value": "1.0",
          "label": "1.0 (Tightest)"
        },
        {
          "value": "1.05",
          "label": "1.05 (Default)"
        },
        {
          "value": "1.1",
          "label": "1.1"
        },
        {
          "value": "1.2",
          "label": "1.2"
        },
        {
          "value": "1.3",
          "label": "1.3"
        },
        {
          "value": "1.4",
          "label": "1.4 (Loose)"
        }
      ],
      "default": "1.05"
    },
    {
      "type": "range",
      "id": "header_letter_spacing",
      "label": "Heading letter spacing",
      "min": -2,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": -2
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "info": "Falls back to base text color if unset",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Body Typography"
    },
    {
      "type": "select",
      "id": "body_line_height",
      "label": "Body line height",
      "options": [
        {
          "value": "1.3",
          "label": "1.3 (Tight)"
        },
        {
          "value": "1.4",
          "label": "1.4"
        },
        {
          "value": "1.5",
          "label": "1.5 (Default)"
        },
        {
          "value": "1.6",
          "label": "1.6"
        },
        {
          "value": "1.8",
          "label": "1.8 (Loose)"
        }
      ],
      "default": "1.5"
    },
    {
      "type": "range",
      "id": "body_letter_spacing",
      "label": "Body letter spacing",
      "min": -1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Used for links and highlights",
      "default": "#E36E15"
    },
    {
      "type": "color",
      "id": "secondary_text_color",
      "label": "Secondary text color",
      "info": "Used for eyebrows and small detail text",
      "default": "#82906B"
    },
    {
      "type": "font_picker",
      "id": "item_title_font",
      "label": "Item title font",
      "info": "Font used for product/item titles (e.g. the old best-seller title font)",
      "default": "poppins_n5"
    }
  ],
  "blocks": [
    {
      "type": "trust_bar",
      "name": "Trust Bar",
      "settings": [
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color",
          "default": "#202009"
        },
        {
          "type": "color",
          "id": "stat_color",
          "label": "Stat color",
          "default": "#F4A027"
        },
        {
          "type": "range",
          "id": "vertical_padding",
          "label": "Vertical padding (px)",
          "min": 8,
          "max": 48,
          "step": 4,
          "default": 20
        },
        {
          "type": "header",
          "content": "Stat 1"
        },
        {
          "type": "select",
          "id": "icon_1",
          "label": "Icon 1",
          "default": "camera",
          "options": [
            {
              "value": "warranty",
              "label": "Shield / Warranty"
            },
            {
              "value": "camera",
              "label": "Camera"
            },
            {
              "value": "film",
              "label": "Film strip"
            },
            {
              "value": "shipping",
              "label": "Shipping / Truck"
            },
            {
              "value": "star",
              "label": "Star"
            },
            {
              "value": "location",
              "label": "Location pin"
            }
          ]
        },
        {
          "type": "text",
          "id": "stat_1",
          "label": "Stat 1",
          "default": "1,000+"
        },
        {
          "type": "text",
          "id": "label_1",
          "label": "Label 1",
          "default": "Cameras Restored"
        },
        {
          "type": "header",
          "content": "Stat 2"
        },
        {
          "type": "select",
          "id": "icon_2",
