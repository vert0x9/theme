{% comment %}
  ============================================================
  BFC New Arrivals  (v2 — house style)
  ------------------------------------------------------------
  Re-skin of the New Arrivals section to match BFC's editorial
  design language as seen on PDPs and the SX-70/refurb sections.

  Key changes vs v1:
    - Cormorant Garamond serif headings, Poppins body
    - BFC tokens: Blank Canvas #F8F6EE, Super Orange #E36E15,
      Charcoal #4E4741, Celadon #ABCC99
    - Section eyebrow as a real schema field (orange, all-caps)
    - Product cards: image + left-aligned title + price below
    - Square corners everywhere (BFC house rule, no radius)
    - Quick-add removed (customers go to PDP for kit + warranty)
    - "Display more" + "Collapse" + "Back to top" rendered as
      text links with arrows, not pill buttons
    - Subtle background tint on card hover, no lift transform

  Schema kept compatible: existing settings (group_id,
  collection_source blocks, manual_products, etc.) still work.
  ============================================================
{% endcomment %}

{% liquid
  assign base_text = section.settings.text_color | default: '#202009'
  assign base_bg = section.settings.background_color | default: '#F8F6EE'
  assign page_width_px = settings.page_width | default: 1240
  assign horizontal_pad = section.settings.horizontal_padding | default: 32
  assign section_pad_top = section.settings.section_padding_top | default: 56
  assign section_pad_bottom = section.settings.section_padding_bottom | default: 56
  assign accent_color = section.settings.accent_color | default: '#E36E15'
  assign secondary_text_color = section.settings.secondary_text_color | default: '#4E4741'
  assign muted_border_color = '#E3DDDA'
%}
<section id="bfc-new-arrivals-{{ section.id }}" class="bfc-na" aria-label="{{ section.settings.section_label | default: 'BFC New Arrivals' }}">
  <style>
    #shopify-section-{{ section.id }} {
      background-color: {{ base_bg }};
      margin: 0;
      padding: {{ section_pad_top }}px 0 {{ section_pad_bottom }}px;
      width: 100%;
    }
    #bfc-new-arrivals-{{ section.id }} {
      --na-text: {{ base_text }};
      --na-bg: {{ base_bg }};
      --na-accent: {{ accent_color }};
      --na-secondary: {{ secondary_text_color }};
      --na-border: {{ muted_border_color }};
      --na-h-pad: {{ horizontal_pad }}px;
      --na-page-width: {{ page_width_px }}px;
      --na-align-pad: clamp(
        var(--na-h-pad),
        calc((100vw - min(100vw, var(--na-page-width))) / 2 + var(--na-h-pad)),
        120px
      );
      color: var(--na-text);
      background: var(--na-bg);
      font-family: 'Poppins', sans-serif;
    }
    #bfc-new-arrivals-{{ section.id }}, #bfc-new-arrivals-{{ section.id }} * { box-sizing: border-box; }

    /* ── Block container ── */
    #bfc-new-arrivals-{{ section.id }} .bfc-na-block { margin: 0 auto; }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-block + .bfc-na-block { margin-top: 24px; }

    /* ── Header (eyebrow + heading + text) ── */
    #bfc-new-arrivals-{{ section.id }} .bfc-na-header {
      max-width: 100%;
      margin: 0 auto 32px;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-header-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-header-text { flex: 1; min-width: 220px; }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-header-controls {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-shrink: 0;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-viewall {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'Poppins', sans-serif;
      font-size: 12px;
      font-weight: 500;
      color: var(--na-text);
      text-decoration: none;
      letter-spacing: 0.04em;
      opacity: 0.85;
      transition: opacity 0.15s;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-viewall:hover { opacity: 1; text-decoration: underline; }
    /* ── Header row + viewall (matches top-sellers) ── */
    #bfc-new-arrivals-{{ section.id }} .bfc-na-header { margin: 0 0 16px; }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-header-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-eyebrow {
      font-family: 'Poppins', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--na-accent);
      margin: 0 0 8px;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(28px, 3vw, 36px);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--na-text);
      margin: 0;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-viewall {
      color: var(--na-text);
      text-decoration: none;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      opacity: 0.85;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-viewall:hover {
      opacity: 1;
      text-decoration: underline;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-text {
      font-family: 'Poppins', sans-serif;
      font-size: 14px;
      line-height: 1.45;
      color: var(--na-secondary);
      margin: 10px 0 0;
      max-width: 70ch;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-text p { margin: 0 0 10px; }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-text p:last-child { margin: 0; }

    /* ── Product rail (matches top-sellers exactly) ── */
    #bfc-new-arrivals-{{ section.id }} .bfc-na-rail-wrap {
      position: relative;
      margin-top: 14px;
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-grid {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: clamp(220px, 24vw, 280px);
      gap: 16px;
      overflow-x: auto;
      overscroll-behavior-x: contain;
      scroll-snap-type: x mandatory;
      scroll-padding-left: var(--na-align-pad);
      padding-left: var(--na-align-pad);
      padding-right: 0;
      padding-top: 6px;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      cursor: grab;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-grid::-webkit-scrollbar { display: none; }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-grid.is-dragging {
      cursor: grabbing;
      scroll-behavior: auto;
    }

    /* ── Product card (matches top-sellers exactly) ── */
    #bfc-new-arrivals-{{ section.id }} .bfc-na-card {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      background: var(--na-bg);
      border: 0;
      border-radius: 0;
      overflow: hidden;
      display: grid;
      grid-template-rows: auto 1fr;
      min-height: 100%;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-img {
      position: relative;
      display: block;
      aspect-ratio: 4 / 3;
      background: color-mix(in srgb, var(--na-text) 6%, transparent);
      overflow: hidden;
      text-decoration: none;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transform: scale(1);
      transition: transform 0.35s ease, opacity 0.35s ease;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-img:hover img { transform: scale(1.03); }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-stock-sticker {
      position: absolute;
      right: 12px;
      top: 12px;
      z-index: 2;
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 600;
      line-height: 1;
      letter-spacing: 0.02em;
      padding: 6px 9px;
      border-radius: 0;
      background: #E36E15;
      color: #fff;
      white-space: nowrap;
      box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-meta {
      padding: 10px 12px 12px;
      display: grid;
      gap: 2px;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-vendor {
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      color: var(--na-secondary);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-name {
      color: var(--na-text);
      text-decoration: none;
      font-family: 'Poppins', sans-serif;
      font-size: 14px;
      line-height: 1.15;
      font-weight: 500;
      letter-spacing: -0.01em;
      margin: 0;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-name:hover { text-decoration: underline; }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-subline {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--na-secondary);
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      line-height: 1.2;
      margin-top: 1px;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-dot { opacity: 0.7; }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-bottom {
      margin-top: 2px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-price {
      display: flex;
      align-items: baseline;
      gap: 8px;
      min-height: 18px;
      font-family: 'Poppins', sans-serif;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-price-now {
      font-size: 14px;
      font-weight: 600;
      color: var(--na-text);
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-price-was {
      font-size: 11px;
      color: var(--na-secondary);
      text-decoration: line-through;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-add { margin: 0; }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-add-btn {
      appearance: none;
      border: 0;
      background: transparent;
      color: var(--na-text);
      border-radius: 0;
      padding: 9px 12px;
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      line-height: 1;
      cursor: pointer;
      transition: background 0.18s ease, opacity 0.18s ease;
      white-space: nowrap;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-add-btn:hover {
      background: color-mix(in srgb, var(--na-text) 7%, transparent);
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-add-btn[disabled] {
      opacity: 0.45;
      cursor: not-allowed;
    }

    /* ── Show-more / collapse / back-to-top as text links ── */
    #bfc-new-arrivals-{{ section.id }} .bfc-na-controls {
      margin-top: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 32px;
      flex-wrap: wrap;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-ctrl {
      background: none;
      border: none;
      padding: 8px 0;
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--na-text);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid var(--na-text);
      transition: color 0.15s ease, border-color 0.15s ease;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-ctrl:hover {
      color: var(--na-accent);
      border-color: var(--na-accent);
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-ctrl svg {
      width: 10px;
      height: 10px;
      display: block;
    }

    /* ── Optional bottom button — also a text link ── */
    #bfc-new-arrivals-{{ section.id }} .bfc-na-cta-wrap {
      margin-top: 40px;
      text-align: center;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--na-text);
      text-decoration: none;
      border: 1px solid var(--na-text);
      background: transparent;
      transition: background 0.2s ease, color 0.2s ease;
    }
    #bfc-new-arrivals-{{ section.id }} .bfc-na-cta:hover {
      background: var(--na-text);
      color: var(--na-bg);
    }

    /* ── Accessibility helpers ── */
    #bfc-new-arrivals-{{ section.id }} .visually-hidden {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }
    #bfc-new-arrivals-{{ section.id }} a:focus-visible,
    #bfc-new-arrivals-{{ section.id }} button:focus-visible {
      outline: 2px solid var(--na-accent);
      outline-offset: 2px;
    }
    @media (prefers-reduced-motion: reduce) {
      #bfc-new-arrivals-{{ section.id }} * {
        animation-duration: .01ms !important;
        transition-duration: .01ms !important;
      }
    }
  </style>

  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'new_arrivals' %}
        {% assign items_to_show = block.settings.items_to_show | default: 12 %}
        {% assign initial_items = block.settings.initial_items | default: 12 %}
        {% assign anchor_id = block.settings.anchor_id | strip | default: 'new-arrivals' %}
        {% assign manual_products = block.settings.manual_products | compact %}
        {% assign has_manual = false %}
        {% if manual_products and manual_products.size > 0 %}
          {% assign has_manual = true %}
        {% endif %}
        {% assign selected_collection = block.settings.collection %}
        {% assign has_single_collection = false %}
        {% if selected_collection %}
          {% assign has_single_collection = true %}
        {% endif %}
        {% assign use_newest_from_collection = block.settings.use_newest_from_collection %}
        {% assign full_rows_only = block.settings.full_rows_only %}
        {% assign full_rows_columns_desktop = block.settings.full_rows_columns_desktop | default: 5 %}
        {% assign disable_see_more = true %}
        {% assign products_to_render = nil %}
        {% assign source_type = '' %}
        {% if has_manual %}
          {% assign products_to_render = manual_products %}
          {% assign source_type = 'products' %}
        {% elsif has_single_collection %}
          {% if use_newest_from_collection %}
            {% assign products_to_render = selected_collection.products | sort: 'created_at' | reverse %}
          {% else %}
            {% assign products_to_render = selected_collection.products %}
          {% endif %}
          {% assign source_type = 'products' %}
        {% else %}
          {%- comment -%} Multi-collection mode via collection_source blocks
              grouped by matching group_id. Deduplicates by product handle. {%- endcomment -%}
          {% assign product_handles_string = ',' %}
          {% assign product_counter = 0 %}
          {% assign arrivals_group = block.settings.group_id | default: block.id %}
          {% for source in section.blocks %}
            {% if product_counter >= items_to_show %}
              {% break %}
            {% endif %}
            {% if source.type == 'collection_source' and source.settings.group_id == arrivals_group %}
              {% if source.settings.collection %}
                {% assign collection_products = source.settings.collection.products %}
                {% for product in collection_products %}
                  {% if product_counter >= items_to_show %}
                    {% break %}
                  {% endif %}
                  {% assign token = ',' | append: product.handle | append: ',' %}
                  {% unless product_handles_string contains token %}
                    {% assign product_handles_string = product_handles_string | append: product.handle | append: ',' %}
                    {% assign product_counter = product_counter | plus: 1 %}
                  {% endunless %}
                {% endfor %}
              {% endif %}
            {% endif %}
          {% endfor %}
          {% assign products_to_render = product_handles_string | split: ',' | uniq | compact %}
          {% assign source_type = 'handles' %}
        {% endif %}

        {%- comment -%} Trim to full rows if requested, so grid never shows an
            orphaned row of 1-2 products at the bottom of desktop. {%- endcomment -%}
        {% assign render_limit = items_to_show %}
        {% if full_rows_only %}
          {% assign remainder = render_limit | modulo: full_rows_columns_desktop %}
          {% if remainder != 0 and render_limit > full_rows_columns_desktop %}
            {% assign render_limit = render_limit | minus: remainder %}
          {% endif %}
        {% endif %}
        {% if initial_items > render_limit %}
          {% assign initial_items = render_limit %}
        {% endif %}
        {% if disable_see_more %}
          {% assign initial_items = render_limit %}
        {% endif %}

        <section
          id="{{ anchor_id }}"
          class="bfc-na-block"
          aria-label="{{ block.settings.heading | default: 'New arrivals' | strip_html | escape }}"
          {{ block.shopify_attributes }}
        >
          <div class="bfc-na-inner">
            {%- if block.settings.eyebrow != blank or block.settings.heading != blank or block.settings.text != blank or block.settings.button_link != blank -%}
              <div class="bfc-na-header">
                {% if block.settings.eyebrow != blank %}
                  <p class="bfc-na-eyebrow">{{ block.settings.eyebrow }}</p>
                {% endif %}
                <div class="bfc-na-header-row">
                  {% if block.settings.heading != blank %}
                    <h2 class="bfc-na-heading">{{ block.settings.heading | strip_html | escape }}</h2>
                  {% endif %}
                  {% if block.settings.button_link != blank %}
                    <a class="bfc-na-viewall" href="{{ block.settings.button_link }}">
                      {{ block.settings.button_text | default: 'Shop all' | escape }}
                    </a>
                  {% endif %}
                </div>
                {% if block.settings.text != blank %}
                  <div class="bfc-na-text rte">{{ block.settings.text }}</div>
                {% endif %}
              </div>
            {%- endif -%}

            {% assign total_products = products_to_render | size | default: 0 %}
            {% if products_to_render and total_products > 0 %}
              <div class="bfc-na-rail-wrap">
              <div class="bfc-na-grid" id="{{ anchor_id }}-grid" role="list">
                {% assign product_index = 0 %}

                {%- comment -%} Two rendering paths because manual/collection
                    yields product drops, while multi-collection yields handles
                    that need all_products lookup. {%- endcomment -%}
                {% if source_type == 'products' %}
                  {% for product in products_to_render limit: render_limit %}
                    {% if product == blank %}{% continue %}{% endif %}
                    {% assign product_index = product_index | plus: 1 %}
                    {% assign image = product.featured_image %}
                    {% assign variant = product.selected_or_first_available_variant %}
                    <article class="bfc-na-card" data-index="{{ product_index }}" role="listitem">
                      <a class="bfc-na-img" href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1" aria-hidden="true">
                        {% if image %}
                          <img
                            src="{{ image | image_url: width: 720 }}"
                            srcset="{{ image | image_url: width: 360 }} 360w, {{ image | image_url: width: 540 }} 540w, {{ image | image_url: width: 720 }} 720w"
                            sizes="(min-width: 990px) 260px, 70vw"
                            alt=""
                            loading="lazy"
                            width="{{ image.width }}"
                            height="{{ image.height }}"
                          >
                        {% else %}
                          <span aria-hidden="true">{{ 'product-1' | placeholder_svg_tag: 'bfc-na-placeholder' }}</span>
                        {% endif %}
                        {% if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny' and variant.inventory_quantity > 0 and variant.inventory_quantity < 3 %}
                          <span class="bfc-na-stock-sticker" aria-hidden="true">Only {{ variant.inventory_quantity }} left</span>
                        {% endif %}
                      </a>
                      <div class="bfc-na-meta">
                        {% if product.vendor != blank %}
                          <div class="bfc-na-vendor">{{ product.vendor | escape }}</div>
                        {% endif %}
                        <a class="bfc-na-name" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                          {{ product.title | escape }}
                        </a>
                        <div class="bfc-na-subline">
                          <span class="bfc-na-stock">
                            {% if product.available %}In stock{% else %}Sold out{% endif %}
                          </span>
                          {% if product.variants.size > 1 %}
                            <span class="bfc-na-dot" aria-hidden="true">•</span>
                            <span class="bfc-na-variants">
                              {{ product.variants.size }} option{% if product.variants.size != 1 %}s{% endif %}
                            </span>
                          {% endif %}
                        </div>
                        <div class="bfc-card-meta">
                          <span class="bfc-card-meta-item bfc-card-meta-free">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                            Restored &amp; Warrantied
                          </span>
                          <span class="bfc-card-activity"
                            data-handle="{{ product.handle }}"
                            data-available="{{ product.available }}"
                            data-qty="{{ product.variants | map: 'inventory_quantity' | sum }}"
                            data-no-stock-text="true"></span>
                        </div>
                        <div class="bfc-na-bottom">
                          <div class="bfc-na-price">
                            {% if product.compare_at_price_max > product.price %}
                              <span class="bfc-na-price-now">{{ product.price | money }}</span>
                              <span class="bfc-na-price-was">{{ product.compare_at_price_max | money }}</span>
                            {% else %}
                              <span class="bfc-na-price-now">{{ product.price | money }}</span>
                            {% endif %}
                          </div>
                          <form class="bfc-na-add" method="post" action="{{ routes.cart_add_url }}" aria-label="Add {{ product.title | escape }} to cart">
                            <input type="hidden" name="id" value="{{ variant.id }}">
                            <input type="hidden" name="quantity" value="1">
                            <button type="submit" class="bfc-na-add-btn" {% unless product.available %}disabled aria-disabled="true"{% endunless %}>
                              Add
                            </button>
                          </form>
                        </div>
                      </div>
                    </article>
                  {% endfor %}
                {% else %}
                  {% assign rendered_count = 0 %}
                  {% for handle in products_to_render %}
                    {% if rendered_count >= render_limit %}{% break %}{% endif %}
                    {% if handle == '' %}{% continue %}{% endif %}
                    {% assign product = all_products[handle] %}
                    {% if product %}
                      {% assign rendered_count = rendered_count | plus: 1 %}
                      {% assign product_index = product_index | plus: 1 %}
                      {% assign image = product.featured_image %}
                      {% assign variant = product.selected_or_first_available_variant %}
                      <article class="bfc-na-card" data-index="{{ product_index }}" role="listitem">
                        <a class="bfc-na-img" href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1" aria-hidden="true">
                          {% if image %}
                            <img
                              src="{{ image | image_url: width: 720 }}"
                              srcset="{{ image | image_url: width: 360 }} 360w, {{ image | image_url: width: 540 }} 540w, {{ image | image_url: width: 720 }} 720w"
                              sizes="(min-width: 990px) 260px, 70vw"
                              alt=""
                              loading="lazy"
                              width="{{ image.width }}"
                              height="{{ image.height }}"
                            >
                          {% else %}
                            <span aria-hidden="true">{{ 'product-1' | placeholder_svg_tag: 'bfc-na-placeholder' }}</span>
                          {% endif %}
                          {% if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny' and variant.inventory_quantity > 0 and variant.inventory_quantity < 3 %}
                            <span class="bfc-na-stock-sticker" aria-hidden="true">Only {{ variant.inventory_quantity }} left</span>
                          {% endif %}
                        </a>
                        <div class="bfc-na-meta">
                          {% if product.vendor != blank %}
                            <div class="bfc-na-vendor">{{ product.vendor | escape }}</div>
                          {% endif %}
                          <a class="bfc-na-name" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                            {{ product.title | escape }}
                          </a>
                          <div class="bfc-na-subline">
                            <span class="bfc-na-stock">
                              {% if product.available %}In stock{% else %}Sold out{% endif %}
                            </span>
                            {% if product.variants.size > 1 %}
                              <span class="bfc-na-dot" aria-hidden="true">•</span>
                              <span class="bfc-na-variants">
                                {{ product.variants.size }} option{% if product.variants.size != 1 %}s{% endif %}
                              </span>
                            {% endif %}
                          </div>
                          <div class="bfc-card-meta">
                            <span class="bfc-card-meta-item bfc-card-meta-free">
                              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                              Restored &amp; Warrantied
                            </span>
                            <span class="bfc-card-activity"
                              data-handle="{{ product.handle }}"
                              data-available="{{ product.available }}"
                              data-qty="{{ product.variants | map: 'inventory_quantity' | sum }}"
                              data-no-stock-text="true"></span>
                          </div>
                          <div class="bfc-na-bottom">
                            <div class="bfc-na-price">
                              {% if product.compare_at_price_max > product.price %}
                                <span class="bfc-na-price-now">{{ product.price | money }}</span>
                                <span class="bfc-na-price-was">{{ product.compare_at_price_max | money }}</span>
                              {% else %}
                                <span class="bfc-na-price-now">{{ product.price | money }}</span>
                              {% endif %}
                            </div>
                            <form class="bfc-na-add" method="post" action="{{ routes.cart_add_url }}" aria-label="Add {{ product.title | escape }} to cart">
                              <input type="hidden" name="id" value="{{ variant.id }}">
                              <input type="hidden" name="quantity" value="1">
                              <button type="submit" class="bfc-na-add-btn" {% unless product.available %}disabled aria-disabled="true"{% endunless %}>
                                Add
                              </button>
                            </form>
                          </div>
                        </div>
                      </article>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>
              </div>

              {% if disable_see_more == false %}
                {% if product_index > initial_items or block.settings.show_back_to_top %}
                  <div class="bfc-na-controls">
                    {% if product_index > initial_items %}
                      <button type="button" class="bfc-na-ctrl" data-show-more aria-expanded="false" aria-controls="{{ anchor_id }}-grid">
                        {{ block.settings.show_more_label | default: 'Show more' }}
                        <svg viewBox="0 0 10 10" fill="none">
                          <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                      <button type="button" class="bfc-na-ctrl" data-collapse style="display:none;" aria-expanded="true" aria-controls="{{ anchor_id }}-grid">
                        {{ block.settings.collapse_label | default: 'Show less' }}
                        <svg viewBox="0 0 10 10" fill="none">
                          <path d="M2 6l3-3 3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    {% endif %}
                    {% if block.settings.show_back_to_top %}
                      <button type="button" class="bfc-na-ctrl" data-back-to-top>
                        {{ block.settings.back_to_top_label | default: 'Back to top' }}
                        <svg viewBox="0 0 10 10" fill="none">
                          <path d="M5 8V2M2 5l3-3 3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    {% endif %}
                  </div>
                {% endif %}
              {% endif %}
            {% endif %}

            {% if block.settings.button_text != blank and block.settings.button_link != blank %}
              <div class="bfc-na-cta-wrap">
                <a href="{{ block.settings.button_link }}" class="bfc-na-cta">
                  {{ block.settings.button_text }}
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            {% endif %}
          </div>

          {% style %}
            #{{ anchor_id }} {
              padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
            }
            #{{ anchor_id }} .bfc-na-inner { margin: 0 auto; max-width: var(--na-page-width); padding-left: var(--na-align-pad); padding-right: var(--na-align-pad); }
            {% case block.settings.header_text_align %}
              {% when 'left' %}
                #{{ anchor_id }} .bfc-na-header { text-align: left; }
                #{{ anchor_id }} .bfc-na-text { margin-left: 0; }
              {% when 'right' %}
                #{{ anchor_id }} .bfc-na-header { text-align: right; }
                #{{ anchor_id }} .bfc-na-text { margin-left: auto; margin-right: 0; }
            {% endcase %}
            @media (max-width: 768px) {
              #{{ anchor_id }} .bfc-na-controls { gap: 20px; margin-top: 28px; }
              #{{ anchor_id }} .bfc-na-header { margin-bottom: 28px; }
            }
          {% endstyle %}

          <script>
            (function() {
              var root = document.getElementById('{{ anchor_id }}');
              if (!root) return;
              var initialItems = {{ initial_items | json }};
              var disableSeeMore = {{ disable_see_more | json }};

              if (!disableSeeMore) {
                var showMoreBtn = root.querySelector('[data-show-more]');
                var collapseBtn = root.querySelector('[data-collapse]');
                if (showMoreBtn && collapseBtn) {
                  showMoreBtn.addEventListener('click', function() {
                    var cards = root.querySelectorAll('.bfc-na-card');
                    for (var i = 0; i < cards.length; i++) {
                      var idx = parseInt(cards[i].getAttribute('data-index'), 10) || 0;
                      if (idx > initialItems) cards[i].classList.remove('is-hidden');
                    }
                    showMoreBtn.setAttribute('aria-expanded', 'true');
                    showMoreBtn.style.display = 'none';
                    collapseBtn.style.display = 'inline-flex';
                  });
                  collapseBtn.addEventListener('click', function() {
                    var cards = root.querySelectorAll('.bfc-na-card');
                    for (var i = 0; i < cards.length; i++) {
                      var idx = parseInt(cards[i].getAttribute('data-index'), 10) || 0;
                      if (idx > initialItems) cards[i].classList.add('is-hidden');
                    }
                    collapseBtn.style.display = 'none';
                    showMoreBtn.style.display = 'inline-flex';
                    root.scrollIntoView({ behavior: 'smooth', block: 'start' });
                  });
                }
              }

              var backToTopBtn = root.querySelector('[data-back-to-top]');
              if (backToTopBtn) {
                backToTopBtn.addEventListener('click', function() {
                  window.scrollTo({ top: 0, behavior: 'smooth' });
                });
              }

              /* ── Rail click-and-drag (desktop) ── */
              var rail = root.querySelector('.bfc-na-grid');
              if (rail) {
                var isDown = false, startX = 0, startScroll = 0;
                rail.addEventListener('mousedown', function(e) {
                  if (e.target.closest('.bfc-na-add-btn, a, button')) return;
                  isDown = true;
                  rail.classList.add('is-dragging');
                  startX = e.pageX - rail.offsetLeft;
                  startScroll = rail.scrollLeft;
                  e.preventDefault();
                });
                rail.addEventListener('mouseleave', function() { isDown = false; rail.classList.remove('is-dragging'); });
                rail.addEventListener('mouseup', function() { isDown = false; rail.classList.remove('is-dragging'); });
                rail.addEventListener('mousemove', function(e) {
                  if (!isDown) return;
                  e.preventDefault();
                  var x = e.pageX - rail.offsetLeft;
                  rail.scrollLeft = startScroll - (x - startX) * 1.5;
                });
              }
            })();
          </script>
        </section>
    {% endcase %}
  {% endfor %}
</section>

{%- comment -%} ── BFC card meta CSS + activity counter (matches top-sellers) ── {%- endcomment -%}
<style>
  .bfc-card-meta {
    display: flex; align-items: center; flex-wrap: wrap; gap: 8px;
    margin: 6px 0 2px;
    font-family: 'Poppins', sans-serif;
  }
  .bfc-card-meta:empty { display: none; }
  .bfc-card-meta-item {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 9.5px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: #4E4741;
  }
  .bfc-card-meta-item svg { color: #2a4820; flex-shrink: 0; }
  .bfc-card-meta-free { color: #2a4820; }
  .bfc-card-meta-free svg { color: #2a4820; }
  .bfc-card-activity {
    display: none; align-items: center; gap: 5px;
    font-size: 9.5px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: #E36E15;
  }
  .bfc-card-activity.is-visible { display: inline-flex; }
  .bfc-card-activity::before {
    content: ''; width: 5px; height: 5px; background: #E36E15;
    flex-shrink: 0;
    animation: bfc-card-pulse 2s ease-in-out infinite;
  }
  @keyframes bfc-card-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
<script>
(function() {
  if (window.__bfcCardActivityInit) return;
  window.__bfcCardActivityInit = true;

  function renderInventoryMessages() {
    var list = [];
    document.querySelectorAll('.bfc-card-activity').forEach(function(el) {
      if (el.dataset.noStockText !== 'true') {
        var available = el.dataset.available === 'true';
        var qty = parseInt(el.dataset.qty, 10);
        if (isNaN(qty)) qty = null;
        if (available && qty !== null && qty > 0 && qty <= 3) {
          el.textContent = qty === 1 ? 'Only 1 left' : 'Only ' + qty + ' left';
          el.classList.add('is-visible');
        }
      }
      list.push(el);
    });
    return list;
  }

  function loadActivity() {
    var list = renderInventoryMessages();
    if (!list.length) return;
    var URL = 'https://app--6910fd9136cfabdf03f66780.base44.app/api/apps/6910fd9136cfabdf03f66780/functions/productActivity?sort=-created_date&limit=500';
    fetch(URL)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var events = Array.isArray(data) ? data : (data.results || data.data || []);
        if (!events.length) return;
        var now = Date.now();
        var counts = {};
        events.forEach(function(e) {
          if (!e || e.event !== 'atc' || !e.handle || !e.created_date) return;
          if (now - new Date(e.created_date).getTime() > 2505600000) return;
          counts[e.handle] = (counts[e.handle] || 0) + 1;
        });
        list.forEach(function(el) {
          var n = counts[el.dataset.handle] || 0;
          if (n < 3) return;
          var cartMsg = n + ' people have this in their cart';
          if (el.classList.contains('is-visible')) {
            el.textContent = el.textContent + ' & ' + cartMsg;
          } else {
            el.textContent = cartMsg;
            el.classList.add('is-visible');
          }
        });
      })
      .catch(function() { /* fail silently */ });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadActivity);
  } else {
    loadActivity();
  }
})();
</script>

