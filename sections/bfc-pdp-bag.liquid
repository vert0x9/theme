<script src="{{ 'product-variants.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign first_collection = product.collections | first
-%}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

{%- comment -%} Breadcrumb collection: setting first, else first product collection {%- endcomment -%}
{%- assign crumb_coll = null -%}
{%- if section.settings.breadcrumb_collection != blank -%}
  {%- assign crumb_coll = collections[section.settings.breadcrumb_collection] -%}
{%- elsif first_collection -%}
  {%- assign crumb_coll = first_collection -%}
{%- endif -%}

{%- comment -%} Detect a color-type option {%- endcomment -%}
{%- assign color_opt_idx = null -%}
{%- assign color_opt_name = '' -%}
{%- assign current_color = '' -%}
{%- for opt in product.options_with_values -%}
  {%- assign onl = opt.name | downcase -%}
  {%- if onl contains 'color' or onl contains 'colour' or onl contains 'leather' or onl == 'cover' or onl == 'finish' -%}
    {%- assign color_opt_idx = forloop.index0 -%}
    {%- assign color_opt_name = opt.name -%}
    {%- assign color_opt_obj = opt -%}
  {%- endif -%}
{%- endfor -%}
{%- if color_opt_idx != null -%}
  {%- assign current_color = current_variant.options[color_opt_idx] -%}
{%- endif -%}

{%- comment -%} Known colors (specific/compound first so "chili red" matches red, "navy blue" matches navy) {%- endcomment -%}
{%- assign known_colors = 'black,charcoal,burgundy,bordeaux,oxblood,maroon,wine,navy,teal,forest,moss,sage,olive,khaki,mustard,rust,copper,cream,ivory,beige,sand,tan,brown,green,blue,gray,grey,red,orange,yellow,purple,pink,white,silver,gold' | split: ',' -%}

<style>
#bfc-pdp-bag-{{ section.id }} {
  --or:#E36E15;--gh:#F4A027;--ce:#ABCC99;--bc:#F8F6EE;
  --bk:#202009;--ch:#4E4741;--db:#5A3E2D;--gr:#E3DDDA;
  --sn:'Poppins',sans-serif;--sd:'Cormorant Garamond',serif;--t:0.2s ease;
}
#bfc-pdp-bag-{{ section.id }} .bfc4,#bfc-pdp-bag-{{ section.id }} .bfc4 *,#bfc-pdp-bag-{{ section.id }} .bfc4 *::before,#bfc-pdp-bag-{{ section.id }} .bfc4 *::after{box-sizing:border-box;margin:0;padding:0}
#bfc-pdp-bag-{{ section.id }} .bfc4{font-family:var(--sn);color:var(--bk);background:var(--bc)}
#bfc-pdp-bag-{{ section.id }} .bfc4-split{display:flex;align-items:flex-start}
@media(max-width:900px){#bfc-pdp-bag-{{ section.id }} .bfc4-split{flex-direction:column}}
#bfc-pdp-bag-{{ section.id }} .bfc4-left{position:sticky;top:0;width:50vw;height:50vw;max-height:100vh;overflow:hidden;background:var(--gr)}
@media(max-width:900px){#bfc-pdp-bag-{{ section.id }} .bfc4-left{position:relative;width:100%;height:100vw;max-height:100vw}}
#bfc-pdp-bag-{{ section.id }} .bfc4-slides{display:flex;width:100%;height:100%;transition:transform 0.5s cubic-bezier(0.4,0,0.2,1);will-change:transform}
#bfc-pdp-bag-{{ section.id }} .bfc4-slide{min-width:100%;height:100%;flex-shrink:0;position:relative}
#bfc-pdp-bag-{{ section.id }} .bfc4-slide img{width:100%;height:100%;object-fit:contain;object-position:center;display:block;cursor:zoom-in}
#bfc-pdp-bag-{{ section.id }} .bfc4-arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:10;background:rgba(32,32,9,0.3);border:none;width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background var(--t)}
#bfc-pdp-bag-{{ section.id }} .bfc4-arrow:hover{background:rgba(32,32,9,0.55)}
#bfc-pdp-bag-{{ section.id }} .bfc4-arrow.is-prev{left:16px}
#bfc-pdp-bag-{{ section.id }} .bfc4-arrow.is-next{right:16px}
#bfc-pdp-bag-{{ section.id }} .bfc4-dots{position:absolute;bottom:16px;left:0;right:0;display:flex;justify-content:center;gap:7px;z-index:10}
#bfc-pdp-bag-{{ section.id }} .bfc4-dot{width:7px;height:7px;background:rgba(255,255,255,0.55);border:none;cursor:pointer;padding:0;transition:background var(--t)}
#bfc-pdp-bag-{{ section.id }} .bfc4-dot.is-active{background:#fff}
#bfc-pdp-bag-{{ section.id }} .bfc4-right{flex:1;padding:36px 40px 56px;min-width:0}
@media(max-width:900px){#bfc-pdp-bag-{{ section.id }} .bfc4-right{padding:28px 20px 48px;width:100%}}
#bfc-pdp-bag-{{ section.id }} .bfc4-breadcrumb{font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--ch);margin-bottom:18px}
#bfc-pdp-bag-{{ section.id }} .bfc4-breadcrumb a{color:var(--ch);text-decoration:none}
#bfc-pdp-bag-{{ section.id }} .bfc4-breadcrumb a:hover{color:var(--or)}
#bfc-pdp-bag-{{ section.id }} .bfc4-title{font-family:var(--sd);font-weight:600;font-size:44px;line-height:1.05;letter-spacing:-0.01em}
@media(max-width:900px){#bfc-pdp-bag-{{ section.id }} .bfc4-title{font-size:36px}}
#bfc-pdp-bag-{{ section.id }} #bfc4-star-placeholder{display:block;margin-top:8px;min-height:16px}
#bfc-pdp-bag-{{ section.id }} .bfc4-color{margin-top:26px}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-head{display:flex;align-items:baseline;gap:8px;margin-bottom:10px}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-label{font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ch)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-name{font-size:12px;font-weight:500;color:var(--bk)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-row{display:flex;flex-wrap:wrap;gap:10px}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch{width:30px;height:30px;border-radius:50%;border:1px solid rgba(0,0,0,0.15);cursor:pointer;padding:0;font-size:0;color:transparent;position:relative;transition:transform var(--t),box-shadow var(--t);flex-shrink:0}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch:hover{transform:scale(1.12)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch.is-active{box-shadow:0 0 0 2px var(--bc),0 0 0 4px var(--bk)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[disabled]{cursor:not-allowed;opacity:0.65}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[disabled]::after{content:'';position:absolute;top:50%;left:-2px;right:-2px;height:1px;background:rgba(120,20,20,0.7);transform:rotate(-45deg)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="black"]{background:#1a1a1a;border-color:rgba(0,0,0,0.25)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="brown"]{background:#5e3a1f;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="tan"]{background:#b48a5d}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="khaki"]{background:#8f7d52}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="olive"]{background:#5a5a30;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="moss"]{background:#6b7340;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="sage"]{background:#9aa87f}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="forest"]{background:#2f4a2f;border-color:rgba(0,0,0,0.25)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="green"]{background:#3a5c3a;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="burgundy"]{background:#7a1f1f;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="bordeaux"]{background:#5e1a25;border-color:rgba(0,0,0,0.25)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="wine"]{background:#6e1f2c;border-color:rgba(0,0,0,0.25)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="maroon"]{background:#5d1a1a;border-color:rgba(0,0,0,0.25)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="oxblood"]{background:#4a181a;border-color:rgba(0,0,0,0.25)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="red"]{background:#c8362b}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="blue"]{background:#2b4566;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="navy"]{background:#1f2d4a;border-color:rgba(0,0,0,0.25)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="teal"]{background:#1f5a5a;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="gray"]{background:#666660}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="grey"]{background:#666660}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="charcoal"]{background:#36352f;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="cream"]{background:#e8e2d4}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="white"]{background:#f0eee6}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="ivory"]{background:#ece4cf}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="beige"]{background:#d8c8a8}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="sand"]{background:#cbb487}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="orange"]{background:#d46818}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="rust"]{background:#8a3a14;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="copper"]{background:#a8541c}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="mustard"]{background:#c8972b}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="yellow"]{background:#c8a72b}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="purple"]{background:#503966;border-color:rgba(0,0,0,0.2)}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="pink"]{background:#c97a8c}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="silver"]{background:#c4c4be}
#bfc-pdp-bag-{{ section.id }} .bfc4-color-swatch[data-color="gold"]{background:#b8932e}
#bfc-pdp-bag-{{ section.id }} .bfc4-buy{margin-top:30px;padding-top:26px;border-top:1px solid rgba(32,32,9,0.1)}
#bfc-pdp-bag-{{ section.id }} .bfc4-price-row{display:flex;align-items:baseline;gap:10px;margin-bottom:14px}
#bfc-pdp-bag-{{ section.id }} .bfc4-price{font-family:var(--sd);font-weight:600;font-size:34px;color:var(--bk)}
#bfc-pdp-bag-{{ section.id }} .bfc4-price-compare{font-size:15px;color:var(--ch);text-decoration:line-through}
#bfc-pdp-bag-{{ section.id }} .bfc4-urgency-wrap{margin:0 0 16px}
#bfc-pdp-bag-{{ section.id }} .bfc4-urgency-wrap:empty{margin:0}
#bfc-pdp-bag-{{ section.id }} .bfc4-atc{width:100%;padding:14px;background:var(--or);color:#fff;border:none;cursor:pointer;font-family:var(--sn);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.14em;transition:background var(--t)}
#bfc-pdp-bag-{{ section.id }} .bfc4-atc:hover:not([disabled]){background:#c9600f}
#bfc-pdp-bag-{{ section.id }} .bfc4-atc[disabled]{opacity:0.5;cursor:not-allowed}
#bfc-pdp-bag-{{ section.id }} .bfc4-atc.is-success{background:#2a4820 !important}
#bfc-pdp-bag-{{ section.id }} .bfc4-desc{margin-top:24px;font-size:14px;line-height:1.65;color:var(--ch)}
#bfc-pdp-bag-{{ section.id }} .bfc4-desc p{margin-bottom:12px}#bfc-pdp-bag-{{ section.id }} .bfc4-desc p:last-child{margin-bottom:0}
#bfc-pdp-bag-{{ section.id }} .bfc4-desc ul,#bfc-pdp-bag-{{ section.id }} .bfc4-desc ol{margin:0 0 12px 18px}
#bfc-pdp-bag-{{ section.id }} .bfc4-desc a{color:var(--or)}
#bfc-pdp-bag-{{ section.id }} .bfc4-policies{margin-top:26px;border-top:1px solid rgba(32,32,9,0.1)}
#bfc-pdp-bag-{{ section.id }} .bfc4-policy{border-bottom:1px solid rgba(32,32,9,0.08)}
#bfc-pdp-bag-{{ section.id }} .bfc4-policy summary{display:flex;align-items:center;justify-content:space-between;padding:14px 0;font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--bk);cursor:pointer;list-style:none;user-select:none}
#bfc-pdp-bag-{{ section.id }} .bfc4-policy summary::-webkit-details-marker{display:none}
#bfc-pdp-bag-{{ section.id }} .bfc4-policy summary::after{content:'+';font-size:15px;font-weight:400;opacity:.4}
#bfc-pdp-bag-{{ section.id }} .bfc4-policy[open] summary::after{content:'\2212'}
#bfc-pdp-bag-{{ section.id }} .bfc4-policy-body{padding:0 0 14px;font-size:13px;line-height:1.6;color:var(--ch)}
#bfc-pdp-bag-{{ section.id }} .bfc4-policy-body a{color:var(--or)}
#bfc-pdp-bag-{{ section.id }} .bfc4-sticky-bar{position:fixed;left:0;right:0;bottom:0;z-index:50;background:var(--bc);border-top:1px solid rgba(32,32,9,0.12);display:flex;align-items:center;justify-content:space-between;gap:16px;padding:12px 24px;transform:translateY(110%);transition:transform 0.3s ease;box-shadow:0 -4px 20px rgba(0,0,0,0.06)}
#bfc-pdp-bag-{{ section.id }} .bfc4-sticky-bar.is-visible{transform:translateY(0)}
#bfc-pdp-bag-{{ section.id }} .bfc4-sticky-info{display:flex;flex-direction:column;gap:2px;min-width:0}
#bfc-pdp-bag-{{ section.id }} .bfc4-sticky-title{font-family:var(--sd);font-size:16px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
#bfc-pdp-bag-{{ section.id }} .bfc4-sticky-price{font-size:13px;font-weight:600;color:var(--or)}
#bfc-pdp-bag-{{ section.id }} .bfc4-sticky-btn{background:var(--or);color:#fff;border:none;padding:12px 28px;font-size:10px;font-weight:600;font-family:var(--sn);text-transform:uppercase;letter-spacing:0.14em;cursor:pointer;white-space:nowrap;flex-shrink:0}
#bfc-pdp-bag-{{ section.id }} .bfc4-sticky-btn:disabled{opacity:0.5;cursor:not-allowed}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail{padding:48px 40px 8px;border-top:1px solid rgba(32,32,9,0.1)}
@media(max-width:900px){#bfc-pdp-bag-{{ section.id }} .bfc4-rail{padding:36px 20px 8px}}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-head{font-family:var(--sd);font-weight:600;font-size:26px;line-height:1.1;margin-bottom:22px}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-track{display:flex;gap:18px;overflow-x:auto;scroll-snap-type:x mandatory;padding-bottom:16px;-webkit-overflow-scrolling:touch}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-track::-webkit-scrollbar{height:5px}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-track::-webkit-scrollbar-thumb{background:rgba(32,32,9,0.18)}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-card{flex:0 0 auto;width:200px;scroll-snap-align:start;text-decoration:none;color:var(--bk);display:block}
@media(max-width:900px){#bfc-pdp-bag-{{ section.id }} .bfc4-rail-card{width:156px}}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-img{width:100%;aspect-ratio:1/1;background:var(--gr);overflow:hidden}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-img img{width:100%;height:100%;object-fit:cover;display:block;transition:transform var(--t)}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-card:hover .bfc4-rail-img img{transform:scale(1.04)}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-name{font-size:13px;font-weight:500;line-height:1.3;margin-top:10px}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-card:hover .bfc4-rail-name{color:var(--or)}
#bfc-pdp-bag-{{ section.id }} .bfc4-rail-price{font-size:12px;color:var(--ch);margin-top:3px}
#bfc-pdp-bag-{{ section.id }} .bfc4-lightbox{display:none;position:fixed;inset:0;background:rgba(32,32,9,0.92);z-index:200;align-items:center;justify-content:center;cursor:zoom-out}
#bfc-pdp-bag-{{ section.id }} .bfc4-lightbox.is-open{display:flex}
#bfc-pdp-bag-{{ section.id }} .bfc4-lightbox img{max-width:90vw;max-height:90vh;object-fit:contain}
#bfc-pdp-bag-{{ section.id }} .bfc4-lightbox-close{position:absolute;top:16px;right:20px;background:none;border:none;color:rgba(255,255,255,0.6);font-size:28px;cursor:pointer}
</style>

<div id="bfc-pdp-bag-{{ section.id }}">
<div class="bfc4">
<div class="bfc4-split">

  <div class="bfc4-left" id="bfc4-top">
    {%- assign media_images = product.media | where: 'media_type', 'image' -%}
    {%- assign total_slides = media_images | size -%}
    <div class="bfc4-slides" id="bfc4-slides">
      {%- for media in media_images limit: 12 -%}
        <div class="bfc4-slide" data-media-id="{{ media.id }}" data-img-key="{{ media.preview_image.src | default: media.src | split: '?' | first | split: '/' | last | downcase }}">
          <img src="{{ media | image_url: width: 900 }}"
            srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 900px) 100vw, 50vw"
            alt="{{ media.alt | default: product.title | escape }}" width="900" height="900"
            onclick="bfc4BagLightbox('{{ media | image_url: width: 1800 }}')"
            {%- if forloop.index <= 2 -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}>
        </div>
      {%- endfor -%}
    </div>
    {%- if total_slides > 1 -%}
      <button class="bfc4-arrow is-prev" onclick="bfc4BagSlide(-1)" aria-label="Previous"><svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8L10 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg></button>
      <button class="bfc4-arrow is-next" onclick="bfc4BagSlide(1)" aria-label="Next"><svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 3L11 8L6 13" stroke="white" stroke-width="1.5" stroke-linecap="square"/></svg></button>
      <div class="bfc4-dots" id="bfc4-dots">
        {%- for i in (1..total_slides) -%}<button class="bfc4-dot{% if forloop.first %} is-active{% endif %}" onclick="bfc4BagGoTo({{ forloop.index0 }})" aria-label="Slide {{ forloop.index }}"></button>{%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="bfc4-right">
    <nav class="bfc4-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> / {% if crumb_coll %}<a href="{{ crumb_coll.url }}">{{ crumb_coll.title }}</a> / {% endif %}{{ product.title }}
    </nav>

    <h1 class="bfc4-title">{{ product.title }}</h1>
    <div id="bfc4-star-placeholder"></div>

    {%- if color_opt_idx != null -%}
      <div class="bfc4-color">
        <div class="bfc4-color-head">
          <span class="bfc4-color-label">{{ color_opt_name }}</span>
          <span class="bfc4-color-name" id="bfc4-color-name">{{ current_color }}</span>
        </div>
        <div class="bfc4-color-row">
          {%- for v_value in color_opt_obj.values -%}
            {%- assign v_available = false -%}
            {%- for var in product.variants -%}
              {%- if var.options[color_opt_idx] == v_value and var.available -%}{%- assign v_available = true -%}{%- endif -%}
            {%- endfor -%}
            {%- comment -%} Smart color: scan each word of the value for a known color (e.g. "Chili Red" -> red) {%- endcomment -%}
            {%- assign v_color = '' -%}
            {%- assign v_words = v_value | downcase | replace: '/', ' ' | replace: '-', ' ' | split: ' ' -%}
            {%- for kc in known_colors -%}
              {%- if v_color != '' -%}{%- break -%}{%- endif -%}
              {%- for w in v_words -%}
                {%- if w == kc -%}{%- assign v_color = kc -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
            {%- if v_color == '' -%}{%- assign v_color = v_value | downcase | split: ' ' | first -%}{%- endif -%}
            <button type="button" class="bfc4-color-swatch{% if v_value == current_color %} is-active{% endif %}"
              data-color="{{ v_color }}" data-color-value="{{ v_value | escape }}" data-opt-index="{{ color_opt_idx }}"
              onclick="bfc4BagSelectColor(this)" title="{{ v_value | escape }}{% unless v_available %} (sold out){% endunless %}"
              aria-label="{{ color_opt_name }}: {{ v_value | escape }}"{% unless v_available %} disabled{% endunless %}>{{ v_value }}</button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="bfc4-buy">
      <div class="bfc4-price-row">
        <span class="bfc4-price" id="bfc4-price">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}<span class="bfc4-price-compare" id="bfc4-price-compare">{{ current_variant.compare_at_price | money }}</span>{%- endif -%}
      </div>
      <div class="bfc4-urgency-wrap">
        {% render 'bfc-pdp-urgency', variant: current_variant, handle: product.handle, show_trust: false, price: current_variant.price %}
      </div>
      <button class="bfc4-atc" id="bfc4-atc" onclick="bfc4BagATC()"{% unless current_variant.available %} disabled{% endunless %}>
        <span id="bfc4-atc-text">{% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}</span>
      </button>
    </div>

    {%- assign desc_plain = product.description | strip_html | strip -%}
    {%- if desc_plain != blank -%}
      <div class="bfc4-desc">{{ product.description }}</div>
    {%- endif -%}

    <div class="bfc4-policies">
      <details class="bfc4-policy">
        <summary>Shipping</summary>
        <div class="bfc4-policy-body">Most orders ship same day from our Brooklyn shop. Domestic delivery via USPS or UPS typically arrives in 2-4 business days. Free shipping on US orders over $399. In-store pickup at 855 Grand Street is always free.</div>
      </details>
      <details class="bfc4-policy">
        <summary>Returns</summary>
        <div class="bfc4-policy-body">Unopened accessories and gear can be returned within 14 days of delivery. Items must be in original condition. Contact <a href="mailto:hello@brooklynfilmcamera.com">hello@brooklynfilmcamera.com</a> to start a return.</div>
      </details>
      <details class="bfc4-policy">
        <summary>Questions?</summary>
        <div class="bfc4-policy-body">Email <a href="mailto:hello@brooklynfilmcamera.com">hello@brooklynfilmcamera.com</a> or stop by the shop — we're open every day. You can also browse our <a href="https://brooklynfilmcamera.com/pages/faq">FAQ</a>. We're happy to help you find the right thing.</div>
      </details>
    </div>
  </div>

</div>

{%- assign rail_shown = 0 -%}
{%- capture rail_cards -%}
  {%- for block in section.blocks -%}
    {%- if block.type != 'rail_product' -%}{%- continue -%}{%- endif -%}
    {%- assign rp = block.settings.product -%}
    {%- if rp == blank -%}{%- continue -%}{%- endif -%}
    {%- unless rp.available -%}{%- continue -%}{%- endunless -%}
    {%- if rp.id == product.id -%}{%- continue -%}{%- endif -%}
    {%- assign rail_shown = rail_shown | plus: 1 -%}
    <a href="{{ rp.url }}" class="bfc4-rail-card" {{ block.shopify_attributes }}>
      <div class="bfc4-rail-img">{%- if rp.featured_image -%}<img src="{{ rp.featured_image | image_url: width: 400 }}" alt="{{ rp.title | escape }}" loading="lazy" width="400" height="400">{%- endif -%}</div>
      <div class="bfc4-rail-name">{{ rp.title }}</div>
      <div class="bfc4-rail-price">{%- if rp.price_varies -%}from {% endif -%}{{ rp.price_min | money }}</div>
    </a>
  {%- endfor -%}
{%- endcapture -%}
{%- if rail_shown > 0 -%}
  <div class="bfc4-rail">
    <h2 class="bfc4-rail-head">{{ section.settings.rail_title | default: 'Need something to go with it?' }}</h2>
    <div class="bfc4-rail-track">{{ rail_cards }}</div>
  </div>
{%- endif -%}

</div>

{%- comment -%} Reviews rendered OUTSIDE the bag wrapper so the scoped .bfc4 reset CSS does not leak into the reviews section {%- endcomment -%}
{% render 'bfc-pdp-reviews', pdp_handle: product.handle, pdp_title: product.title %}

<div class="bfc4-lightbox" id="bfc4-lightbox" onclick="bfc4BagCloseLightbox()">
  <button class="bfc4-lightbox-close" onclick="bfc4BagCloseLightbox()" aria-label="Close">&times;</button>
  <img id="bfc4-lightbox-img" alt="">
</div>

<div class="bfc4-sticky-bar" id="bfc4-sticky-bar" style="display:none">
  <div class="bfc4-sticky-info">
    <span class="bfc4-sticky-title">{{ product.title }}</span>
    <span class="bfc4-sticky-price" id="bfc4-sticky-price">{{ current_variant.price | money }}</span>
  </div>
  <button class="bfc4-sticky-btn" id="bfc4-sticky-btn" onclick="bfc4BagATC()"{% unless current_variant.available %} disabled{% endunless %}>{% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}</button>
</div>

{%- assign bfc4_form_id = 'bfc4-bag-form-' | append: section.id -%}
<div style="display:none">
  <product-form class="product-form" data-hide-errors="false" data-section-id="{{ section.id }}">
    {%- form 'product', product, id: bfc4_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id" id="bfc4-variant-input"/>
      <div class="product-form__buttons" data-display-quantity="false">
        <button id="ProductSubmitButton-{{ section.id }}" type="submit" name="add" class="product-form__submit button button--filled"><span>Add to Cart</span></button>
      </div>
      <div class="product-form__error-message-wrapper" role="alert" hidden><span class="product-form__error-message"></span></div>
    {%- endform -%}
  </product-form>
</div>

</div>

<script>
(function(){
  var SECTION='{{ section.id }}';
  window.__bfcBagVariants=[
    {%- for v in product.variants -%}
    { id:{{ v.id }}, price_fmt:{{ v.price | money | json }}, compare_fmt:{{ v.compare_at_price | money | json }}, has_compare:{% if v.compare_at_price > v.price %}true{% else %}false{% endif %}, available:{{ v.available }}, options:[{% for o in v.options %}{{ o | json }}{% unless forloop.last %},{% endunless %}{% endfor %}], featured_media_id:{% if v.featured_media %}{{ v.featured_media.id }}{% else %}null{% endif %}, featured_image_src:{% if v.featured_image %}{{ v.featured_image.src | json }}{% else %}null{% endif %} }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
  var STATE={variantId:{{ current_variant.id }}};
  var root=document.getElementById('bfc-pdp-bag-'+SECTION);
  if(!root)return;

  var slidesEl=document.getElementById('bfc4-slides');
  var slideTotal=root.querySelectorAll('.bfc4-slide').length, slideCur=0;
  window.bfc4BagSlide=function(d){if(slideTotal<=1)return;bfc4BagGoTo((slideCur+d+slideTotal)%slideTotal);};
  window.bfc4BagGoTo=function(i){slideCur=i;if(slidesEl)slidesEl.style.transform='translateX(-'+(i*100)+'%)';root.querySelectorAll('.bfc4-dot').forEach(function(d,j){d.classList.toggle('is-active',j===i);});var p=root.querySelector('.bfc4-arrow.is-prev');if(p)p.style.visibility=i===0?'hidden':'visible';};
  (function(){var l=root.querySelector('.bfc4-left');if(!l||slideTotal<=1)return;var sx=0;l.addEventListener('touchstart',function(e){sx=e.touches[0].clientX;},{passive:true});l.addEventListener('touchend',function(e){var dx=e.changedTouches[0].clientX-sx;if(Math.abs(dx)>40)bfc4BagSlide(dx<0?1:-1);});})();
  (function(){function pl(){root.querySelectorAll('.bfc4-slide img[loading="lazy"]').forEach(function(im){if(im.dataset.pp)return;im.dataset.pp='1';var p=new Image();if(im.srcset)p.srcset=im.srcset;p.src=im.currentSrc||im.src;im.loading='eager';});}if('requestIdleCallback' in window){requestIdleCallback(pl,{timeout:2000});}else{window.addEventListener('load',function(){setTimeout(pl,300);});}})();

  function jumpImg(vid, colorVal){
    var v=window.__bfcBagVariants.find(function(x){return x.id===vid;});
    if(!v)return;
    var sl=root.querySelectorAll('.bfc4-slide');
    // 1) exact media id match (variant featured media)
    if(v.featured_media_id){
      for(var i=0;i<sl.length;i++){
        if(String(sl[i].dataset.mediaId)===String(v.featured_media_id)){bfc4BagGoTo(i);return;}
      }
    }
    // 2) match by the variant's featured image filename
    if(v.featured_image_src){
      var fname=String(v.featured_image_src).split('?')[0].split('/').pop().toLowerCase();
      for(var j=0;j<sl.length;j++){
        if(sl[j].dataset.imgKey && fname && sl[j].dataset.imgKey===fname){bfc4BagGoTo(j);return;}
      }
    }
    // 3) fallback: match the color word inside the slide image filename
    if(colorVal){
      var cw=String(colorVal).toLowerCase().replace(/[^a-z]+/g,'');
      if(cw){
        for(var k=0;k<sl.length;k++){
          var key=(sl[k].dataset.imgKey||'').replace(/[^a-z]+/g,'');
          if(key && key.indexOf(cw)!==-1){bfc4BagGoTo(k);return;}
        }
      }
    }
  }

  window.bfc4BagSelectColor=function(btn){
    if(btn.disabled)return;
    var nc=btn.dataset.colorValue,oi=parseInt(btn.dataset.optIndex,10);
    root.querySelectorAll('.bfc4-color-swatch').forEach(function(b){b.classList.remove('is-active');});
    btn.classList.add('is-active');
    var nm=document.getElementById('bfc4-color-name');if(nm)nm.textContent=nc;
    var cur=window.__bfcBagVariants.find(function(v){return v.id===STATE.variantId;});if(!cur)return;
    var no=cur.options.slice();no[oi]=nc;
    var m=window.__bfcBagVariants.find(function(v){for(var i=0;i<no.length;i++){if(v.options[i]!==no[i])return false;}return true;});
    if(!m)return;
    STATE.variantId=m.id;
    var inp=document.getElementById('bfc4-variant-input');if(inp)inp.value=m.id;
    var pe=document.getElementById('bfc4-price');if(pe)pe.textContent=m.price_fmt;
    var sp=document.getElementById('bfc4-sticky-price');if(sp)sp.textContent=m.price_fmt;
    var ce=document.getElementById('bfc4-price-compare');if(ce){ce.textContent=m.has_compare?m.compare_fmt:'';ce.style.display=m.has_compare?'':'none';}
    var atc=document.getElementById('bfc4-atc'),at=document.getElementById('bfc4-atc-text'),sb=document.getElementById('bfc4-sticky-btn');
    if(atc)atc.disabled=!m.available;if(sb)sb.disabled=!m.available;if(at)at.textContent=m.available?'Add to Cart':'Sold Out';
    jumpImg(m.id, nc);
  };

  var _adding=false;
  window.bfc4BagATC=function(){
    if(_adding)return;
    var cur=window.__bfcBagVariants.find(function(v){return v.id===STATE.variantId;});
    if(!cur||!cur.available)return;
    _adding=true;
    var t=document.getElementById('bfc4-atc-text'),mb=document.getElementById('bfc4-atc'),sb=document.getElementById('bfc4-sticky-btn');
    function reset(){if(t)t.textContent='Add to Cart';if(mb){mb.disabled=false;mb.classList.remove('is-success');}if(sb){sb.disabled=false;sb.textContent='Add to Cart';sb.style.background='';}_adding=false;}
    if(mb)mb.disabled=true;if(sb)sb.disabled=true;if(t)t.textContent='Adding\u2026';if(sb)sb.textContent='Adding\u2026';
    var s=document.getElementById('ProductSubmitButton-'+SECTION);
    if(!s){reset();return;}
    try{s.click();if(mb)mb.classList.add('is-success');if(t)t.textContent='Added!';if(sb){sb.textContent='Added!';sb.style.background='#2a4820';}setTimeout(reset,2400);}catch(e){reset();}
  };

  window.bfc4BagLightbox=function(src){var lb=document.getElementById('bfc4-lightbox'),im=document.getElementById('bfc4-lightbox-img');if(!lb||!im)return;im.src=src;lb.classList.add('is-open');document.body.style.overflow='hidden';};
  window.bfc4BagCloseLightbox=function(){var lb=document.getElementById('bfc4-lightbox');if(!lb)return;lb.classList.remove('is-open');document.body.style.overflow='';};
  document.addEventListener('keydown',function(e){if(e.key==='Escape')bfc4BagCloseLightbox();});

  var bar=document.getElementById('bfc4-sticky-bar'),atcB=document.getElementById('bfc4-atc');
  if(bar)bar.style.display='';
  if(bar&&atcB){new IntersectionObserver(function(es){es.forEach(function(e){bar.classList.toggle('is-visible',!e.isIntersecting);});},{threshold:0}).observe(atcB);}
  if(bar){var hide=function(){bar.classList.remove('is-visible');};document.addEventListener('click',function(e){if(e.target.closest('a[href="/cart"],a[href^="/cart?"],[data-cart-icon],[data-cart-toggle]'))hide();},true);['cart:open','cart-drawer:open','drawer:open'].forEach(function(ev){document.addEventListener(ev,hide);});}

  bfc4BagGoTo(0);
})();
</script>

{%- render 'bfc-product-schema' -%}

{% schema %}
{
  "name": "BFC Bag PDP",
  "tag": "section",
  "class": "bfc-bag-section",
  "settings": [
    { "type": "header", "content": "Breadcrumb" },
    { "type": "collection", "id": "breadcrumb_collection", "label": "Breadcrumb collection", "info": "e.g. Bags & Cases. If blank, uses the product's first collection." },
    { "type": "header", "content": "Cross-sell Rail" },
    { "type": "text", "id": "rail_title", "label": "Rail heading", "default": "Need something to go with it?" },
    { "type": "paragraph", "content": "Add products with the 'Rail product' blocks below. Drag to reorder. Out-of-stock products are hidden automatically." }
  ],
  "blocks": [
    { "type": "@app" },
    { "type": "rail_product", "name": "Rail product", "settings": [ { "type": "product", "id": "product", "label": "Product" } ] }
  ],
  "presets": [ { "name": "BFC Bag PDP" } ],
  "templates": ["product"]
}
{% endschema %}
