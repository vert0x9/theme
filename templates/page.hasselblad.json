    "custom_liquid_nkNTfN": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\nFilm Developing Membership — Custom Liquid Mockup (UPDATED with membership + credits)\n- Pulls both membership metafield (Memberships) and credits metafield (Custom Credits)\n- Expects JSON for both, e.g.:\n   Memberships: {\"563\":{\"name\":\"Film Developing Club\",\"validuntil\":\"2025-10-04\"}}\n   Custom Credits: {\"281\":{\"name\":\"FILM DEVELOPING CLUB (1M) Bonus 1\",\"count\":4}}\n- Will show membership name + valid date, then list credits.\n{%- endcomment -%}\n\n{%- assign HERO_IMAGE_HANDLE = 'lab-hero.jpg' -%}\n{%- assign HERO_IMAGE_URL = HERO_IMAGE_HANDLE | file_url -%}\n\n<div class=\"bfc-root\">\n\n  <!-- HERO -->\n  <section class=\"bfc-efc-hero bfc-dev-hero\" aria-labelledby=\"bfc-dev-hero-heading\">\n    <div class=\"bfc-efc-hero__bg\" aria-hidden=\"true\"></div>\n\n    <div class=\"bfc-efc-hero__wrap\">\n      <div class=\"bfc-efc-hero__grid\">\n        <!-- COPY -->\n        <div class=\"bfc-efc-hero__copy\">\n          <span class=\"bfc-pill\">Fast & reliable in NYC</span>\n\n          <h1 id=\"bfc-dev-hero-heading\" class=\"bfc-efc-hero__title\">Film Developing Membership</h1>\n\n          <p class=\"bfc-efc-hero__sub\">\n            Now offering in-house film developing. Film is dropped off to our lab every Tuesday, Thursday, and Saturday and returned the same days. Typical turnaround is 2–3 days total (20–24 hrs at the lab). B&amp;W +48 hrs. Noritsu 1800 scans, private portal delivery. (No E-6, ECN-2, or push/pull at this time.)\n          </p>\n\n          <div class=\"bfc-efc-hero__ctas\">\n            <a class=\"bfc-btn bfc-btn--filled\" href=\"#memberships\">Join the Membership</a>\n            <a class=\"bfc-btn bfc-btn--outline\" href=\"#member-credits\">Already a member? View your credits</a>\n          </div>\n        </div>\n\n        <!-- MEDIA -->\n        <div class=\"bfc-efc-hero__media\">\n          <figure class=\"bfc-media-card\">\n            <img class=\"bfc-media-card__img\" src=\"{{ HERO_IMAGE_URL }}\" alt=\"Film developing at Brooklyn Film Camera\" loading=\"eager\">\n          </figure>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- MEMBER STATUS & CREDITS VIEWER -->\n    <!-- MEMBER STATUS & CREDITS VIEWER -->\n  <section id=\"member-credits\" class=\"bfc-credits\" aria-labelledby=\"bfc-credits-heading\">\n    <div class=\"bfc-credits__wrap\">\n      <h2 id=\"bfc-credits-heading\" class=\"bfc-subscribe__title\">Your Membership & Credits</h2>\n\n      {%- comment -%}\n        We attempt multiple likely metafield paths based on your definitions (\"Memberships\" and \"Custom Credits\").\n        MEMBERSHIP candidates (first that exists wins):\n          • customer.metafields.fdc.membership\n          • customer.metafields.memberships.membership\n          • customer.metafields.memberships.data\n          • customer.metafields.memberships.memberships\n        CREDITS candidates:\n          • customer.metafields.fdc.credits\n          • customer.metafields.custom_credits.credits\n          • customer.metafields.custom.credits\n          • customer.metafields.credits.data\n        Values are expected as JSON objects like:\n          membership ⇒ {\"563\":{\"name\":\"Film Developing Club\",\"validuntil\":\"2025-10-04\"}}\n          credits    ⇒ {\"281\":{\"name\":\"FILM DEVELOPING CLUB (1M) Bonus 1\",\"count\":4}}\n      {%- endcomment -%}\n\n      {%- if customer -%}\n        {%- comment -%} Resolve MEMBERSHIP metafield {%- endcomment -%}\n        {%- assign membership_mf = nil -%}\n        {%- if customer.metafields.fdc and customer.metafields.fdc.membership %}{% assign membership_mf = customer.metafields.fdc.membership %}{% endif %}\n        {%- if membership_mf == nil and customer.metafields.memberships and customer.metafields.memberships.membership %}{% assign membership_mf = customer.metafields.memberships.membership %}{% endif %}\n        {%- if membership_mf == nil and customer.metafields.memberships and customer.metafields.memberships.data %}{% assign membership_mf = customer.metafields.memberships.data %}{% endif %}\n        {%- if membership_mf == nil and customer.metafields.memberships and customer.metafields.memberships.memberships %}{% assign membership_mf = customer.metafields.memberships.memberships %}{% endif %}\n\n        {%- comment -%} Resolve CREDITS metafield {%- endcomment -%}\n        {%- assign credits_mf = nil -%}\n        {%- if customer.metafields.fdc and customer.metafields.fdc.credits %}{% assign credits_mf = customer.metafields.fdc.credits %}{% endif %}\n        {%- if credits_mf == nil and customer.metafields.custom_credits and customer.metafields.custom_credits.credits %}{% assign credits_mf = customer.metafields.custom_credits.credits %}{% endif %}\n        {%- if credits_mf == nil and customer.metafields.custom and customer.metafields.custom.credits %}{% assign credits_mf = customer.metafields.custom.credits %}{% endif %}\n        {%- if credits_mf == nil and customer.metafields.credits and customer.metafields.credits.data %}{% assign credits_mf = customer.metafields.credits.data %}{% endif %}\n\n        {%- comment -%} Parse JSON values {%- endcomment -%}\n        {%- assign membership = membership_mf.value -%}\n        {%- if membership == blank and membership_mf -%}\n          {%- assign membership = membership_mf | parse_json -%}\n        {%- endif -%}\n        {%- assign credits = credits_mf.value -%}\n        {%- if credits == blank and credits_mf -%}\n          {%- assign credits = credits_mf | parse_json -%}\n        {%- endif -%}\n\n        {%- comment -%}\n          ===== Membership Card =====\n        {%- endcomment -%}\n        {%- if membership -%}\n          {%- assign now_s = 'now' | date: '%s' -%}\n          {%- assign first_pair = membership | first -%}\n          {%- assign first_key  = first_pair[0] -%}\n          {%- assign mem_item   = membership[first_key] -%}\n          {%- assign plan_name  = mem_item.name | default: first_key -%}\n          {%- assign plan_name_down = plan_name | downcase -%}\n          {%- assign vu_s = mem_item.validuntil | date: '%s' -%}\n          {%- assign is_active = vu_s | minus: now_s | plus: 0 -%}\n\n          <div class=\"bfc-credits__grid\">\n            <article class=\"bfc-credits__card\">\n              <h3 class=\"bfc-credits__plan\">{{ plan_name }}</h3>\n              <p class=\"bfc-credits__count\">\n                Status:\n                {%- if is_active > 0 -%}\n                  <strong>Active</strong>\n                {%- else -%}\n                  <strong>Expired</strong>\n                {%- endif -%}\n                {%- if mem_item.validuntil %} — valid until {{ mem_item.validuntil | date: '%b %d, %Y' }}{% endif -%}\n              </p>\n              <ul class=\"bfc-perks\">\n                {%- if plan_name_down contains 'film developing club (1m)' -%}\n                  <li>3 free developing credits every month</li>\n                  <li>Member dashboard & credit tracking</li>\n                {%- else -%}\n                  <li>Member benefits apply per your plan</li>\n                  <li>High‑res scans / priority may apply on higher tiers</li>\n                {%- endif -%}\n              </ul>\n            </article>\n          </div>\n        {%- else -%}\n          <div class=\"bfc-credits__empty\">\n            <p>You don’t have an active membership.</p>\n            <a class=\"bfc-btn bfc-btn--filled\" href=\"#memberships\">See memberships</a>\n          </div>\n        {%- endif -%}\n\n        {%- comment -%}\n          ===== Credits Grid =====\n        {%- endcomment -%}\n        {%- if credits -%}\n          {%- assign total_count = 0 -%}\n          <div class=\"bfc-credits__grid\" style=\"margin-top:12px;\">\n            {%- for pair in credits -%}\n              {%- assign key = pair[0] -%}\n              {%- assign item = pair[1] -%}\n              <article class=\"bfc-credits__card\">\n                <h3 class=\"bfc-credits__plan\">{{ item.name | default: key }}</h3>\n                <p class=\"bfc-credits__count\"><strong>{{ item.count | default: 0 }}</strong> credits</p>\n              </article>\n              {%- assign c = item.count | default: 0 -%}\n              {%- assign total_count = total_count | plus: c -%}\n            {%- endfor -%}\n          </div>\n          <p class=\"bfc-credits__summary\">Total available: <strong>{{ total_count }}</strong> credits</p>\n        {%- elsif credits_mf and credits_mf != blank -%}\n          <div class=\"bfc-credits__empty\">\n            <p>We found a credits record, but it isn’t valid JSON yet:</p>\n            <pre class=\"bfc-pre\">{{ credits_mf }}</pre>\n          </div>\n        {%- endif -%}\n\n      {%- else -%}\n        <div class=\"bfc-credits__empty\">\n          <p>Please <a href=\"/account/login\">log in</a> to view your membership and credits.</p>\n        </div>\n      {%- endif -%}\n    </div>\n  </section>\n\n</div>",
        "section_width": "max-w-page",
        "color_scheme": "",
        "spacing_top": "2",
        "spacing_bottom": "2"
      }
    },
