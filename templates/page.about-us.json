      "name": "t:sections.seo-content.name",
      "settings": {
        "section_layout": "normal",
        "heading": "<em>A team you can trust</em>",
        "heading_size": "h3",
        "text": "<p>Meet BFC! We are a small team of dedicated photographers and creatives who are trying to make the film community better. We are all passionate about growing our products and providing the best care possible for your cameras. <br/><br/>We have a team of professionally trained camera technicians, experienced business professionals, and passionate camera enthusiasts, all working together to provide expert service and exceptional care for every camera that comes through our doors.<br/><br/>Are you interested in joining our team? <a href=\"/pages/open-positions\" title=\"Open Positions\">See our open positions here </a></p>",
        "content_alignment": "center",
        "section_width": "max-w-narrower",
        "color_scheme": "",
        "spacing_inner": "2",
        "spacing_top": "2",
        "spacing_bottom": "2"
      }
    },
