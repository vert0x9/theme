      "name": "t:sections.custom-liquid.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\nBFC Open Positions — Custom Liquid section\nRedesigned with BFC brand system: Cormorant Garamond + Poppins,\nSuper Orange accent, Blank Canvas background.\n{%- endcomment -%}\n\n<div id=\"bfc-openings-{{ section.id }}\" class=\"bfc-openings\" role=\"region\" aria-label=\"Open Positions\">\n\n  <div class=\"bfc-header\">\n    <p class=\"bfc-eyebrow\">Brooklyn Film Camera</p>\n    <h1 class=\"bfc-title\">Open<br>Positions</h1>\n    <div class=\"bfc-rule\" aria-hidden=\"true\"></div>\n  </div>\n\n  <!-- Tabs -->\n  <div class=\"bfc-tabs\" role=\"tablist\" aria-label=\"Open Positions Categories\">\n    <button type=\"button\" id=\"tab-fulltime-{{ section.id }}\" class=\"bfc-tab\" role=\"tab\" data-tab=\"fulltime\"\n      aria-controls=\"panel-fulltime-{{ section.id }}\" aria-selected=\"false\">\n      <span class=\"bfc-tab-label\">Full Time</span>\n      <span class=\"bfc-tab-count\" aria-label=\"0 open roles\">0</span>\n    </button>\n    <button type=\"button\" id=\"tab-parttime-{{ section.id }}\" class=\"bfc-tab\" role=\"tab\" data-tab=\"parttime\"\n      aria-controls=\"panel-parttime-{{ section.id }}\" aria-selected=\"false\">\n      <span class=\"bfc-tab-label\">Part Time</span>\n      <span class=\"bfc-tab-count\" aria-label=\"1 open role\">1</span>\n    </button>\n    <button type=\"button\" id=\"tab-other-{{ section.id }}\" class=\"bfc-tab\" role=\"tab\" data-tab=\"other\"\n      aria-controls=\"panel-other-{{ section.id }}\" aria-selected=\"false\">\n      <span class=\"bfc-tab-label\">Other</span>\n      <span class=\"bfc-tab-count\" aria-label=\"1 open role\">1</span>\n    </button>\n  </div>\n\n  <!-- ═══════════════════ FULL TIME ═══════════════════ -->\n  <section class=\"bfc-panel\" id=\"panel-fulltime-{{ section.id }}\" role=\"tabpanel\"\n    aria-labelledby=\"tab-fulltime-{{ section.id }}\" hidden>\n    <div class=\"bfc-stack\">\n      <article class=\"bfc-card bfc-card--empty\">\n        <div class=\"bfc-empty-icon\" aria-hidden=\"true\">—</div>\n        <h3 class=\"bfc-empty-title\">No full time roles right now</h3>\n        <p class=\"bfc-muted\">\n          Check back soon, or send a quick intro to\n          <a href=\"mailto:hello@brooklynfilmcamera.com\">hello@brooklynfilmcamera.com</a>.\n        </p>\n      </article>\n    </div>\n  </section>\n\n  <!-- ═══════════════════ PART TIME ═══════════════════ -->\n  <section class=\"bfc-panel\" id=\"panel-parttime-{{ section.id }}\" role=\"tabpanel\"\n    aria-labelledby=\"tab-parttime-{{ section.id }}\" hidden>\n    <div class=\"bfc-stack\">\n\n      <article class=\"bfc-card bfc-accordion\" data-listing=\"true\">\n        <header class=\"bfc-card-head\">\n          <button class=\"bfc-accordion-toggle\" type=\"button\" aria-expanded=\"false\"\n            aria-controls=\"photog-content-{{ section.id }}\">\n            <div class=\"bfc-card-title-block\">\n              <span class=\"bfc-role-title\">Product Photographer</span>\n              <span class=\"bfc-meta-row\">\n                <span class=\"bfc-tag\">Part Time / Freelance</span>\n                <span class=\"bfc-tag\">Williamsburg HQ</span>\n                <span class=\"bfc-tag\">On Site</span>\n              </span>\n            </div>\n            <svg class=\"bfc-caret\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n              <path d=\"M7 10l5 5 5-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\"\n                stroke-linejoin=\"round\"></path>\n            </svg>\n          </button>\n        </header>\n\n        <div id=\"photog-content-{{ section.id }}\" class=\"bfc-accordion-content\" hidden>\n          <div class=\"bfc-card-text\">\n            <p class=\"bfc-intro\">\n              We're hiring a product photographer to shoot vintage and refurbished cameras, film,\n              and accessories for our product display pages across Shopify, Etsy, and eBay. Shoots\n              run on a regular cadence. This role starts as PDP product photography and could grow\n              into more editorial and creative work. Rate depends on structure.\n            </p>\n\n            <h4>Responsibilities</h4>\n            <ul>\n              <li>Light and shoot cameras and accessories in our studio using Profoto strobe lighting</li>\n              <li>Shoot tethered in Capture One; handle capture, culling, and color</li>\n              <li>Edit, retouch, and composite in Photoshop</li>\n              <li>Match the look and style of our existing PDP photography so listings stay consistent</li>\n              <li>Deliver catalog-ready images with consistent quality</li>\n              <li>Keep the studio and gear organized during and after shoots</li>\n            </ul>\n\n            <h4>Requirements</h4>\n            <ul>\n              <li>Proven Profoto strobe lighting experience for product work</li>\n              <li>Strong product photography portfolio</li>\n              <li>Proficient in Capture One, including tethered shooting</li>\n              <li>Strong Photoshop skills: layering, compositing, masking, retouching</li>\n              <li>Able to study existing photography and emulate its lighting, framing, and editing</li>\n              <li>Consistent, efficient, and detail-obsessed: catches dust, reflections, alignment, and color issues</li>\n              <li>Able to work independently without supervision</li>\n            </ul>\n\n            <h4>Nice to Have</h4>\n            <ul>\n              <li>Interest in film and analog cameras</li>\n              <li>Editorial or creative still life range, since the role may expand in that direction</li>\n            </ul>\n\n            <h4>How to Apply</h4>\n            <p>\n              Fill out our <a href=\"https://forms.gle/U1YC3o25vyYG4C3z7\" target=\"_blank\" rel=\"noopener\">application form</a>\n              and we'll be in touch.\n            </p>\n          </div>\n          <div class=\"bfc-action-row\">\n            <a class=\"bfc-btn bfc-btn--primary\" href=\"https://forms.gle/U1YC3o25vyYG4C3z7\"\n              target=\"_blank\" rel=\"noopener\">Apply Now</a>\n          </div>\n        </div>\n      </article>\n\n    </div>\n  </section>\n\n  <!-- ═══════════════════ OTHER ═══════════════════ -->\n  <section class=\"bfc-panel\" id=\"panel-other-{{ section.id }}\" role=\"tabpanel\"\n    aria-labelledby=\"tab-other-{{ section.id }}\" hidden>\n    <div class=\"bfc-stack\">\n\n      <article class=\"bfc-card bfc-accordion\" data-listing=\"true\">\n        <header class=\"bfc-card-head\">\n          <button class=\"bfc-accordion-toggle\" type=\"button\" aria-expanded=\"false\"\n            aria-controls=\"edu-content-{{ section.id }}\">\n            <div class=\"bfc-card-title-block\">\n              <span class=\"bfc-role-title\">Educators, Workshop &amp; Photowalk Leaders</span>\n              <span class=\"bfc-meta-row\">\n                <span class=\"bfc-tag\">Contract / Revenue Share</span>\n                <span class=\"bfc-tag\">Williamsburg HQ</span>\n              </span>\n            </div>\n            <svg class=\"bfc-caret\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n              <path d=\"M7 10l5 5 5-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\"\n                stroke-linejoin=\"round\"></path>\n            </svg>\n          </button>\n        </header>\n\n        <div id=\"edu-content-{{ section.id }}\" class=\"bfc-accordion-content\" hidden>\n          <div class=\"bfc-card-text\">\n            <p class=\"bfc-intro\">\n              We are looking for educators to lead classes, lectures, workshops, and photowalks at our Williamsburg HQ.\n              We handle marketing, ticketing, and supplies, and offer a share of revenue.\n            </p>\n            <h4>How to Apply</h4>\n            <p>\n              Email <a href=\"mailto:hello@brooklynfilmcamera.com\">hello@brooklynfilmcamera.com</a> with the subject\n              <strong>EDUCATION</strong>. Tell us about your teaching background, what you currently lead,\n              and any ideas that would be a great fit at BFC.\n            </p>\n          </div>\n          <div class=\"bfc-action-row\">\n            <a class=\"bfc-btn bfc-btn--primary\"\n              href=\"mailto:hello@brooklynfilmcamera.com?subject=EDUCATION\">Email Us</a>\n            <button type=\"button\" class=\"bfc-btn bfc-btn--ghost\" data-email=\"hello@brooklynfilmcamera.com\">Copy\n              Email</button>\n          </div>\n        </div>\n      </article>\n\n    </div>\n  </section>\n\n  <!-- ═══════════════════ PERKS (always visible) ═══════════════════ -->\n  <article class=\"bfc-card bfc-card--benefits\">\n    <h3 class=\"bfc-benefits-title\">Working with Us</h3>\n    <ul class=\"bfc-benefits-grid\">\n      <li>Employee first culture</li>\n      <li>Flexible schedules when needed</li>\n      <li>Profit sharing</li>\n      <li>Extra paid days off</li>\n      <li>Paid lunches</li>\n      <li>Free film stipend</li>\n      <li>Office snacks and drinks</li>\n      <li>Expanding benefits as we grow</li>\n    </ul>\n  </article>\n\n</div><!-- /#bfc-openings -->\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Poppins:wght@400;500;600;700;900&display=swap');\n\n  #bfc-openings-{{ section.id }} {\n    --ink:       #202009;\n    --canvas:    #F8F6EE;\n    --orange:    #E36E15;\n    --golden:    #F4A027;\n    --olive:     #525741;\n    --celadon:   #ABCC99;\n    --border:    rgba(32,32,9,.12);\n    --shadow:    0 4px 20px rgba(32,32,9,.07);\n    --shadow-lg: 0 10px 32px rgba(32,32,9,.12);\n    --radius:    0px;\n    --track:     .04em;\n  }\n\n  #bfc-openings-{{ section.id }} {\n    font-family: 'Poppins', system-ui, sans-serif;\n    color: var(--ink);\n    background: var(--canvas);\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: clamp(32px, 5vw, 64px) clamp(24px, 4vw, 48px);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-header {\n    margin-bottom: 52px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-eyebrow {\n    font-family: 'Poppins', sans-serif;\n    font-size: .9rem;\n    font-weight: 700;\n    letter-spacing: .18em;\n    text-transform: uppercase;\n    color: var(--orange);\n    margin: 0 0 14px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-title {\n    font-family: 'Cormorant Garamond', Georgia, serif;\n    font-size: clamp(60px, 9vw, 100px);\n    font-weight: 700;\n    line-height: .92;\n    letter-spacing: -.02em;\n    margin: 0 0 18px;\n    color: var(--ink);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-rule {\n    width: 48px;\n    height: 3px;\n    background: var(--orange);\n    border: none;\n    margin: 0;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-tabs {\n    display: flex;\n    gap: 0;\n    margin-bottom: 28px;\n    border-bottom: 2px solid var(--border);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-tab {\n    background: transparent;\n    border: none;\n    border-bottom: 3px solid transparent;\n    margin-bottom: -2px;\n    padding: .9rem 1.8rem;\n    font-family: 'Poppins', sans-serif;\n    font-weight: 700;\n    font-size: .95rem;\n    letter-spacing: .1em;\n    text-transform: uppercase;\n    cursor: pointer;\n    transition: color .15s, border-color .15s;\n    line-height: 1;\n    color: color-mix(in srgb, var(--ink) 45%, transparent);\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-tab:hover { color: var(--ink); }\n\n  #bfc-openings-{{ section.id }} .bfc-tab[aria-selected=\"true\"] {\n    color: var(--ink);\n    border-bottom-color: var(--orange);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-tab-count {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    min-width: 22px;\n    height: 22px;\n    padding: 0 7px;\n    font-family: 'Poppins', sans-serif;\n    font-size: .72rem;\n    font-weight: 700;\n    letter-spacing: 0;\n    color: color-mix(in srgb, var(--ink) 55%, transparent);\n    background: var(--canvas);\n    border: 1px solid var(--border);\n    border-radius: 0;\n    transition: background .15s, color .15s, border-color .15s;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-tab[aria-selected=\"true\"] .bfc-tab-count {\n    background: var(--orange);\n    color: #fff;\n    border-color: var(--orange);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-panel[hidden] { display: none !important; }\n  #bfc-openings-{{ section.id }} .bfc-stack { display: grid; gap: 18px; }\n\n  #bfc-openings-{{ section.id }} .bfc-card {\n    background: #fff;\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    box-shadow: var(--shadow);\n    overflow: hidden;\n    transition: box-shadow .2s, transform .2s;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card[data-listing=\"true\"]:hover {\n    box-shadow: var(--shadow-lg);\n    transform: translateY(-2px);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-head { margin: 0; }\n\n  #bfc-openings-{{ section.id }} .bfc-accordion-toggle {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    width: 100%;\n    border: 0;\n    background: transparent;\n    cursor: pointer;\n    padding: 28px 30px;\n    text-align: left;\n    color: var(--ink);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-title-block {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    min-width: 0;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-role-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: 1.3rem;\n    font-weight: 700;\n    line-height: 1.25;\n    letter-spacing: -.01em;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-meta-row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-tag {\n    font-size: .78rem;\n    font-weight: 700;\n    letter-spacing: .08em;\n    text-transform: uppercase;\n    background: var(--canvas);\n    color: var(--olive);\n    border: 1px solid color-mix(in srgb, var(--olive) 25%, transparent);\n    padding: 5px 11px;\n    border-radius: 0px;\n    white-space: nowrap;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-caret {\n    flex-shrink: 0;\n    opacity: .5;\n    transition: transform .22s, opacity .15s;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-accordion-toggle[aria-expanded=\"true\"] .bfc-caret {\n    transform: rotate(180deg);\n    opacity: 1;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-accordion-content {\n    padding: 0 30px 30px;\n    border-top: 1px solid var(--border);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-text {\n    padding-top: 24px;\n    font-size: 1.05rem;\n    line-height: 1.75;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-intro {\n    margin: 0 0 20px;\n    color: color-mix(in srgb, var(--ink) 70%, transparent);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-text h4 {\n    font-family: 'Poppins', sans-serif;\n    font-size: .82rem;\n    font-weight: 700;\n    letter-spacing: .14em;\n    text-transform: uppercase;\n    color: var(--orange);\n    margin: 24px 0 10px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-text ul {\n    margin: 0 0 16px;\n    padding: 0;\n    list-style: none;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-text ul li {\n    padding-left: 1.3rem;\n    position: relative;\n    margin-bottom: 6px;\n    color: color-mix(in srgb, var(--ink) 80%, transparent);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-text ul li::before {\n    content: '—';\n    position: absolute;\n    left: 0;\n    color: var(--orange);\n    font-weight: 700;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-text p {\n    margin: 0 0 14px;\n    color: color-mix(in srgb, var(--ink) 80%, transparent);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card-text a {\n    color: var(--orange);\n    text-decoration: underline;\n    text-underline-offset: 2px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-action-row {\n    display: flex;\n    gap: 12px;\n    margin-top: 28px;\n    flex-wrap: wrap;\n    align-items: center;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-btn {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    padding: .85rem 1.8rem;\n    font-family: 'Poppins', sans-serif;\n    font-weight: 700;\n    font-size: .88rem;\n    letter-spacing: .1em;\n    text-transform: uppercase;\n    border-radius: 0;\n    cursor: pointer;\n    text-decoration: none !important;\n    line-height: 1;\n    border: 1.5px solid transparent;\n    transition: transform .15s, box-shadow .15s, background .15s, color .15s;\n    white-space: nowrap;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-btn:hover { transform: translateY(-1px); }\n\n  #bfc-openings-{{ section.id }} .bfc-btn--primary {\n    background: var(--orange);\n    color: #fff;\n    border-color: var(--orange);\n    box-shadow: 0 3px 12px rgba(227,110,21,.3);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-btn--ghost {\n    background: transparent;\n    color: color-mix(in srgb, var(--ink) 50%, transparent);\n    border-color: transparent;\n    font-size: .82rem;\n    padding-left: 1rem;\n    padding-right: 1rem;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-btn--ghost:hover {\n    color: var(--ink);\n    background: var(--canvas);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card--empty {\n    padding: 52px 36px;\n    text-align: center;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-empty-icon {\n    font-family: 'Cormorant Garamond', Georgia, serif;\n    font-size: 3.5rem;\n    color: var(--border);\n    margin-bottom: 14px;\n    line-height: 1;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-empty-title {\n    font-size: 1.2rem;\n    font-weight: 700;\n    margin: 0 0 10px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-muted {\n    font-size: 1rem;\n    line-height: 1.7;\n    color: color-mix(in srgb, var(--ink) 55%, transparent);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-muted a {\n    color: var(--orange);\n    text-underline-offset: 2px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-card--benefits {\n    margin-top: 32px;\n    padding: 32px 36px 36px;\n    background: var(--ink);\n    color: #fff;\n    border-color: var(--ink);\n    box-shadow: none;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-benefits-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: .82rem;\n    font-weight: 700;\n    letter-spacing: .18em;\n    text-transform: uppercase;\n    color: var(--golden);\n    margin: 0 0 16px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-benefits-grid {\n    margin: 0;\n    padding: 0;\n    list-style: none;\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));\n    gap: 12px 24px;\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-benefits-grid li {\n    font-size: 1rem;\n    line-height: 1.6;\n    padding-left: 1.3rem;\n    position: relative;\n    color: rgba(255,255,255,.85);\n  }\n\n  #bfc-openings-{{ section.id }} .bfc-benefits-grid li::before {\n    content: '—';\n    position: absolute;\n    left: 0;\n    color: var(--orange);\n    font-weight: 700;\n  }\n\n  @media (max-width: 640px) {\n    #bfc-openings-{{ section.id }} .bfc-tab { padding: .75rem .9rem; font-size: .78rem; gap: 7px; }\n    #bfc-openings-{{ section.id }} .bfc-tab-count { min-width: 19px; height: 19px; font-size: .68rem; padding: 0 5px; }\n    #bfc-openings-{{ section.id }} .bfc-accordion-toggle { padding: 22px 20px; }\n    #bfc-openings-{{ section.id }} .bfc-accordion-content { padding: 0 20px 24px; }\n    #bfc-openings-{{ section.id }} .bfc-benefits-grid { grid-template-columns: 1fr 1fr; }\n    #bfc-openings-{{ section.id }} .bfc-role-title { font-size: 1.1rem; }\n  }\n</style>\n\n<script>\n  (function () {\n    var root = document.getElementById(\"bfc-openings-{{ section.id }}\");\n    if (!root) return;\n\n    var tabs = Array.prototype.slice.call(root.querySelectorAll(\".bfc-tab\"));\n    var panels = {\n      fulltime: root.querySelector(\"#panel-fulltime-{{ section.id }}\"),\n      parttime: root.querySelector(\"#panel-parttime-{{ section.id }}\"),\n      other:    root.querySelector(\"#panel-other-{{ section.id }}\")\n    };\n\n    // Auto-count active listings per panel and update the tab badges\n    Object.keys(panels).forEach(function (key) {\n      var panel = panels[key];\n      if (!panel) return;\n      var count = panel.querySelectorAll('[data-listing=\"true\"]').length;\n      var tab = root.querySelector('[data-tab=\"' + key + '\"]');\n      if (tab) {\n        var badge = tab.querySelector('.bfc-tab-count');\n        if (badge) {\n          badge.textContent = count;\n          badge.setAttribute('aria-label', count + (count === 1 ? ' open role' : ' open roles'));\n        }\n      }\n    });\n\n    function setActive(key) {\n      tabs.forEach(function (t) {\n        t.setAttribute(\"aria-selected\", t.getAttribute(\"data-tab\") === key ? \"true\" : \"false\");\n      });\n      Object.keys(panels).forEach(function (k) {\n        if (panels[k]) panels[k].hidden = (k !== key);\n      });\n    }\n\n    // Default to the first tab with active listings, fallback to fulltime\n    var defaultTab = \"fulltime\";\n    var order = [\"fulltime\", \"parttime\", \"other\"];\n    for (var i = 0; i < order.length; i++) {\n      var p = panels[order[i]];\n      if (p && p.querySelectorAll('[data-listing=\"true\"]').length > 0) {\n        defaultTab = order[i];\n        break;\n      }\n    }\n    setActive(defaultTab);\n\n    tabs.forEach(function (tab) {\n      tab.addEventListener(\"click\", function (e) {\n        e.preventDefault();\n        setActive(tab.getAttribute(\"data-tab\"));\n      });\n    });\n\n    root.querySelectorAll(\".bfc-accordion-toggle\").forEach(function (btn) {\n      btn.addEventListener(\"click\", function () {\n        var expanded = btn.getAttribute(\"aria-expanded\") === \"true\";\n        var content  = root.querySelector(\"#\" + btn.getAttribute(\"aria-controls\"));\n        btn.setAttribute(\"aria-expanded\", expanded ? \"false\" : \"true\");\n        if (content) content.hidden = expanded;\n      });\n    });\n\n    root.querySelectorAll(\"[data-email]\").forEach(function (btn) {\n      btn.addEventListener(\"click\", function () {\n        var email = btn.getAttribute(\"data-email\");\n        function flash() {\n          var prev = btn.textContent;\n          btn.textContent = \"Copied!\";\n          setTimeout(function () { btn.textContent = prev; }, 1400);\n        }\n        if (navigator.clipboard && navigator.clipboard.writeText) {\n          navigator.clipboard.writeText(email).then(flash).catch(function () {\n            window.prompt(\"Copy email:\", email);\n          });\n        } else {\n          window.prompt(\"Copy email:\", email);\n        }\n      });\n    });\n  })();\n</script>",
