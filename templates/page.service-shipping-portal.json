ign: center;\n    margin-top: 8px;\n  }\n\n  .sp-btn:hover {\n    background-color: #c85c0e;\n  }\n\n  .sp-divider-text {\n    text-align: center;\n    font-family: 'Poppins', Helvetica, sans-serif;\n    font-size: 11px;\n    color: var(--warm-mid);\n    margin: 20px 0 0;\n  }\n\n  .sp-divider-text a {\n    color: var(--orange);\n    text-decoration: none;\n  }\n\n  .sp-divider-text a:hover {\n    text-decoration: underline;\n  }\n\n  /* ── Info tiles ── */\n  .sp-tiles {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 1px;\n    background-color: var(--border);\n    border: 1px solid var(--border);\n    border-radius: 2px;\n    overflow: hidden;\n    margin-bottom: 48px;\n  }\n\n  .sp-tile {\n    background-color: var(--canvas);\n    padding: 28px 24px;\n    text-align: center;\n  }\n\n  .sp-tile-icon {\n    width: 36px;\n    height: 36px;\n    background-color: var(--ink);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin: 0 auto 14px;\n  }\n\n  .sp-tile-icon svg {\n    width: 16px;\n    height: 16px;\n    stroke: var(--gold);\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .sp-tile h3 {\n    font-family: 'Cormorant Garamond', Georgia, serif;\n    font-size: 16px;\n    font-weight: 600;\n    color: var(--ink);\n    margin: 0 0 6px;\n  }\n\n  .sp-tile p {\n    font-family: Georgia, serif;\n    font-size: 13px;\n    color: var(--muted);\n    margin: 0;\n    line-height: 1.6;\n  }\n\n  /* ── Questions strip ── */\n  .sp-questions {\n    border-top: 1px solid var(--border);\n    padding-top: 36px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 24px;\n    flex-wrap: wrap;\n  }\n\n  .sp-questions p {\n    font-family: Georgia, serif;\n    font-size: 15px;\n    color: var(--muted);\n    margin: 0;\n    line-height: 1.6;\n  }\n\n  .sp-btn-outline {\n    display: inline-block;\n    border: 1.5px solid var(--orange);\n    color: var(--orange);\n    font-family: 'Poppins', Helvetica, sans-serif;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: .1em;\n    text-transform: uppercase;\n    text-decoration: none;\n    padding: 11px 24px;\n    border-radius: 2px;\n    white-space: nowrap;\n    transition: background-color .15s, color .15s;\n  }\n\n  .sp-btn-outline:hover {\n    background-color: var(--orange);\n    color: var(--canvas);\n  }\n\n  /* ── Footer ── */\n  .sp-footer {\n    background-color: var(--ink);\n    padding: 32px 40px;\n    text-align: center;\n  }\n\n  .sp-footer p {\n    font-family: 'Poppins', Helvetica, sans-serif;\n    font-size: 10px;\n    color: #5a5448;\n    letter-spacing: .06em;\n    margin: 0;\n    line-height: 1.8;\n  }\n\n  .sp-footer a {\n    color: var(--orange);\n    text-decoration: none;\n  }\n\n  @media (max-width: 600px) {\n    .sp-header { padding: 22px 20px; }\n    .sp-hero { padding: 48px 20px 56px; }\n    .sp-body { padding: 40px 16px 60px; }\n    .sp-lookup-card { padding: 28px 20px; }\n    .sp-tiles { grid-template-columns: 1fr; }\n    .sp-questions { flex-direction: column; align-items: flex-start; }\n  }\n</style>\n\n<div class=\"sp-page\">\n\n  <!-- Header -->\n  <header class=\"sp-header\">\n    <a href=\"/\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0575/8638/5068/files/PrimaryLogo.png?v=1769457584\" alt=\"Brooklyn Film Camera\" />\n    </a>\n  </header>\n\n  <!-- Hero -->\n  <div class=\"sp-hero\">\n    <p class=\"sp-hero-eyebrow\">Brooklyn Film Camera</p>\n    <h1>Service Portal</h1>\n    <div class=\"sp-hero-rule\"></div>\n    <p>Track your repair, download your shipping label, and stay up to date on your order.</p>\n  </div>\n\n  <!-- Body -->\n  <main class=\"sp-body\">\n\n    <!-- Order Lookup -->\n    <div class=\"sp-lookup-card\">\n      <h2>Look Up Your Order</h2>\n      <p class=\"sp-card-sub\">Enter your order number and email to access your service details.</p>\n\n      <div class=\"sp-field\">\n        <label for=\"sp-order\">Order Number</label>\n        <input type=\"text\" id=\"sp-order\" placeholder=\"#BFC-1234\" />\n      </div>\n      <div class=\"sp-field\">\n        <label for=\"sp-email\">Email Address</label>\n        <input type=\"email\" id=\"sp-email\" placeholder=\"you@example.com\" />\n      </div>\n\n      <button class=\"sp-btn\" onclick=\"handlePortalLookup()\">Access My Order</button>\n\n      <p class=\"sp-divider-text\">\n        Need help? <a href=\"mailto:hello@brooklynfilmcamera.com\">Email us directly</a>\n      </p>\n    </div>\n\n    <!-- Info tiles -->\n    <div class=\"sp-tiles\">\n      <div class=\"sp-tile\">\n        <div class=\"sp-tile-icon\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"/><polyline points=\"7 10 12 15 17 10\"/><line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"/></svg>\n        </div>\n        <h3>Download Label</h3>\n        <p>Your prepaid shipping label is ready to print from your order page.</p>\n      </div>\n      <div class=\"sp-tile\">\n        <div class=\"sp-tile-icon\">\n          <svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>\n        </div>\n        <h3>Track Status</h3>\n        <p>See where your camera is in the repair or service queue.</p>\n      </div>\n      <div class=\"sp-tile\">\n        <div class=\"sp-tile-icon\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.7 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.55 5.55l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z\"/></svg>\n        </div>\n        <h3>Get in Touch</h3>\n        <p>Questions about your service? We're easy to reach by email or in person.</p>\n      </div>\n    </div>\n\n    <!-- Contact strip -->\n    <div class=\"sp-questions\">\n      <p>Questions about your order or service?<br/>We're happy to help.</p>\n      <a class=\"sp-btn-outline\" href=\"mailto:hello@brooklynfilmcamera.com\">Contact Us</a>\n    </div>\n\n  </main>\n\n  <!-- Footer -->\n  <footer class=\"sp-footer\">\n    <p>\n      &copy; Brooklyn Film Camera &nbsp;&middot;&nbsp; Brooklyn, NY<br/>\n      <a href=\"https://brooklynfilmcamera.com\">brooklynfilmcamera.com</a>\n    </p>\n  </footer>\n\n</div>\n\n<script>\n  function handlePortalLookup() {\n    const order = document.getElementById('sp-order').value.trim();\n    const email = document.getElementById('sp-email').value.trim();\n    if (!order || !email) {\n      alert('Please enter both your order number and email address.');\n      return;\n    }\n    // Wire this up to your portal/Loop URL as needed\n    // e.g. window.location.href = '/tools/lookup?order=' + encodeURIComponent(order) + '&email=' + encodeURIComponent(email);\n    alert('Portal lookup: ' + order + ' / ' + email);\n  }\n</script>",
