s Infinity\", \"Olympus Infinity Stylus\", \"Olympus MJU\", \"Olympus MJU II\", \"Olympus MJU Zoom\", \"Olympus OM-1\", \"Olympus OM-1n\", \"Olympus OM-10\", \"Olympus OM-2\", \"Olympus OM-2SP\", \"Olympus OM-2n\", \"Olympus OM-20\", \"Olympus OM-3\", \"Olympus OM-3Ti\", \"Olympus OM-30\", \"Olympus OM-4\", \"Olympus OM-4Ti\", \"Olympus OM-40\", \"Olympus OM-PC\", \"Olympus Pen\", \"Olympus Pen D\", \"Olympus Pen D2\", \"Olympus Pen EE\", \"Olympus Pen EE2\", \"Olympus Pen EE3\", \"Olympus Pen F\", \"Olympus Pen FT\", \"Olympus StyleZoom\", \"Olympus Stylus\", \"Olympus Stylus Epic\", \"Olympus SuperZoom\", \"Olympus Trip 35\", \"Olympus Trip AF\", \"Olympus XA\", \"Olympus XA2\", \"Olympus XA3\", \"Olympus XA4\", \"Pentax 6x7\", \"Pentax 67\", \"Pentax 67II\", \"Pentax 645\", \"Pentax 645N\", \"Pentax A3\", \"Pentax ES\", \"Pentax Espio\", \"Pentax H1\", \"Pentax H3\", \"Pentax IQZoom\", \"Pentax K1000\", \"Pentax K2\", \"Pentax KM\", \"Pentax KX\", \"Pentax LX\", \"Pentax MA\", \"Pentax ME\", \"Pentax ME Super\", \"Pentax MG\", \"Pentax MV\", \"Pentax MV1\", \"Pentax MX\", \"Pentax PC35AF\", \"Pentax Program A\", \"Pentax S1\", \"Pentax S3\", \"Pentax Spotmatic\", \"Pentax Spotmatic F\", \"Pentax Spotmatic II\", \"Pentax Super A\", \"Pentax UC-1\", \"Plaubel Makina 67\", \"Plaubel Makina W67\", \"Praktica B200\", \"Praktica BX20\", \"Praktica L\", \"Praktica LTL\", \"Praktica MTL3\", \"Praktica MTL5\", \"Ricoh GR1\", \"Ricoh GR1s\", \"Ricoh GR1v\", \"Ricoh GR21\", \"Ricoh KR-10\", \"Ricoh KR-5\", \"Ricoh R1\", \"Ricoh R1s\", \"Ricoh XR-7\", \"Ricoh XR-P\", \"Rolleicord II\", \"Rolleicord III\", \"Rolleicord IV\", \"Rolleicord TLR\", \"Rolleicord Va\", \"Rolleicord Vb\", \"Rolleiflex 2.8E\", \"Rolleiflex 2.8F\", \"Rolleiflex 3.5E\", \"Rolleiflex 3.5F\", \"Rolleiflex 35\", \"Rolleiflex SL35\", \"Rolleiflex SL66\", \"Rolleiflex T\", \"Sigma SA-1\", \"Sigma SA-7\", \"Sinar F1\", \"Sinar F2\", \"Topcon RE Super\", \"Topcon Super D\", \"Topcon Uni\", \"Vivitar V2000\", \"Vivitar V3800N\", \"Voigtlander Bessa L\", \"Voigtlander Bessa R\", \"Voigtlander Bessa R2\", \"Voigtlander Bessa R3A\", \"Voigtlander Bessa R4A\", \"Voigtlander Bessa T\", \"Voigtlander Brillant\", \"Voigtlander Perkeo\", \"Voigtlander Prominent\", \"Voigtlander Vito B\", \"Voigtlander Vito BL\", \"Voigtlander Vito C\", \"Voigtlander Vitomatic\", \"Voigtlander Vitessa\", \"Yashica Electro 35\", \"Yashica Electro 35 GT\", \"Yashica Electro 35 GSN\", \"Yashica Electro 35 GX\", \"Yashica FR\", \"Yashica FR I\", \"Yashica FR II\", \"Yashica FX-3\", \"Yashica FX-D\", \"Yashica Mat\", \"Yashica Mat 124\", \"Yashica Mat 124G\", \"Yashica MG-1\", \"Yashica Samurai\", \"Yashica T2\", \"Yashica T3\", \"Yashica T4\", \"Yashica T5\", \"Yashica TLR\", \"Zeiss Ikon Contarex\", \"Zeiss Ikon Contax IIa\", \"Zeiss Ikon Contax IIIa\", \"Zeiss Ikon Contessa\", \"Zeiss Ikon Ikoflex\", \"Zeiss Ikon Nettar\", \"Zeiss Ikon Super Ikonta\", \"Zeiss Ikon Tenax\", \"Zenit 11\", \"Zenit 12XP\", \"Zenit B\", \"Zenit E\", \"Zenit ET\", \"Zorki 4\", \"Zorki 4K\", \"Zorki 6\"];\n\nfunction rpFilterCameras() {\n  var q = rpEl('rp-model-search-input').value.toLowerCase().trim();\n  var res = rpEl('rp-model-search-results');\n  rpS.customModel = rpEl('rp-model-search-input').value.trim();\n  rpEl('rp-n1').disabled = !rpS.customModel;\n  rpCheckIssue(); rpSidebar();\n  if(!q){ res.style.display='none'; return; }\n  var matches = rpCameraList.filter(function(c){ return c.toLowerCase().indexOf(q) !== -1; });\n  if(!matches.length){ res.style.display='none'; return; }\n  res.innerHTML = matches.slice(0,12).map(function(c){\n    return '<div style=\"padding:8px 12px;font-size:11px;cursor:pointer;border-bottom:1px solid var(--border)\" onmousedown=\"rpPickCamera(\\''+c+'\\')\" onmouseover=\"this.style.background=\\'#f5f2ec\\'\" onmouseout=\"this.style.background=\\'\\'\">' + c + '</div>';\n  }).join('');\n  res.style.display='block';\n}\n\nfunction rpPickCamera(name) {\n  rpEl('rp-model-search-input').value = name;\n  rpEl('rp-model-search-results').style.display='none';\n  rpS.customModel = name;\n  rpEl('rp-n1').disabled = false;\n  rpCheckIssue(); rpSidebar();\n}\n\nfunction rpShowModelSearch(show) {\n  rpEl('rp-model-search').style.display = show ? 'block' : 'none';\n  if(!show){ rpEl('rp-model-search-input').value=''; rpS.customModel=''; }\n}\n\nfunction rpGatePick(){document.getElementById(\"rp-gate\").style.display=\"none\";document.getElementById(\"rp-main\").style.display=\"grid\";}\n\nfunction rpShowSuccess() {\n  rpEl('rp-submit').style.display='none';\n  rpEl('rp-success').style.display='block';\n  rpEl('rp-err').classList.remove('show');\n}\n\nfunction rpAddAnother() {\n  rpS = { what:'', model:'', repair:'', mech:'', lens:'', issue:'', customModel:'' };\n  rpEl('rp-model').value='';\n  rpEl('rp-repair').value='';\n  rpEl('rp-mech').value='';\n  rpEl('rp-lens').value='';\n  rpEl('rp-txt').value='';\n  rpEl('rp-chars').textContent='0 characters';\n  rpEl('rp-serial').value='';\n  rpEl('rp-serial').disabled=false;\n  rpEl('rp-serial-skip').style.borderColor='';\n  rpEl('rp-serial-skip').style.color='';\n  rpEl('rp-submit').style.display='block';\n  rpEl('rp-success').style.display='none';\n  rpEl('rp-wb').classList.remove('sel');\n  rpEl('rp-wl').classList.remove('sel');\n  rpEl('rp-wbo').classList.remove('sel');\n  rpShowModelSearch(false);\n  rpHint('rp-model-hint','');\n  rpSidebar();\n  rpGoTo(0);\n}\n\nvar rpS = { what:'', model:'', repair:'', mech:'', lens:'', issue:'', customModel:'', serial:'', serialSkipped:false };\n\n{% assign _rp = all_products['35mm-and-medium-format-repair'] %}\nvar rpVID = {% if _rp.first_available_variant %}{{ _rp.first_available_variant.id }}{% else %}0{% endif %};\n\nfunction rpEl(id){ return document.getElementById(id); }\nfunction rpShow(id){ var e=rpEl(id); if(e) e.style.display='block'; }\nfunction rpHide(id){ var e=rpEl(id); if(e) e.style.display='none'; }\nfunction rpHint(id, txt, warn){\n  var e=rpEl(id); if(!e) return;\n  e.textContent=txt;\n  e.className='rp-hint'+(txt?' show':'')+(warn?' warn':'');\n}\n\nfunction rpGoTo(step) {\n  for(var i=0;i<5;i++){\n    rpEl('rp-s'+i).classList.toggle('active', i===step);\n    var p=rpEl('rp-p'+i);\n    p.classList.remove('active','done');\n    if(i<step) p.classList.add('done');\n    if(i===step) p.classList.add('active');\n  }\n  rpSidebar();\n  if(step===4) rpBuildReview();\n  window.scrollTo({top:0,behavior:'smooth'});\n}\n\nfunction rpPickWhat(v) {\n  rpS.what=v; rpS.model=''; rpS.repair=''; rpS.mech=''; rpS.lens='';\n  rpEl('rp-wb').classList.remove('sel');\n  rpEl('rp-wl').classList.remove('sel');\n  rpEl('rp-wbo').classList.remove('sel');\n  if(v==='Camera Body') rpEl('rp-wb').classList.add('sel');\n  if(v==='Camera Lens') rpEl('rp-wl').classList.add('sel');\n  if(v==='Both') rpEl('rp-wbo').classList.add('sel');\n  rpEl('rp-n0').disabled = false;\n  rpSidebar();\n}\n\nfunction rpN0() {\n  if(rpS.what==='Camera Lens'){ rpGoTo(2); rpSetupIssue(); }\n  else rpGoTo(1);\n}\n\nfunction rpOnModel() {\n  rpS.model = rpEl('rp-model').value;\n  rpS.customModel = '';\n  rpShowModelSearch(rpS.model==='Other (Mechanical Camera)' || rpS.model==='Other (Electronical Camera)');\n  rpHint('rp-model-hint','');\n  if(rpS.model==='Hasselblad 500CM' || rpS.model==='Hasselblad 503CX / CXi / CW' || rpS.model==='Hasselblad 501C' || rpS.model==='Hasselblad 501CM') rpHint('rp-model-hint', rpS.what==='Both' ? 'Full CLA available for body. Note: we can only repair C/CF lenses \u2014 please confirm your lens mount before proceeding.' : 'Full CLA available \u2014 body cleaning, lubrication, shutter calibration, and film transport adjustment.', rpS.what==='Both');\n  if(rpS.model==='Hasselblad Magazine') rpHint('rp-model-hint','Full CLA available \u2014 all standard Hasselblad magazines can be serviced.');\n  if(rpS.model==='Nikon F3') rpHint('rp-model-hint','Full CLA available \u2014 shutter calibration, mirror damper, cleaning, lubrication, and adjustment.');\n  if(rpS.model==='Rolleicord TLR') rpHint('rp-model-hint','Full CLA available \u2014 cleaning, lubrication, and adjustment of shutter, focus, and film transport.');\n  if(rpS.model==='Yashica TLR') rpHint('rp-model-hint','These cameras are extra finicky \u2014 some models can be fully CLA\u2019d, others are repair-only. We\u2019ll assess and confirm after inspection.', true);\n  if(rpS.model==='Nikon FE / FE2') rpHint('rp-model-hint','Full CLA available \u2014 body cleaning, lubrication, shutter calibration, meter adjustment, and film transport service.');\n  if(rpS.model==='Other (Electronical Camera)') rpHint('rp-model-hint','Limited repairs for electronic cameras. Contact us to confirm.', true);\n  rpEl('rp-n1').disabled = !rpS.model || ((rpS.model==='Other (Mechanical Camera)' || rpS.model==='Other (Electronical Camera)') && !rpS.customModel);\n  rpSidebar();\n}\n\nfunction rpSetupIssue() {\n  rpHide('rp-fi-body'); rpHide('rp-fi-mech'); rpHide('rp-fi-lens'); rpHide('rp-lens-sep');\n  if(rpS.what !== 'Camera Lens') {\n    if(rpS.model==='Other (Mechanical Camera)' || rpS.model==='Other (Electronical Camera)') rpShow('rp-fi-mech');\n    else rpShow('rp-fi-body');\n  }\n  if(rpS.what==='Camera Lens' || rpS.what==='Both') {\n    rpShow('rp-fi-lens');\n    if(rpS.what==='Both') rpShow('rp-lens-sep');\n  }\n  rpCheckIssue();\n}\n\nfunction rpCheckIssue() {\n  var bodyOk=true, lensOk=true;\n  if(rpS.what !== 'Camera Lens') {\n    bodyOk = (rpS.model==='Other (Mechanical Camera)' || rpS.model==='Other (Electronical Camera)') ? (!!rpS.mech && !!rpS.customModel) : !!rpS.repair;\n  }\n  if(rpS.what==='Camera Lens' || rpS.what==='Both') lensOk = !!rpS.lens;\n  rpEl('rp-n2').disabled = !(bodyOk && lensOk);\n}\n\nfunction rpIssueBack() {\n  rpGoTo(rpS.what==='Camera Lens' ? 0 : 1);\n}\n\nfunction rpOnRepair() {\n  rpS.repair = rpEl('rp-repair').value;\n  rpEl('rp-cla-lnk').style.display = rpS.repair==='CLA' ? 'block' : 'none';\n  rpHint('rp-repair-hint',\n    rpS.repair==='Corrosion' ? 'Medium failure rate \\u2014 we will assess.' :\n    rpS.repair==='Door Replacement' ? 'Model & parts dependent.' : '');\n  rpCheckIssue(); rpSidebar();\n}\n\nfunction rpOnMech() {\n  rpS.mech = rpEl('rp-mech').value;\n  ['cla','door','unlisted','hasslens','othermodel','unjam'].forEach(rpCloseModal);\n  var isOther = rpS.model==='Other (Mechanical Camera)' || rpS.model==='Other (Electronical Camera)';\n  if(rpS.mech==='Unlisted Issue'){ rpHint('rp-mech-hint','Risk of denial. Contact us first.',true); rpOpenModal('unlisted'); }\n  else if(rpS.mech==='Door Replacement'){ rpHint('rp-mech-hint','Feasibility depends on parts and model.'); rpOpenModal('door'); }\n  else if(rpS.mech==='Unjam/Unstuck' && isOther){ rpHint('rp-mech-hint',''); rpOpenModal('othermodel'); }\n  else if(rpS.mech==='Unjam/Unstuck'){ rpHint('rp-mech-hint',''); rpOpenModal('unjam'); }\n  else if(isOther && rpS.mech && rpS.mech!=='Light Seals'){ rpHint('rp-mech-hint',''); rpOpenModal('othermodel'); }\n  else rpHint('rp-mech-hint','');\n  rpCheckIssue(); rpSidebar();\n}\n\nfunction rpOnLens() {\n  rpS.lens = rpEl('rp-lens').value;\n  ['cla','door','unlisted','hasslens','othermodel','unjam'].forEach(rpCloseModal);\n  if(rpS.lens==='Hasselblad Lens') rpOpenModal('hasslens');\n  rpHint('rp-lens-hint',\n    rpS.lens==='Hasselblad Lens' ? 'C/CF lenses only. Not sure? Email us at repairs@brooklynfilmcamera.com before booking.' :\n    (rpS.lens==='Haze'||rpS.lens==='Fungus') ? 'Medium success rate \u2014 depends on severity.' :\n    rpS.lens==='Impact Damage' ? 'Higher charge likely.' : '');\n  rpCheckIssue(); rpSidebar();\n}\n\nfunction rpOnDesc() {\n  rpS.issue = rpEl('rp-txt').value;\n  var n=rpS.issue.length;\n  rpEl('rp-chars').textContent = n+' character'+(n!==1?'s':'');\n  rpCheckSerial();\n}\n\nfunction rpOnSerial() {\n  rpS.serial = rpEl('rp-serial').value.trim();\n  if(rpS.serial) {\n    rpS.serialSkipped = false;\n    rpEl('rp-serial-skip').style.borderColor = '';\n    rpEl('rp-serial-skip').style.color = '';\n    rpHint('rp-serial-hint','');\n  }\n  rpCheckSerial();\n}\n\nfunction rpSkipSerial() {\n  rpS.serialSkipped = true;\n  rpEl('rp-serial-skip').style.borderColor = 'var(--ink)';\n  rpEl('rp-serial-skip').style.color = 'var(--ink)';\n  rpHint('rp-serial-hint','No serial number \u2014 you can still type one above if you find it.');\n  rpCheckSerial();\n}\n\nfunction rpCheckSerial() {\n  var serialOk = !!rpS.serial || !!rpS.serialSkipped;\n  rpEl('rp-n3').disabled = rpS.issue.trim().length < 5 || !serialOk;\n}\n\nfunction rpBuildReview() {\n  var rows=[['Item',rpS.what]];\n  if(rpS.model) rows.push(['Model',rpS.customModel||rpS.model]);\n  if(rpS.repair) rows.push(['Repair',rpS.repair]);\n  if(rpS.mech) rows.push(['Mechanical',rpS.mech]);\n  if(rpS.lens) rows.push(['Lens issue',rpS.lens]);\n  rows.push(['Serial #', rpS.serial || 'Not provided']);\n  var html=rows.map(function(r){\n    return '<div class=\"rp-rr\"><span class=\"rp-rk\">'+r[0]+'</span><span class=\"rp-rv\">'+r[1]+'</span></div>';\n  }).join('');\n  var prev=rpS.issue.trim().substring(0,100)+(rpS.issue.trim().length>100?'\\u2026':'');\n  html+='<div class=\"rp-rr\"><span class=\"rp-rk\">Issue</span><span class=\"rp-rv sm\">'+prev+'</span></div>';\n  rpEl('rp-review').innerHTML=html;\n}\n\nfunction rpSidebar() {\n  var html='';\n  if(rpS.what) html+='<div class=\"rp-sb-row\"><span class=\"rp-sb-k\">Item</span><span class=\"rp-sb-v\">'+rpS.what+'</span></div>';\n  if(rpS.model) html+='<div class=\"rp-sb-row\"><span class=\"rp-sb-k\">Model</span><span class=\"rp-sb-v\">'+(rpS.customModel||rpS.model)+'</span></div>';\n  if(rpS.repair) html+='<div class=\"rp-sb-row\"><span class=\"rp-sb-k\">Repair</span><span class=\"rp-sb-v\">'+rpS.repair+'</span></div>';\n  if(rpS.mech) html+='<div class=\"rp-sb-row\"><span class=\"rp-sb-k\">Mechanical</span><span class=\"rp-sb-v\">'+rpS.mech+'</span></div>';\n  if(rpS.lens) html+='<div class=\"rp-sb-row\"><span class=\"rp-sb-k\">Lens</span><span class=\"rp-sb-v\">'+rpS.lens+'</span></div>';\n  rpEl('rp-sb-content').innerHTML=html||'<span class=\"rp-sb-empty\">Fill in the form\\u2026</span>';\n}\n\nfunction rpOpenModal(id){ rpEl('rp-ov-'+id).classList.add('open'); }\nfunction rpCloseModal(id){ rpEl('rp-ov-'+id).classList.remove('open'); }\n\nfunction rpSubmit() {\n  var btn=rpEl('rp-submit'), err=rpEl('rp-err');\n  btn.disabled=true; btn.textContent='Booking\\u2026';\n  err.classList.remove('show');\n  var props={'Camera, Lens, or Both':rpS.what};\n  if(rpS.model) props['Camera Model']=rpS.customModel||rpS.model;\n  if(rpS.repair) props['Repair']=rpS.repair;\n  if(rpS.mech) props['Mechanical Repair']=rpS.mech;\n  if(rpS.lens) props['Lens Issue']=rpS.lens;\n  props['Serial Number']=rpS.serial||'Not provided';\n  props['Issue']=rpS.issue.trim();\n  fetch('/cart/add.js',{\n    method:'POST',\n    headers:{'Content-Type':'application/json'},\n    body:JSON.stringify({id:rpVID,quantity:1,properties:props})\n  }).then(function(r){return r.json();}).then(function(d){\n    if(d.status&&d.status!==200) throw new Error(d.description||'Error');\n    rpShowSuccess();\n  }).catch(function(e){\n    btn.disabled=false; btn.textContent='Book repair \\u2014 $50 \\u2192';\n    err.textContent='Something went wrong: '+e.message; err.classList.add('show');\n  });\n}\n</script>"
      }
    }
