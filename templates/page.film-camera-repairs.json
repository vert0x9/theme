r-spacing:.08em;text-transform:uppercase;color:var(--muted)}\n#bfc-rp .rp-sb-fa{font-size:22px;font-weight:300}\n#bfc-rp .rp-sb-fn{font-size:8px;color:var(--muted);line-height:1.5;display:block;margin-top:2px;margin-bottom:16px}\n#bfc-rp .rp-how-ttl{font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;display:block;border-top:1px solid var(--border);padding-top:16px}\n#bfc-rp .rp-how-row{display:flex;gap:10px;margin-bottom:12px;font-size:10px;line-height:1.5}\n#bfc-rp .rp-how-n{width:18px;height:18px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--muted);flex-shrink:0;margin-top:1px}\n#bfc-rp .rp-how-t{color:var(--muted)}\n#bfc-rp .rp-how-t strong{color:var(--ink);display:block}\n.rp-ov{display:none}\n.rp-ov.open{display:block}\n.rp-modal{background:#fff;padding:20px;border:1.5px solid var(--border);margin-bottom:16px;position:relative}\n.rp-modal-ttl{font-family:'Cormorant Garamond',Georgia,serif;font-size:22px;font-weight:300;margin-bottom:14px;padding-right:24px;display:block}\n.rp-modal p{font-size:11px;line-height:1.7;color:#999;margin-bottom:10px;font-family:'DM Mono',monospace}\n.rp-modal p strong{color:#0e0d0b}\n.rp-modal .warn{color:#b83a1a;font-size:10px}\n.rp-modal-x{position:absolute;top:14px;right:14px;background:none;border:none;font-size:20px;cursor:pointer;color:#999;font-family:'DM Mono',monospace;padding:4px;line-height:1}\n.rp-modal-foot{margin-top:18px;display:flex;gap:8px;flex-wrap:wrap}\n.rp-mbtn{padding:9px 18px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;border:1.5px solid #0e0d0b;text-decoration:none;display:inline-flex;align-items:center;border-radius:0}\n.rp-mbtn.p{background:#0e0d0b;color:#fff}\n.rp-mbtn.s{background:#fff;color:#0e0d0b}\n#bfc-rp .rp-gate{max-width:1000px;margin:0 auto;padding:40px 20px}\n#bfc-rp .rp-gate-title{font-family:'Cormorant Garamond',Georgia,serif;font-size:26px;font-weight:300;line-height:1.1;margin-bottom:4px}\n#bfc-rp .rp-gate-title em{font-style:italic;color:#c8622a}\n#bfc-rp .rp-gate-sub{font-size:10px;color:#999;margin-bottom:18px;line-height:1.5}\n#bfc-rp .rp-gate-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;max-width:460px}\n#bfc-rp .rp-card.disabled{opacity:.45;cursor:not-allowed;pointer-events:none;position:relative}\n#bfc-rp .rp-card-paused{font-size:8px;letter-spacing:.1em;text-transform:uppercase;color:#b83a1a;display:block;margin-top:4px}\n</style>\n\n<div id=\"bfc-rp\">\n  <div class=\"rp-header\">\n    <span class=\"rp-eyebrow\">Brooklyn Film Camera &mdash; Repair Service</span>\n    <span class=\"rp-title\">Book your <em>camera repair.</em></span>\n    <span style=\"display:inline-block;margin-top:12px;font-size:10px;color:#999;font-family:'DM Mono',monospace;\">Looking for Polaroid repairs? <a href=\"/pages/polaroid-repairs\" style=\"color:#c8622a;text-decoration:none;\" onmouseover=\"this.style.textDecoration='underline'\" onmouseout=\"this.style.textDecoration='none'\">Visit our Polaroid repair page &rarr;</a></span>\n  </div>\n  <div class=\"rp-gate\" id=\"rp-gate\">\n    <div class=\"rp-gate-title\">What type of <em>camera</em>?</div>\n    <div class=\"rp-gate-sub\">Select your camera type to get started.</div>\n    <div class=\"rp-gate-cards\">\n      <div class=\"rp-card\" onclick=\"rpGatePick()\">\n        <span class=\"rp-card-ico\">&#9654;</span>\n        <span class=\"rp-card-lbl\">Film Camera</span>\n        <span class=\"rp-card-sub\">35mm, medium format, rangefinder &amp; more</span>\n      </div>\n      <div class=\"rp-card disabled\">\n        <span class=\"rp-card-ico\">&#9670;</span>\n        <span class=\"rp-card-lbl\">Polaroid / Instant</span>\n        <span class=\"rp-card-sub\">Instax, 600, SX-70 &amp; instant cameras</span>\n        <span class=\"rp-card-paused\">Temporarily paused</span>\n      </div>\n    </div>\n  </div>\n  <div class=\"rp-inner\" id=\"rp-main\" style=\"display:none\">\n\n    <div class=\"rp-rail\">\n      <div class=\"rp-ps active\" id=\"rp-p0\"><div class=\"rp-pd\"><span class=\"rp-pnum\">1</span></div><span class=\"rp-pl\">What</span></div>\n      <div class=\"rp-ps\" id=\"rp-p1\"><div class=\"rp-pd\"><span class=\"rp-pnum\">2</span></div><span class=\"rp-pl\">Model</span></div>\n      <div class=\"rp-ps\" id=\"rp-p2\"><div class=\"rp-pd\"><span class=\"rp-pnum\">3</span></div><span class=\"rp-pl\">Issue</span></div>\n      <div class=\"rp-ps\" id=\"rp-p3\"><div class=\"rp-pd\"><span class=\"rp-pnum\">4</span></div><span class=\"rp-pl\">Details</span></div>\n      <div class=\"rp-ps\" id=\"rp-p4\"><div class=\"rp-pd\"><span class=\"rp-pnum\">5</span></div><span class=\"rp-pl\">Review</span></div>\n    </div>\n\n    <div class=\"rp-main\">\n\n      <div class=\"rp-step active\" id=\"rp-s0\">\n        <div class=\"rp-step-title\">What are you<br>bringing in?</div>\n        <div class=\"rp-step-sub\">Select everything that needs service.</div>\n        <div class=\"rp-cards\">\n          <div class=\"rp-card\" id=\"rp-wb\" onclick=\"rpPickWhat('Camera Body')\">\n            <span class=\"rp-card-ico\">&#9634;</span>\n            <span class=\"rp-card-lbl\">Camera Body</span>\n            <span class=\"rp-card-sub\">Body repair or CLA</span>\n          </div>\n          <div class=\"rp-card\" id=\"rp-wl\" onclick=\"rpPickWhat('Camera Lens')\">\n            <span class=\"rp-card-ico\">&#9711;</span>\n            <span class=\"rp-card-lbl\">Camera Lens</span>\n            <span class=\"rp-card-sub\">Lens-only service</span>\n          </div>\n          <div class=\"rp-card\" id=\"rp-wbo\" onclick=\"rpPickWhat('Both')\">\n            <span class=\"rp-card-ico\">&#9670;</span>\n            <span class=\"rp-card-lbl\">Body &amp; Lens</span>\n            <span class=\"rp-card-sub\">Both need service</span>\n          </div>\n        </div>\n        <div class=\"rp-actions\">\n          <button class=\"rp-next\" id=\"rp-n0\" disabled onclick=\"rpN0()\">Next &rarr;</button>\n        </div>\n      </div>\n\n      <div class=\"rp-step\" id=\"rp-s1\">\n        <div class=\"rp-step-title\">Camera <em>model</em></div>\n        <div class=\"rp-step-sub\">Select your camera from the list.</div>\n        <div class=\"rp-field\">\n          <label>Camera model</label>\n          <select class=\"rp-sel\" id=\"rp-model\" onchange=\"rpOnModel()\">\n            <option value=\"\">-- Select model --</option>\n            <option>Canon AE-1</option>\n            <option>Canon AE-1 Program</option>\n            <option value=\"K1000\">Pentax K1000</option>\n            <option>Nikon FE / FE2</option>\n            <option>Hasselblad 500CM</option>\n            <option>Hasselblad 503CX / CXi / CW</option>\n            <option>Hasselblad 501C</option>\n            <option>Hasselblad 501CM</option>\n            <option value=\"Hasselblad Magazine\">Hasselblad Magazine</option>\n            <option>Canonet</option>\n            <option>Canon 7</option>\n            <option>Contax T</option>\n            <option>Contax G2</option>\n            <option>Canon P</option>\n            <option>Nikon F3</option>\n            <option>Rolleicord TLR</option>\n            <option>Yashica TLR</option>\n            <option value=\"Other (Mechanical Camera)\">Other &mdash; Mechanical Camera</option>\n            <option value=\"Other (Electronical Camera)\">Other &mdash; Electronic Camera</option>\n          </select>\n          <span class=\"rp-hint\" id=\"rp-model-hint\"></span>\n        <div id=\"rp-model-search\" style=\"display:none;margin-top:14px\">\n          <div class=\"rp-field\">\n            <label>Your camera model</label>\n            <input type=\"text\" class=\"rp-sel\" id=\"rp-model-search-input\" placeholder=\"Type to search e.g. Olympus XA2...\" oninput=\"rpFilterCameras()\" autocomplete=\"off\" style=\"background-image:none\">\n            <div id=\"rp-model-search-results\" style=\"border:1.5px solid var(--border);border-top:none;max-height:180px;overflow-y:auto;display:none;background:var(--bg)\"></div>\n          </div>\n        </div>\n        </div>\n        <div class=\"rp-actions\">\n          <button class=\"rp-back\" onclick=\"rpGoTo(0)\">&larr; Back</button>\n          <button class=\"rp-next\" id=\"rp-n1\" disabled onclick=\"rpGoTo(2);rpSetupIssue()\">Next &rarr;</button>\n        </div>\n      </div>\n\n      <div class=\"rp-step\" id=\"rp-s2\">\n        <div class=\"rp-step-title\">What&rsquo;s the <em>issue</em>?</div>\n        <div class=\"rp-step-sub\">Select everything that applies.</div>\n        <div id=\"rp-fi-body\" style=\"display:none\">\n          <div class=\"rp-field\">\n            <label>Repair type</label>\n            <select class=\"rp-sel\" id=\"rp-repair\" onchange=\"rpOnRepair()\">\n              <option value=\"\">-- Select repair --</option>\n              <option value=\"Unknown/Other\">Unknown / Other &mdash; full inspection</option>\n              <option value=\"CLA\">CLA (Clean, Lube &amp; Adjust)</option>\n              <option value=\"Seal Replacement\">Light Seal Replacement</option>\n              <option value=\"Shutter issue\">Shutter Issue</option>\n              <option value=\"Meter issue\">Meter Issue</option>\n              <option value=\"Speed Issue\">Speed Issue</option>\n              <option value=\"Squeak/Cough\">Squeak / Cough</option>\n              <option value=\"Door Replacement\">Door Replacement</option>\n              <option value=\"Corrosion\">Corrosion</option>\n            </select>\n            <span class=\"rp-hint\" id=\"rp-repair-hint\"></span>\n          </div>\n          <div class=\"rp-cla-lnk\" id=\"rp-cla-lnk\"><a href=\"#\" onclick=\"rpOpenModal('cla');return false\">What&rsquo;s included in a CLA? &rarr;</a></div>\n        </div>\n        <div id=\"rp-fi-mech\" style=\"display:none\">\n          <div class=\"rp-field\">\n            <label>Mechanical issue</label>\n            <select class=\"rp-sel\" id=\"rp-mech\" onchange=\"rpOnMech()\">\n              <option value=\"\">-- Select issue --</option>\n              <option value=\"Unjam/Unstuck\">Unjam / Unstuck</option>\n              <option value=\"Light Seals\">Light Seal Replacement</option>\n              <option value=\"Cough/Squeak\">Cough / Squeak</option>\n              <option value=\"Door Replacement\">Door Replacement</option>\n              <option value=\"Unlisted Issue\">Unlisted Issue</option>\n            </select>\n            <span class=\"rp-hint\" id=\"rp-mech-hint\"></span>\n          </div>\n        </div>\n        <div id=\"rp-fi-lens\" style=\"display:none\">\n          <hr class=\"rp-sep\" id=\"rp-lens-sep\" style=\"display:none\">\n          <div class=\"rp-field\">\n            <label>Lens issue</label>\n            <select class=\"rp-sel\" id=\"rp-lens\" onchange=\"rpOnLens()\">\n              <option value=\"\">-- Select issue --</option>\n              <option value=\"Hasselblad Lens\">Hasselblad Lens</option>\n              <option value=\"Unlisted\">Unlisted &mdash; we repair most analog lenses</option>\n              <option value=\"Sluggish Aperture\">Sluggish Aperture</option>\n              <option value=\"Stiff Focus\">Stiff Focus</option>\n              <option value=\"Stiff Aperture\">Stiff Aperture</option>\n              <option value=\"Haze\">Haze</option>\n              <option value=\"Fungus\">Fungus</option>\n              <option value=\"Stuck Filter\">Stuck Filter</option>\n              <option value=\"Impact Damage\">Impact Damage</option>\n              <option value=\"AF Issue/Searching\">AF Issue / Searching</option>\n            </select>\n            <span class=\"rp-hint\" id=\"rp-lens-hint\"></span>\n          </div>\n        </div>\n        <div class=\"rp-ov\" id=\"rp-ov-cla\">\n          <div class=\"rp-modal\">\n            <button class=\"rp-modal-x\" onclick=\"rpCloseModal('cla')\">&times;</button>\n            <span class=\"rp-modal-ttl\">CLA &mdash; What&rsquo;s Included</span>\n            <p><strong>Camera CLA</strong><br>Inside-out cleaning of lubricants, dust, and residue. Improves winding, shutter release, protects against wear.</p>\n            <p><strong>Lens CLA</strong><br>Elements removed and cleaned of fungus, haze, dust. Helicoids regreased, aperture cleaned, focus set to infinity.</p>\n            <p class=\"warn\"><strong>Note:</strong> Lens and body CLAs are priced separately.</p>\n            <p style=\"font-size:9px;color:var(--muted);margin-top:12px;border-top:1px solid var(--border);padding-top:10px;\">Questions? Email <strong>repairs@brooklynfilmcamera.com</strong> \u2014 <span style=\"color:#b83a1a\">*</span> Simple questions welcome, but detailed assessments may require booking a bench fee appointment.</p>\n            <div class=\"rp-modal-foot\"><button class=\"rp-mbtn p\" onclick=\"rpCloseModal('cla')\">Got it</button></div>\n          </div>\n        </div>\n                <div class=\"rp-ov\" id=\"rp-ov-hasslens\">\n          <div class=\"rp-modal\">\n            <button class=\"rp-modal-x\" onclick=\"rpCloseModal('hasslens')\">&times;</button>\n            <span class=\"rp-modal-ttl\">Hasselblad Lens Repairs</span>\n            <p>We can only service <strong>C and CF mount Hasselblad lenses</strong>. If your lens is a different mount, we unfortunately cannot repair it.</p>\n            <p class=\"warn\">Not sure which mount you have? C/CF lenses have a distinctive chrome bayonet and were made for the 500 series bodies.</p>\n            <p style=\"font-size:9px;color:var(--muted);margin-top:12px;border-top:1px solid var(--border);padding-top:10px;\">Questions? Email <strong>repairs@brooklynfilmcamera.com</strong> \u2014 <span style=\"color:#b83a1a\">*</span> Simple questions welcome, but detailed assessments may require booking a bench fee appointment.</p>\n            <div class=\"rp-modal-foot\"><button class=\"rp-mbtn p\" onclick=\"rpCloseModal('hasslens')\">Got it</button></div>\n          </div>\n        </div>\n        <div class=\"rp-ov\" id=\"rp-ov-door\">\n          <div class=\"rp-modal\">\n            <button class=\"rp-modal-x\" onclick=\"rpCloseModal('door')\">&times;</button>\n            <span class=\"rp-modal-ttl\">Door Replacement</span>\n            <p>Door replacement possibilities depend on numerous factors including <strong>parts availability, type of door, and camera model</strong>.</p>\n            <p>The most common door replacements we perform are <strong>sliding doors</strong> for cameras like the Olympus MJU, Infinity, Stylus, and similar compact cameras.</p>\n            <p class=\"warn\">We'll assess feasibility after inspection &mdash; the $50 bench fee covers the diagnostic regardless of outcome.</p>\n            <p style=\"font-size:9px;color:var(--muted);margin-top:12px;border-top:1px solid var(--border);padding-top:10px;\">Questions? Email <strong>repairs@brooklynfilmcamera.com</strong> \u2014 <span style=\"color:#b83a1a\">*</span> Simple questions welcome, but detailed assessments may require booking a bench fee appointment.</p>\n            <div class=\"rp-modal-foot\"><button class=\"rp-mbtn p\" onclick=\"rpCloseModal('door')\">Got it</button></div>\n          </div>\n        </div>\n        <div class=\"rp-ov\" id=\"rp-ov-othermodel\">\n          <div class=\"rp-modal\">\n            <button class=\"rp-modal-x\" onclick=\"rpCloseModal('othermodel')\">&times;</button>\n            <span class=\"rp-modal-ttl\">Heads up &mdash; Unlisted Model</span>\n            <p>Your camera is not on our official repair list. We do our best to service as many models as possible, but <strong>there is a risk of denial</strong> for models we haven't previously assessed &mdash; including mechanical unjams, as some cameras cannot be opened regardless of design.</p>\n            <p class=\"warn\">The $50 bench fee is non-refundable, including in cases where we are unable to service your camera after inspection.</p>\n            <p style=\"font-size:9px;color:var(--muted);margin-top:12px;border-top:1px solid var(--border);padding-top:10px;\">Questions? Email <strong>repairs@brooklynfilmcamera.com</strong> \u2014 <span style=\"color:#b83a1a\">*</span> Simple questions welcome, but detailed assessments may require booking a bench fee appointment.</p>\n            <div class=\"rp-modal-foot\">\n              <button class=\"rp-mbtn p\" onclick=\"rpCloseModal('othermodel')\">I understand &mdash; proceed</button>\n              <button class=\"rp-mbtn s\" onclick=\"rpEl('rp-mech').value='';rpS.mech='';rpCheckIssue();rpCloseModal('othermodel')\">Go back</button>\n            </div>\n          </div>\n        </div>\n        <div class=\"rp-ov\" id=\"rp-ov-unjam\">\n          <div class=\"rp-modal\">\n            <button class=\"rp-modal-x\" onclick=\"rpCloseModal('unjam')\">&times;</button>\n            <span class=\"rp-modal-ttl\">Unjam / Unstuck</span>\n            <p>Many mechanical unjams are straightforward and we handle them regularly. That said, <strong>some models cannot be opened or serviced</strong> even for mechanical unjams, depending on design and condition.</p>\n            <p>We'll assess your camera and let you know after inspection. No repair work proceeds without your approval.</p>\n            <p style=\"font-size:9px;color:var(--muted);margin-top:12px;border-top:1px solid var(--border);padding-top:10px;\">Questions? Email <strong>repairs@brooklynfilmcamera.com</strong> \u2014 <span style=\"color:#b83a1a\">*</span> Simple questions welcome, but detailed assessments may require booking a bench fee appointment.</p>\n            <div class=\"rp-modal-foot\"><button class=\"rp-mbtn p\" onclick=\"rpCloseModal('unjam')\">Got it</button></div>\n          </div>\n        </div>\n        <div class=\"rp-ov\" id=\"rp-ov-unlisted\">\n          <div class=\"rp-modal\">\n            <button class=\"rp-modal-x\" onclick=\"rpCloseModal('unlisted')\">&times;</button>\n            <span class=\"rp-modal-ttl\">Heads up &mdash; Unlisted Issue</span>\n            <p>We&rsquo;ll do a full inspection either way &mdash; but there&rsquo;s a chance we may not be able to service your item. If that happens, we&rsquo;ll let you know after assessment.</p>\n            <p>The <strong>$50 bench fee is non-refundable</strong>, but it covers a thorough diagnostic regardless of outcome.</p>\n            <p style=\"font-size:9px;color:var(--muted);margin-top:12px;border-top:1px solid var(--border);padding-top:10px;\">Questions? Email <strong>repairs@brooklynfilmcamera.com</strong> \u2014 <span style=\"color:#b83a1a\">*</span> Simple questions welcome, but detailed assessments may require booking a bench fee appointment.</p>\n            <div class=\"rp-modal-foot\">\n              <button class=\"rp-mbtn p\" onclick=\"rpCloseModal('unlisted')\">I understand &mdash; proceed</button>\n              <button class=\"rp-mbtn s\" onclick=\"rpEl('rp-mech').value='';rpS.mech='';rpCheckIssue();rpCloseModal('unlisted')\">Go back</button>\n            </div>\n          </div>\n        </div>\n                <div class=\"rp-actions\">\n          <button class=\"rp-back\" onclick=\"rpIssueBack()\">&larr; Back</button>\n          <button class=\"rp-next\" id=\"rp-n2\" disabled onclick=\"rpGoTo(3)\">Next &rarr;</button>\n        </div>\n      </div>\n\n      <div class=\"rp-step\" id=\"rp-s3\">\n        <div class=\"rp-step-title\">Describe the <em>issue</em></div>\n        <div class=\"rp-step-sub\">The more detail, the better we can prepare.</div>\n        <div class=\"rp-field\">\n          <label>Serial number <span style=\"color:var(--muted);font-weight:400;letter-spacing:0;text-transform:none;font-size:9px;\">&mdash; usually found inside the film door or on the base</span></label>\n          <div style=\"display:flex;gap:8px;align-items:flex-start\">\n            <input type=\"text\" class=\"rp-sel\" id=\"rp-serial\" placeholder=\"e.g. 123456\" oninput=\"rpOnSerial()\" autocomplete=\"off\" style=\"background-image:none;flex:1\">\n            <button type=\"button\" id=\"rp-serial-skip\" onclick=\"rpSkipSerial()\" style=\"padding:10px 14px;border:1.5px solid var(--border);background:var(--bg);font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);cursor:pointer;white-space:nowrap;flex-shrink:0\">Can't find it</button>\n          </div>\n          <span class=\"rp-hint\" id=\"rp-serial-hint\"></span>\n        </div>\n        <div class=\"rp-tip\">Be specific &mdash; when did it start? What does it do exactly? Any prior repairs or drops?</div>\n        <div class=\"rp-field\">\n          <textarea class=\"rp-textarea\" id=\"rp-txt\" placeholder=\"e.g. Shutter fires but film advance feels sticky since I dropped it last month...\" oninput=\"rpOnDesc()\" rows=\"6\"></textarea>\n          <div class=\"rp-char\" id=\"rp-chars\">0 characters</div>\n        </div>\n        <div class=\"rp-actions\">\n          <button class=\"rp-back\" onclick=\"rpGoTo(2)\">&larr; Back</button>\n          <button class=\"rp-next\" id=\"rp-n3\" disabled onclick=\"rpGoTo(4)\">Review &rarr;</button>\n        </div>\n      </div>\n\n      <div class=\"rp-step\" id=\"rp-s4\">\n        <div class=\"rp-step-title\">Review &amp; <em>confirm</em></div>\n        <div class=\"rp-step-sub\">Confirm your details then pay the $50 bench fee to book your slot.</div>\n        <div class=\"rp-review-box\" id=\"rp-review\"></div>\n        <div class=\"rp-ack\">\n          <div class=\"rp-ack-row\"><strong>$50 bench fee is non-refundable</strong> &mdash; applied toward repair cost if work proceeds.</div>\n          <div class=\"rp-ack-row\"><strong>Remove all film, straps &amp; accessories</strong> before dropping off or shipping.</div>\n          <div class=\"rp-ack-row\">Questions first? <strong>repairs@brooklynfilmcamera.com</strong></div>\n        </div>\n        <div class=\"rp-fee-bar\">\n          <span class=\"rp-fee-lbl\">Due today &mdash; bench fee</span>\n          <span class=\"rp-fee-amt\">$50</span>\n        </div>\n        <div class=\"rp-fee-note\">Applied toward your final repair cost. Non-refundable.</div>\n        <button class=\"rp-submit\" id=\"rp-submit\" onclick=\"rpSubmit()\">Book repair &mdash; $50 &rarr;</button>\n        <div class=\"rp-err\" id=\"rp-err\"></div>\n        <div id=\"rp-success\" style=\"display:none;margin-top:16px\">\n          <div style=\"border-left:2px solid #1a6b3a;padding:10px 14px;margin-bottom:16px\">\n            <div style=\"font-size:11px;color:#1a6b3a;font-weight:500;margin-bottom:4px\">&#10003; Repair added to cart</div>\n            <div style=\"font-size:10px;color:var(--muted)\">Ready to checkout, or add another repair to the same order.</div>\n          </div>\n          <div style=\"display:flex;gap:10px;flex-wrap:wrap\">\n            <button class=\"rp-next\" onclick=\"window.location.href='/checkout'\">Checkout &rarr;</button>\n            <button class=\"rp-back\" style=\"border:1.5px solid var(--border);padding:11px 22px;font-size:10px;letter-spacing:.1em;text-transform:uppercase\" onclick=\"rpAddAnother()\">+ Add another repair</button>\n          </div>\n        </div>\n        <div class=\"rp-actions\" style=\"margin-top:14px\">\n          <button class=\"rp-back\" onclick=\"rpGoTo(3)\">&larr; Edit details</button>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"rp-sb\">\n      <span class=\"rp-sb-ttl\">Summary</span>\n      <div id=\"rp-sb-content\"><span class=\"rp-sb-empty\">Fill in the form&hellip;</span></div>\n      <hr class=\"rp-sb-div\">\n      <div class=\"rp-sb-fee\"><span class=\"rp-sb-fl\">Due today</span><span class=\"rp-sb-fa\">$50</span></div>\n      <span class=\"rp-sb-fn\">Bench fee &mdash; applied to repair.<br>Non-refundable.</span>\n      <span class=\"rp-how-ttl\">How it works</span>\n      <div class=\"rp-how-row\"><div class=\"rp-how-n\">1</div><div class=\"rp-how-t\"><strong>Book &amp; Ship</strong>Pay bench fee, ship or drop off at 855 Grand St, Brooklyn.</div></div>\n      <div class=\"rp-how-row\"><div class=\"rp-how-n\">2</div><div class=\"rp-how-t\"><strong>Diagnostic</strong>Full assessment within 6&ndash;10 business days.</div></div>\n      <div class=\"rp-how-row\"><div class=\"rp-how-n\">3</div><div class=\"rp-how-t\"><strong>Quote</strong>Detailed quote sent. No work until you approve.</div></div>\n      <div class=\"rp-how-row\"><div class=\"rp-how-n\">4</div><div class=\"rp-how-t\"><strong>Repair &amp; Return</strong>2&ndash;4 weeks, 3&ndash;6 month warranty.</div></div>\n    </div>\n\n  </div>\n  </div>\n</div>\n\n\n\n\n<script>\nvar rpCameraList = [\"Agfa Ambi Silette\", \"Agfa Billy\", \"Agfa Flexilette\", \"Agfa Isola\", \"Agfa Isolette\", \"Agfa Karat\", \"Agfa Optima\", \"Agfa Selecta\", \"Agfa Silette\", \"Agfa Super Isolette\", \"Argus C3\", \"Argus C44\", \"Argus C4\", \"Bronica EC\", \"Bronica EC-TL\", \"Bronica ETR\", \"Bronica ETRS\", \"Bronica ETRSi\", \"Bronica GS-1\", \"Bronica S2\", \"Bronica SQ-A\", \"Bronica SQ-Ai\", \"Bronica SQ-B\", \"Canon 7\", \"Canon 7s\", \"Canon A-1\", \"Canon AE-1\", \"Canon AE-1 Program\", \"Canon AL-1\", \"Canon AT-1\", \"Canon AV-1\", \"Canon Canonet\", \"Canon Canonet 28\", \"Canon Canonet QL17\", \"Canon Canonet QL17 GIII\", \"Canon Canonet QL19\", \"Canon Demi\", \"Canon Demi EE17\", \"Canon EF\", \"Canon Elph\", \"Canon F-1\", \"Canon F-1N\", \"Canon FT QL\", \"Canon FTb\", \"Canon FX\", \"Canon IV Sb\", \"Canon IXUS\", \"Canon P\", \"Canon Pellix\", \"Canon Snappy\", \"Canon Sure Shot\", \"Canon Sure Shot AF35M\", \"Canon Sure Shot Supreme\", \"Canon Sureshot Owl\", \"Canon T50\", \"Canon T60\", \"Canon T70\", \"Canon T80\", \"Canon T90\", \"Canon TX\", \"Canon VI-L\", \"Canon VI-T\", \"Contax 137 MA\", \"Contax 137 MD\", \"Contax 139 Quartz\", \"Contax 159 MM\", \"Contax 645\", \"Contax Aria\", \"Contax G1\", \"Contax G2\", \"Contax RTS\", 