    "custom_liquid_HLN6BA": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n\nRequired below:\n<div id=\"order-finder\"> ... </div>\n{%- endcomment -%}\n\n<section class=\"bfc-mailin-hero\" role=\"region\" aria-label=\"Mail-in service\">\n  <div class=\"bfc-mailin-hero__inner page-width\">\n    <div class=\"bfc-mailin-hero__grid\">\n      <div class=\"bfc-mailin-hero__content\">\n        <div class=\"bfc-mailin-hero__kicker\">Mail-in service</div>\n\n        <h1 class=\"bfc-mailin-hero__title\">Mail us your camera</h1>\n\n        <div class=\"bfc-mailin-hero__sub\">\n          Shipping a camera to Brooklyn Film Camera for service is easy. Start by finding your order below, then follow the steps to purchase a label. When buying a prepaid label there’s no need to put any notes inside your box.\n        </div>\n\n        <div class=\"bfc-mailin-hero__note\">\n          If you prefer to use your own label make sure to follow the instructions at the bottom of this page.\n        </div>\n      </div>\n\n      <aside class=\"bfc-mailin-hero__card\" aria-label=\"Quick info\">\n        <div class=\"bfc-mailin-hero__card-title\">Quick info</div>\n\n        <div class=\"bfc-mailin-hero__list\">\n          <div class=\"bfc-mailin-hero__list-item\">\n            <span class=\"bfc-mailin-hero__dot\" aria-hidden=\"true\"></span>\n            <span class=\"bfc-mailin-hero__list-text\">\n              Remove all accessories, bags, cases, and straps before sending in. Any extra accessories left have a chance of not being returned.\n            </span>\n          </div>\n          <div class=\"bfc-mailin-hero__list-item\">\n            <span class=\"bfc-mailin-hero__dot\" aria-hidden=\"true\"></span>\n            <span class=\"bfc-mailin-hero__list-text\">\n              Pack it safely. Don’t want your camera to break even more.\n            </span>\n          </div>\n          <div class=\"bfc-mailin-hero__list-item\">\n            <span class=\"bfc-mailin-hero__dot\" aria-hidden=\"true\"></span>\n            <span class=\"bfc-mailin-hero__list-text\">\n              We’ll confirm when it arrives and keep you updated.\n            </span>\n          </div>\n        </div>\n      </aside>\n    </div>\n  </div>\n\n  <style>\n    /* Hard reset rounding inside module */\n    .bfc-mailin-hero,\n    .bfc-mailin-hero *{\n      border-radius: 0 !important;\n    }\n\n    .bfc-mailin-hero{\n      --bfc-text: #231F20;\n      --bfc-brown: #5A3E2D;\n      --bfc-accent: #F4A027;\n      --bfc-border: rgba(35,31,32,.18);\n\n      background: transparent; /* removed soft yellow */\n      color: var(--bfc-text);\n      padding: 56px 0;\n    }\n\n    .bfc-mailin-hero__inner{\n      padding-left: 20px;\n      padding-right: 20px;\n    }\n\n    .bfc-mailin-hero__grid{\n      display: grid;\n      grid-template-columns: 1.35fr 0.65fr;\n      gap: 18px;\n      align-items: start;\n    }\n\n    .bfc-mailin-hero__content{\n      border: 1px solid var(--bfc-border);\n      background: transparent;\n      padding: 20px;\n    }\n\n    .bfc-mailin-hero__kicker{\n      font-family: \"Univers\",\"Helvetica Neue\",Helvetica,Arial,sans-serif;\n      font-size: 12px;\n      letter-spacing: .12em;\n      text-transform: uppercase;\n      color: var(--bfc-brown);\n      margin: 0 0 10px 0;\n    }\n\n    .bfc-mailin-hero__title{\n      font-family: \"Adobe Garamond Pro\",\"Garamond\",\"Times New Roman\",serif;\n      font-weight: 600;\n      line-height: 1.05;\n      margin: 0 0 10px 0;\n      font-size: clamp(28px, 3.2vw, 44px);\n      letter-spacing: -0.02em;\n      color: var(--bfc-text);\n    }\n\n    .bfc-mailin-hero__sub{\n      font-family: \"Univers\",\"Helvetica Neue\",Helvetica,Arial,sans-serif;\n      font-size: 16px;\n      line-height: 1.55;\n      color: var(--bfc-brown);\n      max-width: 62ch;\n    }\n\n    .bfc-mailin-hero__note{\n      margin-top: 12px;\n      font-family: \"Univers\",\"Helvetica Neue\",Helvetica,Arial,sans-serif;\n      font-size: 12px;\n      line-height: 1.45;\n      color: var(--bfc-brown);\n      max-width: 70ch;\n    }\n\n    .bfc-mailin-hero__card{\n      border: 1px solid var(--bfc-border);\n      background: transparent;\n      padding: 18px;\n      position: relative;\n    }\n\n    .bfc-mailin-hero__card:before{\n      content: \"\";\n      position: absolute;\n      top: 0; left: 0; right: 0;\n      height: 4px;\n      background: var(--bfc-accent);\n    }\n\n    .bfc-mailin-hero__card-title{\n      font-family: \"Univers\",\"Helvetica Neue\",Helvetica,Arial,sans-serif;\n      font-size: 12px;\n      letter-spacing: .12em;\n      text-transform: uppercase;\n      color: var(--bfc-brown);\n      margin: 10px 0 12px 0;\n    }\n\n    .bfc-mailin-hero__list{\n      display: grid;\n      gap: 10px;\n    }\n\n    .bfc-mailin-hero__list-item{\n      display: grid;\n      grid-template-columns: 10px 1fr;\n      gap: 10px;\n      align-items: start;\n    }\n\n    .bfc-mailin-hero__dot{\n      width: 8px;\n      height: 8px;\n      background: var(--bfc-accent);\n      margin-top: 6px;\n      display: inline-block;\n    }\n\n    .bfc-mailin-hero__list-text{\n      font-family: \"Univers\",\"Helvetica Neue\",Helvetica,Arial,sans-serif;\n      font-size: 14px;\n      line-height: 1.45;\n      color: var(--bfc-text);\n    }\n\n    @media (max-width: 900px){\n      .bfc-mailin-hero__grid{ grid-template-columns: 1fr; }\n      .bfc-mailin-hero__content, .bfc-mailin-hero__card{ padding: 16px; }\n    }\n  </style>\n</section>",
        "section_width": "max-w-page",
