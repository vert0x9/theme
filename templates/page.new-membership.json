orm:uppercase;text-decoration:none;transition:all .15s}\n.mem-btn-secondary:hover{border-color:var(--ink);color:var(--ink)}\n.mem-plan.featured .mem-btn-secondary{border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.5)}\n.mem-plan.featured .mem-btn-secondary:hover{border-color:rgba(255,255,255,.6);color:#fff}\n.mem-billing-toggle{display:inline-flex;border:1.5px solid var(--border);border-radius:4px;overflow:hidden;margin-bottom:24px;background:var(--bg)}\n.mem-billing-toggle button{padding:8px 18px;background:transparent;border:none;font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;color:var(--muted);transition:all .15s}\n.mem-billing-toggle button.active{background:var(--ink);color:#fff}\n\/* COMPARISON TABLE *\/\n.mem-compare{border:1.5px solid var(--border);border-radius:8px;overflow:hidden;background:var(--bg);margin-bottom:32px}\n.mem-compare-head{display:grid;grid-template-columns:2fr 1fr 1fr;background:var(--paper)}\n.mem-compare-head div{padding:10px 16px;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)}\n.mem-compare-head div:not(:last-child){border-right:1px solid var(--border)}\n.mem-compare-row{display:grid;grid-template-columns:2fr 1fr 1fr;border-bottom:1px solid #f0ede8}\n.mem-compare-row:last-child{border-bottom:none}\n.mem-compare-row div{padding:11px 16px;font-size:11px;color:var(--ink)}\n.mem-compare-row div:not(:last-child){border-right:1px solid #f0ede8}\n.mem-compare-row div:first-child{color:var(--muted);font-size:10px;letter-spacing:.04em}\n.mem-compare-val{font-weight:500}\n.mem-compare-accent{color:var(--accent)!important;font-weight:500}\n\/* CALCULATOR *\/\n.mem-calc{border:1.5px solid var(--border);border-radius:8px;overflow:hidden;background:var(--bg);margin-bottom:32px}\n.mem-calc-head{padding:16px 20px;border-bottom:1px solid var(--border);background:var(--paper)}\n.mem-calc-title{font-size:11px;letter-spacing:.08em;