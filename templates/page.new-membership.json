px}\n.mem-result-mo{font-size:9px;opacity:.5;margin-bottom:8px}\n.mem-result-saving{font-size:10px;color:var(--accent);font-weight:500}\n.mem-calc-result.best .mem-result-saving{color:#f0a070}\n.mem-result-tag{display:inline-block;background:var(--accent);color:#fff;font-size:7px;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;border-radius:10px;margin-bottom:6px}\n\/* CREDIT NOTE *\/\n.mem-credit-note{background:#fdf6f0;border:1.5px solid #c8622a33;border-radius:8px;padding:16px 20px;margin-bottom:32px;font-size:11px;line-height:1.7;color:var(--ink)}\n.mem-credit-note strong{color:var(--accent)}\n\n\/* ── Mobile swipe carousel ── *\/\n@media(max-width:768px){\n  .mem-hero-layout{grid-template-columns:1fr;gap:0;padding-bottom:0}\n  .mem-hero-card{display:none}\n  .mem-plans-lower{grid-template-columns:1fr}\n  .mem-swipe-track-wrap{overflow:hidden;margin:0 -20px;padding:0 20px 20px}\n  .mem-swipe-track{display:flex;gap:14px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding-right:60px;scrollbar-width:none}\n  .mem-swipe-track::-webkit-scrollbar{display:none}\n  .mem-swipe-card{min-width:78vw;max-width:78vw;scroll-snap-align:start;scroll-snap-stop:always;flex-shrink:0}\n}\n@media(min-width:769px){\n  .mem-swipe-track-wrap{display:none}\n  .mem-hero-card .mem-plan{height:100%}\n  .mobile-teaser{display:none!important}\n}\n@media(max-width:768px){\n  .desktop-teaser{display:none!important}\n  \/* Comparison table: tabbed on mobile *\/\n  .mem-compare-desktop{display:none}\n  .mem-compare-mobile{display:block}\n  .mem-ctab-btns{display:flex;gap:0;border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:12px}\n  .mem-ctab-btn{flex:1;padding:7px 4px;font-size:8px;letter-spacing:.08em;text-transform:uppercase;text-align:center;cursor:pointer;background:var(--paper);color:var(--muted);border:none;font-family:var(--mono);border-right:1px solid var(--border)}\n  .mem-ctab-btn:last-child{border-right:none}\n 