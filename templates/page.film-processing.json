    "custom_liquid_bg7GDb": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\nDeveloping Membership — Updated with Repair Landing Aesthetic + Correct Address\n{%- endcomment -%}\n\n{%- liquid\n  assign HERO_IMAGE_HANDLE = 'lab-hero.jpg'\n  assign HERO_IMAGE_OVERRIDE_URL = 'https://cdn.shopify.com/s/files/1/0575/8638/5068/files/EX_50__Develop_Hero_2.jpg?v=1759169611'\n\n  assign HERO_IMAGE_URL = HERO_IMAGE_OVERRIDE_URL\n  if HERO_IMAGE_URL == blank\n    assign HERO_IMAGE_URL = HERO_IMAGE_HANDLE | file_url\n  endif\n\n  assign ORDER_DEV_MEMBER_URL = '/products/developing-membership-price'\n  assign ORDER_DEV_NON_MEMBER_URL = '/products/developing'\n  \n  assign font_heading = '\"Helvetica Neue\", Helvetica, Arial, sans-serif'\n  assign font_body = '\"Adobe Garamond Pro\", \"Garamond\", \"Times New Roman\", serif'\n-%}\n\n<div class=\"bfc-root\" data-billing-cycle=\"monthly\">\n  \n  <style>\n    .bfc-root {\n      --font-heading: {{ font_heading }};\n      --font-body: {{ font_body }};\n      --bg: #F9F9F9;\n      --text: #1C1C1C;\n      --accent: #CC3300;\n      color: var(--text);\n      background-color: var(--bg);\n    }\n\n    .bfc-root * { \n      box-sizing: border-box; \n    }\n\n    /* TYPOGRAPHY */\n    .bfc-root h1, .bfc-root h2, .bfc-root h3, .bfc-root .bfc-btn, .bfc-root .bfc-pill, .bfc-root .policy-title {\n      font-family: var(--font-heading);\n      letter-spacing: -0.02em;\n    }\n\n    .bfc-root p, .bfc-root li, .bfc-root .bfc-note {\n      font-family: var(--font-body);\n      line-height: 1.5;\n    }\n\n    /* TOP TAB */\n    .bfc-top-tab {\n      position: fixed; top: 12px; right: 12px; z-index: 50;\n      background: var(--text); color: #fff; border: 1px solid var(--text);\n      padding: 10px 16px; font-weight: 700; font-size: 12px; text-transform: uppercase;\n      text-decoration: none; letter-spacing: 0.05em;\n      transition: all .2s ease;\n    }\n    .bfc-top-tab:hover { background: transparent; color: var(--text); }\n\n    /* HERO SECTION */\n    .bfc-efc-hero { position: relative; overflow: hidden; color: var(--text); padding-top: 60px; padding-bottom: 60px;}\n    .bfc-efc-hero__wrap { position: relative; max-width: 1400px; margin: 0 auto; padding: 0 20px; }\n    \n    @media(min-width: 1024px) { \n      .bfc-efc-hero__wrap { padding: 0 50px; } \n      .bfc-efc-hero__grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 80px; align-items: start; }\n    }\n\n    .bfc-pill { \n      display: inline-block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em;\n      border: 1px solid var(--text); padding: 4px 8px; margin-bottom: 20px; background: transparent; color: var(--text);\n    }\n\n    .bfc-efc-hero__title { \n      font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 0.95; margin: 0 0 20px 0; font-weight: 700; \n    }\n    \n    .bfc-efc-hero__sub { \n      font-size: 1.25rem; max-width: 500px; margin-bottom: 20px; opacity: 0.9;\n    }\n\n    /* HERO BUTTONS */\n    .bfc-efc-hero__ctas { display: flex; flex-wrap: wrap; gap: 15px; margin-top: 40px; }\n    \n    .bfc-btn {\n      display: inline-flex; align-items: center; justify-content: center;\n      padding: 14px 28px; font-size: 14px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em;\n      text-decoration: none; border: 1px solid var(--text); cursor: pointer;\n      transition: all 0.2s ease;\n    }\n    \n    .bfc-btn--filled { background: var(--text); color: #fff; }\n    .bfc-btn--filled:hover { background: transparent; color: var(--text); }\n    \n    .bfc-btn--ghost { background: transparent; color: var(--text); }\n    .bfc-btn--ghost:hover { background: rgba(0,0,0,0.05); }\n\n    .bfc-cta-note { width: 100%; margin-top: 15px; font-size: 0.85rem; color: #666; font-style: italic; }\n\n    /* MEDIA CARD (Hero Image) */\n    .bfc-media-card { aspect-ratio: 4/3; width: 100%; background: #eee; overflow: hidden; }\n    .bfc-media-card__img { width: 100%; height: 100%; object-fit: cover; box-shadow: 10px 10px 30px rgba(0,0,0,0.1); }\n\n    /* MEMBERSHIP SECTION */\n    .bfc-memberships { background: #fff; padding: 60px 0; border-top: 1px solid rgba(0,0,0,0.1); }\n    .bfc-subscribe__wrap { max-width: 1400px; margin: 0 auto; padding: 0 20px; }\n    @media(min-width: 1024px) { .bfc-subscribe__wrap { padding: 0 50px; } }\n\n    .bfc-subscribe__title { font-size: 2.5rem; margin: 0 0 30px; font-weight: 700; text-transform: uppercase; }\n\n    /* BILLING TOGGLE */\n    .bfc-billing-toggle { display: flex; gap: 0; margin-bottom: 40px; border: 1px solid var(--text); display: inline-flex; }\n    .bfc-billing-btn { \n      border: none; background: #fff; color: var(--text); padding: 12px 24px; \n      font-weight: 700; font-size: 14px; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em;\n      font-family: var(--font-heading);\n    }\n    .bfc-billing-btn.is-active { background: var(--text); color: #fff; }\n\n    /* CARDS GRID */\n    .bfc-subscribe__grid { display: grid; gap: 30px; }\n    @media(min-width: 768px) { .bfc-subscribe__grid { grid-template-columns: 1fr 1fr; } }\n\n    .bfc-sub-card { \n      border: 1px solid rgba(0,0,0,0.1); padding: 30px; background: #FAFAFA; \n      display: flex; flex-direction: column; transition: box-shadow 0.2s ease;\n    }\n    .bfc-sub-card:hover { box-shadow: 0 10px 30px rgba(0,0,0,0.05); border-color: var(--text); }\n\n    .bfc-sub-card__title { font-size: 1.5rem; margin: 0 0 5px; text-transform: uppercase; }\n    .bfc-sub-card__sub { margin-bottom: 20px; font-size: 1rem; color: #666; font-family: var(--font-body); }\n    \n    .bfc-perks { list-style: none; padding: 0; margin: 0 0 30px; }\n    .bfc-perks li { margin-bottom: 8px; padding-left: 20px; position: relative; font-size: 1rem; }\n    .bfc-perks li::before { content: \"→\"; position: absolute; left: 0; top: 1px; font-size: 0.8em; }\n    \n    .bfc-sub-card__actions { margin-top: auto; }\n    .bfc-sub-card__actions .bfc-btn { width: 100%; }\n\n    .bfc-subscribe__fine { margin-top: 20px; font-size: 0.85rem; color: #888; font-style: italic; }\n\n    /* --- NEW MAIL-IN SECTION --- */\n    .bfc-mail-in { padding: 80px 0; background: #F9F9F9; border-top: 1px solid rgba(0,0,0,0.1); }\n    .bfc-mail-in__wrap { \n      max-width: 1400px; margin: 0 auto; padding: 0 20px; \n      display: grid; gap: 50px; \n    }\n    @media(min-width: 1024px) { \n      .bfc-mail-in__wrap { grid-template-columns: 1fr 1fr; padding: 0 50px; align-items: start; } \n    }\n\n    .bfc-mail-in h2 { font-size: 2.5rem; margin-bottom: 20px; text-transform: uppercase; }\n    .bfc-mail-in p { font-size: 1.1rem; max-width: 500px; margin-bottom: 20px; }\n\n    /* RECEIPT STYLE BOX */\n    .bfc-receipt {\n      background: #fff;\n      padding: 30px;\n      position: relative;\n      box-shadow: 0 10px 30px rgba(0,0,0,0.05);\n      border: 1px solid rgba(0,0,0,0.05);\n    }\n    .bfc-receipt-title {\n      font-family: var(--font-heading);\n      font-weight: 700; text-transform: uppercase; font-size: 0.9rem;\n      color: var(--accent); margin-bottom: 15px; display: block;\n    }\n    .bfc-receipt-row {\n      display: flex; justify-content: space-between;\n      border-bottom: 1px dashed #ccc; padding: 12px 0; font-size: 1rem;\n      font-family: var(--font-body);\n    }\n    .bfc-receipt-row strong { font-family: var(--font-heading); }\n    .bfc-receipt-note { font-size: 0.85rem; margin-top: 15px; color: #666; font-style: italic; }\n\n    /* CREDITS FOOTER */\n    .bfc-credits { background: #111; color: #fff; padding: 40px 0; text-align: center; }\n    .bfc-credits h2 { color: #fff; font-size: 1.5rem; margin-bottom: 5px; }\n    .bfc-credits .bfc-note { color: #888; }\n  </style>\n\n  <a class=\"bfc-top-tab\" href=\"https://brooklynfilmcamera.com/products/developing-membership-price\" aria-label=\"Member Page\">Member Page</a>\n\n  <section class=\"bfc-efc-hero\" aria-labelledby=\"bfc-dev-hero-heading\">\n    <div class=\"bfc-efc-hero__wrap\">\n      <div class=\"bfc-efc-hero__grid\">\n        <div class=\"bfc-efc-hero__copy\">\n          <span class=\"bfc-pill\">Fast & Reliable in NYC</span>\n          <h1 id=\"bfc-dev-hero-heading\" class=\"bfc-efc-hero__title\">Film Developing &amp; Membership</h1>\n          <p class=\"bfc-efc-hero__sub\">\n            Monthly subscriptions start at the price of just one roll of film — and include at least <strong>1 free developing credit</strong> every month. Members also unlock discounted rates on all film processing and services.\n          </p>\n          <p class=\"bfc-efc-hero__sub\">\n            We handle <strong>35mm, medium format, disposables, C-41 color, black &amp; white, push/pull, E6, ECN2</strong> — with typical turnaround of 3–4 days.\n          </p>\n          <div class=\"bfc-efc-hero__ctas\">\n            <a class=\"bfc-btn bfc-btn--filled\" href=\"#memberships\">Join the Membership</a>\n            <a class=\"bfc-btn bfc-btn--ghost\" href=\"{{ ORDER_DEV_MEMBER_URL }}\">Order (Member)</a>\n            <a class=\"bfc-btn bfc-btn--ghost\" href=\"{{ ORDER_DEV_NON_MEMBER_URL }}\">Order (Guest)</a>\n            <p class=\"bfc-cta-note\">Not a member yet? You can still order developing.</p>\n          </div>\n        </div>\n\n        <div class=\"bfc-efc-hero__media\">\n          {% if HERO_IMAGE_URL contains 'cdn.shopify.com' %}\n            <figure class=\"bfc-media-card\">\n              <img class=\"bfc-media-card__img\"\n                   src=\"{{ HERO_IMAGE_URL }}\"\n                   alt=\"Film developing at Brooklyn Film Camera\"\n                   loading=\"eager\" width=\"1600\" height=\"1200\">\n            </figure>\n          {% else %}\n            <figure class=\"bfc-media-card bfc-media-card--placeholder\" aria-hidden=\"true\"></figure>\n          {% endif %}\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section id=\"memberships\" class=\"bfc-memberships\" aria-labelledby=\"bfc-memberships-heading\">\n    <div class=\"bfc-subscribe__wrap\">\n      <h2 id=\"bfc-memberships-heading\" class=\"bfc-subscribe__title\">Memberships</h2>\n\n      <div class=\"bfc-billing-toggle\" role=\"tablist\" aria-label=\"Billing cycle\">\n        <button type=\"button\" class=\"bfc-billing-btn is-active\" role=\"tab\" aria-selected=\"true\" data-cycle=\"monthly\">Monthly</button>\n        <button type=\"button\" class=\"bfc-billing-btn\" role=\"tab\" aria-selected=\"false\" data-cycle=\"yearly\">Yearly</button>\n      </div>\n\n      <div class=\"bfc-subscribe__grid\">\n        <article class=\"bfc-sub-card\"\n          data-month-price=\"15\"   data-year-price=\"180\"\n          data-month-credits=\"1\"  data-year-credits=\"12\"\n          data-link-month=\"https://brooklyn-film-camera.myshopify.com/cart/clear?return_to=/cart/add?items[][id]=44631474307244%26items[][quantity]=1%26items[][selling_plan]=2967437484%26return_to=/checkout\"\n          data-link-year=\"https://brooklyn-film-camera.myshopify.com/cart/clear?return_to=/cart/add?items[][id]=44631474307244%26items[][quantity]=1%26items[][selling_plan]=3007905964%26return_to=/checkout\">\n          <h3 class=\"bfc-sub-card__title\">Casual Shooter</h3>\n          <p class=\"bfc-sub-card__sub\"><span class=\"bfc-price\">$15</span> / <span class=\"bfc-cycle-label\">month</span></p>\n          <ul class=\"bfc-perks\">\n            <li><span class=\"bfc-credits-count\">1</span> free developing credit <span class=\"bfc-period-label\">every month</span></li>\n            <li>Unlimited member discounted pricing</li>\n            <li>Free Sleeving</li>\n            <li>Free TIFF Upgrade</li>\n          </ul>\n          <div class=\"bfc-sub-card__actions\">\n            <a class=\"bfc-btn bfc-btn--filled bfc-cta\" href=\"#\" data-current-link>Buy Monthly</a>\n          </div>\n        </article>\n\n        <article class=\"bfc-sub-card\"\n          data-month-price=\"42\"   data-year-price=\"504\"\n          data-month-credits=\"3\"  data-year-credits=\"36\"\n          data-link-month=\"https://brooklyn-film-camera.myshopify.com/cart/clear?return_to=/cart/add?items[][id]=44631474340012%26items[][quantity]=1%26items[][selling_plan]=2967437484%26return_to=/checkout\"\n          data-link-year=\"https://brooklyn-film-camera.myshopify.com/cart/clear?return_to=/cart/add?items[][id]=44631474340012%26items[][quantity]=1%26items[][selling_plan]=3007905964%26return_to=/checkout\">\n          <h3 class=\"bfc-sub-card__title\">Enthusiast</h3>\n          <p class=\"bfc-sub-card__sub\"><span class=\"bfc-price\">$42</span> / <span class=\"bfc-cycle-label\">month</span></p>\n          <ul class=\"bfc-perks\">\n            <li><span class=\"bfc-credits-count\">3</span> free developing credits <span class=\"bfc-period-label\">every month</span></li>\n            <li>Unlimited member discounted pricing</li>\n            <li>Free Sleeving</li>\n            <li>Free TIFF Upgrade</li>\n          </ul>\n          <div class=\"bfc-sub-card__actions\">\n            <a class=\"bfc-btn bfc-btn--filled bfc-cta\" href=\"#\" data-current-link>Buy Monthly</a>\n          </div>\n        </article>\n      </div>\n      <p class=\"bfc-subscribe__fine\">Credits add every month. Unused credits DO roll over but cap at 50.</p>\n    </div>\n  </section>\n\n  <section class=\"bfc-mail-in\">\n    <div class=\"bfc-mail-in__wrap\">\n      <div class=\"bfc-mail-in__content\">\n        <h2>Shipping us your film?</h2>\n        <p>\n          We accept film for developing from all over the world. Please pack your rolls securely (bubble wrap or a sturdy box is recommended).\n        </p>\n        <p>\n          <strong>Instructions:</strong><br>\n          1. Place your developing order online.<br>\n          2. Write down your <strong>Order Number</strong> and Name on a slip of paper.<br>\n          3. Include the paper in the box with your film.<br>\n          4. Ship to the address listed here.\n        </p>\n        <br>\n        <a href=\"{{ ORDER_DEV_NON_MEMBER_URL }}\" class=\"bfc-btn bfc-btn--primary\">Start Order</a>\n      </div>\n\n      <div class=\"bfc-receipt\">\n        <span class=\"bfc-receipt-title\">Mailing Address</span>\n        \n        <div class=\"bfc-receipt-row\">\n          <span>Ship To</span>\n          <strong>Developing @ BFC</strong>\n        </div>\n        <div class=\"bfc-receipt-row\">\n          <span>Address</span>\n          <strong>697 Grand St #119</strong>\n        </div>\n        <div class=\"bfc-receipt-row\">\n          <span>City/State</span>\n          <strong>Brooklyn, NY</strong>\n        </div>\n        <div class=\"bfc-receipt-row\">\n          <span>Zip Code</span>\n          <strong>11211</strong>\n        </div>\n\n        <p class=\"bfc-receipt-note\">\n          *<strong>Important:</strong> You must select and pay for return shipping at checkout if you want your negatives returned. If shipping is not paid, negatives will be discarded after scanning.\n        </p>\n      </div>\n    </div>\n  </section>\n\n  <section id=\"member-credits\" class=\"bfc-credits\">\n    <div class=\"bfc-credits__wrap\">\n      <h2 style=\"font-size: 1.8rem;\">Your Membership &amp; Credits</h2>\n      <p class=\"bfc-note\"><em>Users must be logged in</em></p>\n    </div>\n  </section>\n\n</div>\n\n<script>\n(function(){\n  const root = document.querySelector('.bfc-root');\n  if(!root) return;\n\n  function setCycle(cycle){\n    // Toggle UI\n    root.querySelectorAll('.bfc-billing-btn').forEach(btn=>{\n      const active = btn.dataset.cycle === cycle;\n      btn.classList.toggle('is-active', active);\n      btn.setAttribute('aria-selected', String(active));\n    });\n\n    // Update each card\n    root.querySelectorAll('.bfc-sub-card').forEach(card=>{\n      const priceEl = card.querySelector('.bfc-price');\n      const cycleLabelEl = card.querySelector('.bfc-cycle-label');\n      const creditsEl = card.querySelector('.bfc-credits-count');\n      const periodEl = card.querySelector('.bfc-period-label');\n      const ctaEl = card.querySelector('.bfc-cta');\n\n      if(!(priceEl && cycleLabelEl && creditsEl && ctaEl)) return;\n\n      if(cycle === 'monthly'){\n        priceEl.textContent = `$${card.dataset.monthPrice}`;\n        cycleLabelEl.textContent = 'month';\n        creditsEl.textContent = card.dataset.monthCredits;\n        if (periodEl) periodEl.textContent = 'every month';\n        ctaEl.textContent = 'Buy Monthly';\n        ctaEl.href = card.dataset.linkMonth || '#';\n      } else {\n        priceEl.textContent = `$${card.dataset.yearPrice}`;\n        cycleLabelEl.textContent = 'year';\n        creditsEl.textContent = card.dataset.yearCredits;\n        if (periodEl) periodEl.textContent = 'per year';\n        ctaEl.textContent = 'Buy Yearly';\n        ctaEl.href = card.dataset.linkYear || '#';\n      }\n    });\n  }\n\n  // Default state\n  setCycle('monthly');\n\n  // Bind clicks\n  root.querySelectorAll('.bfc-billing-btn').forEach(btn=>{\n    btn.addEventListener('click', ()=> setCycle(btn.dataset.cycle));\n  });\n})();\n</script>",
        "section_width": "max-w-page",
        "color_scheme": "",
        "spacing_top": "2",
        "spacing_bottom": "2"
      }
