n.bfc-diff__num{font-size:32px}\n.bfc-diff__ct{font-size:18px}\n}\n<\/style>\n\n<div class=\"bfc-diff\">\n  <p class=\"bfc-diff__ey\">Why Buy From Us<\/p>\n  <h2 class=\"bfc-diff__h\">The Brooklyn Film Camera Difference<\/h2>\n  <p class=\"bfc-diff__sub\">Every camera leaves our shop restored, tested, and backed by our warranty. No exceptions.<\/p>\n\n  <div class=\"bfc-diff__grid\">\n    <div class=\"bfc-diff__card\">\n      <span class=\"bfc-diff__num\">1<\/span>\n      <h3 class=\"bfc-diff__ct\">Restored<\/h3>\n      <span class=\"bfc-diff__acc\"><\/span>\n      <p class=\"bfc-diff__cb\">We lovingly bring vintage analog cameras back to life, in both form and in function.<\/p>\n    <\/div>\n    <div class=\"bfc-diff__card\">\n      <span class=\"bfc-diff__num\">2<\/span>\n      <h3 class=\"bfc-diff__ct\">Tested<\/h3>\n      <span class=\"bfc-diff__acc\"><\/span>\n      <p class=\"bfc-diff__cb\">Every camera we sell is put through professional testing equipment to ensure it works the way it did when it left the factory decades ago.<\/p>\n    <\/div>\n    <div class=\"bfc-diff__card\">\n      <span class=\"bfc-diff__num\">3<\/span>\n      <h3 class=\"bfc-diff__ct\">Guaranteed<\/h3>\n      <span class=\"bfc-diff__acc\"><\/span>\n      <p class=\"bfc-diff__cb\">If for some reason your camera isn't in tip top shape, it comes with a warranty. We replace or fix it, no problem.<\/p>\n    <\/div>\n  <\/div>\n<\/div>","section_width":"max-w-page","color_scheme":"","spacing_top":"2","spacing_bottom":"2"}},"our_process_WBAbLn":{"type":"our-process","blocks":{"card_BVd34n":{"type":"card","settings":{"icon_preset":"none","heading":"1. Restored","description":"We lovingly bring vintage analog cameras back to life, in both form and in function.","card_heading_font_class":"font-heading","card_heading_font_size":2,"card_description_font_class":"font-body","card_description_font_size":1.1}},"card_VdCCfc":{"type":"card","settings":{"icon_preset":"none","heading":"2. Tested","descript