:{"section_layout":"normal","spacing_inner":"2","section_width":"max-w-page","color_scheme":"","spacing_top":"2","spacing_bottom":"2"}},"custom_liquid_id4jAR":{"type":"custom-liquid","name":"t:sections.custom-liquid.name","settings":{"custom_liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n<style>\n  .bfc-intake{max-width:760px;margin:24px auto;padding:18px;border:1px solid rgba(0,0,0,.12);border-radius:14px}\n  .bfc-intake h3{margin:0 0 10px;font-size:18px}\n  .bfc-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}\n  .bfc-grid .full{grid-column:1\/-1}\n  .bfc-field label{display:block;font-size:12px;opacity:.8;margin:0 0 6px}\n  .bfc-field input,.bfc-field textarea,.bfc-field select{\n    width:100%;padding:10px 12px;border:1px solid rgba(0,0,0,.18);border-radius:10px;font-size:14px;background:#fff\n  }\n  .bfc-field textarea{min-height:110px;resize:vertical}\n  .bfc-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:12px}\n  .bfc-btn{appearance:none;border:0;border-radius:999px;padding:10px 14px;font-size:14px;cursor:pointer}\n  .bfc-btn.primary{background:#111;color:#fff}\n  .bfc-help{font-size:12px;opacity:.75;margin-top:8px}\n  @media (max-width: 640px){.bfc-grid{grid-template-columns:1fr}}\n<\/style>\n\n<div class=\"bfc-intake\" id=\"bfc-cart-intake\">\n  <h3>Details for this item<\/h3>\n  <p class=\"bfc-help\">These details will be attached to the cart item and will appear on the order after checkout.<\/p>\n\n  {%- form 'product', product, id: 'bfc_intake_product_form' -%}\n    <input type=\"hidden\" name=\"id\" value=\"{{ v.id }}\">\n\n    <div class=\"bfc-grid\">\n      <div class=\"bfc-field\">\n        <label for=\"bfc_name\">Full name<\/label>\n        <input id=\"bfc_name\" type=\"text\" name=\"properties[Full name]\" required>\n      <\/div>\n\n      <div class=\"bfc-field\">\n        <label for=\"bfc_email\">Email<\/label>\n        <input id=\"bfc_email\" type=\"email\" name=\"properties[Email]\" required>\n      <\/div>\n\n      <div class=\"bfc-field\">\n        <label for=\"bfc_phone\">Phone (optional)<\/label>\n        <input id=\"bfc_phone\" type=\"tel\" name=\"properties[Phone]\">\n      <\/div>\n\n      <div class=\"bfc-field\">\n        <label for=\"bfc_order_hint\">Order number (optional)<\/label>\n        <input id=\"bfc_order_hint\" type=\"text\" name=\"properties[Order number (if known)]\" placeholder=\"#12345\">\n      <\/div>\n\n      <div class=\"bfc-field full\">\n        <label for=\"bfc_notes\">Notes<\/label>\n        <textarea id=\"bfc_notes\" name=\"properties[Notes]\" required><\/textarea>\n      <\/div>\n\n      {%- comment -%} Optional file upload: Shopify line item properties do NOT support file data.\n        Use a file URL upload app, or switch to contact form if you need attachments.\n      {%- endcomment -%}\n\n      {%- comment -%} Useful hidden context that will also attach to the line item {%- endcomment -%}\n      <input type=\"hidden\" name=\"properties[_Product]\" value=\"{{ product.title | escape }}\">\n      <input type=\"hidden\" name=\"properties[_Product URL]\" value=\"{{ shop.url }}{{ product.url }}\">\n    <\/div>\n\n    <div class=\"bfc-actions\">\n      <button class=\"bfc-btn primary\" type=\"submit\" name=\"add\">Add to cart<\/button>\n    <\/div>\n  {%- endform -%}\n<\/div>","section_width":"max-w-page","color_scheme":"","spacing_top":"2","spacing_bottom":"2"}}},"order":["main","complete_the_set_QRxhyG","multitile_KDV8BX","recommendations","166904322806a89075","complete_the_set_Mf7jik","175641204134f8dd6a","custom_liquid_id4jAR"]}