   <!--BELOW ME IS CUSTOM FROM GRIFFIN FOR BRIDGE APP TO ALLOW SHOP USERS TO SEE MEMBERSHIP-->
{% comment %}
<script>
(function() {
  // Default state - works for email login via Liquid
  window.__bfc = {
    isMember: {% if customer.tags contains 'Casual Shooter' or customer.tags contains 'Casual Shooter Yearly' or customer.tags contains 'Enthusiast' or customer.tags contains 'Enthusiast Yearly' or customer.tags contains 'Serious Shooter' or customer.tags contains 'Serious Shooter Yearly' %}true{% else %}false{% endif %},
    isSerious: {% if customer.tags contains 'Serious Shooter' or customer.tags contains 'Serious Shooter Yearly' %}true{% else %}false{% endif %},
    loggedIn: {{ customer != blank }},
    credits: 0,
    planTag: '{% for tag in customer.tags %}{% if tag == "Casual Shooter" or tag == "Casual Shooter Yearly" or tag == "Enthusiast" or tag == "Enthusiast Yearly" or tag == "Serious Shooter" or tag == "Serious Shooter Yearly" %}{{ tag }}{% break %}{% endif %}{% endfor %}'
  };

  {% if customer %}
  try {
    var _cr = '{{ customer.metafields["app--95190188033--block"]["BDATA"] | replace: '"', '\"' }}';
    if (_cr && _cr.length > 2) {
      var _cd = JSON.parse(_cr);
      Object.keys(_cd).forEach(function(k) { window.__bfc.credits += (_cd[k].count || 0); });
    }
  } catch(e) {}
  {% endif %}

  // Check for Shop login bridge params in URL
  var p = new URLSearchParams(window.location.search);
  if (p.get('bfc_member') === '1') {
    var exp = parseInt(p.get('bfc_exp') || '0');
    if (exp > Date.now()) {
      var d = {
        isMember: true,
        isSerious: p.get('bfc_serious') === '1',
        planTag: p.get('bfc_plan') || '',
        credits: 0,
        expires: exp
      };
      try { localStorage.setItem('bfc_member', JSON.stringify(d)); } catch(e) {}
      applyBfc(d);
    }
    // Clean params from URL
    var url = new URL(window.location.href);
    url.searchParams.delete('bfc_member');
    url.searchParams.delete('bfc_serious');
    url.searchParams.delete('bfc_plan');
    url.searchParams.delete('bfc_exp');
    window.history.replaceState({}, '', url.toString());
  } else {
    // Check localStorage for returning Shop login users
    try {
      var stored = localStorage.getItem('bfc_member');
      if (stored) {
        var d = JSON.parse(stored);
        if (d.expires > Date.now()) {
          applyBfc(d);
        } else {
          localStorage.removeItem('bfc_member');
        }
      }
    } catch(e) {}
  }

  function applyBfc(d) {
    window.__bfc.isMember = true;
    window.__bfc.isSerious = !!d.isSerious;
    window.__bfc.loggedIn = true;
    window.__bfc.planTag = d.planTag || '';
    document.dispatchEvent(new CustomEvent('bfc:customer', { detail: window.__bfc }));
  }
})();
</script>

{% endcomment %}
